            type=["csv","txt","tsv","xlsx","xls"],
            key="v121_rules_upload"
        )

        c1, c2, c3 = st.columns(3)
        with c1:
            prefer_session121 = st.checkbox("Use session data if available", value=True, key="v121_use_session")
        with c2:
            block_if_no_rules121 = st.checkbox("Block if no embedded/uploaded rules loaded", value=True, key="v121_block_no_rules")
        with c3:
            show_rows121 = st.number_input("Preview rows", 10, 1000, 200, 10, key="v121_preview_rows")

        if st.button("Run v123 Deep Combo 75 Engine", type="primary", key="v121_run"):
            src = "none"
            df_in = pd.DataFrame()

            if up_playlist121 is not None:
                df_in = _v121_load_any(up_playlist121)
                src = "uploaded playlist/table"
            elif prefer_session121:
                found_key, found_df = _v123_find_daily_stream_table_in_session()
                if isinstance(found_df, pd.DataFrame) and not found_df.empty:
                    df_in = found_df.copy()
                    src = "session:auto_detect:" + str(found_key)
                else:
                    for k in [
                        "v120_truth_fixed_per_event", "v119_per_event", "v117_per_event",
                        "daily_sorted_df", "daily_playlist_df", "playlist_df",
                        "v121_last_playlist"
                    ]:
                        tmp = st.session_state.get(k)
                        if isinstance(tmp, pd.DataFrame) and not tmp.empty:
                            df_in = tmp.copy()
                            src = "session:" + k
                            break

            rules = pd.DataFrame()
            rules_source = "none"
            if up_rules121 is not None:
                rules = _v121_load_any(up_rules121)
                rules_source = "uploaded replacement stack"
                st.session_state["v121_reduction_rules"] = rules.copy()
            else:
                tmp_rules = st.session_state.get("v121_reduction_rules")
                if isinstance(tmp_rules, pd.DataFrame) and not tmp_rules.empty:
                    rules = tmp_rules.copy()
                    rules_source = "session cached stack"
                else:
                    try:
                        rules = pd.DataFrame(V123_EMBEDDED_REDUCTION_RULES)
                        rules_source = "embedded v122 stack"
                    except Exception:
                        rules = pd.DataFrame()
                        rules_source = "none"

            if not isinstance(df_in, pd.DataFrame) or df_in.empty:
                st.warning("No input stream table found. Upload a daily/full stream table.")
            elif block_if_no_rules121 and (not isinstance(rules, pd.DataFrame) or rules.empty):
                st.warning("No embedded or uploaded reduction stack loaded. This should not happen in v122 unless the embedded list was removed.")
            else:
                applied, log = _v121_apply_reduction_stack(df_in, rules)
                applied = _v121_apply_action_members(applied)
                score = _v121_score_if_truth(applied)
                st.session_state["v121_source"] = src + " | rules:" + str(rules_source)
                st.session_state["v121_output"] = applied
                st.session_state["v121_application_log"] = log
                st.session_state["v121_score"] = score
                st.success("v123 engine applied.")

        if st.session_state.get("v121_source"):
            st.write("**v121 source:** " + str(st.session_state.get("v121_source")))

        for title, key, fname in [
            ("v123 score/audit", "v121_score", "core025_v123_score_audit.csv"),
            ("v123 application log", "v121_application_log", "core025_v123_application_log.csv"),
            ("v123 final playlist/output", "v121_output", "core025_v123_final_playlist_output.csv"),
        ]:
            df = st.session_state.get(key)
            if isinstance(df, pd.DataFrame) and not df.empty:
                st.subheader(title)
                st.dataframe(df.head(int(show_rows121)), use_container_width=True, hide_index=True)
                st.download_button(
                    "Download " + title,
                    data=df.to_csv(index=False).encode("utf-8"),
                    file_name=fname,
                    mime="text/csv",
                    use_container_width=True,
                    key=key+"_download",
                    **(_v103_download_kwargs() if "_v103_download_kwargs" in globals() else {})
                )

        st.info("Integration rule: v123 is additive and isolated. Existing baseline outputs remain untouched. Use v123 output as the candidate reduced playlist.")
except Exception as e:
    try:
        st.warning("v121 Deep Combo 75 Engine unavailable: " + str(e))
    except Exception:
        pass


