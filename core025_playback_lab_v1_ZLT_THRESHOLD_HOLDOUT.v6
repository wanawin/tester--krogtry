        except Exception as _v154_rule_e:
            st.error("v154 preflight failed while building walk-forward rule source: " + str(_v154_rule_e))
            st.session_state["v151_walkforward_run_active"] = False
            status.update(label="Walk-forward stopped: rule-source build failed", state="error", expanded=True)
            st.stop()
        active_rule_count_v151 = int(len(v154_base_rules)) if isinstance(v154_base_rules, pd.DataFrame) else 0
        st.info(f"v154 preflight: raw walk-forward rows={raw_lab_row_count_v151:,} | full 78-stream mode=ON | base/fixed rules loaded={active_rule_count_v151:,} | rule source={v154_rule_source_label}")

        if lab_rows is None or not isinstance(lab_rows, pd.DataFrame) or lab_rows.empty:
            st.error("v154 preflight failed: the uploaded history produced zero walk-forward rows. Check that the history file loaded correctly and contains Date/State/Game/Result records.")
            st.session_state["v151_walkforward_run_active"] = False
            status.update(label="Walk-forward stopped: zero raw rows", state="error", expanded=True)
            st.stop()

        # Do not allow placeholder/no-rule scoring. Date-valid truth rules may be built after date slicing,
        # but at least one fixed library rule or eligible date-valid snapshot must exist before scoring.

        prog.progress(25, text="Preparing full 78-stream historical date segments")
        lab_rows = ensure_streamkey_columns(lab_rows, "walk-forward lab rows")
        if "Date" in lab_rows.columns:
            lab_rows["Date"] = pd.to_datetime(lab_rows["Date"], errors="coerce")
            lab_rows = lab_rows[lab_rows["Date"].notna()].sort_values(["Date", "StreamKey"]).copy()

        # v152: split by historical dates, not by rows, so every scored date keeps its full stream playlist.
        _all_dates_v152 = pd.to_datetime(lab_rows["Date"], errors="coerce").dropna().dt.normalize().drop_duplicates().sort_values().tolist()
        v151_full_target_rows = int(len(lab_rows))
        if v151_segment_mode == "2 halves":
            _parts = 2
            _idx = 0 if v151_segment_choice == "Half 1" else 1
        elif v151_segment_mode == "4 quarters":
            _parts = 4
            _idx = int(str(v151_segment_choice).split()[-1]) - 1
        else:
            _parts = 1
            _idx = 0
        _idx = max(0, min(int(_idx), int(_parts) - 1))
        _date_edges = np.linspace(0, len(_all_dates_v152), _parts + 1, dtype=int)
        _date_start = int(_date_edges[_idx])
        _date_end = int(_date_edges[_idx + 1])
        _segment_dates_v152 = _all_dates_v152[_date_start:_date_end]
        if not _segment_dates_v152:
            st.error("v152 preflight failed: selected date segment contains zero dates. Choose a different segment or verify the date range/history file.")
            st.session_state["v151_walkforward_run_active"] = False
            status.update(label="Walk-forward stopped: zero-date segment", state="error", expanded=True)
            st.stop()
        lab_rows = lab_rows[lab_rows["Date"].dt.normalize().isin(_segment_dates_v152)].copy()
        v151_segment_start_row = int(lab_rows.index.min()) if len(lab_rows) else 0
        v151_segment_end_row = int(lab_rows.index.max()) + 1 if len(lab_rows) else 0
        segment_row_count_v151 = int(len(lab_rows))
        v151_segment_label = f"{v151_segment_mode} / {v151_segment_choice}"
        st.info(
            f"v152 selected date segment: {v151_segment_label} | all historical dates={len(_all_dates_v152):,} | "
            f"segment dates={len(_segment_dates_v152):,} | segment rows={segment_row_count_v151:,} | "
            f"date span={pd.to_datetime(_segment_dates_v152[0]).date()}–{pd.to_datetime(_segment_dates_v152[-1]).date()}"
        )
        if segment_row_count_v151 <= 0:
            st.error("v154 preflight failed: selected segment contains zero rows after date slicing.")
            st.session_state["v151_walkforward_run_active"] = False
            status.update(label="Walk-forward stopped: zero-row segment", state="error", expanded=True)
            st.stop()

        # v154: build date-valid truth-mined separator snapshots for the selected dates only.
        v154_separator_history = pd.DataFrame()
        if str(v154_rule_source_mode).startswith("Promoted library fixed + date-valid"):
            prog.progress(27, text="Building date-valid separator history for selected dates")
            try:
                v154_separator_history = v154_build_date_valid_truth_separator_history(truth_file, _segment_dates_v152, truth_min_rate, truth_min_support)
                st.session_state["v154_separator_history"] = v154_separator_history.copy()
                st.info(f"v154 date-valid separator history built for selected segment: rows={len(v154_separator_history):,}; dates with snapshots={v154_separator_history['PredictionDate'].nunique() if isinstance(v154_separator_history, pd.DataFrame) and not v154_separator_history.empty and 'PredictionDate' in v154_separator_history.columns else 0:,}")
            except Exception as _v154_sep_e:
                st.error("v154 date-valid separator-history build failed: " + str(_v154_sep_e))
                st.session_state["v151_walkforward_run_active"] = False
                status.update(label="Walk-forward stopped: separator-history build failed", state="error", expanded=True)
                st.stop()
        else:
            v154_separator_history = st.session_state.get("v154_separator_history", pd.DataFrame())
            if not isinstance(v154_separator_history, pd.DataFrame):
                v154_separator_history = pd.DataFrame()

        v154_effective_rule_probe = v154_base_rules
        if (not isinstance(v154_effective_rule_probe, pd.DataFrame) or v154_effective_rule_probe.empty) and isinstance(v154_separator_history, pd.DataFrame) and not v154_separator_history.empty:
            v154_effective_rule_probe = v154_separator_history
        if v154_effective_rule_probe is None or not isinstance(v154_effective_rule_probe, pd.DataFrame) or v154_effective_rule_probe.empty:
            st.error("v154 preflight failed: no active separator/scoring rules are available after internal build. Upload a promoted separator library and/or FULL TRUTH file, then Build/Refresh Rule Source.")
            st.session_state["v151_walkforward_run_active"] = False
            status.update(label="Walk-forward stopped: no active rules loaded", state="error", expanded=True)
            st.stop()

        # v152: recompute kept_streams advisory flags blind for each date, but never filter by them.
        prog.progress(30, text="Recomputing historical kept-stream advisory flags")
        v152_stream_diag = v152_build_historical_stream_advisory(hist_for_lab, _segment_dates_v152, window_days, prune_pct)
        if isinstance(v152_stream_diag, pd.DataFrame) and not v152_stream_diag.empty:
            _merge_cols_v152 = [c for c in [
                "Date", "StreamKey", "hit_density", "rank", "StreamRank", "kept", "KeptStreamFlag", "KeptStreamAdvisory",
                "RowPercentile", "SingleRow", "RowBucket10", "StreamTier", "RecommendedByTopN", "RecommendedByRowPct", "RecommendedStream"
            ] if c in v152_stream_diag.columns]
            _adv = v152_stream_diag[_merge_cols_v152].copy()
            _adv["Date"] = pd.to_datetime(_adv["Date"], errors="coerce").dt.normalize()
            lab_rows["_v152_DateNorm"] = lab_rows["Date"].dt.normalize()
            lab_rows = lab_rows.merge(_adv.rename(columns={"Date":"_v152_DateNorm"}), on=["_v152_DateNorm", "StreamKey"], how="left", suffixes=("", "_adv"))
            lab_rows = lab_rows.drop(columns=["_v152_DateNorm"], errors="ignore")
        lab_rows["KeptStreamFlag"] = pd.to_numeric(lab_rows.get("KeptStreamFlag", lab_rows.get("kept", 0)), errors="coerce").fillna(0).astype(int)
        lab_rows["KeptStreamAdvisory"] = lab_rows.get("KeptStreamAdvisory", "DOWNRANK_ADVISORY")
        st.info(f"v152 advisory merge: rows preserved={len(lab_rows):,}; streams are NOT filtered by kept_streams.")

        # v148: load prior checkpoint rows from upload and/or session cache.
        prior_parts = []
        if v148_resume_file is not None:
            try:
                raw = _v105_upload_bytes(v148_resume_file) if "_v105_upload_bytes" in globals() else v148_resume_file.getvalue()
                nm = _v105_upload_name(v148_resume_file, "checkpoint.csv") if "_v105_upload_name" in globals() else str(getattr(v148_resume_file, "name", "checkpoint.csv")).lower()
                sep = "\t" if nm.endswith(".tsv") else None
                prior_parts.append(pd.read_csv(io.BytesIO(raw), sep=sep, engine="python"))
            except Exception as _v148_resume_e:
                st.warning("Could not read uploaded checkpoint/resume file: " + str(_v148_resume_e))
        cached_prior = st.session_state.get("v148_walkforward_checkpoint")
        if isinstance(cached_prior, pd.DataFrame) and not cached_prior.empty:
            prior_parts.append(cached_prior.copy())
        prior_res = pd.concat(prior_parts, ignore_index=True) if prior_parts else pd.DataFrame()
        if not prior_res.empty and "StreamKey" in prior_res.columns and "Date" in prior_res.columns:
            prior_res["Date"] = pd.to_datetime(prior_res["Date"], errors="coerce")
            prior_res["_v148_key"] = prior_res["StreamKey"].astype(str) + "|" + prior_res["Date"].dt.strftime("%Y-%m-%d")
            prior_res = prior_res.drop_duplicates("_v148_key", keep="last").drop(columns=["_v148_key"], errors="ignore")
        else:
            prior_res = pd.DataFrame()

        if not lab_rows.empty and "StreamKey" in lab_rows.columns and "Date" in lab_rows.columns:
            lab_rows["_v148_key"] = lab_rows["StreamKey"].astype(str) + "|" + pd.to_datetime(lab_rows["Date"], errors="coerce").dt.strftime("%Y-%m-%d")
            prior_keys = set()
            if not prior_res.empty and "StreamKey" in prior_res.columns and "Date" in prior_res.columns:
                prior_keys = set(prior_res["StreamKey"].astype(str) + "|" + pd.to_datetime(prior_res["Date"], errors="coerce").dt.strftime("%Y-%m-%d"))
            remaining_rows = lab_rows[~lab_rows["_v148_key"].isin(prior_keys)].drop(columns=["_v148_key"], errors="ignore").copy()
        else:
            remaining_rows = lab_rows.copy()
            prior_keys = set()

        total_target_rows_v148 = int(len(lab_rows)) if isinstance(lab_rows, pd.DataFrame) else 0
        already_done_v148 = int(len(prior_res)) if isinstance(prior_res, pd.DataFrame) and not prior_res.empty else 0
        if v148_batch_limit == "All remaining":
            rows_this_batch = remaining_rows.copy()
        else:
            rows_this_batch = remaining_rows.head(int(v148_batch_limit)).copy()
        st.info(f"v151 segment checkpoint status: target rows={total_target_rows_v148:,} | already scored={already_done_v148:,} | scoring this run={len(rows_this_batch):,} | remaining after this run={max(0, len(remaining_rows)-len(rows_this_batch)):,}")

        scored = []
        prog.progress(35, text="Phase 1/4 — scoring selected batch once with v156 fast rule program")
        batch_n = int(len(rows_this_batch))
        _base_program_v156 = v156_prepare_rule_program(v154_base_rules, trait_weight)
        _program_cache_v156 = {}
        _records_v156 = rows_this_batch.to_dict("records")
        _static_rule_mode_v156 = (v154_separator_history is None) or (not isinstance(v154_separator_history, pd.DataFrame)) or v154_separator_history.empty
        for _i, rowd in enumerate(_records_v156, start=1):
            _row_date_v154 = pd.to_datetime(rowd.get("Date"), errors="coerce")
            if _static_rule_mode_v156:
                _rules_for_row_v154 = v154_base_rules
                _program_v156 = _base_program_v156
            else:
                _date_key_v156 = str(_row_date_v154.date()) if pd.notna(_row_date_v154) else ""
                if _date_key_v156 not in _program_cache_v156:
                    _rules_tmp = v154_rules_for_prediction_date(_row_date_v154, v154_separator_history, v154_base_rules)
                    _program_cache_v156[_date_key_v156] = (_rules_tmp, v156_prepare_rule_program(_rules_tmp, trait_weight))
                _rules_for_row_v154, _program_v156 = _program_cache_v156[_date_key_v156]
            if _rules_for_row_v154 is None or not isinstance(_rules_for_row_v154, pd.DataFrame) or _rules_for_row_v154.empty or not _program_v156:
                pick = {
                    "PredictedMember": "", "Top2_pred": "", "Margin": np.nan, "Top2ToTop1Ratio": np.nan,
                    "Top2Zone": 0, "Top2RiskScore": 0, "Top2Decision": "NO_DATE_VALID_RULES", "Top2RiskReasons": "",
                    "DecisionMode": "NO_DATE_VALID_RULES", "MarginSwap": 0, "Fired_Rules": "",
                    "GATED_TOP3": 0, "score_0025": np.nan, "score_0225": np.nan, "score_0255": np.nan
                }
            else:
                pick = v156_pick_from_dict(rowd, _program_v156, min_margin, enable_margin_swap, top2_zone_ratio, top2_zone_margin, top2_risk_threshold)
                pick["v154_RulesAvailableForDate"] = int(len(_rules_for_row_v154))
                pick["v154_RuleSourceMode"] = str(v154_rule_source_label)
                if "SourceCutoffDate" in _rules_for_row_v154.columns:
                    _sc = pd.to_datetime(_rules_for_row_v154["SourceCutoffDate"], errors="coerce")
                    pick["v154_MaxRuleSourceCutoffDate"] = str(_sc.max().date()) if _sc.notna().any() else ""
            if "v154_RulesAvailableForDate" not in pick:
                pick["v154_RulesAvailableForDate"] = 0
            if "v154_RuleSourceMode" not in pick:
                pick["v154_RuleSourceMode"] = str(v154_rule_source_label)
            if "v154_MaxRuleSourceCutoffDate" not in pick:
                pick["v154_MaxRuleSourceCutoffDate"] = ""
            true_member = normalize_member(rowd.get("TrueMember", ""))
            is_core_event = int(bool(true_member))
            top1 = int(is_core_event and pick["PredictedMember"] == true_member)
            top2_needed = int(is_core_event and top1 == 0 and pick["Top2_pred"] == true_member)
            miss = int(is_core_event and top1 == 0 and top2_needed == 0)
            scored.append({**rowd, **pick, "Core025WinnerEvent": is_core_event, "NonCore025Event": int(not is_core_event), "Top1_Correct": top1, "Needed_Top2": top2_needed, "Miss": miss})
            if batch_n and (_i == batch_n or _i % 500 == 0):
                prog.progress(min(72, 35 + int(37 * _i / max(1, batch_n))), text=f"Phase 1/4 — scored {_i:,} / {batch_n:,} rows once")
        new_res = pd.DataFrame(scored) if scored else pd.DataFrame()
        prog.progress(74, text="Phase 2/4 — merging checkpoint and applying play/depth logic")
        res = pd.concat([prior_res, new_res], ignore_index=True) if not prior_res.empty or not new_res.empty else empty_lab_results_frame()
        if not res.empty and "StreamKey" in res.columns and "Date" in res.columns:
            res["Date"] = pd.to_datetime(res["Date"], errors="coerce")
            res["_v148_key"] = res["StreamKey"].astype(str) + "|" + res["Date"].dt.strftime("%Y-%m-%d")
            res = res.drop_duplicates("_v148_key", keep="last").drop(columns=["_v148_key"], errors="ignore").copy()
        if not res.empty:
            # v184 repair principle:
            # Baseline WF scoring must complete/export first. ZLT/movement/row/commonality layers are audit-only.
            # If any tracking layer fails, keep the scored WF rows and continue to summary/downloads.
            res["v184_WFRepairMode"] = bool(st.session_state.get("v184_baseline_first_mode", True))
            res["v184_TrackingStatus"] = "BASELINE_SCORED_BEFORE_TRACKING"
            st.session_state["v184_baseline_scored_rows_pre_tracking"] = res.copy()

            if bool(st.session_state.get("v184_baseline_first_mode", True)):
                # Minimal old-WF-compatible play/depth columns. No member scoring changes.
                if "Top3Rescue" not in res.columns: res["Top3Rescue"] = 0
                if "Top3RescueScore" not in res.columns: res["Top3RescueScore"] = 0
                if "Top3RescueReasons" not in res.columns: res["Top3RescueReasons"] = ""
                if "UniversalFamilyScore" not in res.columns:
                    _score_cols = [c for c in ["score_0025", "score_0225", "score_0255"] if c in res.columns]
                    res["UniversalFamilyScore"] = pd.to_numeric(res[_score_cols].max(axis=1), errors="coerce").fillna(0) if _score_cols else 0
                if "RowPlayType" not in res.columns: res["RowPlayType"] = "row_model_audit_only"
                if "RowPlayTypeReason" not in res.columns: res["RowPlayTypeReason"] = "v184_baseline_first_tracking_does_not_control_wf"
                if "RecommendedStream" not in res.columns: res["RecommendedStream"] = 1
                # Preserve the old play policy assumption for baseline exports: Top1+Top2 unless later layers explicitly change it.
                if "PlayType" not in res.columns:
                    res["PlayType"] = "TOP1_TOP2"
                if "RecommendedPlay" not in res.columns:
                    res["RecommendedPlay"] = res.get("PredictedMember", "").astype(str) + " + " + res.get("Top2_pred", "").astype(str)
            else:
                try:
                    # v152: stream advisory/rank columns were computed blind per historical date before scoring.
                    # Do not merge today's global stream_diag into historical rows.
                    res = add_rare_top3_and_universal_scores(
                        res, enable_top3_rescue, top3_rescue_min_score,
                        w_model, w_row, w_density, w_outlier
                    )
                    row_model_df = build_row_play_model(
                        st.session_state.get("row_single_perf"),
                        row_model_min_hits,
                        row_top3_rate_threshold,
                        row_top2_rate_threshold,
                        row_top1_rate_threshold,
                        row_low_top2_rate_threshold,
                    )
                    st.session_state["row_play_model"] = row_model_df
                    res = apply_row_playtype_model(res, row_model_df, enable_row_playtype_model)
                    res = apply_play_recommendation(res, play_policy)
                    res = v152_apply_daily_hybrid_movement(res)
                    res["v184_TrackingStatus"] = "FULL_TRACKING_APPLIED"
                except Exception as _v184_tracking_e:
                    res["v184_TrackingStatus"] = "TRACKING_FAILED_BASELINE_PRESERVED: " + str(_v184_tracking_e)[:180]
                    st.warning("v184: tracking/post-processing layer failed, but baseline WF rows were preserved: " + str(_v184_tracking_e))
        total = len(res)
        if total and "Core025WinnerEvent" in res.columns:
            winner_mask_v147 = pd.to_numeric(res["Core025WinnerEvent"], errors="coerce").fillna(0).astype(int).eq(1)
        else:
            winner_mask_v147 = pd.Series([True] * total, index=res.index) if total else pd.Series(dtype=bool)
        winner_total_v147 = int(winner_mask_v147.sum()) if total else 0
        non_core_total_v147 = int(total - winner_total_v147) if total else 0
        winner_res_v147 = res[winner_mask_v147].copy() if total else res
        top1 = int(winner_res_v147["Top1_Correct"].sum()) if winner_total_v147 else 0
        needed = int(winner_res_v147["Needed_Top2"].sum()) if winner_total_v147 else 0
        miss = int(winner_res_v147["Miss"].sum()) if winner_total_v147 else 0
        capture = (top1 + needed) / winner_total_v147 * 100 if winner_total_v147 else 0.0

        operational_top2_capture = int(((winner_res_v147["Needed_Top2"] == 1) & (winner_res_v147["PlayType"].isin(["TOP1_TOP2", "TOP1_TOP2_TOP3"]))).sum()) if winner_total_v147 and "PlayType" in winner_res_v147.columns else 0
        operational_top3_capture = int(((winner_res_v147["Miss"] == 1) & (winner_res_v147["PlayType"] == "TOP1_TOP2_TOP3")).sum()) if winner_total_v147 and "PlayType" in winner_res_v147.columns else 0
        operational_captured = top1 + operational_top2_capture + operational_top3_capture
        operational_capture_pct = (operational_captured / winner_total_v147 * 100) if winner_total_v147 else 0.0
        operational_plays = 0
        if total and "PlayType" in res.columns:
            operational_plays = int((res["PlayType"] == "TOP1_ONLY").sum() + 2*(res["PlayType"] == "TOP1_TOP2").sum() + 3*(res["PlayType"] == "TOP1_TOP2_TOP3").sum())
        summary = pd.DataFrame([{
            "walkforward_universe": "FULL_UNIVERSE" if bool(v147_use_full_universe) else "WINNER_EVENTS_ONLY",
            "date_scope": "FULL_UPLOADED_HISTORY" if bool(v147_use_full_history_dates) else "CUSTOM_DATE_RANGE",
            "date_start": str(pd.to_datetime(hist_for_lab["Date"], errors="coerce").min().date()) if isinstance(hist_for_lab, pd.DataFrame) and not hist_for_lab.empty and "Date" in hist_for_lab.columns else "",
            "date_end": str(pd.to_datetime(hist_for_lab["Date"], errors="coerce").max().date()) if isinstance(hist_for_lab, pd.DataFrame) and not hist_for_lab.empty and "Date" in hist_for_lab.columns else "",
            "v152_full_78_daily_movement": True,
            "v152_kept_streams_advisory_only": True,
            "v152_segment_split_basis": "historical_dates_not_rows",
            "v153_winner_nonwinner_trait_mining": True,
            "v153_trait_exports_enabled": True,
            "v151_segment_mode": str(v151_segment_mode),
            "v151_segment_choice": str(v151_segment_choice),
            "v151_segment_label": str(v151_segment_label) if "v151_segment_label" in locals() else "",
            "v151_full_target_rows_before_segment": int(v151_full_target_rows) if "v151_full_target_rows" in locals() else 0,
            "v151_segment_start_row": int(v151_segment_start_row) if "v151_segment_start_row" in locals() else 0,
            "v151_segment_end_row_exclusive": int(v151_segment_end_row) if "v151_segment_end_row" in locals() else 0,
            "total_rows": total,
            "v148_target_rows": int(total_target_rows_v148) if "total_target_rows_v148" in locals() else total,
            "v148_completed_rows": total,
            "v148_remaining_rows": max(0, int(total_target_rows_v148) - total) if "total_target_rows_v148" in locals() else 0,
            "v148_checkpoint_complete": bool(total_target_rows_v148 and total >= total_target_rows_v148) if "total_target_rows_v148" in locals() else True,
            "v148_rows_scored_this_run": int(len(new_res)) if "new_res" in locals() and isinstance(new_res, pd.DataFrame) else total,
            "v151_auto_continue_enabled": bool(st.session_state.get("v151_walkforward_auto_continue", False)),
            "v151_run_active": bool(st.session_state.get("v151_walkforward_run_active", False)),
            "v151_rows_to_score_inside_segment": str(v148_batch_limit),
            "core025_winner_events": winner_total_v147,
            "non_core025_events": non_core_total_v147,
            "top1": top1,
            "top1_pct": round((top1 / winner_total_v147 * 100), 2) if winner_total_v147 else 0.0,
            "needed_top2": needed,
            "top2_burden_pct": round((needed / winner_total_v147 * 100), 2) if winner_total_v147 else 0.0,
            "miss": miss,
            "capture_pct": round(capture, 2),
            "operational_captured": operational_captured,
            "operational_capture_pct": round(operational_capture_pct, 2),
            "operational_plays": operational_plays,
            "operational_plays_per_capture": round(operational_plays / operational_captured, 3) if operational_captured else None,
            "operational_plays_per_evaluated_row": round(operational_plays / total, 3) if total else None,
            "operational_plays_per_core025_winner_event": round(operational_plays / winner_total_v147, 3) if winner_total_v147 else None,
            "top3_rescue_rows": int(res["Top3Rescue"].sum()) if total and "Top3Rescue" in res.columns else 0,
            "top3_rescue_captured_misses": operational_top3_capture,
            "gated_top3": int(res["GATED_TOP3"].sum()) if total else 0,
            "margin_swaps": int(res["MarginSwap"].sum()) if total and "MarginSwap" in res.columns else 0,
            "top2_zone_rows": int(res["Top2Zone"].sum()) if total and "Top2Zone" in res.columns else 0,
            "top2_required_rows": int((res["Top2Decision"] == "TOP2_REQUIRED").sum()) if total and "Top2Decision" in res.columns else 0,
            "top2_safe_rows": int((res["Top2Decision"] == "TOP1_SAFE").sum()) if total and "Top2Decision" in res.columns else 0,
            "kept_streams": int(pd.to_numeric(res.get("KeptStreamFlag", pd.Series(dtype=float)), errors="coerce").fillna(0).sum()) if total else 0,
            "active_rules": int(len(v154_base_rules)) if isinstance(v154_base_rules, pd.DataFrame) else 0,
            "v154_separator_history_rules": int(len(v154_separator_history)) if isinstance(v154_separator_history, pd.DataFrame) else 0,
            "truth_mined_rules": int(len(v154_separator_history)) if isinstance(v154_separator_history, pd.DataFrame) and not v154_separator_history.empty else int(len(st.session_state.get("v154_walkforward_static_truth_rules", pd.DataFrame())) if isinstance(st.session_state.get("v154_walkforward_static_truth_rules", pd.DataFrame()), pd.DataFrame) else 0),
            "v154_rule_source_mode": str(v154_rule_source_label),
            "v155_validation_type": "PRODUCTION_RULEBOOK_VALIDATION" if "Production rulebook validation" in str(v154_rule_source_label) or "NOT BLIND" in str(v154_rule_source_label) else "DATE_VALID_STRICTER_REPLAY",
            "v155_strict_blind_claim": False if "Production rulebook validation" in str(v154_rule_source_label) or "NOT BLIND" in str(v154_rule_source_label) else True,
            "v155_rulebook_note": "Frozen current rulebook/static truth intelligence applied across selected history for robustness/staleness validation; not a strict historical availability claim." if "Production rulebook validation" in str(v154_rule_source_label) or "NOT BLIND" in str(v154_rule_source_label) else "Date-valid stricter replay mode.",
            "decision_layer": "strict_score_ranking_no_third_hijack",
            "margin_swap_enabled": enable_margin_swap,
            "play_policy": play_policy,
            "recommended_stream_rows": int(res["RecommendedStream"].sum()) if total and "RecommendedStream" in res.columns else 0,
            "row_playtype_model_enabled": enable_row_playtype_model,
            "row_model_min_hits": row_model_min_hits,
            "row_top3_rate_threshold": row_top3_rate_threshold,
            "row_top2_rate_threshold": row_top2_rate_threshold,
            "row_low_top2_rate_threshold": row_low_top2_rate_threshold,
            "row_top1_rate_threshold": row_top1_rate_threshold,
            "row_model_top1_only_rows": int((res["PlayType"] == "TOP1_ONLY").sum()) if total and "PlayType" in res.columns else 0,
            "row_model_top1_top2_rows": int((res["PlayType"] == "TOP1_TOP2").sum()) if total and "PlayType" in res.columns else 0,
            "row_model_top1_top2_top3_rows": int((res["PlayType"] == "TOP1_TOP2_TOP3").sum()) if total and "PlayType" in res.columns else 0,
        }])
        try:
            method_tests, single_row_perf = build_stream_method_tests(res, play_policy)
        except Exception as _v184_method_e:
            st.warning("v184: stream/row method tests failed; baseline WF exports remain available: " + str(_v184_method_e))
            method_tests, single_row_perf = pd.DataFrame(), pd.DataFrame()
        pct = res.copy()
        if not pct.empty:
            pct["margin_percentile"] = pct["Margin"].rank(pct=True, method="average").round(4)
        st.session_state["lab_results"] = res
        st.session_state["lab_summary"] = summary
        st.session_state["percentile_df"] = pct
        st.session_state["stream_method_tests"] = method_tests
        st.session_state["row_single_perf"] = single_row_perf
        st.session_state["v148_walkforward_checkpoint"] = res.copy()
        st.session_state["v148_walkforward_checkpoint_summary"] = summary.copy()
        # v79: cache full-312 row coverage and refresh final daily play list after lab completes.
        st.session_state["v645_row_coverage_table"] = v645_row_coverage_table(res) if "v645_row_coverage_table" in globals() else single_row_perf
        if st.session_state.get("daily_playlist") is not None:
            st.session_state["v79_final_daily_play_list"] = v79_prepare_final_daily_play_list(
                st.session_state.get("v64_ensemble_marked", st.session_state.get("daily_playlist")),
                st.session_state.get("v645_row_coverage_table"),
                res,
            )
        if summary.iloc[0].get("v148_checkpoint_complete", True):
            st.session_state["v151_walkforward_run_active"] = False
            prog.progress(100, text="Done — selected walk-forward segment complete")
            status.update(label="Walk-forward segment complete", state="complete", expanded=False)
        else:
            prog.progress(100, text="Pass complete — checkpoint saved")
            if bool(st.session_state.get("v151_walkforward_auto_continue", False)):
                remaining_msg = summary.iloc[0].get("v148_remaining_rows", "unknown")
                status.update(label=f"Pass complete; continuing selected segment remaining rows: {remaining_msg}", state="running", expanded=True)
                st.info("v151 auto-continue is continuing inside the selected segment. Checkpoints are saved after every pass.")
                st.rerun()
            else:
                st.session_state["v151_walkforward_run_active"] = False
                status.update(label="Walk-forward pass complete; checkpoint saved", state="complete", expanded=True)

    if st.session_state["lab_summary"] is not None:
        summary = st.session_state["lab_summary"]
        res = st.session_state["lab_results"]
        pct = st.session_state["percentile_df"]
        if "walkforward_universe" in summary.columns:
            st.success(f"Walk-forward universe used: {summary.iloc[0].get('walkforward_universe')} | Date scope: {summary.iloc[0].get('date_scope')} | Rows evaluated: {summary.iloc[0].get('total_rows')} | Core025 winner events: {summary.iloc[0].get('core025_winner_events', 'n/a')}")
            if "v148_target_rows" in summary.columns:
                st.info(f"v152 segment progress: {summary.iloc[0].get('v148_completed_rows'):,} / {summary.iloc[0].get('v148_target_rows'):,} rows complete | remaining: {summary.iloc[0].get('v148_remaining_rows'):,}")
        st.dataframe(summary, use_container_width=True, hide_index=True)
