# ================================
# v135 DYNAMIC ORDER DIRECTLY AFTER VISIBLE DAILY PLAYLIST
# Display only. Does not change engine output, members, depths, rescues, or rows.
# ================================
def _v135_num(df, col, default=0.0):
    if col in df.columns:
        return pd.to_numeric(df[col], errors="coerce").fillna(default)
    return pd.Series(default, index=df.index)

def _v135_bool01(df, col):
    if col not in df.columns:
        return pd.Series(0, index=df.index, dtype=int)
    s = df[col]
    if getattr(s, "dtype", None) == bool:
        return s.astype(int)
    return s.astype(str).str.strip().str.lower().isin(["1", "true", "yes", "y", "play"]).astype(int)

def _v135_scale_high(s):
    s = pd.to_numeric(s, errors="coerce").astype(float)
    if s.notna().sum() == 0:
        return pd.Series(0.0, index=s.index)
    lo, hi = s.min(), s.max()
    if pd.isna(lo) or pd.isna(hi) or hi == lo:
        return pd.Series(0.5, index=s.index)
    return ((s - lo) / (hi - lo)).fillna(0.0)

def _v135_scale_low(s):
    return 1.0 - _v135_scale_high(s)

def _v135_dynamic_daily_order_view(playlist: pd.DataFrame) -> pd.DataFrame:
    if playlist is None or not isinstance(playlist, pd.DataFrame) or playlist.empty:
        return pd.DataFrame()

    out = playlist.copy()

    # Preserve old order explicitly.
    if "PlaylistRank" in out.columns:
        out["OriginalPlaylistRank_Reference"] = out["PlaylistRank"]
    else:
        out["OriginalPlaylistRank_Reference"] = range(1, len(out) + 1)

    if "StreamRank" in out.columns:
        out["StaticStreamRank_Reference"] = out["StreamRank"]
    elif "SingleRow" in out.columns:
        out["StaticStreamRank_Reference"] = out["SingleRow"]
    else:
        out["StaticStreamRank_Reference"] = out["OriginalPlaylistRank_Reference"]

    # Detect play count from existing display/play columns.
    play_col = next((c for c in ["PlayCount", "ActualBoxPlayCount", "RecommendedPlayCount", "v130_PlayCount", "v128_PlayCount", "v127_PlayCount", "v124_PlayCount"] if c in out.columns), None)
    if play_col is None:
        # Infer from visible play instructions/members when possible.
        instr_col = next((c for c in ["ActualBoxPlay", "RecommendedPlay", "BoxPlayInstruction", "ActualBoxPlayDisplay"] if c in out.columns), None)
        if instr_col:
            txt = out[instr_col].astype(str)
            out["v135_PlayCount"] = np.where(txt.str.contains(r"\+", regex=True), 2,
                                      np.where(txt.str.strip().str.len().gt(0) & ~txt.str.contains("NO|SKIP", case=False, regex=True), 1, 0))
        else:
            # fallback: recommended stream rows are counted as one play if no better data exists
            out["v135_PlayCount"] = np.where(_v135_bool01(out, "RecommendedStream").eq(1), 1, 0)
        play_col = "v135_PlayCount"
    else:
        out["v135_PlayCount"] = pd.to_numeric(out[play_col], errors="coerce").fillna(0).astype(int)
        play_col = "v135_PlayCount"

    # Mined signal direction from full 84,081-row universe:
    # lower Top1_score/gap, higher ratio, higher Top2/Top3 pressure.
    top1_score = _v135_num(out, "Top1_score", 0)
    if "Top1_score" not in out.columns:
        top1_score = _v135_num(out, "ModelConfidenceScore", 0)

    gap = _v135_num(out, "gap", 0)
    if "gap" not in out.columns:
        gap = _v135_num(out, "Margin", 0)

    ratio = _v135_num(out, "ratio", 0)
    if "ratio" not in out.columns:
        ratio = _v135_num(out, "Top2ToTop1Ratio", 0)

    pressure_top23 = _v135_num(out, "Top2_score", 0) + _v135_num(out, "Top3_score", 0)
    pressure_0255 = _v135_num(out, "final_0255", 0) + _v135_num(out, "boost_0255", 0) + _v135_num(out, "rules_0255", 0) + 0.15 * _v135_num(out, "score_0255", 0)
    pressure_0225 = _v135_num(out, "final_0225", 0) + _v135_num(out, "boost_0225", 0) + _v135_num(out, "rules_0225", 0) + 0.15 * _v135_num(out, "score_0225", 0)
    pressure_0025 = _v135_num(out, "final_0025", 0) + _v135_num(out, "boost_0025", 0) + _v135_num(out, "rules_0025", 0) + 0.15 * _v135_num(out, "score_0025", 0)

    out["DynamicStreamPriorityScore_v135"] = (
        1.15 * _v135_scale_low(top1_score)
        + 1.00 * _v135_scale_low(gap)
        + 0.85 * _v135_scale_high(ratio)
        + 0.70 * _v135_scale_high(pressure_top23)
        + 0.45 * _v135_scale_high(pressure_0255)
        + 0.35 * _v135_scale_high(pressure_0225)
        - 0.20 * _v135_scale_high(pressure_0025)
        + 0.25 * _v135_bool01(out, "RecommendedStream")
        + 0.20 * _v135_bool01(out, "RecommendedByTopN")
        + 0.20 * _v135_bool01(out, "RecommendedByRowPct")
        + 0.15 * _v135_bool01(out, "Top3Rescue")
        - 0.15 * _v135_bool01(out, "GATED_TOP3")
    )

    out["DynamicStreamRank_v135"] = out["DynamicStreamPriorityScore_v135"].rank(method="first", ascending=False).astype(int)

    # SingleRow/RowPercentile stabilizer.
    if "SingleRow" in out.columns:
        out["SingleRowPriority_v135"] = pd.to_numeric(out["SingleRow"], errors="coerce")
    elif "RowPercentile" in out.columns:
        out["SingleRowPriority_v135"] = pd.to_numeric(out["RowPercentile"], errors="coerce")
    elif "StreamRank" in out.columns:
        out["SingleRowPriority_v135"] = pd.to_numeric(out["StreamRank"], errors="coerce")
    else:
        out["SingleRowPriority_v135"] = pd.Series(range(1, len(out)+1), index=out.index)

    # Neutral due fallback unless cadence table is available in session.
    out["DuePressureRank_v135"] = out["SingleRowPriority_v135"].rank(method="first", ascending=True)
    cad = st.session_state.get("v133_singlerow_cadence_stats") or st.session_state.get("v134_singlerow_cadence_stats")
    if isinstance(cad, pd.DataFrame) and not cad.empty and "SingleRow" in cad.columns:
        cc = cad.copy()
        cc["SingleRowPriority_v135"] = pd.to_numeric(cc["SingleRow"], errors="coerce")
        if "DuePressure_vsMedian" in cc.columns:
            cc["DuePressure_v135"] = pd.to_numeric(cc["DuePressure_vsMedian"], errors="coerce").fillna(0)
        else:
            cc["DuePressure_v135"] = pd.to_numeric(cc.get("CurrentGapAsOfEnd", 0), errors="coerce").fillna(0)
        cc["DuePressureRank_v135_join"] = cc["DuePressure_v135"].rank(method="first", ascending=False)
        out = out.merge(cc[["SingleRowPriority_v135", "DuePressure_v135", "DuePressureRank_v135_join"]].drop_duplicates("SingleRowPriority_v135"), on="SingleRowPriority_v135", how="left")
        if "DuePressureRank_v135_join" in out.columns:
            out["DuePressureRank_v135"] = pd.to_numeric(out["DuePressureRank_v135_join"], errors="coerce").fillna(out["DuePressureRank_v135"])

    out["FinalDynamicStreamRank_v135_Score"] = (
        0.50 * pd.to_numeric(out["DynamicStreamRank_v135"], errors="coerce").fillna(999)
        + 0.35 * pd.to_numeric(out["SingleRowPriority_v135"], errors="coerce").fillna(999)
        + 0.15 * pd.to_numeric(out["DuePressureRank_v135"], errors="coerce").fillna(999)
    )
    out["FinalDynamicStreamRank_v135"] = out["FinalDynamicStreamRank_v135_Score"].rank(method="first", ascending=True).astype(int)

    out = out.sort_values("FinalDynamicStreamRank_v135").copy()
    out["BudgetOrder"] = range(1, len(out) + 1)
    out["RunningPlayTotal"] = pd.to_numeric(out[play_col], errors="coerce").fillna(0).astype(int).cumsum()
    out["RunningCost_25c_Value"] = out["RunningPlayTotal"] * 0.25
    out["RunningCost_25c"] = out["RunningCost_25c_Value"].map(lambda x: f"${x:,.2f}")

    def _marker(t):
        return "$50" if t >= 200 else "$40" if t >= 160 else "$35" if t >= 140 else "$30" if t >= 120 else "$25" if t >= 100 else "$20" if t >= 80 else "$15" if t >= 60 else "$10" if t >= 40 else "$5" if t >= 20 else ""
    out["BudgetMarkerReached"] = out["RunningPlayTotal"].map(_marker)

    front_cols = [c for c in [
        "BudgetOrder", "FinalDynamicStreamRank_v135", "FinalDynamicStreamRank_v135_Score",
        "DynamicStreamRank_v135", "DynamicStreamPriorityScore_v135",
        "OriginalPlaylistRank_Reference", "StaticStreamRank_Reference",
        "SingleRow", "RowPercentile", "SingleRowPriority_v135", "DuePressureRank_v135",
        "StreamKey", "State", "Game",
        play_col, "RunningPlayTotal", "RunningCost_25c", "BudgetMarkerReached",
        "RecommendedPlay", "ActualBoxPlay", "ActualBoxPlayDisplay", "BoxPlayInstruction",
        "PredictedMember", "Top2_pred", "ThirdMember", "Top1", "Top2", "Top3"
    ] if c in out.columns]
    rest = [c for c in out.columns if c not in front_cols]
    view = out[front_cols + rest].copy()
    if play_col != "PlayCount":
        view = view.rename(columns={play_col: "PlayCount"})
    return view

def _v135_render_dynamic_daily_order(playlist: pd.DataFrame):
    view = _v135_dynamic_daily_order_view(playlist)
    if view is None or view.empty:
        return pd.DataFrame()
    st.subheader("v135 DYNAMIC DAILY PLAYLIST ORDER — FULL LIST, NO ROWS REMOVED")
    st.caption("This is the changed order. It appears directly after the regular v89 Visible Daily Playlist. Old PlaylistRank/StreamRank are reference columns only.")
    total_plays = int(pd.to_numeric(view.get("PlayCount", pd.Series(dtype=float)), errors="coerce").fillna(0).sum())
    st.info(f"Dynamic ordered full list: {len(view)} rows | {total_plays} plays | ${total_plays * 0.25:,.2f} at $0.25/play")
    cuts = []
    for dollars in [5,10,15,20,25,30,35,40,50]:
        plays = int(dollars / 0.25)
        sub = view[pd.to_numeric(view["RunningPlayTotal"], errors="coerce").le(plays)]
        cuts.append({"Budget": f"${dollars}", "PlayCutoff": plays, "RowsIncluded": len(sub), "PlaysUsed": int(pd.to_numeric(sub.get("PlayCount", pd.Series(dtype=float)), errors="coerce").fillna(0).sum()) if not sub.empty else 0, "LastDynamicRankIncluded": int(sub["FinalDynamicStreamRank_v135"].max()) if not sub.empty else ""})
    st.write("**Budget cutoff guide**")
    st.dataframe(pd.DataFrame(cuts), use_container_width=True, hide_index=True)
    st.write("**Full dynamically ordered daily playlist**")
    st.dataframe(view, use_container_width=True, hide_index=True, height=950)
    st.session_state["v135_dynamic_daily_playlist_order"] = view
    st.download_button("Download v135 Dynamic Daily Playlist CSV", view.to_csv(index=False).encode("utf-8"), file_name="core025_v135_dynamic_daily_playlist_order.csv", mime="text/csv", use_container_width=True, key="download_v135_dynamic_daily_playlist_order")
    return view




# ================================
# v139 TRUE HYBRID RANK + DATE/STALENESS PANEL
# Fixes v137/v138 collapse where HybridFinalRank could equal old StreamRank.
# Formula: 50% DynamicRank + 35% historical SingleRow winner-production rank + 15% DuePressure rank.
# Cost is calculated AFTER ranking only.
# ================================
V139_SINGLE_ROW_WINNER_COUNTS = {1:6,2:9,3:4,4:6,5:7,6:7,7:5,8:4,9:4,10:5,11:3,12:3,13:1,14:8,15:4,16:2,17:5,18:3,19:3,20:4,21:5,22:2,23:3,24:12,25:5,26:5,27:2,28:4,29:5,30:9,31:1,32:6,33:4,34:6,35:2,36:4,37:3,38:2,39:2,40:0,41:5,42:3,43:3,44:4,45:4,46:3,47:5,48:2,49:2,50:6,51:3,52:5,53:2,54:1,55:9,56:6,57:2,58:6,59:1,60:6,61:0,62:4,63:2,64:5,65:6,66:6,67:3,68:3,69:7,70:2,71:4,72:2,73:1,74:4,75:2,76:5,77:0,78:3}
V139_EMBEDDED_DUE_PRESSURE = {60:317,69:223,65:94,50:147}

def _v139_num(df, col, default=0.0):
    if col in df.columns:
        return pd.to_numeric(df[col], errors="coerce").fillna(default)
    return pd.Series(default, index=df.index)

def _v139_bool01(df, col):
    if col not in df.columns:
        return pd.Series(0, index=df.index, dtype=int)
    s=df[col]
    if getattr(s,'dtype',None)==bool:
        return s.astype(int)
    return s.astype(str).str.strip().str.lower().isin(['1','true','yes','y','play']).astype(int)

def _v139_scale_high(s):
    s=pd.to_numeric(s, errors='coerce').astype(float)
    if s.notna().sum()==0:
        return pd.Series(0.0,index=s.index)
    lo,hi=s.min(),s.max()
    if pd.isna(lo) or pd.isna(hi) or hi==lo:
        return pd.Series(0.5,index=s.index)
    return ((s-lo)/(hi-lo)).fillna(0.0)

def _v139_scale_low(s):
    return 1.0-_v139_scale_high(s)

def _v139_member_tokens(x):
    found=[]
    for tok in re.findall(r'\d+',str(x)):
        z=tok.zfill(4)
        if z in {'0025','0225','0255'} and z not in found:
            found.append(z)
        elif tok in {'25','225','255'}:
            z={'25':'0025','225':'0225','255':'0255'}[tok]
            if z not in found: found.append(z)
    return found

def _v139_clean_member(x):
    toks=_v139_member_tokens(x)
    return toks[0] if toks else ''

def _v139_actual_members_from_row(row):
    for c in ['ActualBoxPlay','ActualBoxPlayDisplay','BoxPlayInstruction','RecommendedPlay','v130_MembersToPlay','v128_MembersToPlay','v127_MembersToPlay','v124_MembersToPlay','v121_MembersToPlay','MembersToPlay']:
        if c in row.index:
            toks=_v139_member_tokens(row.get(c,''))
            if toks: return toks
    depth=None
    for c in ['ActualPlayCount','PlayCount','v130_PlayCount','v128_PlayCount','v127_PlayCount','v124_PlayCount','v121_PlayCount','v130_Depth','v128_Depth','v127_Depth','v124_Depth','v121_Depth']:
        if c in row.index:
            try:
                depth=int(float(row.get(c))); break
            except Exception: pass
    if depth is None:
        txt=' '.join(str(row.get(c,'')) for c in ['FinalAction','v130_Action','v128_Action','v127_Action','v124_Action','v121_Action','PlayType','RecommendedPlay','ActualBoxPlay','BoxPlayInstruction'] if c in row.index).upper()
        depth=3 if 'TOP3' in txt else 2 if 'TOP2' in txt else 1 if ('TOP1' in txt or 'PLAY' in txt) else 0
    ranked=[]
    for c in ['Top1_Display','PredictedMember','Top1','Top2_Display','Top2_pred','Top2','Top3_Display','ThirdMember','Top3']:
        if c in row.index:
            m=_v139_clean_member(row.get(c,''))
            if m and m not in ranked: ranked.append(m)
    return ranked[:max(0,int(depth or 0))]

def _v139_prediction_date_from_history(hist):
    if hist is None or not isinstance(hist,pd.DataFrame) or hist.empty:
        return None,None
    col=next((c for c in ['Date','date','DrawDate','draw_date'] if c in hist.columns),None)
    if col is None: return None,None
    d=pd.to_datetime(hist[col], errors='coerce').dropna()
    if d.empty: return None,None
    latest=d.max().normalize(); return latest, latest+pd.Timedelta(days=1)

def _v139_render_date_staleness_panel(hist):
    latest,pred=_v139_prediction_date_from_history(hist)
    st.subheader('v139 Date / Staleness Check')
    if latest is None:
        st.warning('No valid history date found.'); return
    c1,c2,c3=st.columns(3)
    c1.metric('Most Recent History Date', latest.date().isoformat())
    c2.metric('Playlist / Prediction Date', pred.date().isoformat())
    c3.metric('Date Rule', 'history max + 1 day')
    st.caption("Uses the uploaded history timeline only — not today's real calendar date.")
    support_rows=[]
    for label,obj in [('FULL TRUTH file', globals().get('truth_file',None)),('Promoted separator library', globals().get('lib_file',None))]:
        support_rows.append({'SupportFile':label,'Status':'uploaded' if obj is not None else 'not uploaded','StalenessNotice':'yellow 60 / orange 90 / red 180 history-days after support refresh baseline'})
    st.dataframe(pd.DataFrame(support_rows), use_container_width=True, hide_index=True)

def _v139_build_true_hybrid_rank_actual_cost(playlist):
    if playlist is None or not isinstance(playlist,pd.DataFrame) or playlist.empty:
        return pd.DataFrame()
    out=playlist.copy()
    out['OldPlaylistRank']=out['PlaylistRank'] if 'PlaylistRank' in out.columns else range(1,len(out)+1)
    out['OldStreamRank']=out['StreamRank'] if 'StreamRank' in out.columns else (out['SingleRow'] if 'SingleRow' in out.columns else out['OldPlaylistRank'])
    # Dynamic score from daily live columns only; no old-rank fallback is allowed to dominate.
    top1=_v139_num(out,'Top1_score',np.nan) if 'Top1_score' in out.columns else _v139_num(out,'ModelConfidenceScore',np.nan)
    gap=_v139_num(out,'gap',np.nan) if 'gap' in out.columns else _v139_num(out,'Margin',np.nan)
    ratio=_v139_num(out,'ratio',np.nan) if 'ratio' in out.columns else _v139_num(out,'Top2ToTop1Ratio',np.nan)
    top23=_v139_num(out,'Top2_score',0)+_v139_num(out,'Top3_score',0)
    s255=_v139_num(out,'score_0255',0)+_v139_num(out,'final_0255',0)+_v139_num(out,'boost_0255',0)+_v139_num(out,'rules_0255',0)
    s225=_v139_num(out,'score_0225',0)+_v139_num(out,'final_0225',0)+_v139_num(out,'boost_0225',0)+_v139_num(out,'rules_0225',0)
    s025=_v139_num(out,'score_0025',0)+_v139_num(out,'final_0025',0)+_v139_num(out,'boost_0025',0)+_v139_num(out,'rules_0025',0)
    out['DynamicScore_v139']=(1.15*_v139_scale_low(top1)+1.0*_v139_scale_low(gap)+0.85*_v139_scale_high(ratio)+0.70*_v139_scale_high(top23)+0.45*_v139_scale_high(s255)+0.35*_v139_scale_high(s225)+0.20*_v139_scale_low(s025)+0.25*_v139_bool01(out,'RecommendedStream')+0.20*_v139_bool01(out,'RecommendedByTopN')+0.20*_v139_bool01(out,'RecommendedByRowPct')+0.15*_v139_bool01(out,'Top3Rescue')+0.10*(1-_v139_bool01(out,'GATED_TOP3')))
    out['DynamicRank_v139']=out['DynamicScore_v139'].rank(method='first', ascending=False).astype(int)
    sr=pd.to_numeric(out['SingleRow'],errors='coerce') if 'SingleRow' in out.columns else (pd.to_numeric(out['RowPercentile'],errors='coerce') if 'RowPercentile' in out.columns else pd.to_numeric(out['OldStreamRank'],errors='coerce'))
    out['SingleRowNumber_v139']=sr
    out['SingleRowWinnerCount_v139']=sr.map(lambda x: V139_SINGLE_ROW_WINNER_COUNTS.get(int(x),0) if pd.notna(x) else 0)
    out['SingleRowWinnerPct_v139']=out['SingleRowWinnerCount_v139']/312.0
    out['SingleRowHistoricalRank_v139']=out['SingleRowWinnerCount_v139'].rank(method='first', ascending=False).astype(int)
    out['DuePressureValue_v139']=sr.map(lambda x: V139_EMBEDDED_DUE_PRESSURE.get(int(x),0) if pd.notna(x) else 0).fillna(0)
    cad=st.session_state.get('v133_singlerow_cadence_stats') or st.session_state.get('v134_singlerow_cadence_stats')
    if isinstance(cad,pd.DataFrame) and not cad.empty and 'SingleRow' in cad.columns:
        cc=cad.copy(); cc['SingleRowNumber_v139']=pd.to_numeric(cc['SingleRow'],errors='coerce')
        src='DuePressure_vsMedian' if 'DuePressure_vsMedian' in cc.columns else 'CurrentGapAsOfEnd' if 'CurrentGapAsOfEnd' in cc.columns else None
        cc['DuePressureValue_join_v139']=pd.to_numeric(cc[src],errors='coerce').fillna(0) if src else 0
        out=out.merge(cc[['SingleRowNumber_v139','DuePressureValue_join_v139']].drop_duplicates('SingleRowNumber_v139'),on='SingleRowNumber_v139',how='left')
        out['DuePressureValue_v139']=pd.to_numeric(out.get('DuePressureValue_join_v139'),errors='coerce').fillna(out['DuePressureValue_v139'])
    out['DuePressureRank_v139']=out['DuePressureValue_v139'].rank(method='first', ascending=False).astype(int)
    out['HybridRankScore_v139']=0.50*out['DynamicRank_v139']+0.35*out['SingleRowHistoricalRank_v139']+0.15*out['DuePressureRank_v139']
    out['HybridFinalRank_v139']=out['HybridRankScore_v139'].rank(method='first', ascending=True).astype(int)
    out['HybridVsOldStreamRankDelta_v139']=pd.to_numeric(out['HybridFinalRank_v139'],errors='coerce')-pd.to_numeric(out['OldStreamRank'],errors='coerce')
    members=out.apply(_v139_actual_members_from_row,axis=1)
    out['ActualMembersToPlay']=members.map(lambda xs:' + '.join(xs))
    out['ActualPlayCount']=members.map(len).astype(int)
    out['Action']=np.where(out['ActualPlayCount'].eq(0),'NO PLAY',np.where(out['ActualPlayCount'].eq(1),'TOP1',np.where(out['ActualPlayCount'].eq(2),'TOP2','TOP3')))
    out['RowCostDisplay']=(out['ActualPlayCount']*0.25).map(lambda x:f'${x:,.2f}')
    out=out.sort_values('HybridFinalRank_v139').copy()
    out['DynamicOrder']=range(1,len(out)+1)
    out['RunningPlayTotal']=out['ActualPlayCount'].cumsum()
    out['RunningCostDisplay']=(out['RunningPlayTotal']*0.25).map(lambda x:f'${x:,.2f}')
    out['BudgetMarkerReached']=out['RunningPlayTotal'].map(lambda t:'$50' if t>=200 else '$40' if t>=160 else '$35' if t>=140 else '$30' if t>=120 else '$25' if t>=100 else '$20' if t>=80 else '$15' if t>=60 else '$10' if t>=40 else '$5' if t>=20 else '')
    out['HybridRankDiagnostic_v139']='TRUE_HYBRID'
    try:
        if (pd.to_numeric(out['HybridFinalRank_v139'],errors='coerce').reset_index(drop=True).equals(pd.to_numeric(out['OldStreamRank'],errors='coerce').reset_index(drop=True))):
            out['HybridRankDiagnostic_v139']='WARNING_COLLAPSED_TO_OLD_STREAMRANK'
    except Exception: pass
    front=[c for c in ['DynamicOrder','HybridFinalRank_v139','StreamKey','State','Game','OldPlaylistRank','OldStreamRank','HybridVsOldStreamRankDelta_v139','SingleRow','RowPercentile','SingleRowWinnerCount_v139','SingleRowWinnerPct_v139','SingleRowHistoricalRank_v139','DynamicRank_v139','DuePressureRank_v139','Action','ActualMembersToPlay','ActualPlayCount','RowCostDisplay','RunningPlayTotal','RunningCostDisplay','BudgetMarkerReached','HybridRankDiagnostic_v139','PredictedMember','Top2_pred','ThirdMember','Top1','Top2','Top3'] if c in out.columns]
    rest=[c for c in out.columns if c not in front]
    return out[front+rest]

def _v139_render_true_hybrid_rank_actual_cost(playlist):
    view=_v139_build_true_hybrid_rank_actual_cost(playlist)
    if view is None or view.empty: return pd.DataFrame()
    st.divider(); st.subheader('v139 TRUE HYBRID RANKED PLAYLIST — ACTUAL COST')
    st.caption('This is the main play list. Rank = 50% Dynamic + 35% historical SingleRow winner-production rank + 15% DuePressure. Cost is added after rank. No rows removed.')
    total=int(pd.to_numeric(view['ActualPlayCount'],errors='coerce').fillna(0).sum())
    moved=int(pd.to_numeric(view['HybridVsOldStreamRankDelta_v139'],errors='coerce').fillna(0).ne(0).sum())
    st.info(f'Full true-hybrid-ranked play list: {len(view)} rows | {moved} rows moved vs old StreamRank | {total} actual plays | ${total*0.25:,.2f} at $0.25/play')
    cuts=[]
    for dollars in [5,10,15,20,25,30,35,40,50]:
        plays=int(dollars/0.25); sub=view[pd.to_numeric(view['RunningPlayTotal'],errors='coerce').le(plays)]
        cuts.append({'Budget':f'${dollars}','PlayCutoff':plays,'RowsIncluded':len(sub),'ActualPlaysUsed':int(pd.to_numeric(sub['ActualPlayCount'],errors='coerce').fillna(0).sum()) if not sub.empty else 0,'LastHybridRankIncluded':int(sub['HybridFinalRank_v139'].max()) if not sub.empty else ''})
    st.write('**Budget guide — informational only, not part of ranking**')
    st.dataframe(pd.DataFrame(cuts), use_container_width=True, hide_index=True)
    st.write('**Final true-hybrid-ranked play list — use this order for budget decisions**')
    st.dataframe(view, use_container_width=True, hide_index=True, height=950)
    st.session_state['v139_true_hybrid_rank_actual_cost_playlist']=view
    st.download_button('Download v139 True Hybrid Ranked Playlist CSV', view.to_csv(index=False).encode('utf-8'), file_name='core025_v139_true_hybrid_rank_actual_cost_playlist.csv', mime='text/csv', use_container_width=True, key='download_v139_true_hybrid_rank_actual_cost_playlist')
    return view


