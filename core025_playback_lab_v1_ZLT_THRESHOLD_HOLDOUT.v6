V128_EMBEDDED_SINGLE_ROW_CADENCE_RULES = [{'Step': 1, 'SingleRow': 30, 'Condition': 'prev_hit=1', 'Action': 'TOP2', 'RowsAffected': 4, 'PlaysSavedThisStep': 4, 'CapturedAfter': 264, 'PlaysAfter': 540}, {'Step': 2, 'SingleRow': 30, 'Condition': 'prev_cap=0', 'Action': 'TOP2', 'RowsAffected': 1, 'PlaysSavedThisStep': 1, 'CapturedAfter': 264, 'PlaysAfter': 539}, {'Step': 3, 'SingleRow': 17, 'Condition': 'prev_cap=0', 'Action': 'TOP1', 'RowsAffected': 1, 'PlaysSavedThisStep': 2, 'CapturedAfter': 264, 'PlaysAfter': 537}, {'Step': 4, 'SingleRow': 21, 'Condition': 'prev_cap=0', 'Action': 'TOP2', 'RowsAffected': 2, 'PlaysSavedThisStep': 2, 'CapturedAfter': 264, 'PlaysAfter': 535}, {'Step': 5, 'SingleRow': 38, 'Condition': 'prev_cap=0', 'Action': 'TOP1', 'RowsAffected': 2, 'PlaysSavedThisStep': 2, 'CapturedAfter': 264, 'PlaysAfter': 533}, {'Step': 6, 'SingleRow': 50, 'Condition': 'prev_hit=1', 'Action': 'TOP2', 'RowsAffected': 2, 'PlaysSavedThisStep': 2, 'CapturedAfter': 264, 'PlaysAfter': 531}, {'Step': 7, 'SingleRow': 51, 'Condition': 'prev_cap=0', 'Action': 'TOP1', 'RowsAffected': 2, 'PlaysSavedThisStep': 2, 'CapturedAfter': 264, 'PlaysAfter': 529}, {'Step': 8, 'SingleRow': 66, 'Condition': 'prev_cap=1', 'Action': 'TOP2', 'RowsAffected': 2, 'PlaysSavedThisStep': 2, 'CapturedAfter': 264, 'PlaysAfter': 527}, {'Step': 9, 'SingleRow': 78, 'Condition': 'prev_cap=1', 'Action': 'TOP1', 'RowsAffected': 2, 'PlaysSavedThisStep': 2, 'CapturedAfter': 264, 'PlaysAfter': 525}, {'Step': 10, 'SingleRow': 3, 'Condition': 'prev_cap=1', 'Action': 'SKIP', 'RowsAffected': 1, 'PlaysSavedThisStep': 1, 'CapturedAfter': 264, 'PlaysAfter': 524}, {'Step': 11, 'SingleRow': 4, 'Condition': 'prev_cap=0', 'Action': 'TOP1', 'RowsAffected': 1, 'PlaysSavedThisStep': 1, 'CapturedAfter': 264, 'PlaysAfter': 523}, {'Step': 12, 'SingleRow': 7, 'Condition': 'prev_cap=1', 'Action': 'TOP2', 'RowsAffected': 1, 'PlaysSavedThisStep': 1, 'CapturedAfter': 264, 'PlaysAfter': 522}, {'Step': 13, 'SingleRow': 18, 'Condition': 'prev_cap=1', 'Action': 'TOP1', 'RowsAffected': 1, 'PlaysSavedThisStep': 1, 'CapturedAfter': 264, 'PlaysAfter': 521}, {'Step': 14, 'SingleRow': 20, 'Condition': 'prev_cap=0', 'Action': 'TOP2', 'RowsAffected': 1, 'PlaysSavedThisStep': 1, 'CapturedAfter': 264, 'PlaysAfter': 520}, {'Step': 15, 'SingleRow': 23, 'Condition': 'prev_cap=1', 'Action': 'TOP1', 'RowsAffected': 1, 'PlaysSavedThisStep': 1, 'CapturedAfter': 264, 'PlaysAfter': 519}, {'Step': 16, 'SingleRow': 24, 'Condition': 'prev_cap=0', 'Action': 'TOP2', 'RowsAffected': 1, 'PlaysSavedThisStep': 1, 'CapturedAfter': 264, 'PlaysAfter': 518}, {'Step': 17, 'SingleRow': 32, 'Condition': 'prev_cap=0', 'Action': 'TOP2', 'RowsAffected': 1, 'PlaysSavedThisStep': 1, 'CapturedAfter': 264, 'PlaysAfter': 517}, {'Step': 18, 'SingleRow': 37, 'Condition': 'prev_cap=1', 'Action': 'TOP1', 'RowsAffected': 1, 'PlaysSavedThisStep': 1, 'CapturedAfter': 264, 'PlaysAfter': 516}, {'Step': 19, 'SingleRow': 64, 'Condition': 'prev_cap=0', 'Action': 'TOP1', 'RowsAffected': 1, 'PlaysSavedThisStep': 1, 'CapturedAfter': 264, 'PlaysAfter': 515}]

def _v128_history_status(df, support_built_through=None):
    latest = None
    if isinstance(df, pd.DataFrame) and not df.empty:
        for c in ["Date", "date", "DrawDate", "draw_date"]:
            if c in df.columns:
                dt = pd.to_datetime(df[c], errors="coerce")
                if dt.notna().any():
                    latest = dt.max().normalize()
                    break
    if latest is None:
        return pd.DataFrame([{"HistoryThrough":"","PlaylistDate":"","SupportBuiltThrough":support_built_through or "","SupportAgeHistoryDays":"","Status":"No usable Date column found"}])
    playlist = latest + pd.Timedelta(days=1)
    return pd.DataFrame([{"HistoryThrough":latest.date().isoformat(),"PlaylistDate":playlist.date().isoformat(),"SupportBuiltThrough":support_built_through or "","SupportAgeHistoryDays":"","Status":"Current relative to supplied history"}])

def _v128_apply_single_row_cadence(final_df):
    out = _v127_force_processed_columns(final_df.copy())
    out["Date"] = pd.to_datetime(out["Date"], errors="coerce") if "Date" in out.columns else pd.NaT
    out["SingleRow"] = pd.to_numeric(out.get("SingleRow", pd.Series(index=out.index)), errors="coerce")
    out["_orig_idx_v128"] = range(len(out))

    true = out.get("TrueMember", pd.Series("", index=out.index)).map(_v121_member)
    top1 = out.get("PredictedMember", pd.Series("", index=out.index)).map(_v121_member)
    top2 = out.get("Top2_pred", pd.Series("", index=out.index)).map(_v121_member)
    top3 = out.get("ThirdMember", pd.Series("", index=out.index)).map(_v121_member)
    depth = pd.to_numeric(out["v127_Depth"], errors="coerce").fillna(0).astype(int).to_numpy(copy=True)
    is_hit = true.isin(["0025","0225","0255"]).to_numpy()
    cap1 = is_hit & top1.eq(true).to_numpy()
    cap2 = is_hit & (top1.eq(true) | top2.eq(true)).to_numpy()
    cap3 = is_hit & (top1.eq(true) | top2.eq(true) | top3.eq(true)).to_numpy()
    base_cap = ((depth>=1)&cap1) | ((depth>=2)&cap2) | ((depth>=3)&cap3)

    work = out.copy()
    work["_base_cap"] = base_cap.astype(int)
    work["_base_hit"] = is_hit.astype(int)
    parts = []
    for sr, g in work.sort_values(["SingleRow","Date","_orig_idx_v128"]).groupby("SingleRow", dropna=False):
        g = g.copy()
        g["prev_cap"] = g["_base_cap"].shift(1).fillna(0).astype(int)
        g["prev_hit"] = g["_base_hit"].shift(1).fillna(0).astype(int)
        parts.append(g)
    work = pd.concat(parts).sort_values("_orig_idx_v128")

    logs = []
    for _, r in pd.DataFrame(V128_EMBEDDED_SINGLE_ROW_CADENCE_RULES).iterrows():
        try:
            sr = int(r.get("SingleRow"))
        except Exception:
            continue
        cond = str(r.get("Condition",""))
        action = str(r.get("Action",""))
        target = {"SKIP":0,"TOP1":1,"TOP2":2,"TOP3":3}.get(action)
        if target is None:
            continue
        mask = work["SingleRow"].eq(sr).to_numpy(copy=True)
        if cond == "prev_cap=1":
            mask = mask & work["prev_cap"].eq(1).to_numpy(copy=True)
        elif cond == "prev_cap=0":
            mask = mask & work["prev_cap"].eq(0).to_numpy(copy=True)
        elif cond == "prev_hit=1":
            mask = mask & work["prev_hit"].eq(1).to_numpy(copy=True)
        elif cond == "prev_hit=0":
            mask = mask & work["prev_hit"].eq(0).to_numpy(copy=True)
        else:
            continue
        apply = mask & (depth > target)
        before = int(depth.sum())
        if apply.any():
            depth[apply] = target
        logs.append({"Step":len(logs)+1,"SingleRow":sr,"Condition":cond,"Action":action,"RowsAffected":int(apply.sum()),"PlayCountBefore":before,"PlayCountAfter":int(depth.sum()),"PlaysSaved":before-int(depth.sum())})

    out["v128_Depth"] = depth
    out["v128_Action"] = np.where(depth==0,"NO_PLAY",np.where(depth==1,"PLAY_TOP1",np.where(depth==2,"PLAY_TOP2","PLAY_TOP3")))
    def _members(row):
        d = int(row.get("v128_Depth",0))
        vals=[]
        if d>=1: vals.append(row.get("PredictedMember",""))
        if d>=2: vals.append(row.get("Top2_pred",""))
        if d>=3: vals.append(row.get("ThirdMember",""))
        return ",".join([str(x) for x in vals if str(x) not in {"","nan","None"}])
    out["v128_MembersToPlay"] = out.apply(_members, axis=1)
    out["v128_PlayCount"] = depth
    return out.drop(columns=[c for c in ["_orig_idx_v128"] if c in out.columns]), pd.DataFrame(logs)

def _v128_score(final_df):
    out = final_df.copy()
    depth_col = "v128_Depth" if "v128_Depth" in out.columns else "v127_Depth"
    true = out.get("TrueMember", pd.Series("", index=out.index)).map(_v121_member)
    top1 = out.get("PredictedMember", pd.Series("", index=out.index)).map(_v121_member)
    top2 = out.get("Top2_pred", pd.Series("", index=out.index)).map(_v121_member)
    top3 = out.get("ThirdMember", pd.Series("", index=out.index)).map(_v121_member)
    d = pd.to_numeric(out[depth_col], errors="coerce").fillna(0).astype(int)
    is_hit = true.isin(["0025","0225","0255"])
    cap = is_hit & (((d>=1)&top1.eq(true)) | ((d>=2)&top2.eq(true)) | ((d>=3)&top3.eq(true)))
    total = int(is_hit.sum())
    captured = int(cap.sum())
    return pd.DataFrame([{"v128_ProcessedRows":len(out),"v128_TotalHits":total,"v128_CapturedHits":captured,"v128_MissedHits":total-captured,"v128_CaptureRate":captured/total if total else None,"v128_TotalPlays":int(d.sum()),"v128_TargetLockedCaptured":264,"v128_TargetLockedPlays":515,"v128_MatchesLocked264_515Tier":bool(total==312 and captured==264 and int(d.sum())==515),"v128_Status":"PROCESSED_V128_CADENCE_FINALIZED_OUTPUT"}])

# ================================
# v127 FORCE PROCESSED WALKFORWARD EXPORT
# Ensures Walkforward Validation exports the v127 processed result, not raw v64 lab output.
# ================================
def _v127_force_processed_columns(final_df):
    out = final_df.copy()
    if "v124_Depth" in out.columns:
        out["v127_Depth"] = pd.to_numeric(out["v124_Depth"], errors="coerce").fillna(0).astype(int)
    elif "v121_Depth" in out.columns:
        out["v127_Depth"] = pd.to_numeric(out["v121_Depth"], errors="coerce").fillna(0).astype(int)
    else:
        out["v127_Depth"] = _v121_initial_depth(out).astype(int)

    out["v127_Action"] = np.where(
        out["v127_Depth"].eq(0), "NO_PLAY",
        np.where(out["v127_Depth"].eq(1), "PLAY_TOP1",
        np.where(out["v127_Depth"].eq(2), "PLAY_TOP2", "PLAY_TOP3"))
    )

    def _members(row):
        d = int(row.get("v127_Depth", 0))
        vals = []
        if d >= 1: vals.append(row.get("PredictedMember", ""))
        if d >= 2: vals.append(row.get("Top2_pred", ""))
        if d >= 3: vals.append(row.get("ThirdMember", ""))
        vals = [str(x) for x in vals if str(x) not in {"", "nan", "None"}]
        return ",".join(vals)

    out["v127_MembersToPlay"] = out.apply(_members, axis=1)
    out["v127_PlayCount"] = out["v127_Depth"].astype(int)
    return out

def _v127_score_processed(final_df):
    out = _v127_force_processed_columns(final_df)
    true = out.get("TrueMember", pd.Series("", index=out.index)).map(_v121_member)
    top1 = out.get("PredictedMember", pd.Series("", index=out.index)).map(_v121_member)
    top2 = out.get("Top2_pred", pd.Series("", index=out.index)).map(_v121_member)
    top3 = out.get("ThirdMember", pd.Series("", index=out.index)).map(_v121_member)
    d = pd.to_numeric(out["v127_Depth"], errors="coerce").fillna(0).astype(int)

    is_hit = true.isin(["0025","0225","0255"])
    cap = is_hit & (((d>=1)&top1.eq(true)) | ((d>=2)&top2.eq(true)) | ((d>=3)&top3.eq(true)))
    total_hits = int(is_hit.sum())
    captured = int(cap.sum())

    return out, pd.DataFrame([{
        "v127_ProcessedRows": len(out),
        "v127_TotalHits": total_hits,
        "v127_CapturedHits": captured,
        "v127_MissedHits": total_hits - captured,
        "v127_CaptureRate": captured / total_hits if total_hits else None,
        "v127_TotalPlays": int(d.sum()),
        "v127_Top1Rows": int((d==1).sum()),
        "v127_Top2Rows": int((d==2).sum()),
        "v127_Top3Rows": int((d==3).sum()),
        "v127_NoPlayRows": int((d==0).sum()),
        "v127_TargetLockedCaptured": 264,
        "v127_TargetLockedPlaysApprox": 544,
        "v127_MatchesLocked264Tier": bool(total_hits == 312 and captured == 264 and abs(int(d.sum()) - 544) <= 5),
        "v127_Status": "PROCESSED_V127_FINALIZED_OUTPUT",
    }])

def _v127_run_walkforward_engine(input_df):
    final, reduction_log, rescue_log, _old_score = _v124_run_engine(input_df, "walkforward")
    final = _v127_force_processed_columns(final)
    final, score = _v127_score_processed(final)
    return final, reduction_log, rescue_log, score

def _v127_validate_processed_output(final_df):
    required = {"v127_Depth","v127_Action","v127_MembersToPlay","v127_PlayCount"}
    missing = [c for c in required if c not in final_df.columns]
    if missing:
        return False, "Missing finalized v127 columns: " + ", ".join(missing)
    return True, "v127 finalized columns present."





# ================================
# v134 DYNAMIC STREAMRANK PRIORITY FINAL PLAYLIST — DISPLAY ONLY
# Old StreamRank is preserved as StaticStreamRank_Reference.
# New play/display order is FinalDynamicStreamRank_v134.
# No rows/members/depths/rescues are changed.
# ================================
def _v134_norm_stream_key(x):
    s = str(x).lower().replace("&", "and")
    s = re.sub(r"[^a-z0-9]+", " ", s)
    s = re.sub(r"\s+", " ", s).strip()
    return s.replace("washington d c", "washington dc")

def _v134_num(df, col, default=0.0):
    if col in df.columns:
        return pd.to_numeric(df[col], errors="coerce").fillna(default)
    return pd.Series(default, index=df.index)

def _v134_bool01(df, col):
    if col not in df.columns:
        return pd.Series(0, index=df.index, dtype=int)
    s = df[col]
    if getattr(s, "dtype", None) == bool:
        return s.astype(int)
    return s.astype(str).str.strip().str.lower().isin(["1","true","yes","y","play"]).astype(int)

def _v134_scale_high(s):
    s = pd.to_numeric(s, errors="coerce").astype(float)
    if s.notna().sum() == 0:
        return pd.Series(0.0, index=s.index)
    lo, hi = s.min(), s.max()
    if pd.isna(lo) or pd.isna(hi) or hi == lo:
        return pd.Series(0.5, index=s.index)
    return ((s - lo) / (hi - lo)).fillna(0.0)

def _v134_scale_low(s):
    return 1.0 - _v134_scale_high(s)

def _v134_final_cols(df):
    depth_col = next((c for c in ["v134_Depth","v133_Depth","v131_Depth","v130_Depth","v128_Depth","v127_Depth","v124_Depth","v121_Depth"] if c in df.columns), None)
    play_col = next((c for c in ["v134_PlayCount","v133_PlayCount","v131_PlayCount","v130_PlayCount","v128_PlayCount","v127_PlayCount","v124_PlayCount","v121_PlayCount"] if c in df.columns), None)
    action_col = next((c for c in ["v134_Action","v133_Action","v131_Action","v130_Action","v128_Action","v127_Action","v124_Action","v121_Action"] if c in df.columns), None)
    members_col = next((c for c in ["v134_MembersToPlay","v133_MembersToPlay","v131_MembersToPlay","v130_MembersToPlay","v128_MembersToPlay","v127_MembersToPlay","v124_MembersToPlay","v121_MembersToPlay"] if c in df.columns), None)
    return depth_col, play_col, action_col, members_col

def _v134_compute_dynamic_rank_from_daily(df):
    out = df.copy()
    if "Top1" not in out.columns and "PredictedMember" in out.columns:
        out["Top1"] = out["PredictedMember"]
    if "Top2" not in out.columns and "Top2_pred" in out.columns:
        out["Top2"] = out["Top2_pred"]
    if "Top3" not in out.columns and "ThirdMember" in out.columns:
        out["Top3"] = out["ThirdMember"]

    top1_score = _v134_num(out, "Top1_score", 0)
    if "Top1_score" not in out.columns:
        top1_score = _v134_num(out, "ModelConfidenceScore", 0)
    gap = _v134_num(out, "gap", 0)
    if "gap" not in out.columns:
        gap = _v134_num(out, "Margin", 0)
    ratio = _v134_num(out, "ratio", 0)
    if "ratio" not in out.columns:
        ratio = _v134_num(out, "Top2ToTop1Ratio", 0)

    top2_score = _v134_num(out, "Top2_score", 0)
    top3_score = _v134_num(out, "Top3_score", 0)
    pressure_0255 = _v134_num(out, "final_0255", 0) + _v134_num(out, "boost_0255", 0) + _v134_num(out, "rules_0255", 0) + 0.15*_v134_num(out, "score_0255", 0)
    pressure_0225 = _v134_num(out, "final_0225", 0) + _v134_num(out, "boost_0225", 0) + _v134_num(out, "rules_0225", 0) + 0.15*_v134_num(out, "score_0225", 0)
    pressure_0025 = _v134_num(out, "final_0025", 0) + _v134_num(out, "boost_0025", 0) + _v134_num(out, "rules_0025", 0) + 0.15*_v134_num(out, "score_0025", 0)

    score = (
        1.15*_v134_scale_low(top1_score) +
        1.00*_v134_scale_low(gap) +
        0.85*_v134_scale_high(ratio) +
        0.70*_v134_scale_high(top2_score + top3_score) +
        0.45*_v134_scale_high(pressure_0255) +
        0.35*_v134_scale_high(pressure_0225) -
        0.20*_v134_scale_high(pressure_0025) +
        0.25*_v134_bool01(out, "RecommendedStream") +
        0.20*_v134_bool01(out, "RecommendedByTopN") +
        0.20*_v134_bool01(out, "RecommendedByRowPct") +
        0.15*_v134_bool01(out, "Top3Rescue") -
        0.15*_v134_bool01(out, "GATED_TOP3")
    )
    out["DynamicStreamPriorityScore_v134"] = score
    out["DynamicStreamRank_v134"] = score.rank(method="first", ascending=False).astype(int)
    out["DynamicStreamRankSource_v134"] = "computed_from_daily_live_columns"
    return out

def _v134_build_dynamic_final_playlist(df):
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return pd.DataFrame()
    out = df.copy()

    if "StreamKey" not in out.columns and "State" in out.columns and "Game" in out.columns:
        out["StreamKey"] = out["State"].astype(str) + " | " + out["Game"].astype(str)

    out["StaticStreamRank_Reference"] = out["StreamRank"] if "StreamRank" in out.columns else (out["rank"] if "rank" in out.columns else (out["SingleRow"] if "SingleRow" in out.columns else ""))

    depth_col, play_col, action_col, members_col = _v134_final_cols(out)
    if play_col is None and depth_col is not None:
        out["v134_Display_PlayCount"] = pd.to_numeric(out[depth_col], errors="coerce").fillna(0).astype(int)
        play_col = "v134_Display_PlayCount"
    elif play_col is not None:
        out["v134_Display_PlayCount"] = pd.to_numeric(out[play_col], errors="coerce").fillna(0).astype(int)
        play_col = "v134_Display_PlayCount"
    else:
        out["v134_Display_PlayCount"] = 0
        play_col = "v134_Display_PlayCount"

    if action_col is None:
        out["v134_Display_Action"] = np.where(out[play_col].eq(0), "NO_PLAY", np.where(out[play_col].eq(1), "PLAY_TOP1", np.where(out[play_col].eq(2), "PLAY_TOP2", "PLAY_TOP3")))
        action_col = "v134_Display_Action"
    if members_col is None:
        out["v134_Display_MembersToPlay"] = ""
        members_col = "v134_Display_MembersToPlay"

    out = _v134_compute_dynamic_rank_from_daily(out)

    for c in ["SingleRow","RowPercentile","StreamRank","rank"]:
        if c in out.columns:
            out[c + "_num_v134"] = pd.to_numeric(out[c], errors="coerce")
    if "SingleRow_num_v134" in out.columns:
        out["SingleRowPriority_v134"] = out["SingleRow_num_v134"]
    elif "RowPercentile_num_v134" in out.columns:
        out["SingleRowPriority_v134"] = out["RowPercentile_num_v134"]
    elif "StreamRank_num_v134" in out.columns:
        out["SingleRowPriority_v134"] = out["StreamRank_num_v134"]
    else:
        out["SingleRowPriority_v134"] = pd.Series(np.arange(1, len(out)+1), index=out.index)

    # Cadence due is optional; neutral fallback keeps rank functional.
    out["DuePressureRank_v134"] = out["SingleRowPriority_v134"].rank(method="first", ascending=True)
    out["DuePressure_v134"] = 0.0
    cad = st.session_state.get("v133_singlerow_cadence_stats")
    if isinstance(cad, pd.DataFrame) and not cad.empty and "SingleRow" in cad.columns:
        cc = cad.copy()
        cc["SingleRowPriority_v134"] = pd.to_numeric(cc["SingleRow"], errors="coerce")
        cc["DuePressure_v134"] = pd.to_numeric(cc["DuePressure_vsMedian"] if "DuePressure_vsMedian" in cc.columns else cc.get("CurrentGapAsOfEnd", 0), errors="coerce").fillna(0)
        cc["DuePressureRank_v134_join"] = cc["DuePressure_v134"].rank(method="first", ascending=False)
        out = out.merge(cc[["SingleRowPriority_v134","DuePressure_v134","DuePressureRank_v134_join"]].drop_duplicates("SingleRowPriority_v134"), on="SingleRowPriority_v134", how="left", suffixes=("", "_cad"))
        if "DuePressure_v134_cad" in out.columns:
            out["DuePressure_v134"] = pd.to_numeric(out["DuePressure_v134_cad"], errors="coerce").fillna(out["DuePressure_v134"])
        if "DuePressureRank_v134_join" in out.columns:
            out["DuePressureRank_v134"] = pd.to_numeric(out["DuePressureRank_v134_join"], errors="coerce").fillna(out["DuePressureRank_v134"])

    out["FinalDynamicStreamRank_v134_Score"] = (
        0.50*pd.to_numeric(out["DynamicStreamRank_v134"], errors="coerce").fillna(999) +
        0.35*pd.to_numeric(out["SingleRowPriority_v134"], errors="coerce").fillna(999) +
        0.15*pd.to_numeric(out["DuePressureRank_v134"], errors="coerce").fillna(999)
    )
    out["FinalDynamicStreamRank_v134"] = out["FinalDynamicStreamRank_v134_Score"].rank(method="first", ascending=True).astype(int)

    before_col = "v121_Depth" if "v121_Depth" in out.columns else None
    after_col = next((c for c in ["v127_Depth","v124_Depth","v128_Depth",depth_col] if c and c in out.columns), None)
    if before_col and after_col:
        out["RescueAddedDepth"] = (pd.to_numeric(out[after_col], errors="coerce").fillna(0) - pd.to_numeric(out[before_col], errors="coerce").fillna(0)).clip(lower=0).astype(int)
    else:
        out["RescueAddedDepth"] = 0
    out["RescueAdded"] = np.where(out["RescueAddedDepth"].gt(0), "YES", "")

    out = out.sort_values("FinalDynamicStreamRank_v134").copy()
    out["BudgetOrder"] = range(1, len(out)+1)
    out["RunningPlayTotal"] = pd.to_numeric(out[play_col], errors="coerce").fillna(0).astype(int).cumsum()
    out["RunningCost_25c_Value"] = out["RunningPlayTotal"] * 0.25
    out["RunningCost_25c"] = out["RunningCost_25c_Value"].map(lambda x: f"${x:,.2f}")
    out["BudgetMarkerReached"] = out["RunningPlayTotal"].map(lambda t: "$50" if t>=200 else "$40" if t>=160 else "$35" if t>=140 else "$30" if t>=120 else "$25" if t>=100 else "$20" if t>=80 else "$15" if t>=60 else "$10" if t>=40 else "$5" if t>=20 else "")

    display_cols = []
    for c in ["BudgetOrder","FinalDynamicStreamRank_v134","FinalDynamicStreamRank_v134_Score","DynamicStreamRank_v134","DynamicStreamRankSource_v134","DynamicStreamPriorityScore_v134","StaticStreamRank_Reference","SingleRow","RowPercentile","SingleRowPriority_v134","DuePressure_v134","DuePressureRank_v134","StreamKey","State","Game",action_col,members_col,play_col,"RunningPlayTotal","RunningCost_25c","BudgetMarkerReached","RescueAdded","RescueAddedDepth","PredictedMember","Top2_pred","ThirdMember","Top1","Top2","Top3","TrueMember","Result","Top1_Correct","Needed_Top2","Miss","v121_Depth","v124_Depth","v127_Depth","v128_Depth","v130_Depth"]:
        if c in out.columns and c not in display_cols:
            display_cols.append(c)
    return out[display_cols].rename(columns={action_col:"FinalAction", members_col:"MembersToPlay", play_col:"PlayCount"})

def _v134_render_dynamic_final_playlist(df, key_prefix="v134_dynamic_final"):
    view = _v134_build_dynamic_final_playlist(df)
    if view is None or view.empty:
        return pd.DataFrame()
    st.subheader("v134 DYNAMIC STREAMRANK FINAL PLAYLIST — FULL LIST, NO ROWS REMOVED")
    st.caption("Old fixed StreamRank is preserved as StaticStreamRank_Reference. The final displayed play order is FinalDynamicStreamRank_v134. No members/depths/rescues/rows are changed.")
    total_plays = int(pd.to_numeric(view.get("PlayCount", pd.Series(dtype=float)), errors="coerce").fillna(0).sum())
    st.info(f"Full dynamically ordered list: {len(view)} rows | {total_plays} plays | ${total_plays*0.25:,.2f} at $0.25/play")
    cuts = []
    for dollars in [5,10,15,20,25,30,35,40,50]:
        plays = int(dollars/0.25)
        sub = view[pd.to_numeric(view["RunningPlayTotal"], errors="coerce").le(plays)]
        cuts.append({"Budget":f"${dollars}","PlayCutoff":plays,"RowsIncluded":len(sub),"PlaysUsed":int(pd.to_numeric(sub.get("PlayCount", pd.Series(dtype=float)), errors="coerce").fillna(0).sum()) if not sub.empty else 0,"LastDynamicRankIncluded":int(sub["FinalDynamicStreamRank_v134"].max()) if not sub.empty else ""})
    st.dataframe(pd.DataFrame(cuts), use_container_width=True, hide_index=True)
    st.dataframe(view, use_container_width=True, hide_index=True, height=950)
    st.session_state["v134_dynamic_streamrank_final_playlist"] = view
    try:
        _v125_download_button("Download v134 Dynamic Final Playlist CSV", view, "core025_v134_dynamic_streamrank_final_playlist.csv", key_prefix+"_csv")
    except Exception:
        st.download_button("Download v134 Dynamic Final Playlist CSV", view.to_csv(index=False).encode("utf-8"), file_name="core025_v134_dynamic_streamrank_final_playlist.csv", mime="text/csv", use_container_width=True, key=key_prefix+"_csv_fallback")
    return view


# ================================
# v133 HYBRID BUDGET PLANNER + LOSS REVIEW — DISPLAY ONLY
# This section does NOT alter prediction logic, reductions, rescues, cadence, depths, members, or captures.
# It only creates a sorted full-list view with HybridBudgetRank, running plays/cost, and loss-review fields.
# ================================

def _v133_norm_stream_key(x):
    s = str(x).lower().replace("&", "and")
    s = re.sub(r"[^a-z0-9]+", " ", s)
    s = re.sub(r"\s+", " ", s).strip()
    s = s.replace("washington d c", "washington dc")
    return s

def _v133_num_series(df, col, default=0.0):
    if col in df.columns:
        return pd.to_numeric(df[col], errors="coerce").fillna(default)
    return pd.Series(default, index=df.index)

def _v133_final_play_columns(final_df):
    depth_col = next((c for c in ["v133_Depth", "v131_Depth", "v130_Depth", "v128_Depth", "v127_Depth", "v124_Depth", "v121_Depth"] if c in final_df.columns), None)
    play_col = next((c for c in ["v133_PlayCount", "v131_PlayCount", "v130_PlayCount", "v128_PlayCount", "v127_PlayCount", "v124_PlayCount", "v121_PlayCount"] if c in final_df.columns), None)
    action_col = next((c for c in ["v133_Action", "v131_Action", "v130_Action", "v128_Action", "v127_Action", "v124_Action", "v121_Action"] if c in final_df.columns), None)
    members_col = next((c for c in ["v133_MembersToPlay", "v131_MembersToPlay", "v130_MembersToPlay", "v128_MembersToPlay", "v127_MembersToPlay", "v124_MembersToPlay", "v121_MembersToPlay"] if c in final_df.columns), None)
    return depth_col, play_col, action_col, members_col

def _v133_build_hybrid_budget_planner(final_df: pd.DataFrame) -> pd.DataFrame:
    if final_df is None or not isinstance(final_df, pd.DataFrame) or final_df.empty:
        return pd.DataFrame()

    out = final_df.copy()
    depth_col, play_col, action_col, members_col = _v133_final_play_columns(out)

    if play_col is None and depth_col is not None:
        out["v133_Display_PlayCount"] = pd.to_numeric(out[depth_col], errors="coerce").fillna(0).astype(int)
        play_col = "v133_Display_PlayCount"
    elif play_col is not None:
        out["v133_Display_PlayCount"] = pd.to_numeric(out[play_col], errors="coerce").fillna(0).astype(int)
        play_col = "v133_Display_PlayCount"
    else:
        out["v133_Display_PlayCount"] = 0
        play_col = "v133_Display_PlayCount"

    if action_col is None:
        out["v133_Display_Action"] = np.where(
            out[play_col].eq(0), "NO_PLAY",
            np.where(out[play_col].eq(1), "PLAY_TOP1",
            np.where(out[play_col].eq(2), "PLAY_TOP2", "PLAY_TOP3"))
        )
        action_col = "v133_Display_Action"

    if members_col is None:
        out["v133_Display_MembersToPlay"] = ""
        members_col = "v133_Display_MembersToPlay"

    # Rescue-added display only: compare baseline depth to rescue/cadence layer when possible.
    before_col = "v121_Depth" if "v121_Depth" in out.columns else None
    after_col = next((c for c in ["v127_Depth", "v124_Depth", "v128_Depth", depth_col] if c and c in out.columns), None)
    if before_col and after_col:
        out["RescueAddedDepth"] = (
            pd.to_numeric(out[after_col], errors="coerce").fillna(0)
            - pd.to_numeric(out[before_col], errors="coerce").fillna(0)
        ).clip(lower=0).astype(int)
    else:
        out["RescueAddedDepth"] = 0
    out["RescueAdded"] = np.where(out["RescueAddedDepth"].gt(0), "YES", "")

    # Ensure identity/sort columns exist.
    if "StreamKey" not in out.columns and "State" in out.columns and "Game" in out.columns:
        out["StreamKey"] = out["State"].astype(str) + " | " + out["Game"].astype(str)

    for c in ["SingleRow", "RowPercentile", "StreamRank", "rank", "PlaylistRank", "v79_FinalPlayRank"]:
        if c in out.columns:
            out[c + "_v133_num"] = pd.to_numeric(out[c], errors="coerce")

    # Dynamic rank availability:
    # If the app has a v132/v133 dynamic table in session, join it by Date+StreamKey.
    # If not, use existing dynamic columns if present; otherwise fallback to StreamRank/SingleRow.
    out["v133_norm_stream"] = out["StreamKey"].map(_v133_norm_stream_key) if "StreamKey" in out.columns else out.index.astype(str)
    if "Date" in out.columns:
        out["v133_Date"] = pd.to_datetime(out["Date"], errors="coerce")
    elif "transition_date" in out.columns:
        out["v133_Date"] = pd.to_datetime(out["transition_date"], errors="coerce")
    else:
        out["v133_Date"] = pd.NaT

    dynamic_joined = False
    for sess_key in ["v132_dynamic_daily_ranked", "v132_dynamic_ranked", "v133_dynamic_daily_ranked"]:
        dyn = st.session_state.get(sess_key)
        if isinstance(dyn, pd.DataFrame) and not dyn.empty:
            d = dyn.copy()
            if "Date" in d.columns and "StreamKey" in d.columns:
                d["v133_Date"] = pd.to_datetime(d["Date"], errors="coerce")
                d["v133_norm_stream"] = d["StreamKey"].map(_v133_norm_stream_key)
                keep = [c for c in ["v133_Date", "v133_norm_stream", "DynamicStreamRank_v132", "DynamicDailyStreamScore_v132", "DynamicMinedRank", "DynamicMinedScore"] if c in d.columns]
                if len(keep) >= 3:
                    d = d[keep].drop_duplicates(["v133_Date", "v133_norm_stream"])
                    out = out.merge(d, on=["v133_Date", "v133_norm_stream"], how="left", suffixes=("", "_from_session"))
                    dynamic_joined = True
                    break

    dyn_col = next((c for c in ["DynamicMinedRank", "DynamicStreamRank_v132", "DynamicStreamRank", "DynamicRank"] if c in out.columns), None)
    if dyn_col:
        out["DynamicRankDisplay"] = pd.to_numeric(out[dyn_col], errors="coerce")
    else:
        # Fallback preserves function if no dynamic rank has been run yet.
        fallback_rank = next((c for c in ["StreamRank_v133_num", "SingleRow_v133_num", "rank_v133_num"] if c in out.columns), None)
        out["DynamicRankDisplay"] = pd.to_numeric(out[fallback_rank], errors="coerce") if fallback_rank else pd.Series(np.nan, index=out.index)

    # SingleRow/RowPercentile priority.
    if "SingleRow_v133_num" in out.columns:
        out["SingleRowPriority"] = out["SingleRow_v133_num"]
    elif "RowPercentile_v133_num" in out.columns:
        out["SingleRowPriority"] = out["RowPercentile_v133_num"]
    elif "StreamRank_v133_num" in out.columns:
        out["SingleRowPriority"] = out["StreamRank_v133_num"]
    else:
        out["SingleRowPriority"] = pd.Series(np.arange(1, len(out)+1), index=out.index)

    # Due/cadence pressure:
    # Prefer cadence stats if loaded in session or embedded from prior outputs; otherwise neutral midpoint rank.
    out["DuePressureRank"] = 999.0
    out["DuePressure"] = 0.0
    cad = st.session_state.get("v133_singlerow_cadence_stats")
    if not isinstance(cad, pd.DataFrame) or cad.empty:
        # Try any known cadence file in local working directory when Streamlit has filesystem access.
        try:
            if Path("core025_singlerow_solo_cadence_stats_1_to_78.csv").exists():
                cad = pd.read_csv("core025_singlerow_solo_cadence_stats_1_to_78.csv")
        except Exception:
            cad = pd.DataFrame()
    if isinstance(cad, pd.DataFrame) and not cad.empty and "SingleRow" in cad.columns:
        cc = cad.copy()
        cc["SingleRowPriority"] = pd.to_numeric(cc["SingleRow"], errors="coerce")
        if "DuePressure_vsMedian" in cc.columns:
            cc["DuePressure"] = pd.to_numeric(cc["DuePressure_vsMedian"], errors="coerce").fillna(0)
        elif "CurrentGapAsOfEnd" in cc.columns:
            cc["DuePressure"] = pd.to_numeric(cc["CurrentGapAsOfEnd"], errors="coerce").fillna(0)
        else:
            cc["DuePressure"] = 0
        cc["DuePressureRank_join"] = cc["DuePressure"].rank(method="first", ascending=False)
        out = out.merge(cc[["SingleRowPriority", "DuePressure", "DuePressureRank_join"]].drop_duplicates("SingleRowPriority"), on="SingleRowPriority", how="left", suffixes=("", "_cad"))
        out["DuePressure"] = pd.to_numeric(out.get("DuePressure_cad", out.get("DuePressure", 0)), errors="coerce").fillna(out["DuePressure"])
        out["DuePressureRank"] = pd.to_numeric(out.get("DuePressureRank_join", out.get("DuePressureRank", 999)), errors="coerce").fillna(999)

    # If dynamic rank is missing on daily because lab was not run, use SingleRow fallback, but label it.
    out["DynamicRankDisplay"] = pd.to_numeric(out["DynamicRankDisplay"], errors="coerce")
    if out["DynamicRankDisplay"].isna().all():
        out["DynamicRankDisplay"] = out["SingleRowPriority"]
        out["DynamicRankSource"] = "Fallback: SingleRow/Static"
    else:
        # fill only missing rows with worst+1 within daily list
        max_dyn = out["DynamicRankDisplay"].max()
        out["DynamicRankDisplay"] = out["DynamicRankDisplay"].fillna(max_dyn + 1 if pd.notna(max_dyn) else out["SingleRowPriority"])
        out["DynamicRankSource"] = "Dynamic/session if available; fallback for missing"

    out["DuePressureRank"] = pd.to_numeric(out["DuePressureRank"], errors="coerce")
    if out["DuePressureRank"].isna().all() or out["DuePressureRank"].eq(999).all():
        # neutral due rank: do not dominate sort
        out["DuePressureRank"] = out["SingleRowPriority"].rank(method="first", ascending=True)
        out["DuePressureSource"] = "Neutral fallback"
    else:
        out["DuePressureSource"] = "Cadence DuePressure"

    # Hybrid budget score and rank. Lower = better.
    out["HybridBudgetScore"] = (
        0.50 * pd.to_numeric(out["DynamicRankDisplay"], errors="coerce").fillna(999)
        + 0.35 * pd.to_numeric(out["SingleRowPriority"], errors="coerce").fillna(999)
        + 0.15 * pd.to_numeric(out["DuePressureRank"], errors="coerce").fillna(999)
    )
    out["HybridBudgetRank"] = out["HybridBudgetScore"].rank(method="first", ascending=True).astype(int)

    # Sort full list by HybridBudgetRank; no rows removed.
    out = out.sort_values(["HybridBudgetRank"]).copy()
    out["BudgetOrder"] = range(1, len(out) + 1)
    out["RunningPlayTotal"] = pd.to_numeric(out[play_col], errors="coerce").fillna(0).astype(int).cumsum()
    out["RunningCost_25c_Value"] = out["RunningPlayTotal"] * 0.25
    out["RunningCost_25c"] = out["RunningCost_25c_Value"].map(lambda x: f"${x:,.2f}")

    def _budget_marker(total):
        marks = [(20, "$5"), (40, "$10"), (60, "$15"), (80, "$20"), (100, "$25"), (120, "$30"), (140, "$35"), (160, "$40"), (200, "$50")]
        hit = [lab for plays, lab in marks if int(total) >= plays]
        return hit[-1] if hit else ""
    out["BudgetMarkerReached"] = out["RunningPlayTotal"].map(_budget_marker)

    # Loss-review fields: preserve truth/capture fields if available, otherwise blank.
    if "TrueMember" not in out.columns and "winning_member" in out.columns:
        out["TrueMember"] = out["winning_member"]
    if "Result" not in out.columns and "ActualResult" in out.columns:
        out["Result"] = out["ActualResult"]

    # A simple review status when truth is available.
    true_col = next((c for c in ["TrueMember", "winning_member"] if c in out.columns), None)
    if true_col:
        true_norm = out[true_col].map(_v121_member) if "_v121_member" in globals() else out[true_col].astype(str)
        top1_norm = out.get("PredictedMember", pd.Series("", index=out.index)).map(_v121_member) if "_v121_member" in globals() and "PredictedMember" in out.columns else out.get("PredictedMember", pd.Series("", index=out.index)).astype(str)
        top2_norm = out.get("Top2_pred", pd.Series("", index=out.index)).map(_v121_member) if "_v121_member" in globals() and "Top2_pred" in out.columns else out.get("Top2_pred", pd.Series("", index=out.index)).astype(str)
        top3_norm = out.get("ThirdMember", pd.Series("", index=out.index)).map(_v121_member) if "_v121_member" in globals() and "ThirdMember" in out.columns else out.get("ThirdMember", pd.Series("", index=out.index)).astype(str)
        d = pd.to_numeric(out[play_col], errors="coerce").fillna(0).astype(int)
        out["LossReview_CapturedByDisplayedPlay"] = np.where(
            ((d >= 1) & top1_norm.eq(true_norm)) |
            ((d >= 2) & (top1_norm.eq(true_norm) | top2_norm.eq(true_norm))) |
            ((d >= 3) & (top1_norm.eq(true_norm) | top2_norm.eq(true_norm) | top3_norm.eq(true_norm))),
            "CAPTURED",
            np.where(true_norm.isin(["0025", "0225", "0255"]), "MISSED_MEMBER_OR_DEPTH", "")
        )
    else:
        out["LossReview_CapturedByDisplayedPlay"] = ""

    display_cols = []
    for c in [
        "BudgetOrder", "HybridBudgetRank", "HybridBudgetScore",
        "DynamicRankDisplay", "DynamicRankSource",
        "SingleRow", "RowPercentile", "SingleRowPriority",
        "DuePressure", "DuePressureRank", "DuePressureSource",
        "StreamRank", "rank", "State", "Game", "StreamKey",
        action_col, members_col, play_col,
        "RunningPlayTotal", "RunningCost_25c", "BudgetMarkerReached",
        "RescueAdded", "RescueAddedDepth",
        "PredictedMember", "Top2_pred", "ThirdMember",
        "TrueMember", "Result", "LossReview_CapturedByDisplayedPlay",
        "v121_Depth", "v124_Depth", "v127_Depth", "v128_Depth", "v130_Depth",
        "Top1_Correct", "Needed_Top2", "Miss"
    ]:
        if c in out.columns and c not in display_cols:
            display_cols.append(c)

    budget = out[display_cols].copy()
    budget = budget.rename(columns={
        action_col: "FinalAction",
        members_col: "MembersToPlay",
        play_col: "PlayCount",
    })
    return budget

def _v133_render_hybrid_budget_planner(final_df: pd.DataFrame, key_prefix: str = "v133_hybrid_budget"):
    budget = _v133_build_hybrid_budget_planner(final_df)
    if budget is None or budget.empty:
        return pd.DataFrame()

    st.subheader("v133 HYBRID BUDGET PLANNER — FULL FINAL PLAYLIST, NO ROWS REMOVED")
    st.caption(
        "Display/prioritization only. Sorts by HybridBudgetRank = 50% DynamicRank + 35% SingleRow/RowPercentile + 15% Row Cadence DuePressure. "
        "Running cost uses $0.25/play. This does not change the engine, rescues, cadence, members, or captures."
    )
    total_plays = int(pd.to_numeric(budget.get("PlayCount", pd.Series(dtype=float)), errors="coerce").fillna(0).sum())
    st.info(f"Full list shown: {len(budget)} rows | {total_plays} plays | ${total_plays * 0.25:,.2f} at $0.25/play")

    # Budget cut summaries.
    cuts = []
    for dollars in [5, 10, 15, 20, 25, 30, 35, 40, 50]:
        plays = int(dollars / 0.25)
        sub = budget[pd.to_numeric(budget["RunningPlayTotal"], errors="coerce").le(plays)]
        cuts.append({
            "Budget": f"${dollars}",
            "PlayCutoff": plays,
            "RowsIncluded": len(sub),
            "PlaysUsed": int(pd.to_numeric(sub.get("PlayCount", pd.Series(dtype=float)), errors="coerce").fillna(0).sum()) if not sub.empty else 0,
            "LastHybridRankIncluded": int(sub["HybridBudgetRank"].max()) if not sub.empty and "HybridBudgetRank" in sub.columns else "",
        })
    st.write("**Budget cutoff guide**")
    st.dataframe(pd.DataFrame(cuts), use_container_width=True, hide_index=True)

    st.write("**Full final playlist sorted by HybridBudgetRank**")
    st.dataframe(budget, use_container_width=True, hide_index=True, height=950)

    st.session_state["v133_hybrid_budget_planner"] = budget

    try:
        _v125_download_button(
            "Download v133 Hybrid Budget Planner CSV",
            budget,
            "core025_v133_hybrid_budget_planner_full_playlist.csv",
            key_prefix + "_csv_dl",
        )
    except Exception:
        st.download_button(
            "Download v133 Hybrid Budget Planner CSV",
            budget.to_csv(index=False).encode("utf-8"),
            file_name="core025_v133_hybrid_budget_planner_full_playlist.csv",
            mime="text/csv",
            use_container_width=True,
            key=key_prefix + "_csv_dl_fallback",
        )
    return budget

# Also allow cadence stats upload directly in app sidebar/section when needed.
def _v133_render_optional_cadence_loader():
    with st.expander("v133 Optional Cadence Stats Loader", expanded=False):
        st.caption("Optional. Upload core025_singlerow_solo_cadence_stats_1_to_78.csv to activate real DuePressure. Without it, due pressure uses neutral fallback.")
        up = st.file_uploader("Upload SingleRow cadence stats CSV", type=["csv", "txt", "tsv", "xlsx", "xls"], key="v133_cadence_stats_upload")
        if up is not None:
            try:
                if str(up.name).lower().endswith((".xlsx", ".xls")):
                    cad = pd.read_excel(up)
                else:
                    cad = pd.read_csv(up)
                st.session_state["v133_singlerow_cadence_stats"] = cad
                st.success(f"Loaded cadence stats: {len(cad)} rows")
                st.dataframe(cad, use_container_width=True, hide_index=True, height=300)
            except Exception as e:
                st.warning("Could not load cadence stats: " + str(e))

try:
    _v133_render_optional_cadence_loader()
except Exception:
    pass


# ================================
# v131 DAILY BUDGET PLANNER — DISPLAY ONLY
# Does NOT modify prediction logic, depth, rescues, reductions, cadence, or captures.
# Shows the full final playlist on screen in SingleRow / RowPercentile order with running play count and $0.25 cost.
# ================================
def _v131_daily_budget_planner(final_df: pd.DataFrame) -> pd.DataFrame:
    if final_df is None or not isinstance(final_df, pd.DataFrame) or final_df.empty:
        return pd.DataFrame()

    out = final_df.copy()

    # Select final action/depth/member columns without changing existing engine columns.
    depth_col = next((c for c in ["v131_Depth", "v130_Depth", "v128_Depth", "v127_Depth", "v124_Depth", "v121_Depth"] if c in out.columns), None)
    play_col = next((c for c in ["v131_PlayCount", "v130_PlayCount", "v128_PlayCount", "v127_PlayCount", "v124_PlayCount", "v121_PlayCount"] if c in out.columns), None)
    action_col = next((c for c in ["v131_Action", "v130_Action", "v128_Action", "v127_Action", "v124_Action", "v121_Action"] if c in out.columns), None)
    members_col = next((c for c in ["v131_MembersToPlay", "v130_MembersToPlay", "v128_MembersToPlay", "v127_MembersToPlay", "v124_MembersToPlay", "v121_MembersToPlay"] if c in out.columns), None)

    if play_col is None and depth_col is not None:
        out["v131_Display_PlayCount"] = pd.to_numeric(out[depth_col], errors="coerce").fillna(0).astype(int)
        play_col = "v131_Display_PlayCount"
    elif play_col is not None:
        out["v131_Display_PlayCount"] = pd.to_numeric(out[play_col], errors="coerce").fillna(0).astype(int)
        play_col = "v131_Display_PlayCount"
    else:
        out["v131_Display_PlayCount"] = 0
        play_col = "v131_Display_PlayCount"

    if action_col is None:
        out["v131_Display_Action"] = np.where(
            out[play_col].eq(0), "NO_PLAY",
            np.where(out[play_col].eq(1), "PLAY_TOP1",
            np.where(out[play_col].eq(2), "PLAY_TOP2", "PLAY_TOP3"))
        )
        action_col = "v131_Display_Action"

    if members_col is None:
        members_col = "v131_Display_MembersToPlay"
        out[members_col] = ""

    # Rescue-added flag/depth display only.
    before_col = "v121_Depth" if "v121_Depth" in out.columns else None
    after_col = next((c for c in ["v127_Depth", "v124_Depth", depth_col] if c and c in out.columns), None)
    if before_col and after_col:
        out["v131_RescueAddedDepth"] = (
            pd.to_numeric(out[after_col], errors="coerce").fillna(0)
            - pd.to_numeric(out[before_col], errors="coerce").fillna(0)
        ).clip(lower=0).astype(int)
    else:
        out["v131_RescueAddedDepth"] = 0
    out["v131_RescueAddedFlag"] = np.where(out["v131_RescueAddedDepth"].gt(0), "YES", "")

    # Numeric order helpers. SingleRow is the practical row-percentile order used for this budget view.
    for c in ["SingleRow", "RowPercentile", "StreamRank", "rank", "PlaylistRank", "v79_FinalPlayRank"]:
        if c in out.columns:
            out[c + "_v131_num"] = pd.to_numeric(out[c], errors="coerce")

    sort_cols = []
    if "SingleRow_v131_num" in out.columns:
        sort_cols.append("SingleRow_v131_num")
    elif "RowPercentile_v131_num" in out.columns:
        sort_cols.append("RowPercentile_v131_num")
    elif "StreamRank_v131_num" in out.columns:
        sort_cols.append("StreamRank_v131_num")
    if "StreamRank_v131_num" in out.columns and "StreamRank_v131_num" not in sort_cols:
        sort_cols.append("StreamRank_v131_num")

    if sort_cols:
        out = out.sort_values(sort_cols, ascending=True, na_position="last").copy()
    else:
        out = out.copy()

    out["BudgetOrder"] = range(1, len(out) + 1)
    out["RunningPlayTotal"] = pd.to_numeric(out[play_col], errors="coerce").fillna(0).astype(int).cumsum()
    out["RunningCost_25c"] = out["RunningPlayTotal"] * 0.25
    out["RunningCost_25c_Display"] = out["RunningCost_25c"].map(lambda x: f"${x:,.2f}")

    # Budget marker for fast visual stopping.
    def _budget_marker(total):
        try:
            total = int(total)
        except Exception:
            return ""
        marks = []
        for plays, dollars in [(20,5),(40,10),(60,15),(80,20),(100,25),(120,30),(140,35),(160,40),(200,50)]:
            if total >= plays:
                marks.append(f"${dollars}")
        return marks[-1] if marks else ""

    out["BudgetMarkerReached"] = out["RunningPlayTotal"].map(_budget_marker)

    # Clean display columns, preserving available identifiers.
    display_cols = []
    for c in [
        "BudgetOrder", "SingleRow", "RowPercentile", "StreamRank", "rank",
        "State", "Game", "StreamKey",
        action_col, members_col, play_col,
        "RunningPlayTotal", "RunningCost_25c_Display", "BudgetMarkerReached",
        "v131_RescueAddedFlag", "v131_RescueAddedDepth",
        "PredictedMember", "Top2_pred", "ThirdMember"
    ]:
        if c in out.columns and c not in display_cols:
            display_cols.append(c)

    budget = out[display_cols].copy()

    # Rename selected engine-specific columns to stable v131 display names.
    rename_map = {
        action_col: "FinalAction",
        members_col: "MembersToPlay",
        play_col: "PlayCount",
        "RunningCost_25c_Display": "RunningCost_25c",
        "v131_RescueAddedFlag": "RescueAdded",
        "v131_RescueAddedDepth": "RescueAddedDepth",
    }
    budget = budget.rename(columns=rename_map)
    return budget

def _v131_render_daily_budget_planner(final_df: pd.DataFrame, key_prefix: str = "v131_daily_budget"):
    budget = _v131_daily_budget_planner(final_df)
    if budget is None or budget.empty:
        return pd.DataFrame()

    st.subheader("DAILY BUDGET PLANNER — FULL LIST ON SCREEN")
    st.caption(
        "Display-only. Ordered by SingleRow / RowPercentile strength. "
        "Use RunningPlayTotal and RunningCost_25c to decide how deep to play. "
        "This does not change reductions, rescues, cadence, or final engine output."
    )

    total_plays = int(pd.to_numeric(budget.get("PlayCount", pd.Series([], dtype=int)), errors="coerce").fillna(0).sum())
    st.info(f"Full v131 budget list shown on screen: {len(budget)} rows | {total_plays} plays | ${total_plays * 0.25:,.2f} at $0.25/play")

    # Show full list, not just head(250). For daily this is only ~78 rows.
    st.dataframe(budget, use_container_width=True, hide_index=True, height=900)

    try:
        _v125_download_button(
            "Download Daily Budget Planner CSV",
            budget,
            "core025_v131_daily_budget_planner_full_onscreen.csv",
            key_prefix + "_csv_dl",
        )
    except Exception:
        st.download_button(
            "Download Daily Budget Planner CSV",
            budget.to_csv(index=False).encode("utf-8"),
            file_name="core025_v131_daily_budget_planner_full_onscreen.csv",
            mime="text/csv",
            use_container_width=True,
            key=key_prefix + "_csv_dl_fallback",
        )
    return budget


