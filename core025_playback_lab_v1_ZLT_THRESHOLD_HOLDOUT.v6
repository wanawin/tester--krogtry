        "group":"B1_SAFE_ZLT_LOW_SUPPORT",
        "name":"true ZLT count = 0",
        "definition":"CUT STREAM when true ZLT count equals 0.",
        "history_note":"v64 winner-only file: rule count <=1 lost 0 winners; Oregon-day winner survived.",
        "input_fields":"v159/v161/v162 FiredRuleIDs, RuleFlags",
        "mode":"B1_ZLT_LE1",
    },
    {
        "id":"B1Z1",
        "group":"B1_SAFE_ZLT_LOW_SUPPORT",
        "name":"true ZLT count = 1",
        "definition":"CUT STREAM when true ZLT count equals 1.",
        "history_note":"v64 winner-only file: rule count <=1 lost 0 winners; Oregon-day winner survived.",
        "input_fields":"v159/v161/v162 FiredRuleIDs, RuleFlags",
        "mode":"B1_ZLT_LE1",
    },
    {
        "id":"B2Z2N225",
        "group":"B2_PROTECTED_ZLT2",
