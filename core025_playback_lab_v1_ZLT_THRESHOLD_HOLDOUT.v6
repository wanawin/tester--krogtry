# ================================
# v108 ISOLATED DEEP MINER PANEL
# ================================
try:
    st.divider()
    with st.expander("v109 Isolated Deep Miner Separator Panel", expanded=False):
        st.caption("Read-only/isolated. This panel does not touch FULL HISTORY upload, Daily Prediction, ranking, member engine, cadence, or straight logic.")
        st.subheader("Implementation queue")
        q108 = st.session_state.get("v108_implementation_queue")
        if not isinstance(q108, pd.DataFrame):
            q108 = _v108_queue()
            st.session_state["v108_implementation_queue"] = q108
        st.dataframe(q108, use_container_width=True, hide_index=True)
        st.download_button(
            "Download v108 implementation queue",
            data=q108.to_csv(index=False).encode("utf-8"),
            file_name="core025_v108_implementation_queue.csv",
            mime="text/csv",
            use_container_width=True,
            key="v108_queue_download",
            **(_v103_download_kwargs() if "_v103_download_kwargs" in globals() else {})
        )

        uploaded108 = st.file_uploader(
            "Upload full 312 per-event export or classified miner output for isolated separator mining",
            type=["csv","txt","tsv","xlsx","xls"],
            key="v108_deep_miner_upload"
        )
        min_support108 = st.number_input("v108 separator minimum support", min_value=2, max_value=100, value=5, step=1, key="v108_min_support")
        run108 = st.button("Run v108 isolated separator mining", key="v108_run_miner", type="primary")

        if run108:
            if uploaded108 is None:
                st.warning("Upload a per-event/classified file for isolated mining. The live history uploader is intentionally not reused here.")
            else:
                raw108 = _v108_load_miner_table(uploaded108)
                classified108 = _v108_classify_miner_rows(raw108)
                classified108 = _v108_add_miner_traits(classified108)
                scores108 = _v108_score_miner_traits(classified108, min_support=int(min_support108))
                st.session_state["v108_miner_source"] = _v108_miner_name(uploaded108)
                st.session_state["v108_miner_classified"] = classified108
                st.session_state["v108_miner_scores"] = scores108

        classified108 = st.session_state.get("v108_miner_classified")
        scores108 = st.session_state.get("v108_miner_scores")

        if isinstance(classified108, pd.DataFrame) and not classified108.empty:
            st.success("v108 isolated miner data available")
            st.write("**Source:** " + str(st.session_state.get("v108_miner_source", "")))
            if "v108_OutcomeGroup" in classified108.columns:
                st.subheader("Outcome group summary")
                st.dataframe(classified108["v108_OutcomeGroup"].astype(str).value_counts().rename_axis("OutcomeGroup").reset_index(name="Rows"), use_container_width=True, hide_index=True)
            st.download_button(
                "Download v108 classified table",
                data=classified108.to_csv(index=False).encode("utf-8"),
                file_name="core025_v108_isolated_miner_classified_table.csv",
                mime="text/csv",
                use_container_width=True,
                key="v108_classified_download",
                **(_v103_download_kwargs() if "_v103_download_kwargs" in globals() else {})
            )

        if isinstance(scores108, pd.DataFrame) and not scores108.empty:
            st.subheader("v108 separator candidates")
            st.dataframe(scores108.head(150), use_container_width=True, hide_index=True)
            st.download_button(
                "Download v108 separator trait scores",
                data=scores108.to_csv(index=False).encode("utf-8"),
                file_name="core025_v108_isolated_separator_trait_scores.csv",
                mime="text/csv",
                use_container_width=True,
                key="v108_scores_download",
                **(_v103_download_kwargs() if "_v103_download_kwargs" in globals() else {})
            )
except Exception as _v108_panel_error:
    try:
        st.warning("v108 isolated deep miner panel unavailable: " + str(_v108_panel_error))
    except Exception:
        pass


# ================================
# v109 STAGED POST-RANK SEPARATOR OPTIMIZER PANEL
# ================================
try:
    st.divider()
    with st.expander("v111 Correct-Target Bucket-Feature Separator Optimizer", expanded=False):
        st.caption("Preview-only. Applies mined separator rules after current stream/rank selection. It does not change the live playlist automatically.")
        scores109 = st.session_state.get("v108_miner_scores")
        scores_upload109 = st.file_uploader("Optional: upload v108 separator trait scores CSV", type=["csv","txt","tsv"], key="v109_scores_upload")
        if scores_upload109 is not None:
            try:
                scores109 = _v108_load_miner_table(scores_upload109)
                st.session_state["v108_miner_scores"] = scores109
            except Exception as e:
                st.warning("Could not load score upload: " + str(e))
        c1,c2,c3,c4 = st.columns(4)
        with c1:
            min_support109 = st.number_input("v109 min support", 2, 100, 5, 1, key="v109_min_support")
        with c2:
            min_gap109 = st.number_input("v109 min gap", 0.0, 1.0, 0.05, 0.01, format="%.2f", key="v109_min_gap")
        with c3:
            min_rate109 = st.number_input("v109 min target rate", 0.0, 1.0, 0.20, 0.01, format="%.2f", key="v109_min_rate")
        with c4:
            max_rules109 = st.number_input("v109 max rules", 10, 1000, 250, 10, key="v109_max_rules")
        enable_skip109 = st.checkbox("Preview MISS rules as SKIP rows", value=False, key="v109_skip_preview")
        require_row_history110 = st.checkbox(
            "Require active row history before separator preview",
            value=True,
            key="v110_require_row_history",
            help="Leave ON. If playlist still says NO_ROW_HISTORY_YET, separator promotion is blocked until Walk-forward/row history is active."
        )
        if st.button("Build v109 staged separator preview", type="primary", key="v109_run_preview"):
            if not isinstance(scores109, pd.DataFrame) or scores109.empty:
                st.warning("Run v108 miner or upload v108 separator trait scores first.")
            else:
                try:
                    src109, daily109 = v85_get_daily_playlist()
                except Exception:
                    src109, daily109 = None, pd.DataFrame()
                if not isinstance(daily109, pd.DataFrame) or daily109.empty:
                    st.warning("Run Daily Prediction first.")
                else:
                    _ok110, _blocked_preview110, _audit110 = _v110_gate_preview_if_needed(daily109, bool(require_row_history110))
                    st.session_state["v110_row_history_audit"] = _audit110
                    if not _ok110:
                        prev109 = _blocked_preview110
                    else:
                        prev109 = _v109_apply_staged_optimizer(daily109, scores109, int(min_support109), float(min_gap109), float(min_rate109), int(max_rules109), bool(enable_skip109))
                    st.session_state["v109_staged_preview"] = prev109
                    st.session_state["v109_staged_summary"] = _v109_summary(prev109)
                    st.session_state["v109_staged_source"] = str(src109)
        audit110 = st.session_state.get("v110_row_history_audit")
        if isinstance(audit110, pd.DataFrame) and not audit110.empty:
            st.subheader("v110 row-history activation audit")
            st.dataframe(audit110, use_container_width=True, hide_index=True)
            st.download_button(
                "Download v110 row-history audit",
                data=audit110.to_csv(index=False).encode("utf-8"),
                file_name="core025_v120_row_history_activation_audit.csv",
                mime="text/csv",
                use_container_width=True,
                key="v110_row_history_audit_download",
                **(_v103_download_kwargs() if "_v103_download_kwargs" in globals() else {})
            )
        
        summary109 = st.session_state.get("v109_staged_summary")
        preview109 = st.session_state.get("v109_staged_preview")
        if isinstance(summary109, pd.DataFrame) and not summary109.empty:
            st.subheader("v109 staged summary")
            st.write("**Daily playlist source:** " + str(st.session_state.get("v109_staged_source","")))
            st.dataframe(summary109, use_container_width=True, hide_index=True)
            st.download_button("Download v109 staged summary", data=summary109.to_csv(index=False).encode("utf-8"), file_name="core025_v120_staged_separator_summary.csv", mime="text/csv", use_container_width=True, key="v109_summary_download", **(_v103_download_kwargs() if "_v103_download_kwargs" in globals() else {}))
        if isinstance(preview109, pd.DataFrame) and not preview109.empty:
            st.subheader("v109 staged preview")
            show109 = [c for c in ["StreamKey","StreamRank","RowPercentile","SingleRow","PlayType","ActualBoxPlay","PredictedMember","Top2_pred","ThirdMember","v109_CurrentMembersToPlay","v109_CurrentPlayCount","v109_SeparatorAction","v109_PreviewMembersToPlay","v109_PreviewPlayCount","v109_PlayCountDelta","v109_SeparatorReason"] if c in preview109.columns]
            st.dataframe(preview109[show109], use_container_width=True, hide_index=True)
            st.download_button("Download v109 staged separator preview", data=preview109.to_csv(index=False).encode("utf-8"), file_name="core025_v120_staged_separator_preview.csv", mime="text/csv", use_container_width=True, key="v109_preview_download", **(_v103_download_kwargs() if "_v103_download_kwargs" in globals() else {}))
except Exception as _v109_panel_error:
    try:
        st.warning("v109 staged separator panel unavailable: " + str(_v109_panel_error))
    except Exception:
        pass


