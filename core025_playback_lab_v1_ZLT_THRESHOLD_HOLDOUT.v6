            st.download_button("Download Lab Summary CSV", summary.to_csv(index=False).encode("utf-8"), "lab_summary__core025_northern_lights_v156_SINGLE_PASS_FAST_CHECKPOINT.csv", "text/csv", use_container_width=True, on_click="ignore",
