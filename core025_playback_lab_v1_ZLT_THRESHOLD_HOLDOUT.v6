# ================================
# v119 SCHEMA-AWARE TARGET CLASSIFIER PANEL
# ================================
try:
    st.divider()
    with st.expander("v119 Schema-Aware Target Classifier + Focused Separator Fix", expanded=True):
        st.caption("Fixes v118 UNCLASSIFIED rows by mapping the actual per-event file schema first.")
        up=st.file_uploader("Optional fallback: upload latest walk-forward/per-event file", type=["csv","txt","tsv","xlsx","xls"], key="v119_upload")
        c1,c2,c3,c4=st.columns(4)
        with c1: sup=st.number_input("Min support",2,100,8,1,key="v119_sup")
        with c2: gap=st.number_input("Min gap",0.0,1.0,0.05,0.01,format="%.2f",key="v119_gap")
        with c3: pairs=st.number_input("Max pair traits",5,150,60,5,key="v119_pairs")
        with c4: maxr=st.number_input("Max rules",20,2000,500,20,key="v119_max")
        if st.button("Run v119 schema-aware focused correction", type="primary", key="v119_run"):
            src,df=_v118_src(["v113_per_event","v112_per_event","v114_per_event","v117_per_event"], up) if "_v118_src" in globals() else ("uploaded", _v118_load(up))
            if not isinstance(df,pd.DataFrame) or df.empty:
                st.warning("No per-event file found. Upload latest walk-forward/per-event file.")
            else:
                work,mp,tm,rules,audit=_v119_mine(df,int(sup),float(gap),int(pairs),int(maxr))
                scored=_v119_score(work,mp,tm,rules)
                locked=scored[scored["PromotionStatus"].isin(["LOCK_CANDIDATE_ZERO_HARM","PROTECTIVE_RULE_CANDIDATE","SWAP_CANDIDATE_REVIEW","REVIEW_LOW_HARM_HIGH_VALUE"])].copy() if isinstance(scored,pd.DataFrame) and not scored.empty else pd.DataFrame()
                breakdown=work["v119_TargetLabel"].value_counts().rename_axis("TargetGroup").reset_index(name="Rows")
                st.session_state["v119_source_trait_count"]=pd.DataFrame([{"Source":src,"Rows":len(work),"TraitsUsed":tm.shape[1] if isinstance(tm,pd.DataFrame) else 0}])
                st.session_state["v119_schema_audit"]=audit
                st.session_state["v119_target_breakdown"]=breakdown
                st.session_state["v119_focused_rules"]=rules
                st.session_state["v119_harm_scored_focused_rules"]=scored
                st.session_state["v119_locked_review_queue"]=locked
        for title,key,fname in [
            ("v119 source / trait count","v119_source_trait_count","core025_v120_source_trait_count.csv"),
            ("v119 schema audit","v119_schema_audit","core025_v120_schema_audit.csv"),
            ("v119 target breakdown","v119_target_breakdown","core025_v120_target_breakdown.csv"),
            ("v119 focused separator rules","v119_focused_rules","core025_v120_focused_separator_rules.csv"),
            ("v119 harm-scored focused rules","v119_harm_scored_focused_rules","core025_v120_harm_scored_focused_rules.csv"),
            ("v119 locked/review queue","v119_locked_review_queue","core025_v120_locked_review_queue.csv"),
        ]:
