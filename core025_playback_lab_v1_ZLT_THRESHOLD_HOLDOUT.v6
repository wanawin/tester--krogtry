                st.download_button("Download "+title, data=df.to_csv(index=False).encode("utf-8"), file_name=fname, mime="text/csv", use_container_width=True, key=key+"_download", **(_v103_download_kwargs() if "_v103_download_kwargs" in globals() else {}))
