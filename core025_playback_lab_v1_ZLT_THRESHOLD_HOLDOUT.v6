            st.json(_v106_report)

            _v106_top40 = _v106_topn_overlap_report(_v106_diag_df, 40)
            if isinstance(_v106_top40, pd.DataFrame) and not _v106_top40.empty:
                st.caption("Top 40 comparison basis: StreamRank vs RowPercentile. BOTH_AGREE rows are candidates for the agreed final playlist test.")
                _v106_cols = [c for c in ["StreamKey", "StreamRank", "RowPercentile", "SingleRow", "PlaylistRank", "v106_InTopN_StreamRank", "v106_InTopN_RowPercentile", "v106_InTopN_AgreedBoth", "v106_TopN_Source"] if c in _v106_top40.columns]
                st.dataframe(_v106_top40[_v106_cols].head(100), use_container_width=True)
                v92_download_pair("v106 Top40 StreamRank vs RowPercentile agreement", _v106_top40, "core025_v106_top40_streamrank_rowpct_overlap")
            else:
                st.warning("v106 could not build Top40 overlap. Required columns: StreamKey, StreamRank, and RowPercentile or SingleRow.")
        else:
            st.info("Run Daily Prediction first to validate rank/row separation and build the Top40 overlap report.")
except Exception as _v106_diag_error:
