        with tab_daily124:
            st.caption("Daily flow: run the main Daily Prediction first; this tab auto-detects that output. Upload here only as an override.")
            up_daily124 = st.file_uploader("Optional override: Daily playlist. Leave blank to auto-use latest Daily Prediction output from session.", type=["csv","txt","tsv","xlsx","xls"], key="v129_daily_override_upload")
            if st.button("Run v130 Daily Engine", type="primary", key="v124_run_daily"):
                if up_daily124 is not None:
                    df_in = _v121_load_any(up_daily124)
                    source = "uploaded daily override"
                else:
                    key, df_in = _v129_find_daily_playlist_from_session()
                    source = "session:auto_daily_output:" + str(key)
                if not isinstance(df_in, pd.DataFrame) or df_in.empty:
                    st.warning("No Daily playlist found in session. First run the main Daily Prediction tab, or upload a Daily playlist override here.")
                else:
                    final, rlog, qlog, _score_pre_cadence = _v124_run_engine(df_in, "daily")
                    final = _v127_force_processed_columns(final)
                    final, clog = _v128_apply_single_row_cadence(final)
                    score = _v128_score(final)
                    st.session_state["v128_daily_cadence_log"] = clog
                    st.session_state["v128_daily_date_status"] = _v128_history_status(df_in)
                    st.session_state["v124_daily_output"] = final
                    st.session_state["v124_daily_reduction_log"] = rlog
                    st.session_state["v124_daily_rescue_log"] = qlog
                    st.session_state["v124_daily_score"] = score
                    st.session_state["v124_daily_source"] = source
                    st.success("v130 Daily Engine complete.")

            if st.session_state.get("v124_daily_source"):
                st.write("**Daily source:** " + str(st.session_state.get("v124_daily_source")))
                _v130_ds = st.session_state.get("v128_daily_date_status")
                if isinstance(_v130_ds, pd.DataFrame) and not _v130_ds.empty:
                    _r = _v130_ds.iloc[0].to_dict()
                    st.info("History Through: {h} | Playlist Date: {p} | Status: {s}".format(h=_r.get("HistoryThrough", ""), p=_r.get("PlaylistDate", ""), s=_r.get("Status", "")))
            for title, key, fname in [
                ("Daily score", "v124_daily_score", "core025_v130_daily_score.csv"),
                ("Daily date status", "v128_daily_date_status", "core025_v130_daily_date_status.csv"),
                ("Daily cadence log", "v128_daily_cadence_log", "core025_v130_daily_cadence_log.csv"),
                ("Daily reduction log", "v124_daily_reduction_log", "core025_v130_daily_reduction_log.csv"),
                ("Daily rescue log", "v124_daily_rescue_log", "core025_v130_daily_rescue_log.csv"),
                ("Daily finalized playlist", "v124_daily_output", "core025_v130_daily_finalized_playlist.csv"),
            ]:
                x = st.session_state.get(key)
                if isinstance(x, pd.DataFrame) and not x.empty:
                    st.subheader(title)
                    st.dataframe(x.head(250), use_container_width=True, hide_index=True)
                    _v125_download_button("Download " + title, x, fname, key+"_dl")
                    if key == "v124_daily_output":
                        try:
                            budget = _v131_render_daily_budget_planner(x, "v131_daily_budget_main")
                            st.session_state["v131_daily_budget_planner"] = budget
                            try:
                                v133_budget = _v133_render_hybrid_budget_planner(x, "v133_hybrid_budget_main")
                                st.session_state["v133_hybrid_budget_planner"] = v133_budget
                                try:
                                    v134_view = _v134_render_dynamic_final_playlist(x, "v134_dynamic_final_main")
                                    st.session_state["v134_dynamic_streamrank_final_playlist"] = v134_view
                                except Exception as _v134_e:
                                    st.warning("v134 Dynamic StreamRank Final Playlist unavailable: " + str(_v134_e))
                            except Exception as _v133_e:
                                st.warning("v133 Hybrid Budget Planner unavailable: " + str(_v133_e))
                        except Exception as _v131_e:
                            st.warning("Daily Budget Planner unavailable: " + str(_v131_e))

        with tab_wf124:
            st.caption("Walkforward flow: this uses a separate per-event input/autodetect path, not the Daily playlist.")
            up_wf124 = st.file_uploader("Walkforward per-event upload / override. Leave blank to auto-use latest Walkforward Lab per-event output.", type=["csv","txt","tsv","xlsx","xls"], key="v129_wf_per_event_upload")
            if st.button("Run v130 Walkforward Validation", type="primary", key="v124_run_wf"):
                if up_wf124 is not None:
                    df_in = _v121_load_any(up_wf124)
