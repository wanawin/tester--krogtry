]

V163_RARE_TRAIT_RULES = [
    {"id":"RTE001", "group":"RARE_ZERO_CORE025_TRAIT", "name":"cnt0=1 & has8=1", "definition":"CUT STREAM when seed contains exactly one 0 and at least one 8.", "history_note":"0 Core025 conversions in merged full history through 2026-06-04.", "input_fields":"cnt0, has8"},
    {"id":"RTE002", "group":"RARE_ZERO_CORE025_TRAIT", "name":"cnt2=0 & cnt9=2", "definition":"CUT STREAM when seed contains no 2s and exactly two 9s.", "history_note":"0 Core025 conversions in merged full history through 2026-06-04.", "input_fields":"cnt2, cnt9"},
    {"id":"RTE003", "group":"RARE_ZERO_CORE025_TRAIT", "name":"cnt8=1 & even=2 & sum_bucket=sum_22_plus", "definition":"CUT STREAM when seed contains exactly one 8, exactly two even digits, and seed sum is 22+.", "history_note":"0 Core025 conversions in merged full history through 2026-06-04.", "input_fields":"cnt8, even, sum_bucket"},
    {"id":"RTE004", "group":"RARE_ZERO_CORE025_TRAIT", "name":"cnt8=1 & has2=1 & has5=0", "definition":"CUT STREAM when seed contains exactly one 8, contains a 2, and lacks 5.", "history_note":"0 Core025 conversions in merged full history through 2026-06-04.", "input_fields":"cnt8, has2, has5"},
    {"id":"RTE005", "group":"RARE_ZERO_CORE025_TRAIT", "name":"cnt5=0 & seed_highlow_pattern=HLLL", "definition":"CUT STREAM when seed lacks 5 and has high/low pattern HLLL.", "history_note":"0 Core025 conversions in merged full history through 2026-06-04. Note: HLLL alone was NOT used because it converted above baseline.", "input_fields":"cnt5, seed_highlow_pattern"},
]
V164_RARE_TRAIT_RULES = V163_RARE_TRAIT_RULES


def _v163_zlt_ids_from_text(x):
    return re.findall(r"\bZLT\d{3}\b", str(x) if x is not None else "")


def _v163_compute_true_zlt_count(out: pd.DataFrame) -> pd.Series:
    """Return confirmed true ZLT count.

    Critical v168 fix: missing ZLT source must NOT be treated as ZLT=0.
    Earlier printable builds cut every row when the visible table did not carry
    v159/v161 fired-rule columns, because all rows looked like count 0.

    Values:
      -1 = unknown / no confirmed ZLT source on this row/table
       0 = confirmed ZLT source exists and no ZLT IDs fired
      >0 = confirmed count of unique ZLT IDs
    """
    text_cols = [c for c in ["v159_FiredRuleIDs", "v161_FiredRuleIDs", "v162_FiredRuleIDs", "RuleFlags"] if c in out.columns]
    count_cols = [c for c in ["v159_RuleFiredCount", "v161_RuleFiredCount", "v162_RuleFiredCount"] if c in out.columns]

    # If the table has no ZLT text/count source at all, preserve as unknown.
    if not text_cols and not count_cols:
        return pd.Series(-1, index=out.index, dtype="int")

    vals = []
    for idx, row in out.iterrows():
        ids = []
        has_text_source = False
        for c in text_cols:
            raw = row.get(c, "")
            if pd.notna(raw) and str(raw).strip() != "":
                has_text_source = True
            ids.extend(_v163_zlt_ids_from_text(raw))
        if ids:
            vals.append(len(list(dict.fromkeys(ids))))
            continue

        # Fallback to explicit rule-count columns when present and non-null.
        count_val = None
        for c in count_cols:
            raw = row.get(c, np.nan)
            cv = pd.to_numeric(pd.Series([raw]), errors="coerce").iloc[0]
            if pd.notna(cv):
                count_val = int(cv)
                break
        if count_val is not None:
            vals.append(count_val)
        elif has_text_source:
            # Confirmed fired-rule source exists but no ZLT IDs in it.
            vals.append(0)
        else:
            vals.append(-1)
    return pd.Series(vals, index=out.index, dtype="int")

def _v169_direct_zlt_ids_from_rules(feats: pd.DataFrame) -> pd.Series:
    """Evaluate the embedded ZLT rule stack directly from row features.

    This is a safety repair for cases where the v159 display layer fails before it can
    write v159_FiredRuleIDs. The printable/final-cleaned layer still needs the ZLTs to
    fire, count, and trim to Top1 before B1/B2 cuts are applied.
    """
    zids = pd.Series([[] for _ in range(len(feats))], index=feats.index, dtype="object")
    try:
        rules = V159_ZERO_LOSS_TOP1_RULES
    except Exception:
        return zids
    for rule in rules:
        try:
            m = _v159_eval_rule(rule, feats).fillna(False)
        except Exception:
            m = pd.Series(False, index=feats.index)
        if bool(m.any()):
            rid = str(rule.get("id", "")).strip()
            if not rid:
                continue
            for idx in feats.index[m]:
                if rid not in zids.at[idx]:
                    zids.at[idx].append(rid)
    return zids

def _v164_get_feature_frame(out: pd.DataFrame) -> pd.DataFrame:
    try:
        feats = _v159_feature_frame(out)
    except Exception:
        feats = out.copy()
    for c in out.columns:
        if c not in feats.columns:
            feats[c] = out[c]
    return feats


def _v163_eval_rare_traits(feats: pd.DataFrame) -> pd.Series:
    out = pd.Series([[] for _ in range(len(feats))], index=feats.index, dtype="object")
    def n(col, default=0):
        return pd.to_numeric(feats[col], errors="coerce").fillna(default) if col in feats.columns else pd.Series(default, index=feats.index)
    def s(col, default=""):
        return feats[col].astype(str) if col in feats.columns else pd.Series(default, index=feats.index, dtype="object")
    masks = {
        "RTE001": n("cnt0").eq(1) & n("has8").eq(1),
        "RTE002": n("cnt2").eq(0) & n("cnt9").eq(2),
        "RTE003": n("cnt8").eq(1) & n("even").eq(2) & s("sum_bucket").eq("sum_22_plus"),
        "RTE004": n("cnt8").eq(1) & n("has2").eq(1) & n("has5").eq(0),
        "RTE005": n("cnt5").eq(0) & (s("seed_highlow_pattern").eq("HLLL") | s("highlow_pattern").eq("HLLL")),
    }
    label_map = {r["id"]: r["name"] for r in V163_RARE_TRAIT_RULES}
    for rid, m in masks.items():
        for idx in feats.index[m.fillna(False)]:
            out.at[idx].append(f"{rid}:{label_map.get(rid, rid)}")
    return out


def _v164_eval_budget_flag_ids(out: pd.DataFrame, feats: pd.DataFrame, zlt_count: pd.Series, top1_long: pd.Series, rare_lists: pd.Series) -> pd.Series:
    flag_ids = pd.Series([[] for _ in range(len(out))], index=out.index, dtype="object")
    for idx in out.index[zlt_count.eq(0)]:
        flag_ids.at[idx].append("B1Z0")
    for idx in out.index[zlt_count.eq(1)]:
        flag_ids.at[idx].append("B1Z1")
    for idx in out.index[zlt_count.eq(2) & ~top1_long.eq("0225")]:
        flag_ids.at[idx].append("B2Z2N225")
    for idx in out.index:
        for item in rare_lists.at[idx]:
            rid = str(item).split(":", 1)[0]
            if rid:
                flag_ids.at[idx].append(rid)
    return flag_ids


def _v164_flag_definition_lookup() -> dict:
    rows = []
    for r in V164_BUDGET_FLAG_RULES:
        rows.append((r["id"], r["definition"]))
    for r in V163_RARE_TRAIT_RULES:
        rows.append((r["id"], r["definition"]))
    return dict(rows)


def _v164_flag_name_lookup() -> dict:
    rows = []
    for r in V164_BUDGET_FLAG_RULES:
        rows.append((r["id"], r["name"]))
    for r in V163_RARE_TRAIT_RULES:
        rows.append((r["id"], r["name"]))
    return dict(rows)


def _v163_selected_budget_mode():
    """v165: no user selection. The final-cleaned default is always B2 + Rare Traits."""
    return V165_DEFAULT_BUDGET_MODE


def _v164_mode_allows_flag(mode: str, fid: str) -> bool:
    if mode == "OFF":
        return False
    if mode == "B1_ZLT_LE1":
        return fid in {"B1Z0", "B1Z1"}
    if mode == "B2_ZLT_LE1_PLUS_ZLT2_TOP1_NOT_0225":
        return fid in {"B1Z0", "B1Z1", "B2Z2N225"}
    return fid in {"B1Z0", "B1Z1", "B2Z2N225", "RTE001", "RTE002", "RTE003", "RTE004", "RTE005"}


def _v163_apply_budget_layers(out: pd.DataFrame, mode: Optional[str] = None) -> pd.DataFrame:
    if out is None or not isinstance(out, pd.DataFrame) or out.empty:
        return out
    out = out.copy()
    # v165 default: always apply B2 + Rare Traits unless an internal test explicitly passes another mode.
    mode = mode or _v163_selected_budget_mode()
    if mode not in V163_BUDGET_MODES:
        mode = V165_DEFAULT_BUDGET_MODE

    feats = _v164_get_feature_frame(out)
    for c in feats.columns:
        if c not in out.columns and c in ["cnt0","cnt2","cnt5","cnt8","cnt9","has2","has5","has8","even","sum_bucket","seed_highlow_pattern","PredictedMember_str"]:
            out[c] = feats[c]

    # v169: compute ZLTs directly as a fallback/source of truth for the final-cleaned layer.
    # If v159 failed before writing v159_FiredRuleIDs, B1/B2 must still fire.
    direct_zlt_ids = _v169_direct_zlt_ids_from_rules(feats) if "_v169_direct_zlt_ids_from_rules" in globals() else pd.Series([[] for _ in range(len(out))], index=out.index, dtype="object")
    direct_zlt_count = direct_zlt_ids.map(lambda xs: len(list(dict.fromkeys(xs)))).astype(int)
    zlt_count_from_text = _v163_compute_true_zlt_count(out)
    zlt_count = zlt_count_from_text.copy()
    zlt_count.loc[zlt_count.lt(0)] = direct_zlt_count.loc[zlt_count.lt(0)]
    top1_long = feats["PredictedMember_str"].map(_v159_long_member) if "PredictedMember_str" in feats.columns else pd.Series("", index=out.index)
    rare_lists = _v163_eval_rare_traits(feats)
    rare_count = rare_lists.map(len).astype(int)
    all_flag_ids = _v164_eval_budget_flag_ids(out, feats, zlt_count, top1_long, rare_lists)
    allowed_flag_ids = all_flag_ids.map(lambda xs: [x for x in xs if _v164_mode_allows_flag(mode, x)])

    # v167 base source fix:
    # The full visible table remains notes-only, but the printable cleaned table must start
    # from the best available ACTUAL playable count, not from a stale/all-zero adjusted
    # column.  Prefer adjusted columns only when they contain nonzero playable rows.
    def _pick_count_col(candidates):
        for c in candidates:
            if c in out.columns:
                vals = pd.to_numeric(out[c], errors="coerce").fillna(0)
                if int(vals.sum()) > 0:
                    return c
        return next((c for c in candidates if c in out.columns), None)

    base_action_col = next((c for c in ["v159_Action", "FINAL_ACTION_v162", "v161_Action", "Action"] if c in out.columns), None)
    base_members_col = next((c for c in ["v159_AdjustedMembersToPlay", "FINAL_MEMBERS_TO_PLAY_v162", "v161_AdjustedMembersToPlay", "MembersToPlay", "ActualMembersToPlay", "ActualBoxPlay"] if c in out.columns), None)
    base_count_col = _pick_count_col(["v159_AdjustedPlayCount", "FINAL_PLAY_COUNT_v162", "v161_AdjustedPlayCount", "PlayCount", "ActualPlayCount"])

    base_action = out[base_action_col].astype(str) if base_action_col else pd.Series("KEEP ORIGINAL", index=out.index)
    base_members = out[base_members_col].astype(str) if base_members_col else pd.Series("", index=out.index)
    base_count = pd.to_numeric(out[base_count_col], errors="coerce").fillna(0).astype(int) if base_count_col else pd.Series(0, index=out.index, dtype="int")

    # Prior stream cuts are visible in several places depending on which legacy layer built the table.
    # Treat them as already cut for the printable cleaned view even when the audit table still shows them.
    _txt_for_cut = pd.Series("", index=out.index, dtype="object")
    for _c in ["RecommendedActionFlag", "RuleFlags", "PlayNote", "v164_RuleFlagsWithBudget", "v164_PlayNoteWithBudget"]:
        if _c in out.columns:
            _txt_for_cut = _txt_for_cut + " | " + out[_c].astype(str)
    prior_cut_mask = (
        base_action.str.contains("CUT", case=False, na=False)
        | _txt_for_cut.str.contains("CUT REVIEW|CUT STREAM|SCL-D2|SCL-M0", case=False, na=False, regex=True)
    )
    # v169: when ZLTs fire and the row is not already cut, the playable member list
    # must be trimmed to Top1 before printable/export totals are built.
    zlt_top1_trim_mask = zlt_count.gt(0) & ~prior_cut_mask & top1_long.astype(str).str.strip().ne("")
    base_action.loc[zlt_top1_trim_mask] = "PLAY TOP1 ONLY"
    base_members.loc[zlt_top1_trim_mask] = top1_long.loc[zlt_top1_trim_mask]
    base_count.loc[zlt_top1_trim_mask] = 1

    already_cut = base_count.eq(0) | prior_cut_mask
    cut_mask = allowed_flag_ids.map(lambda xs: len(xs) > 0)

    # Do not re-cut already-cut rows for added-cut metrics, but v164 final action remains cut.
    new_cut_mask = cut_mask & ~already_cut
    final_cut_mask = already_cut | new_cut_mask

    def _defs(xs):
        lookup = _v164_flag_definition_lookup()
        return " | ".join([f"{fid}: {lookup.get(fid, '')}" for fid in xs])
    def _names(xs):
        lookup = _v164_flag_name_lookup()
        return " | ".join([f"{fid}: {lookup.get(fid, '')}" for fid in xs])
    def _cut_reason(xs):
        if not xs:
            return ""
        return "CUT STREAM per " + "; ".join(xs)

    out["v163_BudgetMode"] = mode
    out["v163_TrueZLTCount"] = zlt_count.astype(int)
    out["v169_DirectZLTIDs"] = direct_zlt_ids.map(lambda xs: ", ".join(list(dict.fromkeys(xs))))
    out["v169_DirectZLTCount"] = direct_zlt_count.astype(int)
    out["v169_ZLTCountSource"] = np.where(zlt_count_from_text.lt(0), "direct_rule_eval", "existing_fired_rule_source")
    out["v163_Top1Protected0225"] = top1_long.eq("0225")
    out["v163_RareTraitFlag"] = rare_count.gt(0)
    out["v163_RareTraitCount"] = rare_count
    out["v163_RareTraitList"] = rare_lists.map(lambda xs: " | ".join(xs))
    out["v164_BudgetFlagIDs_AllCandidates"] = all_flag_ids.map(lambda xs: ", ".join(dict.fromkeys(xs)))
    out["v164_BudgetFlagIDs"] = allowed_flag_ids.map(lambda xs: ", ".join(dict.fromkeys(xs)))
    out["v164_BudgetFlagNames"] = allowed_flag_ids.map(_names)
    out["v164_BudgetFlagDefinitions"] = allowed_flag_ids.map(_defs)
    out["v163_BudgetCutCandidate"] = cut_mask
    out["v163_AddedCutByBudgetLayer"] = new_cut_mask
    out["v163_BudgetCutReason"] = allowed_flag_ids.map(_cut_reason)
    out["v163_Action"] = base_action.copy()
    out["v163_AdjustedMembersToPlay"] = base_members.copy()
    out["v163_AdjustedPlayCount"] = base_count.copy()
    out.loc[final_cut_mask, "v163_Action"] = "CUT STREAM"
    out.loc[final_cut_mask, "v163_AdjustedMembersToPlay"] = ""
    out.loc[final_cut_mask, "v163_AdjustedPlayCount"] = 0
    out["v163_RunningPlayTotal"] = pd.to_numeric(out["v163_AdjustedPlayCount"], errors="coerce").fillna(0).astype(int).cumsum()
    out["v163_RunningCost"] = out["v163_RunningPlayTotal"].map(lambda x: f"${float(x)*0.25:,.2f}")
    out["v163_Build"] = V163_BUILD_LABEL

    # Make the new layer visible exactly like other final-play flags/notes.
    out["v164_RuleFlagsWithBudget"] = out.get("RuleFlags", pd.Series("", index=out.index)).astype(str)
    mask_has_ids = out["v164_BudgetFlagIDs"].astype(str).str.strip().ne("")
    out.loc[mask_has_ids, "v164_RuleFlagsWithBudget"] = (
        out.loc[mask_has_ids, "v164_RuleFlagsWithBudget"].astype(str).str.strip().str.strip(",")
        + ", " + out.loc[mask_has_ids, "v164_BudgetFlagIDs"].astype(str)
    ).str.strip().str.strip(",")
    out["v164_PlayNoteWithBudget"] = out.get("PlayNote", pd.Series("", index=out.index)).astype(str)
    out.loc[mask_has_ids, "v164_PlayNoteWithBudget"] = (
        out.loc[mask_has_ids, "v164_PlayNoteWithBudget"].astype(str).str.strip()
        + " | " + out.loc[mask_has_ids, "v163_BudgetCutReason"].astype(str)
    ).str.strip().str.strip("|").str.strip()

    if "FamilyFitScore_Core025" not in out.columns:
        if "UniversalFamilyScore" in out.columns:
            out["FamilyFitScore_Core025"] = pd.to_numeric(out["UniversalFamilyScore"], errors="coerce")
        elif "HybridScore" in out.columns:
            out["FamilyFitScore_Core025"] = pd.to_numeric(out["HybridScore"], errors="coerce")
        elif "HybridScore_v141" in out.columns:
            out["FamilyFitScore_Core025"] = pd.to_numeric(out["HybridScore_v141"], errors="coerce")
        else:
            out["FamilyFitScore_Core025"] = np.nan
    return out


def _v163_budget_rule_key_dataframe() -> pd.DataFrame:
    rows = []
    rows.append({"RuleID":"B1", "Layer":"Budget mode summary", "ActionText":"CUT STREAM", "Definition":"Enable B1Z0 and B1Z1.", "HistoricalNote":"B1 means cut true ZLT count <= 1.", "InputFields":"FiredRuleIDs"})
    rows.append({"RuleID":"B2", "Layer":"Budget mode summary", "ActionText":"CUT STREAM", "Definition":"Enable B1Z0 + B1Z1 + B2Z2N225.", "HistoricalNote":"B2 means cut true ZLT <=1 plus ZLT=2 when Top1 is not 0225.", "InputFields":"FiredRuleIDs + PredictedMember/Top1"})
    for r in V164_BUDGET_FLAG_RULES:
        rows.append({"RuleID":r["id"], "Layer":r["group"], "ActionText":"CUT STREAM", "Definition":r["definition"], "HistoricalNote":r["history_note"], "InputFields":r["input_fields"]})
    for r in V163_RARE_TRAIT_RULES:
        rows.append({"RuleID":r["id"], "Layer":r["group"], "ActionText":"CUT STREAM", "Definition":r["definition"], "HistoricalNote":r["history_note"], "InputFields":r["input_fields"]})
    rows.append({"RuleID":"FamilyFitScore_Core025", "Layer":"Future multi-family comparison support", "ActionText":"DISPLAY SCORE", "Definition":"Copy of UniversalFamilyScore when available, else HybridScore fallback.", "HistoricalNote":"For comparing Core025 against future family engines stream-by-stream.", "InputFields":"UniversalFamilyScore/HybridScore"})
    return pd.DataFrame(rows)

def _v159_rule_key_dataframe() -> pd.DataFrame:
    rows = list(V159_BASE_RULE_KEY_ROWS)
    for r in V159_ZERO_LOSS_TOP1_RULES[:30]:
        rows.append({"RuleID":r['id'], "Layer":"ZLT Top1-only trim", "ActionText":"PLAY TOP1 ONLY", "Definition":f"{r['feature']} / {r['context']} / {r['values']}", "HistoricalNote":f"zero-loss greedy candidate; support={r['support']}, top1={r['top1pct']}%, marginal saved/day={round(r['avg_saved'],3)}", "InputFields":"see definition"})
    if len(V159_ZERO_LOSS_TOP1_RULES) > 30:
        rows.append({"RuleID":"ZLT031-ZLT152", "Layer":"ZLT Top1-only trim", "ActionText":"PLAY TOP1 ONLY", "Definition":"Additional zero-loss greedy candidates are embedded and fire by exact trait match.", "HistoricalNote":"Full details in generated mining ledger; app displays exact ZLT ID when a rule fires.", "InputFields":"prior member + seed/member traits"})
    return pd.DataFrame(rows)

# v145 PRESENTATION-ONLY ALL-STREAM VISIBILITY REPAIR
# No ranking/member/depth/rescue logic changes.
# Keeps all streams visible; stream reduction remains advisory labels/flags only.
# ================================
def _v145_prepare_all_streams_visible_table(playlist: pd.DataFrame) -> pd.DataFrame:
    table = pd.DataFrame()
    try:
        if "_v143_build_rank_comparison_first_table" in globals():
            table = _v143_build_rank_comparison_first_table(playlist)
    except Exception:
        table = pd.DataFrame()
    if table is None or not isinstance(table, pd.DataFrame) or table.empty:
        try:
            if "_v141_build_verification_play_table" in globals():
                table = _v141_build_verification_play_table(playlist)
        except Exception:
            table = pd.DataFrame()
    if table is None or not isinstance(table, pd.DataFrame) or table.empty:
        try:
            if "_v139_build_true_hybrid_rank_actual_cost" in globals():
                table = _v139_build_true_hybrid_rank_actual_cost(playlist)
        except Exception:
            table = pd.DataFrame()
    if table is None or not isinstance(table, pd.DataFrame) or table.empty:
        return pd.DataFrame()

    out = table.copy()

    # v166: keep the full/all-stream audit table visible, but do not let an
    # upstream notes-only/display helper failure block the true final-cleaned
    # cut layer.  Each layer is isolated and additive.
    try:
        out = _v157_add_keeper_flags_and_notes(out)
    except Exception as _v157_e:
        out["v157FlagError"] = str(_v157_e)
    try:
        out = _v158_add_seed_aware_notes(out)
    except Exception as _v158_e:
        out["v158FlagError"] = str(_v158_e)
    try:
        out = _v159_apply_locked58_actions(out)
    except Exception as _v159_e:
        out["v159FlagError"] = str(_v159_e)

    # This must always run even if the full visible playlist has display-only
    # errors, because the printable playlist is based on what remains after
    # default B2 + Rare Trait cuts.
    try:
        if "_v163_apply_budget_layers" in globals():
            out = _v163_apply_budget_layers(out)
    except Exception as _v163_e:
        out["v163BudgetLayerError"] = str(_v163_e)

    if "StreamRank_COMPARE_FIRST" not in out.columns:
        out["StreamRank_COMPARE_FIRST"] = out["OldStreamRank"] if "OldStreamRank" in out.columns else (out["StreamRank"] if "StreamRank" in out.columns else "")
    if "PctRank_COMPARE_FIRST" not in out.columns:
        if "SingleRowHistoricalRank_v141" in out.columns:
            out["PctRank_COMPARE_FIRST"] = out["SingleRowHistoricalRank_v141"]
        elif "SingleRowHistoricalRank_v139" in out.columns:
            out["PctRank_COMPARE_FIRST"] = out["SingleRowHistoricalRank_v139"]
        elif "RowPercentile" in out.columns:
            out["PctRank_COMPARE_FIRST"] = out["RowPercentile"]
        elif "SingleRow" in out.columns:
            out["PctRank_COMPARE_FIRST"] = out["SingleRow"]
        else:
            out["PctRank_COMPARE_FIRST"] = ""
    if "HybridRank_COMPARE_FIRST" not in out.columns:
        out["HybridRank_COMPARE_FIRST"] = out["HybridFinalRank_v141"] if "HybridFinalRank_v141" in out.columns else (out["HybridFinalRank_v139"] if "HybridFinalRank_v139" in out.columns else out.get("PlayOrder", ""))

    if "MembersToPlay" not in out.columns:
        out["MembersToPlay"] = out["ActualMembersToPlay"] if "ActualMembersToPlay" in out.columns else ""
    if "PlayCount" not in out.columns:
        out["PlayCount"] = out["ActualPlayCount"] if "ActualPlayCount" in out.columns else 0
    if "RowCost" not in out.columns:
        out["RowCost"] = out["RowCostDisplay"] if "RowCostDisplay" in out.columns else ""
    if "RunningCost" not in out.columns:
        out["RunningCost"] = out["RunningCostDisplay"] if "RunningCostDisplay" in out.columns else ""
    if "Movement" not in out.columns:
        out["Movement"] = out["MovementVsOldStreamRank_v141"] if "MovementVsOldStreamRank_v141" in out.columns else (out["HybridVsOldStreamRankDelta_v139"] if "HybridVsOldStreamRankDelta_v139" in out.columns else "")
    if "DynamicRank" not in out.columns:
        out["DynamicRank"] = out["DynamicRank_v141"] if "DynamicRank_v141" in out.columns else (out["DynamicRank_v139"] if "DynamicRank_v139" in out.columns else "")
    if "DueRank" not in out.columns:
        out["DueRank"] = out["DuePressureRank_v141"] if "DuePressureRank_v141" in out.columns else (out["DuePressureRank_v139"] if "DuePressureRank_v139" in out.columns else "")
    if "HybridScore" not in out.columns:
        out["HybridScore"] = out["HybridScore_v141"] if "HybridScore_v141" in out.columns else (out["HybridRankScore_v139"] if "HybridRankScore_v139" in out.columns else "")

    front = [c for c in [
        "StreamRank_COMPARE_FIRST","PctRank_COMPARE_FIRST","HybridRank_COMPARE_FIRST",
        "PlayOrder","StreamKey","State","Game","Action","MembersToPlay","v159_Action","v159_AdjustedMembersToPlay","v163_BudgetMode","v163_Action","v163_AdjustedMembersToPlay","v163_AdjustedPlayCount","v163_TrueZLTCount","v163_Top1Protected0225","v163_RareTraitFlag","v163_RareTraitCount","v163_RareTraitList","v169_DirectZLTIDs","v169_DirectZLTCount","v169_ZLTCountSource","v164_BudgetFlagIDs","v164_BudgetFlagNames","v164_BudgetFlagDefinitions","v163_BudgetCutReason","FamilyFitScore_Core025","v164_PlayNoteWithBudget","v164_RuleFlagsWithBudget","PlayNote","RuleFlags","RecommendedActionFlag","v159_FiredRuleIDs","PlayCount","v159_AdjustedPlayCount","v159_RunningPlayTotal","v159_RunningCost","v159_RuleFiredCount",
        "RowCost","RunningPlayTotal","RunningCost","Movement","DynamicRank","DynamicSingleRowWins","MovementWins","MovementWinnerRatePct","MovementBucket_v157","SeedSumUsed_v158","PriorWinnerMemberUsed_v158","SeedAwareStatus_v158","DueRank",
        "HybridScore","OldPlaylistRank","OldStreamRank","SingleRow","RowPercentile",
        "SingleRowWinnerCount_v141","SingleRowWinnerPct_v141","SingleRowHistoricalRank_v141",
        "RankDiagnostic_v141"
    ] if c in out.columns]
    rest = [c for c in out.columns if c not in front]
    return out[front + rest].copy()


def _v165_printable_final_playlist(table: pd.DataFrame) -> pd.DataFrame:
    """v167 final cleaned/printable playlist.

    Full audit playlist: all streams stay visible.
    Printable playlist: only rows with a positive post-default-cut play count remain.
    """
    if table is None or not isinstance(table, pd.DataFrame) or table.empty:
        return pd.DataFrame()
    out = table.copy()

    # Always recompute the default final-cleaned stack for print/export.
    # This prevents the printable table from inheriting the all-stream audit source or a stale
    # zeroed adjusted-count column.
    if "_v163_apply_budget_layers" in globals():
        try:
            out = _v163_apply_budget_layers(out, mode=V165_DEFAULT_BUDGET_MODE)
        except Exception as _v167_e:
            out["v168PrintableApplyError"] = str(_v167_e)

    def _pick_count_col(candidates):
        for c in candidates:
            if c in out.columns:
                vals = pd.to_numeric(out[c], errors="coerce").fillna(0)
                if int(vals.sum()) > 0:
                    return c
        return next((c for c in candidates if c in out.columns), None)

    play_col = _pick_count_col(["v163_AdjustedPlayCount", "v159_AdjustedPlayCount", "FINAL_PLAY_COUNT_v162", "v161_AdjustedPlayCount", "PlayCount", "ActualPlayCount"])
    member_col = next((c for c in ["v163_AdjustedMembersToPlay", "v159_AdjustedMembersToPlay", "FINAL_MEMBERS_TO_PLAY_v162", "v161_AdjustedMembersToPlay", "MembersToPlay", "ActualMembersToPlay", "ActualBoxPlay"] if c in out.columns), None)
    action_col = next((c for c in ["v163_Action", "v159_Action", "FINAL_ACTION_v162", "v161_Action", "Action"] if c in out.columns), None)

    out["PrintableFinalPlayCount"] = pd.to_numeric(out[play_col], errors="coerce").fillna(0).astype(int) if play_col else 0
    out["PrintableFinalMembersToPlay"] = out[member_col].astype(str) if member_col else ""
    out["PrintableFinalAction"] = out[action_col].astype(str) if action_col else "PLAY"

    # Hard exclusion for any row that legacy or new layers identify as cut/review-cut.
    cut_text = pd.Series("", index=out.index, dtype="object")
    for c in ["PrintableFinalAction", "RecommendedActionFlag", "RuleFlags", "PlayNote", "v164_RuleFlagsWithBudget", "v164_PlayNoteWithBudget", "v163_BudgetCutReason"]:
        if c in out.columns:
            cut_text = cut_text + " | " + out[c].astype(str)
    printable_cut_mask = cut_text.str.contains("CUT REVIEW|CUT STREAM|SCL-D2|SCL-M0", case=False, na=False, regex=True)

    cleaned = out[out["PrintableFinalPlayCount"].gt(0) & ~printable_cut_mask & out["PrintableFinalMembersToPlay"].astype(str).str.strip().ne("")].copy()
    cleaned["PrintableOrder"] = range(1, len(cleaned) + 1)
    cleaned["PrintableRunningPlayTotal"] = cleaned["PrintableFinalPlayCount"].cumsum()
    cleaned["PrintableRunningCost"] = cleaned["PrintableRunningPlayTotal"].map(lambda x: f"${float(x) * 0.25:,.2f}")
    cleaned["FinalAction"] = cleaned["PrintableFinalAction"]

    if "FamilyFitScore_Core025" not in cleaned.columns:
        if "UniversalFamilyScore" in cleaned.columns:
            cleaned["FamilyFitScore_Core025"] = pd.to_numeric(cleaned["UniversalFamilyScore"], errors="coerce")
        elif "HybridScore" in cleaned.columns:
            cleaned["FamilyFitScore_Core025"] = pd.to_numeric(cleaned["HybridScore"], errors="coerce")
        elif "HybridScore_v141" in cleaned.columns:
            cleaned["FamilyFitScore_Core025"] = pd.to_numeric(cleaned["HybridScore_v141"], errors="coerce")
        else:
            cleaned["FamilyFitScore_Core025"] = np.nan

    cleaned["BudgetRuleIDs"] = cleaned.get("v164_BudgetFlagIDs", pd.Series("", index=cleaned.index)).astype(str)
    cleaned["BudgetRuleNotes"] = cleaned.get("v164_PlayNoteWithBudget", cleaned.get("PlayNote", pd.Series("", index=cleaned.index))).astype(str)

    # v170: printable output must be a TRUE ticket/print schema only.
    # Do NOT append diagnostic/internal columns here; the full flagged table above remains
    # the audit source. This fixes TXT downloads that looked different from the on-screen
    # printable table because they were exporting the whole dataframe.
    front = [c for c in [
        "PrintableOrder", "PlayOrder", "StreamKey", "State", "Game",
        "PrintableFinalMembersToPlay", "PrintableFinalPlayCount",
        "PrintableRunningPlayTotal", "PrintableRunningCost",
        "FamilyFitScore_Core025", "FinalAction", "BudgetRuleIDs"
    ] if c in cleaned.columns]
    return cleaned[front].copy()


def _v170_printable_txt(printable: pd.DataFrame) -> str:
    """Human-readable printable ticket text; no diagnostics, no seed columns."""
    if printable is None or not isinstance(printable, pd.DataFrame) or printable.empty:
        return "Printable final cleaned playlist is empty.\n"
    lines = []
    total_plays = int(pd.to_numeric(printable.get("PrintableFinalPlayCount", pd.Series(dtype=float)), errors="coerce").fillna(0).sum())
    lines.append("CORE025 PRINTABLE FINAL CLEANED PLAYLIST — DEFAULT B2 + RARE TRAITS")
    lines.append(f"Streams: {len(printable)} | Plays: {total_plays} | Cost: ${total_plays * 0.25:,.2f}")
    lines.append("")
    for _, r in printable.iterrows():
        order = str(r.get("PrintableOrder", "")).strip()
        stream = str(r.get("StreamKey", "")).strip()
        members = str(r.get("PrintableFinalMembersToPlay", "")).replace("**", "").strip()
        count = str(r.get("PrintableFinalPlayCount", "")).strip()
        running = str(r.get("PrintableRunningPlayTotal", "")).strip()
        cost = str(r.get("PrintableRunningCost", "")).strip()
        fit = r.get("FamilyFitScore_Core025", "")
        try:
            fit_txt = f" | Fit: {float(fit):.2f}" if pd.notna(fit) and str(fit).strip() != "" else ""
        except Exception:
            fit_txt = ""
        plural = "s" if str(count) != "1" else ""
        lines.append(f"{order}. {stream}")
        lines.append(f"   PLAY: {members}  ({count} play{plural})")
        lines.append(f"   Running plays: {running} | Running cost: {cost}{fit_txt}")
        lines.append("")
    return "\n".join(lines)


def _v145_render_all_streams_visible(playlist: pd.DataFrame):
    table = _v145_prepare_all_streams_visible_table(playlist)
    if table is None or not isinstance(table, pd.DataFrame) or table.empty:
        st.warning("v145 final play table unavailable: no playlist table could be built.")
        return pd.DataFrame()

    st.divider()
    st.subheader("FINAL PLAY THIS TODAY — TRUE HYBRID RANK + ACTUAL COST")
    st.caption("Presentation-only cleanup. First columns compare StreamRank vs PctRank vs HybridRank. All streams remain visible; stream reduction is advisory only. Cost is calculated after rank and never affects rank.")

    total_plays = int(pd.to_numeric(table.get("PlayCount", pd.Series(dtype=float)), errors="coerce").fillna(0).sum())
    moved = int(pd.to_numeric(table.get("Movement", pd.Series([0]*len(table))), errors="coerce").fillna(0).ne(0).sum())
    missing_members = 0
    if "Action" in table.columns and "MembersToPlay" in table.columns:
        missing_members = int((table["Action"].astype(str).str.upper().ne("NO PLAY") & table["Action"].astype(str).str.upper().ne("NO_PLAY") & table["MembersToPlay"].astype(str).str.strip().eq("")).sum())

    expected_streams = 78
    rows_shown = len(table)
    c1, c2, c3, c4, c5a = st.columns(5)
    adj_total_plays = int(pd.to_numeric(table.get("v159_AdjustedPlayCount", table.get("PlayCount", pd.Series(dtype=float))), errors="coerce").fillna(0).sum())
    c1.metric("Rows shown", f"{rows_shown} / {rows_shown}")
    c2.metric("Expected stream count", expected_streams)
    c3.metric("Rows moved vs old StreamRank", moved)
    c4.metric("Original plays", total_plays)
    c5a.metric("v159 adjusted plays", adj_total_plays)
    if "v163_AdjustedPlayCount" in table.columns:
        v163_total_plays = int(pd.to_numeric(table["v163_AdjustedPlayCount"], errors="coerce").fillna(0).sum())
        st.metric("Default final cleaned plays", v163_total_plays)
        st.caption(f"Default final-cleaned cost: ${v163_total_plays * 0.25:,.2f} | mode: B2 + Rare Traits (fixed default)")
    st.caption(f"v159 adjusted cost: ${adj_total_plays * 0.25:,.2f} | original full-list cost: ${total_plays * 0.25:,.2f}. Full list remains visible; adjusted count reflects flags/actions only.")
    if rows_shown == expected_streams:
        st.success("All 78 streams shown. Stream reduction is advisory only — it labels/prioritizes streams but does not hide rows.")
    else:
        st.warning(f"Rows shown: {rows_shown} / {expected_streams}. This table is not showing the expected 78 streams. Check upstream playlist generation; this presentation layer does not intentionally remove rows.")

    c5, c6, c7 = st.columns(3)
    c5.success("Hybrid movement check: PASS" if moved > 0 else "Hybrid movement check: FAIL")
    c6.success("Actual play extraction: PASS" if missing_members == 0 else f"Actual play extraction: {missing_members} rows missing members")
    rank_missing = sum(1 for c in ["StreamRank_COMPARE_FIRST","PctRank_COMPARE_FIRST","HybridRank_COMPARE_FIRST"] if c not in table.columns)
    c7.success("Rank compare columns: PASS" if rank_missing == 0 else f"Rank columns missing: {rank_missing}")

    if "v159_RunningPlayTotal" in table.columns or "RunningPlayTotal" in table.columns:
        cuts = []
        running_col = "v159_RunningPlayTotal" if "v159_RunningPlayTotal" in table.columns else "RunningPlayTotal"
        play_col = "v159_AdjustedPlayCount" if "v159_AdjustedPlayCount" in table.columns else "PlayCount"
        for dollars in [5,10,15,20,25,30,35,40,50]:
            plays = int(dollars/0.25)
            sub = table[pd.to_numeric(table[running_col], errors="coerce").le(plays)]
            cuts.append({"Budget":f"${dollars}","PlayCutoff":plays,"RowsIncluded":len(sub),"ActualPlaysUsed":int(pd.to_numeric(sub.get(play_col, pd.Series(dtype=float)), errors="coerce").fillna(0).sum()) if not sub.empty else 0,"LastHybridRankIncluded":int(pd.to_numeric(sub.get("HybridRank_COMPARE_FIRST", pd.Series(dtype=float)), errors="coerce").max()) if not sub.empty else ""})
        st.write("**Budget stopping guide — informational only, not part of ranking**")
        st.dataframe(pd.DataFrame(cuts), use_container_width=True, hide_index=True)

    st.write("**FINAL PLAY THIS TODAY — first columns compare ranking systems, then exact plays and running cost**")
    st.caption(f"Rows shown: {len(table)} / {len(table)}. All streams in the final playlist are shown below. Stream reduction is advisory only, not removal.")

    paginate = st.checkbox(
        "Optional pagination view — OFF by default; leave unchecked to view the full final playlist",
        value=False,
        key="v145_optional_pagination_final_play_table",
    )
    if paginate:
        page_size = st.selectbox("Rows per page", [20, 26, 39, 78], index=3, key="v145_final_table_page_size")
        max_page = max(1, int(np.ceil(len(table) / int(page_size))))
        page = st.number_input("Page", min_value=1, max_value=max_page, value=1, step=1, key="v145_final_table_page")
        start = (int(page) - 1) * int(page_size)
        end = start + int(page_size)
        display_table = table.iloc[start:end].copy()
        st.caption(f"Pagination ON: showing rows {start + 1}-{min(end, len(table))} of {len(table)}. Full CSV/TXT downloads still include all rows.")
        st.dataframe(display_table, use_container_width=True, hide_index=True, height=1400)
    else:
        st.dataframe(table, use_container_width=True, hide_index=True, height=2600)
    st.session_state["v145_all_streams_visible_table"] = table
    st.download_button("Download v173 Full Flagged Final Play Table CSV", table.to_csv(index=False).encode("utf-8"), file_name="core025_v173_full_flagged_final_play_table.csv", mime="text/csv", use_container_width=True, key="download_v165_full_flagged_final_play_table_csv")
    st.download_button("Download v173 Full Flagged Final Play Table TXT", table.to_csv(index=False, sep="\t").encode("utf-8"), file_name="core025_v173_full_flagged_final_play_table.txt", mime="text/plain", use_container_width=True, key="download_v165_full_flagged_final_play_table_txt")

    printable = _v165_printable_final_playlist(table) if "_v165_printable_final_playlist" in globals() else pd.DataFrame()
    st.divider()
    st.subheader("v173 Pre-clean Collapse Guard")
    _v172_health = _v172_score_health(table, printable)
    _v172_status = str(_v172_health[_v172_health["Check"].eq("VISIBLE AFFIRMATION")]["Status"].iloc[0]) if not _v172_health.empty and _v172_health["Check"].eq("VISIBLE AFFIRMATION").any() else "FAIL"
    if _v172_status == "PASS":
        st.success("VISIBLE AFFIRMATION: pre-clean list did NOT collapse. Cleaned printable list is based on a live multi-member scoring source.")
    else:
        st.error("VISIBLE AFFIRMATION: pre-clean list COLLAPSED or member-score inputs failed. Do not trust the cleaned printable list as an independent result.")
    st.dataframe(_v172_health, use_container_width=True, hide_index=True)
    st.divider()
    st.subheader("v173 PRINTABLE FINAL CLEANED PLAYLIST — DEFAULT B2 + RARE TRAITS")
    st.caption("Only streams and members left after the default B2 + Rare Trait cut stack. Full audit table above still shows every stream; this ticket/print view shows only what you actually play.")
    if printable is None or printable.empty:
        st.warning("Printable final playlist is empty or unavailable.")
    else:
        pplays = int(pd.to_numeric(printable.get("PrintableFinalPlayCount", pd.Series(dtype=float)), errors="coerce").fillna(0).sum())
        st.success(f"Printable final cleaned playlist: {len(printable)} streams | {pplays} plays | ${pplays * 0.25:,.2f}")
        st.dataframe(printable, use_container_width=True, hide_index=True, height=1000)
        st.session_state["v168_printable_final_cleaned_playlist"] = printable
        st.download_button("Download v173 Printable Final Cleaned Playlist CSV", printable.to_csv(index=False).encode("utf-8"), file_name="core025_v173_PRINTABLE_final_cleaned_playlist_DEFAULT_B2_RARE.csv", mime="text/csv", use_container_width=True, key="download_v170_printable_final_cleaned_playlist_csv")
        printable_txt = _v170_printable_txt(printable) if "_v170_printable_txt" in globals() else printable.to_csv(index=False, sep="\t")
        st.download_button("Download v173 Printable Final Cleaned Playlist TXT", printable_txt.encode("utf-8"), file_name="core025_v173_PRINTABLE_final_cleaned_playlist_DEFAULT_B2_RARE.txt", mime="text/plain", use_container_width=True, key="download_v170_printable_final_cleaned_playlist_txt")
    return table






# ================================
# v172 SUPPORT VALIDATION + ANTI-COLLAPSE GUARD
# Protects the production scoring engine from simplified/session-generated support files.
# Generated files remain downloadable, but only schema-compatible support files self-integrate.
# ================================
def _v172_member_counts(df: pd.DataFrame, col: str) -> dict:
    if not isinstance(df, pd.DataFrame) or df.empty or col not in df.columns:
        return {}
    s = df[col].apply(normalize_member).astype(str)
    return {k: int(v) for k, v in s.value_counts(dropna=False).to_dict().items()}

def _v172_validate_truth_for_scoring(truth: pd.DataFrame) -> tuple[bool, list[str]]:
    reasons = []
    if not isinstance(truth, pd.DataFrame) or truth.empty:
        return False, ["Truth is empty"]
    required_basic = ["seed", "WinningMember"]
    missing_basic = [c for c in required_basic if c not in truth.columns]
    if missing_basic:
        reasons.append("missing basic columns: " + ", ".join(missing_basic))
    # The old production truth file is a full intelligence table, not a small raw-winner ledger.
    # It carries row/stream/model columns used by older scoring and diagnostics.  The v171 raw
    # rebuild created only ~57 columns, which is useful as a backup/export but not safe as active scoring input.
    if len(truth.columns) < 100:
        reasons.append(f"truth schema too small for active scoring: {len(truth.columns)} columns < 100")
    if len(truth) < 250:
        reasons.append(f"truth rows unexpectedly low: {len(truth)} < 250")
    counts = _v172_member_counts(truth, "WinningMember")
    for m in ["25", "225", "255"]:
        if counts.get(m, 0) < 50:
            reasons.append(f"truth member support too low for {m}: {counts.get(m, 0)}")
    return len(reasons) == 0, reasons

def _v172_validate_separator_for_scoring(lib: pd.DataFrame) -> tuple[bool, list[str]]:
    reasons = []
    if not isinstance(lib, pd.DataFrame) or lib.empty:
        return False, ["Separator library is empty"]
    required = ["pair", "trait_stack", "winner_member", "winner_rate", "support", "stack_size"]
    missing = [c for c in required if c not in lib.columns]
    if missing:
        reasons.append("missing separator columns: " + ", ".join(missing))
    # Production promoted library has pairwise separator fields.  A tiny TRUTH_MINED-only table
    # can overfit and collapse member scores.
    expected_optional = ["loser_member", "loser_rate", "rate_0025", "rate_0225", "rate_0255"]
    missing_opt = [c for c in expected_optional if c not in lib.columns]
    if missing_opt:
        reasons.append("missing promoted-library scoring columns: " + ", ".join(missing_opt))
    if len(lib) < 100:
        reasons.append(f"separator rule count too low: {len(lib)} < 100")
    if "pair" in lib.columns:
        pair_vals = set(lib["pair"].astype(str).unique())
        needed_pairs = {"0025_vs_0225", "0025_vs_0255", "0225_vs_0255"}
        if not needed_pairs.intersection(pair_vals):
            reasons.append("separator is not pairwise/promoted; pair values are " + ", ".join(sorted(list(pair_vals))[:5]))
    if "winner_member" in lib.columns:
        counts = _v172_member_counts(lib, "winner_member")
        for m in ["25", "225", "255"]:
            if counts.get(m, 0) < 20:
                reasons.append(f"separator member rule support too low for {m}: {counts.get(m, 0)} < 20")
    return len(reasons) == 0, reasons

def _v172_validate_support_pair(truth: pd.DataFrame, lib: pd.DataFrame) -> tuple[bool, pd.DataFrame]:
    ok_t, rt = _v172_validate_truth_for_scoring(truth)
    ok_l, rl = _v172_validate_separator_for_scoring(lib)
    rows = []
    rows.append({"Check": "Truth active-schema validation", "Status": "PASS" if ok_t else "FAIL", "Value": "; ".join(rt) if rt else "schema compatible"})
    rows.append({"Check": "Separator active-schema validation", "Status": "PASS" if ok_l else "FAIL", "Value": "; ".join(rl) if rl else "schema compatible"})
    rows.append({"Check": "Truth member balance", "Status": "INFO", "Value": str(_v172_member_counts(truth, "WinningMember"))})
    rows.append({"Check": "Separator member balance", "Status": "INFO", "Value": str(_v172_member_counts(lib, "winner_member"))})
    rows.append({"Check": "Self-integration allowed", "Status": "PASS" if (ok_t and ok_l) else "FAIL", "Value": "session-generated files will be active" if (ok_t and ok_l) else "session-generated files are download-only; uploaded support files remain active"})
    return ok_t and ok_l, pd.DataFrame(rows)

def _v172_score_health(table: pd.DataFrame, printable: pd.DataFrame | None = None) -> pd.DataFrame:
    rows = []
    if not isinstance(table, pd.DataFrame) or table.empty:
        return pd.DataFrame([{"Check":"Pre-clean ranking collapse guard", "Status":"FAIL", "Value":"No full playlist table"}])
    pred = table.get("PredictedMember", pd.Series(dtype=object)).apply(normalize_member).astype(str)
    pred_counts = {k:int(v) for k,v in pred.value_counts(dropna=False).to_dict().items()}
    max_share = (max(pred_counts.values()) / len(table)) if pred_counts else 1.0
    nonzero_scores = {}
    for c in ["score_0025", "score_0225", "score_0255"]:
        if c in table.columns:
            vals = pd.to_numeric(table[c], errors="coerce").fillna(0)
            nonzero_scores[c] = int(vals.ne(0).sum())
        else:
            nonzero_scores[c] = -1
    raw_ok = (len([k for k,v in pred_counts.items() if k not in ["", "nan", "None"] and v > 0]) >= 2) and max_share <= 0.85 and all(v != 0 for v in nonzero_scores.values())
    rows.append({"Check":"Pre-clean member distribution", "Status":"PASS" if raw_ok else "FAIL", "Value":f"PredictedMember={pred_counts}; max_share={max_share:.1%}"})
    rows.append({"Check":"Member score nonzero coverage", "Status":"PASS" if all(v > 0 for v in nonzero_scores.values()) else "FAIL", "Value":str(nonzero_scores)})
    if isinstance(printable, pd.DataFrame) and not printable.empty and "PrintableFinalMembersToPlay" in printable.columns:
        ps = printable["PrintableFinalMembersToPlay"].astype(str).str.extract(r"(0025|0225|0255)")[0].fillna("").map(lambda x: {"0025":"25","0225":"225","0255":"255"}.get(x, x))
        p_counts = {k:int(v) for k,v in ps.value_counts(dropna=False).to_dict().items()}
        rows.append({"Check":"Printable member distribution", "Status":"INFO", "Value":str(p_counts)})
    rows.append({"Check":"VISIBLE AFFIRMATION", "Status":"PASS" if raw_ok else "FAIL", "Value":"PRE-CLEAN LIST DID NOT COLLAPSE" if raw_ok else "PRE-CLEAN LIST COLLAPSED OR SCORE INPUTS FAILED — do not trust cleaned printable list until fixed"})
    return pd.DataFrame(rows)

# ================================
# v171 SUPPORT FILE MAINTENANCE
# Rebuild Truth + Separator from uploaded cleaned history, self-integrate into session,
# and keep downloads as backup only. Does not remove full audit visibility.
# ================================
def _v171_core_columns():
    return ["Date", "State", "Game", "StreamKey", "Result", "seed", "TrueMember", "WinningMember", "Core025Member"]

def _v171_df_max_date(df: pd.DataFrame):
    if not isinstance(df, pd.DataFrame) or df.empty:
        return None
    for c in ["SourceHistoryMaxDate", "HistoryMaxDate", "MaxDate", "Date", "date", "DrawDate", "draw_date"]:
        if c in df.columns:
            ss = pd.to_datetime(df[c], errors="coerce").dropna()
            if not ss.empty:
                return ss.max().normalize()
    return None

def _v171_upload_to_df(obj, loader_func=None):
    if obj is None:
        return pd.DataFrame()
    try:
        df = load_upload(obj)
        if loader_func is not None:
            df = loader_func(df)
        return df
    except Exception:
        return pd.DataFrame()

def _v171_build_truth_from_history(hist: pd.DataFrame) -> pd.DataFrame:
    if hist is None or not isinstance(hist, pd.DataFrame) or hist.empty:
        raise ValueError("No loaded history available to rebuild Truth.")
    h = hist.copy()
    if "Core025Member" not in h.columns:
        h["Core025Member"] = h["Result"].apply(result_to_core025_member)
    h = h.sort_values(["StreamKey", "Date"]).copy()
    h["seed"] = h.groupby("StreamKey")["Result"].shift(1)
    truth = h[h["Core025Member"].astype(str).str.len().gt(0) & h["seed"].astype(str).str.len().gt(0)].copy()
    if truth.empty:
        raise ValueError("No Core025 winner rows with prior seed were found in the uploaded history.")
    truth["TrueMember"] = truth["Core025Member"].map(normalize_member)
    truth["WinningMember"] = truth["TrueMember"]
    truth["SourceHistoryMaxDate"] = pd.to_datetime(h["Date"], errors="coerce").max().normalize().date().isoformat()
    truth["SourceHistoryRows"] = int(len(h))
    truth["SourceHistoryStreams"] = int(h["StreamKey"].nunique())
    truth = enrich_seed_features(truth, "seed")
    front = [c for c in _v171_core_columns() + ["SourceHistoryMaxDate", "SourceHistoryRows", "SourceHistoryStreams"] if c in truth.columns]
    rest = [c for c in truth.columns if c not in front]
    return truth[front + rest].reset_index(drop=True)

def _v171_build_separator_from_truth(truth: pd.DataFrame, min_rate: float, min_support: int) -> pd.DataFrame:
    if truth is None or not isinstance(truth, pd.DataFrame) or truth.empty:
        raise ValueError("No Truth dataframe available to rebuild Separator.")
    t = ensure_truth(truth)
    t = enrich_seed_features(t, "seed")
    sep = deep_mine_separators(t, min_rate, min_support)
    if sep is None or sep.empty:
        sep = pd.DataFrame(columns=["trait_stack", "winner_member", "winner_rate", "support", "stack_size", "pair", "pair_gap"])
    if "SourceHistoryMaxDate" in truth.columns:
        sep["SourceHistoryMaxDate"] = str(truth["SourceHistoryMaxDate"].dropna().astype(str).iloc[0]) if truth["SourceHistoryMaxDate"].dropna().shape[0] else ""
    sep["BuildDate"] = pd.Timestamp.today().date().isoformat()
    sep["BuildSource"] = "v171_generated_from_uploaded_history"
    # Ensure library compatibility even when no rules are mined.
    for c in ["trait_stack", "winner_member", "winner_rate", "support", "stack_size"]:
        if c not in sep.columns:
            sep[c] = [] if len(sep) == 0 else ""
    return sep.reset_index(drop=True)

def _v171_history_quality_report(hist: pd.DataFrame) -> pd.DataFrame:
    if hist is None or not isinstance(hist, pd.DataFrame) or hist.empty:
        return pd.DataFrame([{"Check": "History", "Status": "EMPTY", "Value": "No loaded history"}])
    h = hist.copy()
    rows = []
    max_date = pd.to_datetime(h["Date"], errors="coerce").max().normalize() if "Date" in h.columns else None
    min_date = pd.to_datetime(h["Date"], errors="coerce").min().normalize() if "Date" in h.columns else None
    rows.append({"Check": "History rows", "Status": "OK", "Value": int(len(h))})
    rows.append({"Check": "Streams", "Status": "OK", "Value": int(h["StreamKey"].nunique()) if "StreamKey" in h.columns else "missing"})
    rows.append({"Check": "Date range", "Status": "OK" if max_date is not None else "WARN", "Value": f"{min_date.date() if min_date is not None else ''} through {max_date.date() if max_date is not None else ''}"})
    if {"Date", "StreamKey", "Result"}.issubset(h.columns):
        dupes = int(h.duplicated(subset=["Date", "StreamKey", "Result"]).sum())
        rows.append({"Check": "Exact duplicate rows", "Status": "OK" if dupes == 0 else "WARN", "Value": dupes})
        per_stream = h.groupby("StreamKey")["Date"].nunique()
        rows.append({"Check": "Stream date coverage", "Status": "INFO", "Value": f"min={int(per_stream.min())}, median={int(per_stream.median())}, max={int(per_stream.max())}"})
    if "Core025Member" in h.columns:
        hits = int(h["Core025Member"].astype(str).str.len().gt(0).sum())
    elif "Result" in h.columns:
        hits = int(h["Result"].apply(result_to_core025_member).astype(str).str.len().gt(0).sum())
    else:
        hits = 0
    rows.append({"Check": "Core025 family wins", "Status": "OK", "Value": hits})
    return pd.DataFrame(rows)

def _v171_get_active_truth(uploaded_truth_df: pd.DataFrame | None):
    """v182 production safety rule: the daily engine uses ONLY the sidebar-uploaded Truth file.

    Session-generated/rebuilt Truth outputs are download/reference artifacts only.
    If a new Truth is accepted later, the user must download it and re-upload it in
    the sidebar so the active production source is explicit and visible.
    """
    if isinstance(uploaded_truth_df, pd.DataFrame) and not uploaded_truth_df.empty:
        return uploaded_truth_df.copy(), "uploaded Truth (production)"
    return None, "none — upload Truth in sidebar"

def _v171_get_active_library(uploaded_lib_df: pd.DataFrame | None):
    """v182 production safety rule: the daily engine uses ONLY the sidebar-uploaded Separator file.

    Session-generated/rebuilt Separator outputs are download/reference artifacts only.
    If a new Separator is accepted later, the user must download it and re-upload it
    in the sidebar so the active production source is explicit and visible.
    """
    if isinstance(uploaded_lib_df, pd.DataFrame) and not uploaded_lib_df.empty:
        return uploaded_lib_df.copy(), "uploaded Separator (production)"
    return None, "none — upload Separator in sidebar"


def _v173_support_detail_table(hist: pd.DataFrame, uploaded_truth_df=None, uploaded_lib_df=None) -> pd.DataFrame:
    """Visible support-file size/schema/status table so rebuilt support cannot silently be tiny/placeholders."""
    active_truth, active_truth_src = _v171_get_active_truth(uploaded_truth_df)
    active_lib, active_lib_src = _v171_get_active_library(uploaded_lib_df)
    gen_t = st.session_state.get("v171_generated_truth")
    gen_s = st.session_state.get("v171_generated_separator")
    built_at = st.session_state.get("v171_rebuild_timestamp", "")
    def _shape(df):
        if isinstance(df, pd.DataFrame):
            return int(len(df)), int(len(df.columns))
        return 0, 0
    h_rows, h_cols = _shape(hist)
    at_rows, at_cols = _shape(active_truth)
    al_rows, al_cols = _shape(active_lib)
    gt_rows, gt_cols = _shape(gen_t)
    gs_rows, gs_cols = _shape(gen_s)
    active_ok = bool(st.session_state.get("v172_generated_support_active_ok", False))
    return pd.DataFrame([
        {"Item":"Uploaded history", "Source":"uploaded", "Rows":h_rows, "Columns":h_cols, "Generated/Rebuilt":"", "ProductionActive":"reference"},
        {"Item":"Active Truth", "Source":active_truth_src, "Rows":at_rows, "Columns":at_cols, "Generated/Rebuilt":built_at if "session-generated" in str(active_truth_src) else "", "ProductionActive":"YES" if at_rows else "NO"},
        {"Item":"Active Separator", "Source":active_lib_src, "Rows":al_rows, "Columns":al_cols, "Generated/Rebuilt":built_at if "session-generated" in str(active_lib_src) else "", "ProductionActive":"YES" if al_rows else "NO"},
        {"Item":"Latest generated Truth", "Source":"session cache", "Rows":gt_rows, "Columns":gt_cols, "Generated/Rebuilt":built_at, "ProductionActive":"NO - download/re-upload required" if gt_rows else "none"},
        {"Item":"Latest generated Separator", "Source":"session cache", "Rows":gs_rows, "Columns":gs_cols, "Generated/Rebuilt":built_at, "ProductionActive":"NO - download/re-upload required" if gs_rows else "none"},
    ])

def _v173_minimum_rules_table() -> pd.DataFrame:
    return pd.DataFrame([
        {"Gate":"Truth minimum rows", "Required":">= 300", "Purpose":"Reject tiny/placeholder truth rebuilds."},
        {"Gate":"Truth minimum columns", "Required":">= 50", "Purpose":"Reject malformed truth rebuilds; original production file is much wider."},
        {"Gate":"Separator minimum rules", "Required":">= 75", "Purpose":"Reject tiny separator rebuilds that cannot support member scoring."},
        {"Gate":"Separator member diversity", "Required":"0025, 0225, and 0255 all represented", "Purpose":"Prevent one-member separator collapse."},
        {"Gate":"Score health", "Required":"No all-zero member score columns", "Purpose":"Prevent full playlist collapse before cleaning."},
        {"Gate":"Pre-clean member diversity", "Required":"At least 2 predicted members and no single member > 90%", "Purpose":"Visible affirmation that cleaned list did not come from a collapsed full list."},
    ])

def _v171_make_support_report(hist: pd.DataFrame, uploaded_truth_df=None, uploaded_lib_df=None) -> pd.DataFrame:
    hmax = _v171_df_max_date(hist)
    truth_df, truth_src = _v171_get_active_truth(uploaded_truth_df)
    lib_df, lib_src = _v171_get_active_library(uploaded_lib_df)
    tmax = _v171_df_max_date(truth_df) if isinstance(truth_df, pd.DataFrame) else None
    lmax = _v171_df_max_date(lib_df) if isinstance(lib_df, pd.DataFrame) else None
    def status(smax):
        if hmax is None:
            return "UNKNOWN_HISTORY_DATE"
        if smax is None:
            return "UNKNOWN_OR_NOT_DATED"
        return "CURRENT" if smax >= hmax else "STALE"
    return pd.DataFrame([
        {"Support": "Uploaded history", "ActiveSource": "uploaded", "MaxDate": hmax.date().isoformat() if hmax is not None else "", "Status": "REFERENCE"},
        {"Support": "FULL TRUTH", "ActiveSource": truth_src, "MaxDate": tmax.date().isoformat() if tmax is not None else "", "Status": status(tmax)},
        {"Support": "Separator library", "ActiveSource": lib_src, "MaxDate": lmax.date().isoformat() if lmax is not None else "", "Status": status(lmax)},
    ])

def _v171_render_support_maintenance(hist: pd.DataFrame, truth_file_obj, lib_file_obj, truth_min_rate: float, truth_min_support: int):
    st.subheader("v171 Support File Maintenance — Truth + Separator")
    st.caption("v182 upload-only production rule: generated support files never self-integrate. If you accept a future Truth/Separator change, download it and re-upload it in the sidebar before it can affect production.")
    uploaded_truth = _v171_upload_to_df(truth_file_obj, ensure_truth) if truth_file_obj is not None else pd.DataFrame()
    uploaded_lib = _v171_upload_to_df(lib_file_obj, ensure_library) if lib_file_obj is not None else pd.DataFrame()
    report = _v171_make_support_report(hist, uploaded_truth, uploaded_lib)
    st.dataframe(report, use_container_width=True, hide_index=True)
    active_truth, active_truth_src = _v171_get_active_truth(uploaded_truth)
    active_lib, active_lib_src = _v171_get_active_library(uploaded_lib)
    st.info(f"ACTIVE SUPPORT SOURCE: Truth = {active_truth_src}; Separator = {active_lib_src}")
    st.write("**Support file size/schema confirmation**")
    st.dataframe(_v173_support_detail_table(hist, uploaded_truth, uploaded_lib), use_container_width=True, hide_index=True)
    with st.expander("Required minimums / acceptance gates", expanded=False):
        st.dataframe(_v173_minimum_rules_table(), use_container_width=True, hide_index=True)
    if "download-only" in str(active_truth_src) or "download-only" in str(active_lib_src):
        st.error("No schema-compatible uploaded fallback is active. The generated raw rebuild is useful for backup/download, but it is not safe for production scoring.")
    if st.button("Rebuild Truth + Separator from Uploaded History", type="secondary", use_container_width=True, key="v171_rebuild_support_files"):
        try:
            truth_new = _v171_build_truth_from_history(hist)
            sep_new = _v171_build_separator_from_truth(truth_new, truth_min_rate, truth_min_support)
            quality = _v171_history_quality_report(hist)
            ok_support, validation = _v172_validate_support_pair(truth_new, sep_new)
            st.session_state["v171_generated_truth"] = truth_new.copy()
            st.session_state["v171_generated_separator"] = sep_new.copy()
            st.session_state["v171_rebuild_timestamp"] = pd.Timestamp.now().strftime("%Y-%m-%d %H:%M:%S")
            st.session_state["v172_generated_support_active_ok"] = False  # v182: generated files never auto-activate production
            st.session_state["v171_rebuild_report"] = pd.concat([
                pd.DataFrame([
                    {"Check": "Generated Truth rows", "Status": "OK", "Value": int(len(truth_new))},
                    {"Check": "Generated Separator rows", "Status": "OK", "Value": int(len(sep_new))},
                    {"Check": "Self integration", "Status": "OK" if ok_support else "BLOCKED", "Value": "Generated files are DOWNLOAD ONLY; upload them in the sidebar to activate"},
                ]),
                validation,
                quality
            ], ignore_index=True)
            if ok_support:
                st.success(f"Rebuilt support files passed validation but were NOT activated: Truth rows={len(truth_new):,}; Separator rows={len(sep_new):,}. Download and re-upload through the sidebar to use them.")
            else:
                st.warning(f"Rebuilt files were generated but NOT activated: Truth rows={len(truth_new):,}; Separator rows={len(sep_new):,}. Validation failed; uploaded production support files remain active.")
        except Exception as e:
            st.error("Support rebuild failed: " + str(e))
    gen_t = st.session_state.get("v171_generated_truth")
    gen_s = st.session_state.get("v171_generated_separator")
    gen_r = st.session_state.get("v171_rebuild_report")
    if isinstance(gen_t, pd.DataFrame) and not gen_t.empty:
        st.download_button("Download updated Truth CSV", gen_t.to_csv(index=False).encode("utf-8"), file_name="core025_v171_updated_truth.csv", mime="text/csv", use_container_width=True, key="v171_dl_truth_csv")
        st.download_button("Download updated Truth TXT", gen_t.to_csv(index=False, sep="\t").encode("utf-8"), file_name="core025_v171_updated_truth.txt", mime="text/plain", use_container_width=True, key="v171_dl_truth_txt")
    if isinstance(gen_s, pd.DataFrame):
        st.download_button("Download updated Separator CSV", gen_s.to_csv(index=False).encode("utf-8"), file_name="core025_v171_updated_separator.csv", mime="text/csv", use_container_width=True, key="v171_dl_sep_csv")
        st.download_button("Download updated Separator TXT", gen_s.to_csv(index=False, sep="\t").encode("utf-8"), file_name="core025_v171_updated_separator.txt", mime="text/plain", use_container_width=True, key="v171_dl_sep_txt")
    if isinstance(gen_r, pd.DataFrame) and not gen_r.empty:
        st.download_button("Download rebuild report CSV", gen_r.to_csv(index=False).encode("utf-8"), file_name="core025_v171_support_rebuild_report.csv", mime="text/csv", use_container_width=True, key="v171_dl_report_csv")
        with st.expander("View latest rebuild report", expanded=False):
            st.dataframe(gen_r, use_container_width=True, hide_index=True)



# ================================
# v174 SUPPORT REBUILD ONLY — DEEP SEPARATOR BUILDER INTEGRATION
# Does NOT change daily ranking/play engine, weights, ZLT, B2, RTE, SCL, or printable logic.
# Replaces only the support-file rebuild path with the original-style deep pairwise separator mining.
# ================================
def _v174_pair_token_pattern(digs):
    toks = []
    try:
        for i in range(4):
            for j in range(i + 1, 4):
                toks.append("".join(sorted([str(int(digs[i])), str(int(digs[j]))])))
    except Exception:
        return ""
    return "|".join(sorted(toks))

def _v174_add_deep_compat_features(df: pd.DataFrame, seed_col: str = "seed") -> pd.DataFrame:
    out = enrich_seed_features(df.copy(), seed_col)
    ds = out[seed_col].apply(digits4)
    out["sum"] = out["seed_sum"]
    out["spread"] = out["seed_spread"]
    out["sorted_seed"] = ["".join(map(str, sorted(d))) for d in ds]
    out["first2"] = [f"{d[0]}{d[1]}" for d in ds]
    out["last2"] = [f"{d[2]}{d[3]}" for d in ds]
    out["pair_token_pattern"] = [_v174_pair_token_pattern(d) for d in ds]
    return out

def _v174_deep_feature_columns() -> list[str]:
    return [
        "sum_bucket", "spread_bucket", "even", "odd", "high", "low", "unique", "pair", "max_rep",
        "sorted_seed", "first2", "last2", "consec_links", "parity_pattern", "highlow_pattern",
        "pair_token_pattern", "structure",
    ] + [f"has{k}" for k in range(10)] + [f"cnt{k}" for k in range(10)]

def _v174_mask_for_conditions(df: pd.DataFrame, conditions) -> pd.Series:
    mask = pd.Series(True, index=df.index)
    for col, val in conditions:
        if col not in df.columns:
            return pd.Series(False, index=df.index)
        cur = df[col].map(lambda x: "" if pd.isna(x) else (str(int(x)) if isinstance(x, float) and float(x).is_integer() else str(x)))
        mask &= (cur == str(val))
    return mask

def _v174_condition_str(conditions) -> str:
    return " && ".join([f"{c}={v}" for c, v in conditions])

def _v174_stability_stats(sub: pd.DataFrame) -> dict:
    ym_col = next((c for c in ["year_month", "year_month_x", "year_month_y"] if c in sub.columns), None)
    if ym_col is None:
        return {"stream_count": int(sub["stream"].nunique()) if "stream" in sub.columns else 0, "month_count": 0}
    return {"stream_count": int(sub["stream"].nunique()), "month_count": int(sub[ym_col].nunique())}

def _v174_score_candidate(pair_df: pd.DataFrame, left_member: str, right_member: str, conditions) -> dict | None:
    sub = pair_df[_v174_mask_for_conditions(pair_df, conditions)].copy()
    support = len(sub)
    if support == 0:
        return None
    left_count = int((sub["next_member"] == left_member).sum())
    right_count = int((sub["next_member"] == right_member).sum())
    left_rate = left_count / support
    right_rate = right_count / support
    winner = left_member if left_rate >= right_rate else right_member
    loser = right_member if winner == left_member else left_member
    winner_rate = max(left_rate, right_rate)
    loser_rate = min(left_rate, right_rate)
    gap = winner_rate - loser_rate
    stable = _v174_stability_stats(sub)
    covered_keys = sorted((sub["event_date"].astype(str) + "|" + sub["stream"].astype(str)).unique().tolist()) if {"event_date","stream"}.issubset(sub.columns) else []
    return {
        "pair": f"{left_member}_vs_{right_member}",
        "trait_stack": _v174_condition_str(conditions),
        "stack_size": len(conditions),
        "support": support,
        "winner_member": winner,
        "loser_member": loser,
        "winner_rate": winner_rate,
        "loser_rate": loser_rate,
        "pair_gap": gap,
        "stream_count": stable["stream_count"],
        "month_count": stable["month_count"],
        f"rate_{left_member}": left_rate,
        f"rate_{right_member}": right_rate,
        "rate_0025": left_rate if left_member == "0025" else (right_rate if right_member == "0025" else 0.0),
        "rate_0225": left_rate if left_member == "0225" else (right_rate if right_member == "0225" else 0.0),
        "rate_0255": left_rate if left_member == "0255" else (right_rate if right_member == "0255" else 0.0),
        "left_count": left_count,
        "right_count": right_count,
        "covered_keys": repr(covered_keys),
    }

def _v174_candidate_priority(row: dict) -> tuple:
    return (float(row.get("winner_rate",0)), float(row.get("pair_gap",0)), int(row.get("support",0)), int(row.get("stream_count",0)), int(row.get("month_count",0)))

def _v174_base_candidates(pair_df: pd.DataFrame) -> list[tuple[str,str]]:
    candidates = []
    for col in _v174_deep_feature_columns():
        if col not in pair_df.columns:
            continue
        vals = pair_df[col].dropna().unique().tolist()
        try:
            vals = sorted(vals)
        except Exception:
            pass
        for val in vals:
            candidates.append((col, str(int(val)) if isinstance(val, float) and float(val).is_integer() else str(val)))
    return candidates

def _v174_deep_mine_pair(core_hits: pd.DataFrame, left_member: str, right_member: str,
                         min_single_support: int = 12, min_single_winner_rate: float = 0.58, min_single_gap: float = 0.06,
                         min_stack_support: int = 8, min_stack_winner_rate: float = 0.67, min_stack_gap: float = 0.18,
                         min_streams: int = 2, min_months: int = 2, beam_width: int = 120, max_stack_size: int = 3) -> pd.DataFrame:
    pair_df = core_hits[core_hits["next_member"].isin([left_member, right_member])].copy()
    if pair_df.empty:
        return pd.DataFrame()
    base_candidates = _v174_base_candidates(pair_df)
    accepted_by_level = []
    master_rows = []
    level1 = []
    for cond in base_candidates:
        row = _v174_score_candidate(pair_df, left_member, right_member, [cond])
        if row is None:
            continue
        if row["support"] < int(min_single_support) or row["winner_rate"] < float(min_single_winner_rate) or row["pair_gap"] < float(min_single_gap):
            continue
        if row["stream_count"] < int(min_streams) or row["month_count"] < int(min_months):
            continue
        master_rows.append(row)
        level1.append(((cond[0], cond[1]),))
    level1_scored = []
    for conds in level1:
        row = _v174_score_candidate(pair_df, left_member, right_member, list(conds))
        if row is not None:
            level1_scored.append((_v174_candidate_priority(row), conds))
    accepted_by_level.append([conds for _, conds in sorted(level1_scored, reverse=True)[:int(beam_width)]])
    for stack_size in range(2, int(max_stack_size) + 1):
        prev_level = accepted_by_level[-1] if accepted_by_level else []
        if not prev_level:
            break
        next_candidates = set()
        for conds in prev_level:
            used_cols = {c for c, _ in conds}
            for extra in base_candidates:
                if extra[0] in used_cols:
                    continue
                merged = tuple(sorted(list(conds) + [extra], key=lambda x: x[0]))
                next_candidates.add(merged)
        scored_next = []
        for conds in next_candidates:
            row = _v174_score_candidate(pair_df, left_member, right_member, list(conds))
            if row is None:
                continue
            if row["support"] < int(min_stack_support) or row["winner_rate"] < float(min_stack_winner_rate) or row["pair_gap"] < float(min_stack_gap):
                continue
            if row["stream_count"] < int(min_streams) or row["month_count"] < int(min_months):
                continue
            master_rows.append(row)
            scored_next.append((_v174_candidate_priority(row), conds))
        accepted_by_level.append([conds for _, conds in sorted(scored_next, reverse=True)[:int(beam_width)]])
    out = pd.DataFrame(master_rows)
    if out.empty:
        return out
    return out.drop_duplicates(subset=["pair","trait_stack","winner_member"]).sort_values(
        ["winner_rate", "pair_gap", "support", "stream_count", "month_count", "stack_size"],
        ascending=[False, False, False, False, False, True]
    ).reset_index(drop=True)

def _v174_promote_rules(master_df: pd.DataFrame,
                        min_promoted_support: int = 10, min_promoted_winner_rate: float = 0.68,
                        min_promoted_gap: float = 0.20, min_promoted_streams: int = 2,
                        min_promoted_months: int = 2) -> pd.DataFrame:
    if not isinstance(master_df, pd.DataFrame) or master_df.empty:
        return pd.DataFrame()
    work = master_df.copy()
    work = work[
        (pd.to_numeric(work["support"], errors="coerce").fillna(0) >= int(min_promoted_support)) &
        (pd.to_numeric(work["winner_rate"], errors="coerce").fillna(0) >= float(min_promoted_winner_rate)) &
        (pd.to_numeric(work["pair_gap"], errors="coerce").fillna(0) >= float(min_promoted_gap)) &
        (pd.to_numeric(work["stream_count"], errors="coerce").fillna(0) >= int(min_promoted_streams)) &
        (pd.to_numeric(work["month_count"], errors="coerce").fillna(0) >= int(min_promoted_months))
    ].copy()
    if work.empty:
        return work
    return work.sort_values(
        ["winner_rate", "pair_gap", "support", "stream_count", "month_count", "stack_size"],
        ascending=[False, False, False, False, False, True]
    ).reset_index(drop=True)

def _v174_pair_summary(master_df: pd.DataFrame, promoted_df: pd.DataFrame) -> pd.DataFrame:
    if not isinstance(master_df, pd.DataFrame) or master_df.empty:
        return pd.DataFrame(columns=["pair","master_rules","promoted_rules"])
    ms = master_df.groupby("pair").size().rename("master_rules")
    if isinstance(promoted_df, pd.DataFrame) and not promoted_df.empty:
        ps = promoted_df.groupby("pair").size().rename("promoted_rules")
        out = pd.concat([ms, ps], axis=1).fillna(0).reset_index()
    else:
        out = ms.reset_index(); out["promoted_rules"] = 0
    out["master_rules"] = out["master_rules"].astype(int)
    out["promoted_rules"] = out["promoted_rules"].astype(int)
    return out.sort_values("pair").reset_index(drop=True)

def _v174_build_core_hits_from_truth(truth: pd.DataFrame) -> pd.DataFrame:
    t = truth.copy()
    t = _v174_add_deep_compat_features(t, "seed")
    if "StreamKey" in t.columns:
        t["stream"] = t["StreamKey"].astype(str)
    elif "stream" not in t.columns:
        t["stream"] = t.get("State", "").astype(str) + "|" + t.get("Game", "").astype(str)
    if "Date" in t.columns:
        t["event_date"] = pd.to_datetime(t["Date"], errors="coerce")
    elif "date" in t.columns:
        t["event_date"] = pd.to_datetime(t["date"], errors="coerce")
    else:
        t["event_date"] = pd.NaT
    t["year_month"] = pd.to_datetime(t["event_date"], errors="coerce").dt.to_period("M").astype(str)
    member_col = "TrueMember" if "TrueMember" in t.columns else "WinningMember"
    t["next_member"] = t[member_col].apply(normalize_member)
    t = t[t["next_member"].isin(["0025","0225","0255"])]
    return t.reset_index(drop=True)

def _v171_build_separator_from_truth(truth: pd.DataFrame, min_rate: float, min_support: int) -> pd.DataFrame:
    """v174 override: original-style deep pairwise separator rebuild; support-file rebuild only."""
    if truth is None or not isinstance(truth, pd.DataFrame) or truth.empty:
        raise ValueError("No Truth dataframe available to rebuild deep Separator.")
    core_hits = _v174_build_core_hits_from_truth(truth)
    if core_hits.empty:
        raise ValueError("No Core025 hit rows available for deep separator mining.")
    # Use the original March deep-builder defaults; sidebar min_rate/min_support are retained for legacy simple panels, not to weaken deep defaults.
    p1 = _v174_deep_mine_pair(core_hits, "0025", "0225")
    p2 = _v174_deep_mine_pair(core_hits, "0225", "0255")
    p3 = _v174_deep_mine_pair(core_hits, "0025", "0255")
    master = pd.concat([x for x in [p1, p2, p3] if isinstance(x, pd.DataFrame) and not x.empty], ignore_index=True) if any(isinstance(x, pd.DataFrame) and not x.empty for x in [p1,p2,p3]) else pd.DataFrame()
    promoted = _v174_promote_rules(master)
    if promoted is None or promoted.empty:
        promoted = pd.DataFrame(columns=["pair","trait_stack","stack_size","support","winner_member","loser_member","winner_rate","loser_rate","pair_gap","stream_count","month_count","rate_0025","rate_0225","rate_0255","left_count","right_count","covered_keys"])
    for c in ["rate_0025","rate_0225","rate_0255"]:
        if c not in promoted.columns:
            promoted[c] = 0.0
    if "SourceHistoryMaxDate" in truth.columns and truth["SourceHistoryMaxDate"].dropna().shape[0]:
        promoted["SourceHistoryMaxDate"] = str(truth["SourceHistoryMaxDate"].dropna().astype(str).iloc[0])
    else:
        promoted["SourceHistoryMaxDate"] = str(_v171_df_max_date(truth).date()) if _v171_df_max_date(truth) is not None else ""
    promoted["BuildDate"] = pd.Timestamp.today().date().isoformat()
    promoted["BuildSource"] = "v174_deep_pairwise_separator_rebuild_support_only"
    st.session_state["v174_deep_master_separator"] = master.copy()
    st.session_state["v174_deep_pair_summary"] = _v174_pair_summary(master, promoted)
    return promoted.reset_index(drop=True)

def _v172_validate_truth_for_scoring(truth: pd.DataFrame) -> tuple[bool, list[str]]:
    """v174: generated truth can be a support ledger; active daily engine is protected by separator + collapse validation."""
    reasons = []
    if not isinstance(truth, pd.DataFrame) or truth.empty:
        return False, ["Truth is empty"]
    required_basic = ["seed", "WinningMember"]
    missing_basic = [c for c in required_basic if c not in truth.columns]
    if missing_basic:
        reasons.append("missing basic columns: " + ", ".join(missing_basic))
    if len(truth) < 300:
        reasons.append(f"truth rows unexpectedly low: {len(truth)} < 300")
    if len(truth.columns) < 50:
        reasons.append(f"truth support-ledger schema too small: {len(truth.columns)} columns < 50")
    counts = _v172_member_counts(truth, "WinningMember")
    for m in ["25", "225", "255"]:
        if counts.get(m, 0) < 75:
            reasons.append(f"truth member support too low for {m}: {counts.get(m, 0)} < 75")
    return len(reasons) == 0, reasons

def _v172_validate_separator_for_scoring(lib: pd.DataFrame) -> tuple[bool, list[str]]:
    reasons = []
    if not isinstance(lib, pd.DataFrame) or lib.empty:
        return False, ["Separator library is empty"]
    required = ["pair", "trait_stack", "winner_member", "winner_rate", "support", "stack_size", "loser_member", "loser_rate", "pair_gap", "stream_count", "month_count"]
    missing = [c for c in required if c not in lib.columns]
    if missing:
        reasons.append("missing separator columns: " + ", ".join(missing))
    if len(lib) < 300:
        reasons.append(f"deep separator rule count too low: {len(lib)} < 300")
    if "pair" in lib.columns:
        pair_vals = set(lib["pair"].astype(str).unique())
        needed_pairs = {"0025_vs_0225", "0025_vs_0255", "0225_vs_0255"}
        missing_pairs = needed_pairs - pair_vals
        if missing_pairs:
            reasons.append("missing pairwise coverage: " + ", ".join(sorted(missing_pairs)))
    if "winner_member" in lib.columns:
        counts = _v172_member_counts(lib, "winner_member")
        for m in ["25", "225", "255"]:
            if counts.get(m, 0) < 50:
                reasons.append(f"separator member rule support too low for {m}: {counts.get(m, 0)} < 50")
    return len(reasons) == 0, reasons

def _v173_minimum_rules_table() -> pd.DataFrame:
    return pd.DataFrame([
        {"Gate":"Support rebuild scope", "Required":"SUPPORT REBUILD ONLY", "Purpose":"Daily engine/rules/weights/ZLT/B2/RTE/SCL/printable logic are not reverted."},
        {"Gate":"Truth minimum rows", "Required":">= 300", "Purpose":"Reject tiny/placeholder truth rebuilds."},
        {"Gate":"Truth minimum columns", "Required":">= 50", "Purpose":"Accept support-ledger truth only if it has the needed seed/trait columns."},
        {"Gate":"Deep separator minimum rules", "Required":">= 300", "Purpose":"Reject shallow rebuilds that caused 0025 collapse."},
        {"Gate":"Pairwise coverage", "Required":"0025_vs_0225, 0025_vs_0255, 0225_vs_0255", "Purpose":"Preserve original deep separator structure."},
        {"Gate":"Separator member diversity", "Required":"0025, 0225, and 0255 each >= 50 rules", "Purpose":"Prevent one-member separator collapse."},
        {"Gate":"Score health", "Required":"No all-zero member score columns", "Purpose":"Prevent full playlist collapse before cleaning."},
        {"Gate":"Pre-clean member diversity", "Required":"At least 2 predicted members and no single member > 85%", "Purpose":"Visible affirmation that cleaned list did not come from a collapsed full list."},
    ])

