        prog.progress(20, text="Preflighting walk-forward rows and support files")

        # v154 hard preflight: build all 78-stream daily playlists, but keep stream reduction advisory only.
        # Active rules are built inside Walk-forward from the uploaded support files or from the v154 prep utility,
        # not borrowed from Daily Prediction session cache.
        raw_lab_row_count_v151 = int(len(lab_rows)) if isinstance(lab_rows, pd.DataFrame) else 0
        v154_rule_source_label = st.session_state.get("v154_walkforward_rule_source_label", st.session_state.get("v154_walkforward_rule_source_mode", "Production rulebook validation: fixed promoted library + static full-truth mined rules (NOT STRICT BLIND)"))
        try:
