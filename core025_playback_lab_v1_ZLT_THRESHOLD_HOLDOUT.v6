# ================================
# v114 PROMOTION EXECUTOR PANEL
# ================================
try:
    st.divider()
    with st.expander("v114 Promotion Executor — Daily Play Reduction Preview", expanded=True):
        st.caption("Applies promotable separator rules to the current daily playlist as a preview. Core app logic is not overwritten.")
        up114 = st.file_uploader("Optional fallback: upload rules log / separator scores", type=["csv","txt","tsv","xlsx","xls"], key="v114_rules_upload")
        c1,c2,c3,c4 = st.columns(4)
        with c1: sup114 = st.number_input("Promotion min support",2,100,8,1,key="v114_sup")
        with c2: gap114 = st.number_input("Promotion min gap",0.0,1.0,0.05,0.01,format="%.2f",key="v114_gap")
        with c3: rate114 = st.number_input("Promotion min target rate",0.0,1.0,0.20,0.01,format="%.2f",key="v114_rate")
        with c4: max114 = st.number_input("Max promoted rules",10,1000,300,10,key="v114_max")
        allowmiss114 = st.checkbox("Allow MISS flags as review actions", value=True, key="v114_allowmiss")
        skip114 = st.checkbox("Actually skip MISS-flag rows in preview", value=False, key="v114_skip")
        if st.button("Run v114 promotion executor preview", type="primary", key="v114_run"):
            try:
                dsrc, daily = v85_get_daily_playlist()
            except Exception:
                dsrc, daily = None, pd.DataFrame()
            rsrc, rawrules = _v114_get_rule_source(up114)
            promoted = _v114_filter_rules(rawrules, int(sup114), float(gap114), float(rate114), bool(allowmiss114), int(max114))
            if not isinstance(daily, pd.DataFrame) or daily.empty:
                st.warning("Run Daily Prediction first.")
            elif not isinstance(promoted, pd.DataFrame) or promoted.empty:
                st.warning("No promotable rules found with current thresholds.")
            else:
                preview, summary = _v114_apply_daily(daily, promoted, bool(skip114))
                st.session_state["v114_daily_source"] = str(dsrc)
                st.session_state["v114_rule_source"] = str(rsrc)
                st.session_state["v114_promoted_rules"] = promoted
                st.session_state["v114_execution_preview"] = preview
                st.session_state["v114_execution_summary"] = summary
        if st.session_state.get("v114_daily_source"):
            st.write("**Daily source:** " + str(st.session_state.get("v114_daily_source")))
            st.write("**Rule source:** " + str(st.session_state.get("v114_rule_source")))
        for title,key,fname in [
            ("v114 execution summary","v114_execution_summary","core025_v120_execution_summary.csv"),
            ("v114 promoted rules","v114_promoted_rules","core025_v120_promoted_rules.csv"),
            ("v114 daily execution preview","v114_execution_preview","core025_v120_daily_execution_preview.csv"),
        ]:
