    {"RuleID":"MPT2", "Layer":"LOCKED depth trim", "ActionText":"PLAY TOP1 ONLY per MPT2", "Definition":"Exact movement winner rate <= 0.10%.", "HistoricalNote":"Depth trim. Original Top1/Top2/Top3 remain visible; adjusted members show Top1 only.", "InputFields":"MovementWinnerRatePct"},
    {"RuleID":"ZLT001-ZLT152", "Layer":"LOCKED candidate Top1 trims", "ActionText":"PLAY TOP1 ONLY per matching ZLT rule", "Definition":"Zero-loss greedy overlap stack from prior-member + seed scalar/digit/mirror/VTrack feature mining.", "HistoricalNote":"Combined with locked stack validated at ~57.95 plays/day, 238/314 capture. Rules are shown individually when they fire.", "InputFields":"Prior winner member, seed digits/traits, Top1/Top2/Top3/TopPair, movement bucket, VTrack/mirror/scalar traits"},
    {"RuleID":"DNOTE-46", "Layer":"Display note", "ActionText":"Row 46: Top1 won 70%", "Definition":"DynamicRank 46 had 10 winners; Top1 won 70%. Note only.", "HistoricalNote":"Display only, not an action.", "InputFields":"DynamicRank"},
    {"RuleID":"DNOTE-53", "Layer":"Display note", "ActionText":"Row 53: Top2 needed 75%", "Definition":"DynamicRank 53 had 8 winners; Top2 was needed 75%. Note only.", "HistoricalNote":"Display only, not an action.", "InputFields":"DynamicRank"},
    {"RuleID":"DNOTE-65", "Layer":"Display note", "ActionText":"Row 65: Top1 won 80%", "Definition":"DynamicRank 65 had 5 winners; Top1 won 80%. Note only.", "HistoricalNote":"Display only, not an action.", "InputFields":"DynamicRank"},
    {"RuleID":"DNOTE-69", "Layer":"Display note", "ActionText":"Row 69: Top1 won 100%", "Definition":"DynamicRank 69 had 5 winners; Top1 won 100%. Note only.", "HistoricalNote":"Display only, not an action.", "InputFields":"DynamicRank"},
    {"RuleID":"DNOTE-1", "Layer":"Display note", "ActionText":"Row 1: Top2 needed 80%", "Definition":"DynamicRank 1 had 5 winners; Top2 was needed 80%. Note only.", "HistoricalNote":"Display only, not an action.", "InputFields":"DynamicRank"},
]

def _v159_short_member(x):
    s = str(x).strip().replace(" ", "").replace("_", "")
    if s in {"0025", "025", "25", "25.0"}: return "25"
    if s in {"0225", "225", "225.0"}: return "225"
    if s in {"0255", "255", "255.0"}: return "255"
    return s

def _v159_long_member(x):
    s = _v159_short_member(x)
    return {"25":"0025", "225":"0225", "255":"0255"}.get(s, s)

def _v159_digits(value):
    import re
    digs = re.findall(r"\d", str(value) if value is not None else "")
    return [int(d) for d in digs[:4]] if len(digs) >= 4 else []

def _v159_get_seed_series(out: pd.DataFrame):
    # 1) explicit seed columns on playlist rows
    for c in ["seed", "Seed", "CurrentSeed", "PredictionSeed", "LastSeed", "PrevSeed", "PreviousSeed"]:
        cc = _v157_first_col(out, [c])
        if cc is not None:
            vals = out[cc].astype(str)
            if vals.map(lambda x: len(_v159_digits(x)) >= 4).any():
                return vals, cc
    # 2) derive per-stream latest result from uploaded history
    try:
        hist = st.session_state.get("history_df")
        sk_col = _v157_first_col(out, ["StreamKey"])
        if isinstance(hist, pd.DataFrame) and sk_col is not None and "StreamKey" in hist.columns and "Result" in hist.columns:
            hh = hist.copy()
            if "Date" in hh.columns:
                hh["_dt"] = pd.to_datetime(hh["Date"], errors="coerce")
                hh = hh.sort_values(["StreamKey", "_dt"])
            latest = hh.dropna(subset=["StreamKey"]).groupby("StreamKey").tail(1).set_index("StreamKey")["Result"].astype(str).to_dict()
            return out[sk_col].map(latest).fillna(""), "history_df.latest_result_by_StreamKey"
    except Exception:
        pass
    return pd.Series([""] * len(out), index=out.index, dtype="object"), "missing"

def _v159_member_from_result(res):
    digs = ''.join(str(d) for d in _v159_digits(res))
    if len(digs) < 4: return ""
    s = ''.join(sorted(digs))
    if s == "0025": return "0025"
    if s == "0225": return "0225"
    if s == "0255": return "0255"
    return ""

def _v159_prior_core025_member_from_history():
    try:
        hist = st.session_state.get("history_df")
        if not isinstance(hist, pd.DataFrame) or hist.empty or "Result" not in hist.columns:
            return "", "missing"
        hh = hist.copy()
        hh["_member"] = hh["Result"].map(_v159_member_from_result)
        hh = hh[hh["_member"].isin(["0025", "0225", "0255"])]
        if hh.empty: return "", "history_df.no_prior_core025"
        if "Date" in hh.columns:
            hh["_dt"] = pd.to_datetime(hh["Date"], errors="coerce")
            hh = hh.sort_values("_dt")
        return str(hh.iloc[-1]["_member"]), "history_df.latest_core025_result"
    except Exception as e:
        return "", "error:" + str(e)[:80]

def _v159_prior_member_series(out: pd.DataFrame):
    # row-level columns win; otherwise derive from history once
    c = _v157_first_col(out, ["PriorWinnerMemberUsed_v158", "PriorWinnerMember", "PriorCore025WinnerMember", "LastWinnerMember", "LastCore025Member", "PriorWinnerMember_str"])
    if c is not None:
        vals = out[c].map(_v159_long_member)
        if vals.astype(str).str.len().gt(0).any():
            return vals, c
    val, src = _v159_prior_core025_member_from_history()
    return pd.Series([val] * len(out), index=out.index, dtype="object"), src

def _v159_root_sum(n):
    try: n = int(n)
    except Exception: return np.nan
    if n == 0: return 0
    return 1 + ((n - 1) % 9)

def _v159_repeat_shape(ds):
    from collections import Counter
    if len(ds) < 4: return ("", "")
    counts = sorted(Counter(ds).values(), reverse=True)
    if counts == [1,1,1,1]: return ("ABCD", "all_unique")
    if counts == [2,1,1]: return ("AABC", "one_pair")
    if counts == [2,2]: return ("AABB", "two_pair")
    if counts == [3,1]: return ("AAAB", "triple")
    if counts == [4]: return ("AAAA", "quad")
    return ("", "")

def _v159_consec_links(ds):
    if len(ds) < 2: return np.nan
    ss = sorted(set(ds))
    return int(sum(1 for a,b in zip(ss, ss[1:]) if abs(a-b) == 1))

def _v159_vtrack_digit(d):
    return {0:1,5:1,1:2,6:2,2:3,7:3,3:4,8:4,4:5,9:5}.get(int(d), np.nan)

def _v159_feature_frame(out: pd.DataFrame) -> pd.DataFrame:
    feats = pd.DataFrame(index=out.index)
    seed_series, seed_src = _v159_get_seed_series(out)
    feats["_seed_source"] = seed_src
    feats["seed"] = seed_series.astype(str)
    prior, prior_src = _v159_prior_member_series(out)
    feats["PriorWinnerMember_str"] = prior.map(_v159_short_member)
    feats["_prior_member_source"] = prior_src
    top1 = _v157_str_series(out, ["PredictedMember", "Top1", "Top1_Display"], default="").map(_v159_short_member)
    top2 = _v157_str_series(out, ["Top2_pred", "Top2", "Top2_Display"], default="").map(_v159_short_member)
    top3 = _v157_str_series(out, ["ThirdMember", "Top3", "Top3_Display"], default="").map(_v159_short_member)
    feats["PredictedMember_str"] = top1
    feats["Top2_pred_str"] = top2
    feats["ThirdMember_str"] = top3
    feats["TopPair"] = top1 + "-" + top2
    mv_bucket = out["MovementBucket_v157"].astype(str) if "MovementBucket_v157" in out.columns else _v157_num_series(out, ["Movement", "MovementVsStream", "MovementVsOldStreamRank_v141"], default=np.nan).map(_v157_movement_bucket)
    feats["AppMovementBucket"] = mv_bucket.astype(str).str.replace("_", "", regex=False).str.replace("plus", "plus", regex=False)
    # seed derived scalar/digit features
    rows=[]
    for val in seed_series:
        ds = _v159_digits(val)
        rec = {}
        for d in range(10):
            rec[f"cnt{d}"] = int(ds.count(d)) if len(ds) >= 4 else 0
            rec[f"has{d}"] = int(d in ds)
            rec[f"lacks{d}"] = int(d not in ds) if len(ds) >= 4 else 0
        if len(ds) >= 4:
            s=sum(ds); spread=max(ds)-min(ds); parity=''.join('E' if d%2==0 else 'O' for d in ds); hl=''.join('L' if d<=4 else 'H' for d in ds)
            even_cnt=sum(1 for d in ds if d%2==0); odd_cnt=4-even_cnt; high_cnt=sum(1 for d in ds if d>=5); low_cnt=4-high_cnt
            struct, rep = _v159_repeat_shape(ds)
            vts=[_v159_vtrack_digit(d) for d in ds]
            rec.update({
                "seed_sum": s, "seed_sum_lastdigit": s%10, "seed_root_sum": _v159_root_sum(s), "seed_sum_parity": "even" if s%2==0 else "odd",
                "sum_bucket": "sum_0_9" if s<=9 else ("sum_10_13" if s<=13 else ("sum_14_17" if s<=17 else ("sum_18_21" if s<=21 else "sum_22_plus"))),
                "even": even_cnt, "odd": odd_cnt, "high": high_cnt, "low": low_cnt,
                "seed_spread_str": str(spread), "spread_bucket": "spread_0_2" if spread<=2 else ("spread_3_4" if spread<=4 else ("spread_5_6" if spread<=6 else "spread_7_plus")),
                "seed_parity_pattern": parity, "seed_highlow_pattern": hl, "structure": struct, "seed_repeat_shape": rep, "max_rep": max([ds.count(d) for d in set(ds)]) if ds else np.nan,
                "consec_links": _v159_consec_links(ds), "first_digit": str(ds[0]), "last_digit": str(ds[-1]),
                "mirror_count_str": str(sum(1 for a,b in [(0,5),(1,6),(2,7),(3,8),(4,9)] if a in ds and b in ds)),
                "mirror_ge1": "ge1" if any(a in ds and b in ds for a,b in [(0,5),(1,6),(2,7),(3,8),(4,9)]) else "zero",
                "mirror_sum_lastdigit": sum(ds)%10, "vtrack_pattern": ''.join(str(int(v)) for v in vts), "vtrack_count": len(set(vts)), "vtrack_sum_lastdigit": int(sum(vts)%10),
            })
            for k in range(1,6):
                rec[f"vtrack{k}_present"] = int(k in vts)
                rec[f"vtrack{k}_absent"] = int(k not in vts)
        rows.append(rec)
    dd=pd.DataFrame(rows, index=out.index)
    for c in dd.columns: feats[c]=dd[c]
    return feats

def _v159_eval_rule(rule, feats: pd.DataFrame) -> pd.Series:
    mask = pd.Series(True, index=feats.index)
    prior = rule.get('prior','')
    if prior:
        mask &= feats.get('PriorWinnerMember_str', pd.Series('', index=feats.index)).astype(str).eq(prior)
    feature = str(rule.get('feature',''))
    family = str(rule.get('family',''))
    context = str(rule.get('context',''))
    ctxval = str(rule.get('context_value',''))
    values = str(rule.get('values',''))
    # digit include/exclude candidates use family/context columns
    if feature.startswith('has_') or feature.startswith('lacks_'):
        parts = [p for p in feature.split('_')[1:] if p.isdigit()]
        for p in parts:
            col = ('has' if feature.startswith('has_') else 'lacks') + p
            if col in feats.columns: mask &= pd.to_numeric(feats[col], errors='coerce').fillna(0).eq(1)
            else: return pd.Series(False, index=feats.index)
        if context == 'Top1' and ctxval:
            mask &= feats['PredictedMember_str'].eq(_v159_short_member(ctxval))
        elif context == 'TopPair' and ctxval:
            mask &= feats['TopPair'].eq(str(ctxval).replace('.0',''))
        elif context == 'ALL':
            pass
        return mask.fillna(False)
    # scalar candidates have context components and values like "25 + 0 + 255"
    if '+' in context and '+' in values:
        comps=[x.strip() for x in context.split('+')]
        vals=[x.strip() for x in values.split('+')]
        if len(comps)!=len(vals): return pd.Series(False,index=feats.index)
        for comp,val in zip(comps,vals):
            val = val.replace('.0','')
            if comp in ['PriorWinnerMember_str','PredictedMember_str','Top2_pred_str','ThirdMember_str']:
                val = _v159_short_member(val)
            if comp not in feats.columns:
                return pd.Series(False,index=feats.index)
            mask &= feats[comp].astype(str).eq(str(val))
        return mask.fillna(False)
    return pd.Series(False, index=feats.index)

def _v159_apply_locked58_actions(out: pd.DataFrame) -> pd.DataFrame:
    if out is None or not isinstance(out, pd.DataFrame) or out.empty: return out
    out = out.copy()
    feats = _v159_feature_frame(out)
    for c in feats.columns:
        if c not in out.columns and c in ["seed","PriorWinnerMember_str","PredictedMember_str","Top2_pred_str","ThirdMember_str","TopPair","seed_sum","seed_spread_str","seed_parity_pattern","seed_highlow_pattern","structure","seed_repeat_shape","consec_links","first_digit","last_digit","mirror_count_str","mirror_ge1","mirror_sum_lastdigit","vtrack_pattern","vtrack_count","vtrack_sum_lastdigit"]:
            out[c] = feats[c]
    # preserve existing flags/notes
    if "RuleFlags" not in out.columns: out["RuleFlags"] = ""
    if "PlayNote" not in out.columns: out["PlayNote"] = ""
    if "RecommendedActionFlag" not in out.columns: out["RecommendedActionFlag"] = ""
    top1_long = feats["PredictedMember_str"].map(_v159_long_member)
    base_play_count = pd.to_numeric(out.get("PlayCount", out.get("ActualPlayCount", pd.Series([2]*len(out), index=out.index))), errors="coerce").fillna(0).astype(int)
    action = pd.Series("KEEP ORIGINAL", index=out.index, dtype="object")
    adj_members = out.get("MembersToPlay", out.get("ActualMembersToPlay", pd.Series([""]*len(out), index=out.index))).astype(str).copy()
    adj_count = base_play_count.copy()
    fired = pd.Series([[] for _ in range(len(out))], index=out.index, dtype="object")
    notes = pd.Series([[] for _ in range(len(out))], index=out.index, dtype="object")
    # locked stream cuts from corrected dynamic row/movement
    cut_mask = pd.Series(False, index=out.index)
    if "DynamicSingleRowWins" in out.columns:
        cut_mask |= pd.to_numeric(out["DynamicSingleRowWins"], errors="coerce").fillna(99).le(2)
    if "MovementWins" in out.columns:
        cut_mask |= pd.to_numeric(out["MovementWins"], errors="coerce").fillna(99).eq(0)
    for idx in out.index[cut_mask]:
        fired.at[idx].append("SCL-D2/SCL-M0"); notes.at[idx].append("CUT STREAM: locked stream-elimination flag fired; row remains visible")
    action.loc[cut_mask] = "CUT STREAM"
    adj_members.loc[cut_mask] = ""
    adj_count.loc[cut_mask] = 0
    # MPT2 and zero-loss stack top1-only trims on remaining rows
    top1_mask = pd.Series(False, index=out.index)
    if "MovementWinnerRatePct" in out.columns:
        top1_mask |= pd.to_numeric(out["MovementWinnerRatePct"], errors="coerce").fillna(999).le(0.10)
    zlt_missing_inputs = pd.Series(0, index=out.index, dtype="int")
    for rule in V159_ZERO_LOSS_TOP1_RULES:
        m = _v159_eval_rule(rule, feats)
        if m.any():
            for idx in out.index[m]:
                fired.at[idx].append(rule['id'])
                notes.at[idx].append(f"PLAY TOP1 ONLY per {rule['id']}: {rule.get('feature')} / {rule.get('context')} / {rule.get('values')}")
            top1_mask |= m
    top1_mask &= ~cut_mask
    for idx in out.index[top1_mask]:
        if "MPT2" not in fired.at[idx] and pd.to_numeric(out.get("MovementWinnerRatePct", pd.Series([999]*len(out), index=out.index)), errors="coerce").fillna(999).at[idx] <= 0.10:
            fired.at[idx].append("MPT2"); notes.at[idx].append("PLAY TOP1 ONLY per MPT2")
    action.loc[top1_mask] = "PLAY TOP1 ONLY"
    adj_members.loc[top1_mask] = top1_long.loc[top1_mask]
    adj_count.loc[top1_mask] = 1
    # combine display fields
    def _merge(old, xs):
        vals=[]
        for part in str(old).split(','):
            p=part.strip()
            if p: vals.append(p)
        for x in xs:
            if x and x not in vals: vals.append(x)
        return ', '.join(vals)
    def _merge_notes(old, xs):
        vals=[]
        for part in str(old).split('|'):
            p=part.strip()
            if p: vals.append(p)
        for x in xs:
            if x and x not in vals: vals.append(x)
        return ' | '.join(vals)
    for idx in out.index:
        out.at[idx,"RuleFlags"] = _merge(out.at[idx,"RuleFlags"], fired.at[idx])
        out.at[idx,"PlayNote"] = _merge_notes(out.at[idx,"PlayNote"], notes.at[idx])
    out["v159_Action"] = action
    out["v159_AdjustedMembersToPlay"] = adj_members
    out["v159_AdjustedPlayCount"] = adj_count.astype(int)
    out["v159_RunningPlayTotal"] = out["v159_AdjustedPlayCount"].cumsum()
    out["v159_RunningCost"] = out["v159_RunningPlayTotal"].map(lambda x: f"${float(x)*0.25:,.2f}")
    out["v159_RuleFiredCount"] = fired.map(len)
    out["v159_FiredRuleIDs"] = fired.map(lambda xs: ', '.join(dict.fromkeys(xs)))
    out["v159_InputStatus"] = "seed=" + str(feats.get("_seed_source", pd.Series(["missing"], index=out.index)).iloc[0]) + "; prior_member=" + str(feats.get("_prior_member_source", pd.Series(["missing"], index=out.index)).iloc[0])
    out["v159_Build"] = V159_BUILD_LABEL
    return out


# ================================
# v164 BUDGET FLAGS: B1/B2 + rare raw seed trait eliminators
# Additive only. v159/v162 columns are preserved.
# This layer behaves like the existing ZLT/SCL flags:
# - every new cut condition has a unique visible ID
# - IDs are appended into RuleFlags and PlayNote
# - definitions are shown in the Notes / Rule Key tab
# - final playlist keeps all rows visible and exposes adjusted play count separately
# ================================
V163_BUILD_LABEL = "v177_SUPPORT_AUDIT_CONTRIBUTION_LIFECYCLE__2026-06-06"
V164_BUILD_LABEL = V163_BUILD_LABEL
V165_DEFAULT_BUDGET_MODE = "B2_PLUS_RARE_TRAITS"
V163_BUDGET_MODES = ["OFF", "B1_ZLT_LE1", "B2_ZLT_LE1_PLUS_ZLT2_TOP1_NOT_0225", "B2_PLUS_RARE_TRAITS"]
V164_BUDGET_MODES = V163_BUDGET_MODES

