        st.caption("Tells you whether the per-event proof file needs refreshing based on current play date vs. newest date in the per-event file.")
        up_fresh117 = st.file_uploader("Optional fallback: upload per-event file for freshness check", type=["csv","txt","tsv","xlsx","xls"], key="v117_freshness_upload")
        max_age117 = st.number_input("Maximum allowed per-event age in days", min_value=0, max_value=30, value=1, step=1, key="v117_max_age")
        if st.button("Check v117 per-event freshness", type="primary", key="v117_run_freshness"):
            try:
                _, daily117 = v85_get_daily_playlist()
            except Exception:
                daily117 = pd.DataFrame()
            audit117 = _v117_freshness_audit(daily_df=daily117, uploaded_per_event=up_fresh117, max_age_days=int(max_age117))
            st.session_state["v117_freshness_audit"] = audit117

        audit117 = st.session_state.get("v117_freshness_audit")
        if isinstance(audit117, pd.DataFrame) and not audit117.empty:
            status = str(audit117.iloc[0].get("FreshnessStatus", ""))
            if status == "CURRENT":
                st.success(str(audit117.iloc[0].get("Message", "")))
            elif status in {"STALE_REFRESH_RECOMMENDED", "MISSING_OR_NO_DATE"}:
                st.error(str(audit117.iloc[0].get("Message", "")))
            else:
                st.warning(str(audit117.iloc[0].get("Message", "")))
            st.dataframe(audit117, use_container_width=True, hide_index=True)
            st.download_button(
                "Download v117 freshness audit",
                data=audit117.to_csv(index=False).encode("utf-8"),
                file_name="core025_v120_per_event_freshness_audit.csv",
