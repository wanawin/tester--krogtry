                else:
                    key, df_in = _v129_find_walkforward_per_event_from_session()
                    source = "session:auto_walkforward_per_event:" + str(key)
                if not isinstance(df_in, pd.DataFrame) or df_in.empty:
                    st.warning("No Walkforward per-event table found. Run Walkforward Lab or upload lab_per_event.")
                else:
                    final, rlog, qlog, _score_pre_cadence = _v127_run_walkforward_engine(df_in)
                    final, clog = _v128_apply_single_row_cadence(final)
                    score = _v128_score(final)
                    st.session_state["v128_wf_cadence_log"] = clog
                    st.session_state["v128_wf_date_status"] = _v128_history_status(df_in)
                    ok, msg = _v127_validate_processed_output(final)
                    st.session_state["v124_wf_output"] = final
                    st.session_state["v124_wf_reduction_log"] = rlog
                    st.session_state["v124_wf_rescue_log"] = qlog
                    st.session_state["v124_wf_score"] = score
                    st.session_state["v124_wf_source"] = source + " | " + msg
                    if ok:
                        st.success("v130 Walkforward Validation complete — processed finalized output exported.")
                    else:
                        st.error("v127 Walkforward Validation blocked: " + msg)

            if st.session_state.get("v124_wf_source"):
                st.write("**Walkforward source:** " + str(st.session_state.get("v124_wf_source")))
                _v130_wds = st.session_state.get("v128_wf_date_status")
                if isinstance(_v130_wds, pd.DataFrame) and not _v130_wds.empty:
                    _r = _v130_wds.iloc[0].to_dict()
                    st.info("History Through: {h} | Playlist Date: {p} | Status: {s}".format(h=_r.get("HistoryThrough", ""), p=_r.get("PlaylistDate", ""), s=_r.get("Status", "")))
                _v127_score_preview = st.session_state.get("v124_wf_score")
                if isinstance(_v127_score_preview, pd.DataFrame) and not _v127_score_preview.empty:
                    _r = _v127_score_preview.iloc[0].to_dict()
                    st.info(
                        "v127 processed rows: {rows} | captured: {cap}/{hits} | plays: {plays} | locked-tier match: {match}".format(
                            rows=_r.get("v127_ProcessedRows"),
                            cap=_r.get("v127_CapturedHits"),
                            hits=_r.get("v127_TotalHits"),
                            plays=_r.get("v127_TotalPlays"),
                            match=_r.get("v127_MatchesLocked264Tier"),
                        )
                    )
            for title, key, fname in [
                ("Walkforward score", "v124_wf_score", "core025_v130_walkforward_score.csv"),
                ("Walkforward date status", "v128_wf_date_status", "core025_v130_walkforward_date_status.csv"),
                ("Walkforward cadence log", "v128_wf_cadence_log", "core025_v130_walkforward_cadence_log.csv"),
                ("Walkforward reduction log", "v124_wf_reduction_log", "core025_v130_walkforward_reduction_log.csv"),
                ("Walkforward rescue log", "v124_wf_rescue_log", "core025_v130_walkforward_rescue_log.csv"),
                ("Walkforward finalized predictions", "v124_wf_output", "core025_v130_walkforward_finalized_predictions.csv"),
            ]:
                x = st.session_state.get(key)
                if isinstance(x, pd.DataFrame) and not x.empty:
                    st.subheader(title)
                    st.dataframe(x.head(250), use_container_width=True, hide_index=True)
                    _v125_download_button("Download " + title, x, fname, key+"_dl")

        with tab_probe124:
            st.caption("Tests whether the finalized v124 output can be further reduced by SingleRow / RowPercentile / rank gates. Use after Walkforward Validation.")
            if st.button("Run post-v124 Row/Percentile Probe", key="v124_probe_run"):
                src = st.session_state.get("v124_wf_output")
                if not isinstance(src, pd.DataFrame) or src.empty:
                    src = st.session_state.get("v124_daily_output")
                if isinstance(src, pd.DataFrame) and not src.empty:
                    probe = _v124_row_percentile_probe(src)
                    st.session_state["v124_row_probe"] = probe
                    st.success("Row/percentile probe complete.")
                else:
                    st.warning("Run v124 Daily or Walkforward first.")
            probe = st.session_state.get("v124_row_probe")
            if isinstance(probe, pd.DataFrame) and not probe.empty:
                st.dataframe(probe.sort_values(["CaptureRate","TotalPlays"], ascending=[False, True]).head(200), use_container_width=True, hide_index=True)
                _v125_download_button("Download post-v125 row probe", probe, "core025_v125_post_row_percentile_probe.csv", "v125_probe_dl")
except Exception as e:
    try:
        st.warning("v124 Locked 264 Engine unavailable: " + str(e))
    except Exception:
        pass


