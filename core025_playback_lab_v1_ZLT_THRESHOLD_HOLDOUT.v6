# ============================================================
# v176 SUPPORT AUDIT LAB — TRUSTED AUDIT + PATCH MANAGER
# ============================================================
# Additive only. This replaces the buried v175 audit rendering with an early,
# validated audit section. It does not alter the daily engine or overwrite
# Truth/Separator files. Approved changes are handled as a separate patch overlay.

V176_BUILD_MARKER = "BUILD: core025_northern_lights__2026-06-06_v177_SUPPORT_AUDIT_CONTRIBUTION_LIFECYCLE"
V176_MEMBERS = ["0025", "0225", "0255"]


def _v176_csv_bytes(df):
    try:
        return df.to_csv(index=False).encode("utf-8")
    except Exception:
        return b""


def _v176_txt_bytes(s):
    try:
        return str(s).encode("utf-8")
    except Exception:
        return b""


def _v176_load_any(uploaded):
    if uploaded is None:
        return pd.DataFrame()
    try:
        name = str(getattr(uploaded, "name", "")).lower()
        if name.endswith(".csv"):
            return pd.read_csv(uploaded, dtype=str)
        if name.endswith((".txt", ".tsv")):
            raw = uploaded.getvalue() if hasattr(uploaded, "getvalue") else uploaded.read()
            try:
                return pd.read_csv(io.BytesIO(raw), sep="\t", dtype=str)
            except Exception:
                return pd.read_csv(io.BytesIO(raw), sep=None, engine="python", dtype=str)
        if name.endswith((".xlsx", ".xls")):
            return pd.read_excel(uploaded, dtype=str)
        return pd.read_csv(uploaded, dtype=str)
    except Exception as e:
        try:
            st.warning(f"v176 could not load file: {e}")
        except Exception:
            pass
        return pd.DataFrame()


def _v176_norm_col(c):
    return re.sub(r"[^a-z0-9]+", "", str(c).lower())


def _v176_column_map(df):
    if df is None or not isinstance(df, pd.DataFrame):
        return {}
    return {_v176_norm_col(c): c for c in df.columns}


def _v176_pick_col(df, candidates, contains_any=None):
    if df is None or df.empty:
        return None
    cmap = _v176_column_map(df)
    for cand in candidates:
        key = _v176_norm_col(cand)
        if key in cmap:
            return cmap[key]
    if contains_any:
        words = [_v176_norm_col(x) for x in contains_any]
        for c in df.columns:
            n = _v176_norm_col(c)
            if any(w in n for w in words):
                return c
    return None


def _v176_norm_result(x):
    digs = re.findall(r"\d", str(x))
    return "".join(digs[:4]) if len(digs) >= 4 else ""


def _v176_box_key(x):
    s = _v176_norm_result(x)
    return "".join(sorted(s)) if len(s) == 4 else ""


def _v176_to_member(x):
    s0 = str(x).strip()
    if s0 == "" or s0.lower() in {"nan", "none"}:
        return ""
    digs = re.findall(r"\d", s0)
    if not digs:
        return ""
    s = "".join(digs)
    if s in {"25", "025", "0025"}: return "0025"
    if s in {"225", "0225"}: return "0225"
    if s in {"255", "0255"}: return "0255"
    if len(s) >= 4:
        b = "".join(sorted(s[:4]))
        if b in V176_MEMBERS:
            return b
    return ""


def _v176_sum_bucket(x):
    try: x = int(x)
    except Exception: return ""
    if x <= 9: return "sum_00_09"
    if x <= 13: return "sum_10_13"
    if x <= 17: return "sum_14_17"
    if x <= 21: return "sum_18_21"
    return "sum_22_plus"


def _v176_spread_bucket(x):
    try: x = int(x)
    except Exception: return ""
    if x <= 2: return "spread_0_2"
    if x <= 4: return "spread_3_4"
    if x <= 6: return "spread_5_6"
    return "spread_7_plus"


def _v176_structure(digs):
    try:
        counts = sorted(pd.Series(digs).value_counts().tolist(), reverse=True)
    except Exception:
        return ""
    return { (1,1,1,1):"ABCD", (2,1,1):"AABC", (2,2):"AABB", (3,1):"AAAB", (4,):"AAAA" }.get(tuple(counts), "OTHER")


def _v176_add_seed_features(df, seed_col="seed"):
    out = df.copy()
    if seed_col not in out.columns:
        out[seed_col] = ""
    seeds = out[seed_col].astype(str).map(_v176_norm_result)
    seeds = seeds.where(seeds.str.len().eq(4), out[seed_col].astype(str).str.extract(r"(\d{4})", expand=False).fillna("0000"))
    digs = seeds.map(lambda s: [int(ch) for ch in str(s).zfill(4)[-4:]])
    out["seed"] = seeds
    out["sum"] = digs.map(sum); out["seed_sum"] = out["sum"]
    out["spread"] = digs.map(lambda d: max(d) - min(d)); out["seed_spread"] = out["spread"]
    out["sum_bucket"] = out["sum"].map(_v176_sum_bucket)
    out["spread_bucket"] = out["spread"].map(_v176_spread_bucket)
    out["even"] = digs.map(lambda d: sum(1 for x in d if x % 2 == 0))
    out["odd"] = digs.map(lambda d: sum(1 for x in d if x % 2 != 0))
    out["high"] = digs.map(lambda d: sum(1 for x in d if x >= 5))
    out["low"] = digs.map(lambda d: sum(1 for x in d if x <= 4))
    out["unique"] = digs.map(lambda d: len(set(d)))
    out["pair"] = digs.map(lambda d: int(len(set(d)) < 4))
    out["max_rep"] = digs.map(lambda d: max(pd.Series(d).value_counts().tolist()))
    out["consec_links"] = digs.map(lambda d: sum(1 for a,b in zip(sorted(set(d))[:-1], sorted(set(d))[1:]) if b-a == 1))
    out["parity_pattern"] = digs.map(lambda d: "".join("E" if x % 2 == 0 else "O" for x in d))
    out["highlow_pattern"] = digs.map(lambda d: "".join("H" if x >= 5 else "L" for x in d))
    out["structure"] = digs.map(_v176_structure)
    out["sorted_seed"] = digs.map(lambda d: "".join(str(x) for x in sorted(d)))
    out["first2"] = digs.map(lambda d: f"{d[0]}{d[1]}")
    out["last2"] = digs.map(lambda d: f"{d[2]}{d[3]}")
    for k in range(10):
        out[f"has{k}"] = digs.map(lambda d, kk=k: int(kk in d))
        out[f"cnt{k}"] = digs.map(lambda d, kk=k: int(sum(1 for x in d if x == kk)))
    out["seed_highlow_pattern"] = out["highlow_pattern"]
    out["seed_parity_pattern"] = out["parity_pattern"]
    out["seed_repeat_shape"] = out["structure"]
    out["seed_has9"] = out["has9"]
    out["seed_has0"] = out["has0"]
    out["seed_even_cnt"] = out["even"]
    out["seed_high_cnt"] = out["high"]
    out["seed_low_cnt"] = out["low"]
    return out


def _v176_prepare_history(df_raw):
    if df_raw is None or not isinstance(df_raw, pd.DataFrame) or df_raw.empty:
        return pd.DataFrame()
    df = df_raw.copy(); df.columns = [str(c).strip() for c in df.columns]
    date_col = _v176_pick_col(df, ["Date", "DrawDate", "draw_date"], ["date"])
    state_col = _v176_pick_col(df, ["State", "Jurisdiction"], ["state", "jurisdiction"])
    game_col = _v176_pick_col(df, ["Game"], ["game"])
    result_col = _v176_pick_col(df, ["Results", "Result", "Winning Numbers", "winning_numbers"], ["result", "winning"])
    if date_col is None or result_col is None:
        if df.shape[1] >= 4:
            date_col, state_col, game_col, result_col = df.columns[:4]
        else:
            return pd.DataFrame()
    out = pd.DataFrame()
    out["Date"] = pd.to_datetime(df[date_col], errors="coerce")
    out["State"] = df[state_col].astype(str) if state_col else ""
    out["Game"] = df[game_col].astype(str) if game_col else ""
    out["Result"] = df[result_col].map(_v176_norm_result)
    out = out[out["Date"].notna() & out["Result"].astype(str).str.len().eq(4)].copy()
    out["StreamKey"] = out["State"].astype(str).str.strip() + " | " + out["Game"].astype(str).str.strip()
    out["Box"] = out["Result"].map(_v176_box_key)
    out["Core025Member"] = out["Box"].where(out["Box"].isin(V176_MEMBERS), "")
    return out.sort_values(["StreamKey", "Date"]).reset_index(drop=True)


def _v176_build_transitions(hist):
    rows = []
    if hist is None or hist.empty:
        return pd.DataFrame()
    for stream, g in hist.groupby("StreamKey"):
        g = g.sort_values("Date").reset_index(drop=True)
        for i in range(1, len(g)):
            rows.append({
                "StreamKey": stream,
                "State": g.loc[i, "State"],
                "Game": g.loc[i, "Game"],
                "seed_date": g.loc[i-1, "Date"],
                "event_date": g.loc[i, "Date"],
                "seed": g.loc[i-1, "Result"],
                "Result": g.loc[i, "Result"],
                "next_member": g.loc[i, "Core025Member"] if g.loc[i, "Core025Member"] in V176_MEMBERS else "",
                "is_core025_hit": int(g.loc[i, "Core025Member"] in V176_MEMBERS),
            })
    out = pd.DataFrame(rows)
    if out.empty: return out
    out = _v176_add_seed_features(out, "seed")
    return out.sort_values(["event_date", "StreamKey"]).reset_index(drop=True)


def _v176_detect_member_col(df):
    if df is None or df.empty:
        return None, pd.Series(dtype=str), pd.DataFrame()
    candidates = [
        "TrueMember","WinningMember","WinnerMember","Winner","Core025Member","CapturedMember",
        "ActualMember","TargetMember","member","winning_member","winner_member","Box","Result","Results"
    ]
    rows = []
    best_col, best_count, best_members = None, -1, None
    for c in df.columns:
        n = _v176_norm_col(c)
        likely = any(_v176_norm_col(x) == n for x in candidates) or any(w in n for w in ["truemember","winningmember","winnermember","core025member","capturedmember","actualmember","targetmember"])
        if not likely:
            continue
        members = df[c].map(_v176_to_member)
        count = int(members.isin(V176_MEMBERS).sum())
        rows.append({"CandidateColumn": c, "DetectedCore025Members": count})
        if count > best_count:
            best_col, best_count, best_members = c, count, members
    # fallback: scan every column when no likely column worked
    if best_count <= 0:
        for c in df.columns:
            members = df[c].map(_v176_to_member)
            count = int(members.isin(V176_MEMBERS).sum())
            if count > best_count:
                best_col, best_count, best_members = c, count, members
        rows.append({"CandidateColumn": "FALLBACK_BEST_SCAN=" + str(best_col), "DetectedCore025Members": int(best_count)})
    if best_members is None:
        best_members = pd.Series([""] * len(df), index=df.index)
    return best_col, best_members, pd.DataFrame(rows)


def _v176_parse_conditions(trait_stack):
    parts = [p.strip() for p in re.split(r"\s+&&\s+", str(trait_stack)) if p.strip()]
    conds = []
    for p in parts:
        if "==" in p:
            col, val = p.split("==", 1)
        elif "=" in p:
            col, val = p.split("=", 1)
        else:
            continue
        conds.append((col.strip(), val.strip()))
    return conds


def _v176_condition_mask(df, conds):
    mask = pd.Series(True, index=df.index)
    missing = []
    for col, val in conds:
        aliases = [col]
        if col.startswith("seed_"):
            aliases.append(col.replace("seed_", ""))
        else:
            aliases.append("seed_" + col)
        real_col = next((c for c in aliases if c in df.columns), None)
        if real_col is None:
            missing.append(col); mask &= False; continue
        def fmt(x):
            if pd.isna(x): return ""
            s = str(x)
            try:
                f = float(s)
                if f.is_integer(): return str(int(f))
            except Exception:
                pass
            return s.strip()
        mask &= df[real_col].map(fmt).astype(str).str.strip().eq(str(val).strip())
    return mask, (";".join(missing) if missing else "")


def _v176_validate_separator(sep):
    if sep is None or not isinstance(sep, pd.DataFrame) or sep.empty:
        return pd.DataFrame([{"Check":"Separator loaded", "Status":"FAIL", "Detail":"No separator rows"}]), {}
    work = sep.copy(); work.columns = [str(c).strip() for c in work.columns]
    trait_col = _v176_pick_col(work, ["trait_stack", "TraitStack", "trait", "RuleTrait"], ["trait"])
    winner_col = _v176_pick_col(work, ["winner_member", "WinnerMember", "winning_member", "member"], ["winner", "member"])
    pair_col = _v176_pick_col(work, ["pair", "Pair"], ["pair"])
    members = work[winner_col].map(_v176_to_member) if winner_col else pd.Series([""]*len(work))
    member_counts = members.value_counts().reindex(V176_MEMBERS).fillna(0).astype(int).to_dict()
    pair_counts = work[pair_col].astype(str).value_counts().to_dict() if pair_col else {}
    checks = []
    checks.append({"Check":"Separator rows loaded", "Status":"PASS" if len(work)>0 else "FAIL", "Detail":str(len(work))})
    checks.append({"Check":"Trait stack column found", "Status":"PASS" if trait_col else "FAIL", "Detail":str(trait_col or "missing")})
    checks.append({"Check":"Winner member column found", "Status":"PASS" if winner_col else "FAIL", "Detail":str(winner_col or "missing")})
    checks.append({"Check":"Pair column found", "Status":"PASS" if pair_col else "WARN", "Detail":str(pair_col or "missing")})
    checks.append({"Check":"0025 rules", "Status":"PASS" if member_counts.get("0025",0)>0 else "FAIL", "Detail":str(member_counts.get("0025",0))})
    checks.append({"Check":"0225 rules", "Status":"PASS" if member_counts.get("0225",0)>0 else "FAIL", "Detail":str(member_counts.get("0225",0))})
    checks.append({"Check":"0255 rules", "Status":"PASS" if member_counts.get("0255",0)>0 else "FAIL", "Detail":str(member_counts.get("0255",0))})
    for pair_name in ["0025_vs_0225", "0025_vs_0255", "0225_vs_0255", "0225_vs_0025", "0255_vs_0025", "0255_vs_0225"]:
        if pair_col and any(pair_name in str(x) for x in work[pair_col].astype(str).unique()):
            checks.append({"Check":"Pair coverage " + pair_name, "Status":"PASS", "Detail":"present"})
    meta = {"trait_col": trait_col, "winner_col": winner_col, "pair_col": pair_col, "member_counts": member_counts, "pair_counts": pair_counts}
    return pd.DataFrame(checks), meta


def _v176_truth_audit(old_truth, transitions):
    core = transitions[transitions["is_core025_hit"] == 1].copy() if isinstance(transitions, pd.DataFrame) and not transitions.empty else pd.DataFrame()
    current_dist = core["next_member"].value_counts().reindex(V176_MEMBERS).fillna(0).astype(int) if not core.empty else pd.Series({m:0 for m in V176_MEMBERS})
    old_rows = old_cols = 0; old_max_date = "missing"; member_col = ""; detect = pd.DataFrame(); old_dist = pd.Series({m:0 for m in V176_MEMBERS})
    if old_truth is not None and isinstance(old_truth, pd.DataFrame) and not old_truth.empty:
        old = old_truth.copy(); old.columns = [str(c).strip() for c in old.columns]
        old_rows, old_cols = len(old), len(old.columns)
        member_col, old_members, detect = _v176_detect_member_col(old)
        old_dist = old_members[old_members.isin(V176_MEMBERS)].value_counts().reindex(V176_MEMBERS).fillna(0).astype(int)
        date_col = _v176_pick_col(old, ["Date", "date", "event_date", "EventDate", "DrawDate"], ["date"])
        if date_col:
            ds = pd.to_datetime(old[date_col], errors="coerce")
            old_max_date = str(ds.max().date()) if ds.notna().any() else "unknown"
        else:
            old_max_date = "unknown"
    current_max_date = str(pd.to_datetime(transitions["event_date"], errors="coerce").max().date()) if isinstance(transitions, pd.DataFrame) and not transitions.empty and "event_date" in transitions.columns else "unknown"
    dist_rows = []
    for m in V176_MEMBERS:
        dist_rows.append({"Member":m, "OldTruthCount":int(old_dist.get(m,0)), "CurrentHistoryCoreHitCount":int(current_dist.get(m,0)), "DeltaCount":int(current_dist.get(m,0))-int(old_dist.get(m,0))})
    meta = pd.DataFrame([{"OldTruthRows":int(old_rows), "OldTruthColumns":int(old_cols), "DetectedOldTruthMemberColumn":str(member_col or "NONE"), "OldTruthMaxDate":old_max_date, "CurrentTransitionRows":int(len(transitions)) if isinstance(transitions,pd.DataFrame) else 0, "CurrentCore025Hits":int(len(core)), "CurrentHistoryMaxEventDate":current_max_date, "AuditMode":"audit_only_no_auto_replace"}])
    checks = []
    checks.append({"Check":"Old truth file loaded", "Status":"PASS" if old_rows>0 else "FAIL", "Detail":str(old_rows)})
    checks.append({"Check":"Old truth member column detected", "Status":"PASS" if member_col else "FAIL", "Detail":str(member_col or "none")})
    checks.append({"Check":"Old truth member counts nonzero", "Status":"PASS" if int(sum(old_dist))>0 else "FAIL", "Detail":str(dict(old_dist))})
    checks.append({"Check":"Current history Core025 hits", "Status":"PASS" if len(core)>0 else "FAIL", "Detail":str(len(core))})
    return pd.DataFrame(dist_rows), meta, pd.DataFrame(checks), detect


def _v176_audit_separator(old_sep, transitions, min_support=5, weaken_delta=0.08, flip_margin=0.05):
    if old_sep is None or old_sep.empty or transitions is None or transitions.empty:
        return pd.DataFrame(), pd.DataFrame(), pd.DataFrame(), {}
    sep = old_sep.copy(); sep.columns = [str(c).strip() for c in sep.columns]
    parse_checks, meta = _v176_validate_separator(sep)
    trait_col = meta.get("trait_col") or "trait_stack"
    winner_col = meta.get("winner_col") or "winner_member"
    pair_col = meta.get("pair_col") or "pair"
    if trait_col not in sep.columns:
        return pd.DataFrame([{"Status":"PARSE_OR_SCHEMA_REVIEW", "EvalNote":"missing trait_stack"}]), pd.DataFrame(), parse_checks, meta
    if winner_col not in sep.columns:
        sep[winner_col] = ""
    if pair_col not in sep.columns:
        sep[pair_col] = ""
    core = transitions[transitions["is_core025_hit"] == 1].copy()
    rows=[]
    for idx, r in sep.iterrows():
        trait = str(r.get(trait_col, ""))
        old_member = _v176_to_member(r.get(winner_col, ""))
        old_support = pd.to_numeric(r.get("support", r.get("Support", "")), errors="coerce")
        old_rate = pd.to_numeric(r.get("winner_rate", r.get("WinnerRate", "")), errors="coerce")
        old_gap = pd.to_numeric(r.get("pair_gap", r.get("PairGap", "")), errors="coerce")
        conds = _v176_parse_conditions(trait)
        mask, missing = _v176_condition_mask(core, conds)
        sub = core[mask].copy()
        new_support = int(len(sub))
        counts = sub["next_member"].value_counts().reindex(V176_MEMBERS).fillna(0).astype(int).to_dict()
        if new_support > 0:
            rates = {m: counts.get(m,0)/new_support for m in V176_MEMBERS}
            new_best = max(rates, key=rates.get); new_best_rate = rates[new_best]; old_member_new_rate = rates.get(old_member, 0.0) if old_member else 0.0
        else:
            rates = {m:0.0 for m in V176_MEMBERS}; new_best=""; new_best_rate=0.0; old_member_new_rate=0.0
        delta_old = (float(old_rate)-old_member_new_rate) if pd.notna(old_rate) else None
        if missing:
            status="PARSE_OR_SCHEMA_REVIEW"; action="Do not change; parser could not verify rule."
        elif new_support < int(min_support):
            status="INSUFFICIENT_CURRENT_SUPPORT"; action="Do not change; not enough current support."
        elif old_member and new_best and new_best != old_member and (new_best_rate - old_member_new_rate) >= float(flip_margin):
            status="FLIPPED_REVIEW"; action="Candidate patch only after manual approval."
        elif delta_old is not None and delta_old >= float(weaken_delta):
            status="WEAKENED_REVIEW"; action="Keep production rule for now; monitor or test contribution."
        elif old_member and new_best == old_member:
            status="STILL_HOLDS"; action="Keep unchanged."
        else:
            status="REVIEW"; action="Manual review."
        rows.append({"RuleID": str(r.get("RuleID", r.get("rule_id", f"SEP_ROW_{idx+1}"))), "RuleRow":idx+1, "Pair":r.get(pair_col,""), "TraitStack":trait, "OldWinnerMember":old_member, "OldSupport":old_support if pd.notna(old_support) else "", "OldWinnerRate":old_rate if pd.notna(old_rate) else "", "OldPairGap":old_gap if pd.notna(old_gap) else "", "CurrentSupport":new_support, "CurrentBestMember":new_best, "CurrentBestRate":round(new_best_rate,4), "CurrentOldMemberRate":round(old_member_new_rate,4), "DeltaOldMemberRate":round(delta_old,4) if delta_old is not None else "", "Count_0025":counts.get("0025",0), "Count_0225":counts.get("0225",0), "Count_0255":counts.get("0255",0), "Status":status, "RecommendedAction":action, "EvalNote":missing})
    audit=pd.DataFrame(rows)
    summary=audit.groupby("Status").size().rename("RuleCount").reset_index().sort_values("RuleCount",ascending=False) if not audit.empty else pd.DataFrame()
    return audit, summary, parse_checks, meta


def _v176_make_proposed_changes(sep_audit):
    if sep_audit is None or not isinstance(sep_audit, pd.DataFrame) or sep_audit.empty:
        return pd.DataFrame()
    review = sep_audit[sep_audit["Status"].isin(["FLIPPED_REVIEW", "WEAKENED_REVIEW", "PARSE_OR_SCHEMA_REVIEW", "INSUFFICIENT_CURRENT_SUPPORT", "REVIEW"])].copy()
    if review.empty:
        return pd.DataFrame(columns=["Approve","RuleID","RuleRow","TraitStack","CurrentAction","ProposedAction","OldWinnerMember","ProposedWinnerMember","EvidenceSummary","Reason"])
    out = pd.DataFrame()
    out["Approve"] = "NO"
    out["RuleID"] = review.get("RuleID", "")
    out["RuleRow"] = review["RuleRow"]
    out["TraitStack"] = review["TraitStack"]
    out["CurrentAction"] = review["Status"]
    out["ProposedAction"] = review["Status"].map(lambda s: "CHANGE_WINNER_MEMBER" if s=="FLIPPED_REVIEW" else ("DISABLE_OR_MONITOR" if s=="WEAKENED_REVIEW" else "NO_CHANGE_REVIEW"))
    out["OldWinnerMember"] = review["OldWinnerMember"]
    out["ProposedWinnerMember"] = review["CurrentBestMember"]
    out["EvidenceSummary"] = review.apply(lambda r: f"old={r.get('OldWinnerMember')}@{r.get('OldWinnerRate')} support={r.get('OldSupport')} | current_best={r.get('CurrentBestMember')}@{r.get('CurrentBestRate')} support={r.get('CurrentSupport')}", axis=1)
    out["Reason"] = review["RecommendedAction"]
    return out


def _v176_patch_template(proposed=None):
    cols = ["Approve","RuleID","RuleRow","TraitStack","PatchAction","OldWinnerMember","NewWinnerMember","DisableRule","Reason","ApprovedBy","ApprovedDate"]
    if proposed is None or not isinstance(proposed, pd.DataFrame) or proposed.empty:
        return pd.DataFrame(columns=cols)
    p = proposed.head(250).copy()
    out = pd.DataFrame()
    out["Approve"] = "NO"
    out["RuleID"] = p.get("RuleID", "")
    out["RuleRow"] = p.get("RuleRow", "")
    out["TraitStack"] = p.get("TraitStack", "")
    out["PatchAction"] = p.get("ProposedAction", "")
    out["OldWinnerMember"] = p.get("OldWinnerMember", "")
    out["NewWinnerMember"] = p.get("ProposedWinnerMember", "")
    out["DisableRule"] = "NO"
    out["Reason"] = p.get("EvidenceSummary", "")
    out["ApprovedBy"] = ""
    out["ApprovedDate"] = ""
    return out[cols]


def _v176_apply_patch_preview(sep, patch):
    if sep is None or sep.empty or patch is None or patch.empty:
        return sep.copy() if isinstance(sep, pd.DataFrame) else pd.DataFrame(), pd.DataFrame([{"PatchStatus":"NO_PATCHES_ACTIVE", "Applied":0}])
    out = sep.copy(); out.columns = [str(c).strip() for c in out.columns]
    winner_col = _v176_pick_col(out, ["winner_member", "WinnerMember", "winning_member", "member"], ["winner", "member"]) or "winner_member"
    if winner_col not in out.columns: out[winner_col] = ""
    applied=[]
    p = patch.copy(); p.columns = [str(c).strip() for c in p.columns]
    for _, r in p.iterrows():
        approve = str(r.get("Approve", "")).strip().upper() in {"YES","Y","TRUE","1"}
        if not approve: continue
        rule_row = pd.to_numeric(r.get("RuleRow", ""), errors="coerce")
        if pd.isna(rule_row): continue
        idx = int(rule_row) - 1
        if idx < 0 or idx >= len(out): continue
        if str(r.get("DisableRule", "")).strip().upper() in {"YES","Y","TRUE","1"}:
            out.loc[out.index[idx], "PatchDisabled"] = 1
            applied.append({"RuleRow":idx+1,"PatchApplied":"DISABLE_RULE"})
        elif _v176_to_member(r.get("NewWinnerMember", "")) in V176_MEMBERS:
            out.loc[out.index[idx], winner_col] = _v176_to_member(r.get("NewWinnerMember"))
            out.loc[out.index[idx], "PatchUpdatedWinnerMember"] = 1
            applied.append({"RuleRow":idx+1,"PatchApplied":"CHANGE_WINNER_MEMBER","NewWinnerMember":_v176_to_member(r.get("NewWinnerMember"))})
    patched = out[out.get("PatchDisabled",0).astype(str)!="1"].copy() if "PatchDisabled" in out.columns else out
    return patched, pd.DataFrame(applied) if applied else pd.DataFrame([{"PatchStatus":"NO_APPROVED_PATCH_ROWS", "Applied":0}])


def _v176_notes(truth_meta, truth_dist, truth_checks, sep_checks, sep_summary, sep_audit, proposed):
    lines=[]
    lines.append("CORE025 SUPPORT AUDIT LAB — v176")
    lines.append("Mode: AUDIT + PATCH PROPOSAL ONLY. No production files were replaced automatically.")
    lines.append("")
    lines.append("AUDIT TRUST STATUS")
    for label, df in [("Truth checks", truth_checks), ("Separator parse checks", sep_checks)]:
        if isinstance(df,pd.DataFrame) and not df.empty:
            bad = df[df["Status"].isin(["FAIL"])]
            lines.append(f"- {label}: {'PASS' if bad.empty else 'FAIL'}")
            for _,r in df.iterrows(): lines.append(f"  - {r.get('Check')}: {r.get('Status')} ({r.get('Detail','')})")
    lines.append("")
    if isinstance(truth_meta,pd.DataFrame) and not truth_meta.empty:
        lines.append("TRUTH / HISTORY EVIDENCE")
        for k,v in truth_meta.iloc[0].to_dict().items(): lines.append(f"- {k}: {v}")
    if isinstance(truth_dist,pd.DataFrame) and not truth_dist.empty:
        lines.append(""); lines.append("MEMBER DISTRIBUTION CHECK")
        for _,r in truth_dist.iterrows(): lines.append(f"- {r['Member']}: old={r['OldTruthCount']} current={r['CurrentHistoryCoreHitCount']} delta={r['DeltaCount']}")
    if isinstance(sep_summary,pd.DataFrame) and not sep_summary.empty:
        lines.append(""); lines.append("SEPARATOR RULE STATUS SUMMARY")
        for _,r in sep_summary.iterrows(): lines.append(f"- {r['Status']}: {r['RuleCount']} rules")
    if isinstance(proposed,pd.DataFrame):
        lines.append(""); lines.append(f"PROPOSED REVIEW/PATCH ITEMS: {len(proposed)}")
    if isinstance(sep_audit,pd.DataFrame) and not sep_audit.empty:
        focus = sep_audit[sep_audit["Status"].isin(["FLIPPED_REVIEW","WEAKENED_REVIEW","PARSE_OR_SCHEMA_REVIEW","INSUFFICIENT_CURRENT_SUPPORT"])].head(50)
        lines.append(""); lines.append("TOP REVIEW ITEMS")
        if focus.empty: lines.append("- None.")
        for _,r in focus.iterrows():
            lines.append(f"- Rule {r.get('RuleRow')} [{r.get('Status')}]: {r.get('TraitStack')} | old={r.get('OldWinnerMember')}@{r.get('OldWinnerRate')} | current best={r.get('CurrentBestMember')}@{r.get('CurrentBestRate')} | action={r.get('RecommendedAction')}")
    return "\n".join(lines)


def _v176_render_support_audit_lab(hist_default=None, truth_file_obj=None, lib_file_obj=None):
    st.divider()
    st.subheader("v176 Support Audit Lab — trusted audit + patch manager")
    st.caption("Audit/revise only. Production Truth/Separator are not replaced. Approved changes are exported as a separate patch overlay.")
    st.info("Run this when you want evidence for support-file changes. Daily seed changes alone do not require this audit.")
    c1,c2,c3 = st.columns(3)
    with c1:
        hist_up = st.file_uploader("Audit history override optional", type=["csv","txt","tsv","xlsx","xls"], key="v176_hist_upload")
    with c2:
        truth_up = st.file_uploader("Truth override optional", type=["csv","txt","tsv","xlsx","xls"], key="v176_truth_upload")
    with c3:
        sep_up = st.file_uploader("Separator override optional", type=["csv","txt","tsv","xlsx","xls"], key="v176_sep_upload")
    patch_up = st.file_uploader("Optional approved patch overlay CSV/TXT", type=["csv","txt","tsv","xlsx","xls"], key="v176_patch_upload")
    with st.expander("Audit thresholds", expanded=False):
        min_support = st.number_input("Minimum current support to consider revising a rule", min_value=1, value=5, step=1, key="v176_min_support")
        weaken_delta = st.slider("Weakened threshold: old-member rate drop", 0.01, 0.30, 0.08, 0.01, key="v176_weaken_delta")
        flip_margin = st.slider("Flip threshold: new best beats old member by", 0.01, 0.30, 0.05, 0.01, key="v176_flip_margin")
    if st.button("Run Trusted Support Audit — no replacement", type="primary", use_container_width=True, key="v176_run_audit"):
        hist_raw = _v176_load_any(hist_up) if hist_up is not None else (hist_default.copy() if isinstance(hist_default,pd.DataFrame) else pd.DataFrame())
        old_truth = _v176_load_any(truth_up) if truth_up is not None else (_v171_upload_to_df(truth_file_obj, ensure_truth) if truth_file_obj is not None else pd.DataFrame())
        old_sep = _v176_load_any(sep_up) if sep_up is not None else (_v171_upload_to_df(lib_file_obj, ensure_library) if lib_file_obj is not None else pd.DataFrame())
        hist = hist_raw if {"Date","StreamKey","Result"}.issubset(set(hist_raw.columns)) else _v176_prepare_history(hist_raw)
        transitions = _v176_build_transitions(hist)
        truth_dist, truth_meta, truth_checks, truth_detect = _v176_truth_audit(old_truth, transitions)
        sep_audit, sep_summary, sep_checks, sep_meta = _v176_audit_separator(old_sep, transitions, int(min_support), float(weaken_delta), float(flip_margin))
        proposed = _v176_make_proposed_changes(sep_audit)
        patch_template = _v176_patch_template(proposed)
        notes = _v176_notes(truth_meta, truth_dist, truth_checks, sep_checks, sep_summary, sep_audit, proposed)
        st.session_state["v176_truth_dist"] = truth_dist; st.session_state["v176_truth_meta"] = truth_meta
        st.session_state["v176_truth_checks"] = truth_checks; st.session_state["v176_truth_detect"] = truth_detect
        st.session_state["v176_sep_audit"] = sep_audit; st.session_state["v176_sep_summary"] = sep_summary
        st.session_state["v176_sep_checks"] = sep_checks; st.session_state["v176_proposed"] = proposed
        st.session_state["v176_patch_template"] = patch_template; st.session_state["v176_notes"] = notes
        st.session_state["v176_loaded_separator_for_patch"] = old_sep
        st.success("Trusted support audit complete. No files were replaced or activated.")
    truth_checks=st.session_state.get("v176_truth_checks"); sep_checks=st.session_state.get("v176_sep_checks")
    truth_meta=st.session_state.get("v176_truth_meta"); truth_dist=st.session_state.get("v176_truth_dist"); truth_detect=st.session_state.get("v176_truth_detect")
    sep_summary=st.session_state.get("v176_sep_summary"); sep_audit=st.session_state.get("v176_sep_audit"); proposed=st.session_state.get("v176_proposed"); patch_template=st.session_state.get("v176_patch_template"); notes=st.session_state.get("v176_notes")
    if isinstance(truth_checks,pd.DataFrame) or isinstance(sep_checks,pd.DataFrame):
        st.subheader("Audit Trust Gate")
        checks = pd.concat([df for df in [truth_checks, sep_checks] if isinstance(df,pd.DataFrame)], ignore_index=True)
        fail = checks[checks["Status"].eq("FAIL")] if not checks.empty else pd.DataFrame()
        if fail.empty:
            st.success("AUDIT TRUSTWORTHY: header normalization, truth counts, and separator parse checks passed.")
        else:
            st.error("AUDIT NOT TRUSTWORTHY YET: fix failed checks before using proposed changes.")
        st.dataframe(checks, use_container_width=True, hide_index=True)
    if isinstance(truth_meta,pd.DataFrame) and not truth_meta.empty:
        st.subheader("Truth / History Audit Meta")
        st.dataframe(truth_meta, use_container_width=True, hide_index=True)
    if isinstance(truth_dist,pd.DataFrame) and not truth_dist.empty:
        st.subheader("Member Distribution Audit")
        st.dataframe(truth_dist, use_container_width=True, hide_index=True)
    if isinstance(truth_detect,pd.DataFrame) and not truth_detect.empty:
        with st.expander("Truth member-column normalization details", expanded=False):
            st.dataframe(truth_detect, use_container_width=True, hide_index=True)
    if isinstance(sep_summary,pd.DataFrame) and not sep_summary.empty:
        st.subheader("Separator Status Summary")
        st.dataframe(sep_summary, use_container_width=True, hide_index=True)
    if isinstance(sep_audit,pd.DataFrame) and not sep_audit.empty:
        st.subheader("Separator Rule Audit Detail")
        view_cols=[c for c in ["Status","RuleID","RuleRow","TraitStack","OldWinnerMember","CurrentBestMember","OldSupport","CurrentSupport","OldWinnerRate","CurrentBestRate","CurrentOldMemberRate","DeltaOldMemberRate","RecommendedAction","EvalNote"] if c in sep_audit.columns]
        st.dataframe(sep_audit[view_cols], use_container_width=True, hide_index=True, height=650)
        st.download_button("Download Full Separator Audit CSV", _v176_csv_bytes(sep_audit), "core025_v176_separator_rule_audit.csv", "text/csv", use_container_width=True, key="v176_sep_audit_csv")
    if isinstance(proposed,pd.DataFrame) and not proposed.empty:
        st.subheader("Proposed Review / Patch Items")
        st.dataframe(proposed.head(500), use_container_width=True, hide_index=True, height=500)
        st.download_button("Download Proposed Changes CSV", _v176_csv_bytes(proposed), "core025_v176_proposed_changes.csv", "text/csv", use_container_width=True, key="v176_proposed_csv")
        st.download_button("Download Proposed Changes TXT", _v176_txt_bytes(proposed.to_string(index=False)), "core025_v176_proposed_changes.txt", "text/plain", use_container_width=True, key="v176_proposed_txt")
    if isinstance(patch_template,pd.DataFrame):
        st.subheader("Approved Patch Overlay Template")
        st.caption("Edit Approve=YES only for rules you explicitly accept. Upload this overlay later; the base separator file stays unchanged.")
        st.download_button("Download Approved Patch Template CSV", _v176_csv_bytes(patch_template), "core025_v176_approved_separator_patch_TEMPLATE.csv", "text/csv", use_container_width=True, key="v176_patch_template_csv")
        st.download_button("Download Approved Patch Template TXT", _v176_txt_bytes(patch_template.to_csv(index=False, sep="\t")), "core025_v176_approved_separator_patch_TEMPLATE.txt", "text/plain", use_container_width=True, key="v176_patch_template_txt")
    if patch_up is not None:
        patch_df = _v176_load_any(patch_up)
        sep_base = st.session_state.get("v176_loaded_separator_for_patch", pd.DataFrame())
        patched, patch_log = _v176_apply_patch_preview(sep_base, patch_df)
        st.subheader("Patch Overlay Preview")
        st.dataframe(patch_log, use_container_width=True, hide_index=True)
        st.download_button("Download Patched Separator Preview CSV", _v176_csv_bytes(patched), "core025_v176_PATCHED_SEPARATOR_PREVIEW.csv", "text/csv", use_container_width=True, key="v176_patched_sep_preview")
    if isinstance(notes,str) and notes:
        st.download_button("Download Human-Readable Audit Notes TXT", _v176_txt_bytes(notes), "core025_v176_support_audit_notes.txt", "text/plain", use_container_width=True, key="v176_notes_txt")


# ============================================================
# v177 SUPPORT AUDIT CONTRIBUTION + RULE LIFECYCLE
# ============================================================
# Additive only. Uses v176 trusted audit as a base, then adds a separator-only
# leave-one-rule-out contribution audit and rule lifecycle buckets. It does not
# alter daily engine weights, ZLT, B2, RTE, SCL, or printable playlist logic.

V177_BUILD_MARKER = "BUILD: core025_northern_lights__2026-06-06_v177_SUPPORT_AUDIT_CONTRIBUTION_LIFECYCLE"


def _v177_sep_rule_cols(sep):
    trait_col = _v176_pick_col(sep, ["trait_stack", "TraitStack", "trait", "RuleTrait"], ["trait"])
    winner_col = _v176_pick_col(sep, ["winner_member", "WinnerMember", "winning_member", "member"], ["winner", "member"])
    rate_col = _v176_pick_col(sep, ["winner_rate", "WinnerRate", "rate"], ["winner", "rate"])
    support_col = _v176_pick_col(sep, ["support", "Support"], ["support"])
    pair_col = _v176_pick_col(sep, ["pair", "Pair"], ["pair"])
    return trait_col, winner_col, rate_col, support_col, pair_col


def _v177_fire_rule_on_row(row, conds):
    try:
        for col, val in conds:
            if col not in row.index:
                return False
            cur = row.get(col)
            if pd.isna(cur):
                cur_s = ""
            elif isinstance(cur, float) and float(cur).is_integer():
                cur_s = str(int(cur))
            else:
                cur_s = str(cur)
            if cur_s.strip() != str(val).strip():
                return False
        return True
    except Exception:
        return False


def _v177_score_row_from_rules(row, rules_meta, skip_rule_index=None, weight_mode="rate"):
    boosts = {m: 0.0 for m in V176_MEMBERS}
    fired = []
    for j, rm in enumerate(rules_meta):
        if skip_rule_index is not None and j == skip_rule_index:
            continue
        if _v177_fire_rule_on_row(row, rm["conds"]):
            # v180: older contribution scoring expected rm["winner"],
            # but current metadata stores OldWinnerMember. Use a normalized fallback
            # so the audit cannot crash with KeyError('winner').
            m = _v176_to_member(rm.get("winner", rm.get("OldWinnerMember", rm.get("winner_member", ""))))
            if m in boosts:
                w = rm.get("rate", 1.0)
                try:
                    w = float(w)
                except Exception:
                    w = 1.0
                if not pd.notna(w) or w <= 0:
                    w = 1.0
                boosts[m] += w
                fired.append(j)
    ordered = sorted(boosts.items(), key=lambda x: (x[1], x[0]), reverse=True)
    pred = ordered[0][0] if ordered else ""
    margin = (ordered[0][1] - ordered[1][1]) if len(ordered) > 1 else 0.0
    total = sum(boosts.values())
    if total <= 0:
        pred = "NO_RULE_SCORE"
    return pred, boosts, margin, fired


def _v177_separator_contribution_audit(old_sep, transitions, max_rules=1000):
    """
    Separator-only leave-one-rule-out contribution test.
    For each Core025 historical hit event:
      - score with all separator rules
      - score again with each fired rule removed
      - helped: all-rules correct, without-this-rule wrong
      - harmed: all-rules wrong, without-this-rule correct
    This measures contribution inside the separator scoring stack rather than rate alone.
    """
    if old_sep is None or not isinstance(old_sep, pd.DataFrame) or old_sep.empty:
        return pd.DataFrame(), pd.DataFrame()
    if transitions is None or not isinstance(transitions, pd.DataFrame) or transitions.empty:
        return pd.DataFrame(), pd.DataFrame()
    sep = old_sep.copy(); sep.columns = [str(c).strip() for c in sep.columns]
    trait_col, winner_col, rate_col, support_col, pair_col = _v177_sep_rule_cols(sep)
    if trait_col is None or winner_col is None:
        return pd.DataFrame(), pd.DataFrame()
    core = transitions[transitions.get("is_core025_hit", 0).astype(str).isin(["1", "True", "true"])].copy()
    if core.empty:
        core = transitions[transitions.get("next_member", "").isin(V176_MEMBERS)].copy()
    rules_meta=[]
    for idx, r in sep.head(int(max_rules)).iterrows():
        trait = str(r.get(trait_col, ""))
        conds = _v176_parse_conditions(trait)
        winner = _v176_to_member(r.get(winner_col, ""))
        if not conds or winner not in V176_MEMBERS:
            continue
        rate = pd.to_numeric(r.get(rate_col, 1.0) if rate_col else 1.0, errors="coerce")
        support = pd.to_numeric(r.get(support_col, "") if support_col else "", errors="coerce")
        rules_meta.append({
            "orig_index": idx,
            "RuleID": str(r.get("RuleID", r.get("rule_id", f"SEP_ROW_{idx+1}"))),
            "RuleRow": int(idx)+1,
            "TraitStack": trait,
            "OldWinnerMember": winner,
            "winner": winner,  # v180 compatibility alias for older scoring helper; prevents KeyError('winner')
            "OldWinnerRate": float(rate) if pd.notna(rate) else "",
            "OldSupport": int(support) if pd.notna(support) else "",
            "Pair": r.get(pair_col, "") if pair_col else "",
            "conds": conds,
        })
    rows = []
    detail_rows = []
    stats = {j: {"RuleID": rm["RuleID"], "RuleRow": rm["RuleRow"], "Pair": rm["Pair"], "TraitStack": rm["TraitStack"], "OldWinnerMember": rm["OldWinnerMember"], "OldWinnerRate": rm["OldWinnerRate"], "OldSupport": rm["OldSupport"], "FiredEvents":0, "DirectCorrect":0, "DirectWrong":0, "LOO_Helped":0, "LOO_Harmed":0, "LOO_Neutral":0, "LOO_NoScore":0} for j,rm in enumerate(rules_meta)}
    for ev_i, row in core.iterrows():
        true = _v176_to_member(row.get("next_member", ""))
        if true not in V176_MEMBERS:
            continue
        full_pred, full_boosts, full_margin, fired = _v177_score_row_from_rules(row, rules_meta)
        full_correct = int(full_pred == true)
        for j in fired:
            rm = rules_meta[j]
            stj = stats[j]
            stj["FiredEvents"] += 1
            if rm["OldWinnerMember"] == true:
                stj["DirectCorrect"] += 1
            else:
                stj["DirectWrong"] += 1
            without_pred, without_boosts, without_margin, _ = _v177_score_row_from_rules(row, rules_meta, skip_rule_index=j)
            without_correct = int(without_pred == true)
            if full_correct == 1 and without_correct == 0:
                stj["LOO_Helped"] += 1
                effect = "HELPED"
            elif full_correct == 0 and without_correct == 1:
                stj["LOO_Harmed"] += 1
                effect = "HARMED"
            elif without_pred == "NO_RULE_SCORE":
                stj["LOO_NoScore"] += 1
                effect = "NO_SCORE_WITHOUT_RULE"
            else:
                stj["LOO_Neutral"] += 1
                effect = "NEUTRAL"
            # keep only compact details for non-neutral cases to avoid giant outputs
            if effect in {"HELPED", "HARMED"}:
                detail_rows.append({
                    "RuleID": rm["RuleID"], "RuleRow": rm["RuleRow"], "Effect": effect,
                    "EventDate": row.get("event_date", ""), "StreamKey": row.get("StreamKey", ""),
                    "Seed": row.get("seed", ""), "TrueMember": true,
                    "AllRulesPrediction": full_pred, "WithoutRulePrediction": without_pred,
                    "AllRulesMargin": round(full_margin, 4), "WithoutRuleMargin": round(without_margin, 4),
                })
    for j, d in stats.items():
        fired = int(d["FiredEvents"])
        direct_acc = (d["DirectCorrect"] / fired) if fired else 0.0
        net = int(d["LOO_Helped"]) - int(d["LOO_Harmed"])
        harm = int(d["LOO_Harmed"])
        helped = int(d["LOO_Helped"])
        if fired == 0:
            lifecycle = "INACTIVE_NO_CURRENT_FIRE"
            weight_tier = "NO_CURRENT_EVIDENCE"
        elif harm > helped and harm >= 2:
            lifecycle = "MANUAL_REVIEW_HARMFUL"
            weight_tier = "HARM_REVIEW"
        elif net > 0:
            lifecycle = "KEEP_CONTRIBUTES"
            weight_tier = "CONTRIBUTING"
        elif direct_acc >= 0.70 and fired >= 10:
            lifecycle = "ACTIVE_STRONG"
            weight_tier = "FULL_WEIGHT_70_PLUS"
        elif direct_acc >= 0.60 and fired >= 10:
            lifecycle = "ACTIVE_MODERATE"
            weight_tier = "HALF_WEIGHT_60_69"
        elif direct_acc >= 0.55 and fired >= 10:
            lifecycle = "WEAK_MONITOR"
            weight_tier = "QUARTER_WEIGHT_55_59"
        elif fired >= 15:
            lifecycle = "INACTIVE_CANDIDATE_PRESERVE"
            weight_tier = "INACTIVE_BELOW_55"
        else:
            lifecycle = "LOW_SUPPORT_MONITOR"
            weight_tier = "LOW_SUPPORT"
        d.update({
            "DirectAccuracy": round(direct_acc, 4),
            "LOO_NetContribution": net,
            "LifecycleRecommendation": lifecycle,
            "WeightTierSuggestion": weight_tier,
            "PreserveForever": "YES",
            "DeleteRule": "NO",
        })
        rows.append(d)
    contrib = pd.DataFrame(rows)
    if not contrib.empty:
        contrib = contrib.sort_values(["LOO_NetContribution", "DirectAccuracy", "FiredEvents"], ascending=[False, False, False]).reset_index(drop=True)
    details = pd.DataFrame(detail_rows)
    return contrib, details


def _v177_make_proposed_changes(sep_audit, contrib=None):
    base = _v176_make_proposed_changes(sep_audit)
    if base is None or not isinstance(base, pd.DataFrame):
        base = pd.DataFrame()
    if contrib is None or not isinstance(contrib, pd.DataFrame) or contrib.empty:
        return base
    # Add contribution/lifecycle proposed items that may not appear in v176 rate-only review.
    c = contrib.copy()
    review_life = ["MANUAL_REVIEW_HARMFUL", "INACTIVE_CANDIDATE_PRESERVE", "WEAK_MONITOR", "ACTIVE_MODERATE", "KEEP_CONTRIBUTES"]
    c = c[c["LifecycleRecommendation"].isin(review_life)].copy()
    if c.empty:
        return base
    out = pd.DataFrame()
    out["Approve"] = "NO"
    out["RuleID"] = c["RuleID"]
    out["RuleRow"] = c["RuleRow"]
    out["TraitStack"] = c["TraitStack"]
    out["CurrentAction"] = c["LifecycleRecommendation"]
    def action_for(life):
        if life == "MANUAL_REVIEW_HARMFUL": return "DISABLE_TO_INACTIVE_LIBRARY"
        if life == "INACTIVE_CANDIDATE_PRESERVE": return "MOVE_TO_INACTIVE_LIBRARY"
        if life == "WEAK_MONITOR": return "WEAKEN_WEIGHT_MONITOR"
        if life == "ACTIVE_MODERATE": return "REDUCE_WEIGHT_KEEP_ACTIVE"
        return "KEEP_ACTIVE_CONTRIBUTES"
    out["ProposedAction"] = c["LifecycleRecommendation"].map(action_for)
    out["OldWinnerMember"] = c["OldWinnerMember"]
    out["ProposedWinnerMember"] = c["OldWinnerMember"]
    out["EvidenceSummary"] = c.apply(lambda r: f"fires={r.get('FiredEvents')} direct_acc={r.get('DirectAccuracy')} helped={r.get('LOO_Helped')} harmed={r.get('LOO_Harmed')} net={r.get('LOO_NetContribution')} tier={r.get('WeightTierSuggestion')}", axis=1)
    out["Reason"] = "Contribution/lifecycle audit; preserve forever, do not delete."
    if base.empty:
        return out
    merged = pd.concat([base, out], ignore_index=True)
    merged = merged.drop_duplicates(subset=["RuleRow", "ProposedAction"], keep="first")
    return merged


def _v177_notes(v176_notes, contrib=None):
    lines = []
    lines.append("CORE025 SUPPORT AUDIT CONTRIBUTION ADDENDUM — v177")
    lines.append("Mode: AUDIT + LIFECYCLE ONLY. No rules were deleted or auto-replaced.")
    lines.append("Contribution method: separator-only leave-one-rule-out test on Core025 historical hit transitions.")
    lines.append("")
    if isinstance(contrib, pd.DataFrame) and not contrib.empty:
        lines.append("CONTRIBUTION / LIFECYCLE SUMMARY")
        summ = contrib.groupby("LifecycleRecommendation").size().rename("RuleCount").reset_index().sort_values("RuleCount", ascending=False)
        for _, r in summ.iterrows():
            lines.append(f"- {r['LifecycleRecommendation']}: {int(r['RuleCount'])} rules")
        lines.append("")
        lines.append("TOP POSITIVE CONTRIBUTORS")
        for _, r in contrib.sort_values(["LOO_NetContribution", "LOO_Helped"], ascending=[False, False]).head(20).iterrows():
            lines.append(f"- {r.get('RuleID')} row {r.get('RuleRow')}: net={r.get('LOO_NetContribution')} helped={r.get('LOO_Helped')} harmed={r.get('LOO_Harmed')} fires={r.get('FiredEvents')} acc={r.get('DirectAccuracy')} | {r.get('TraitStack')}")
        lines.append("")
        lines.append("TOP HARM REVIEW")
        harm = contrib[contrib["LOO_Harmed"] > contrib["LOO_Helped"]].sort_values(["LOO_Harmed", "LOO_NetContribution"], ascending=[False, True]).head(20)
        if harm.empty:
            lines.append("- None found by leave-one-rule-out contribution test.")
        else:
            for _, r in harm.iterrows():
                lines.append(f"- {r.get('RuleID')} row {r.get('RuleRow')}: net={r.get('LOO_NetContribution')} helped={r.get('LOO_Helped')} harmed={r.get('LOO_Harmed')} fires={r.get('FiredEvents')} acc={r.get('DirectAccuracy')} | {r.get('TraitStack')}")
        lines.append("")
        lines.append("RULE PRESERVATION POLICY")
        lines.append("- No separator rule should be deleted by audit.")
        lines.append("- Weak/dead rules move to inactive/weak libraries and remain eligible for future reactivation audits.")
        lines.append("- Approved patch overlays should change only manually approved rows.")
    else:
        lines.append("No contribution audit table was generated.")
    lines.append("\n---\n")
    if isinstance(v176_notes, str) and v176_notes:
        lines.append(v176_notes)
    return "\n".join(lines)


def _v177_patch_template(proposed=None):
    base = _v176_patch_template(proposed)
    if base is None or not isinstance(base, pd.DataFrame):
        base = pd.DataFrame()
    for col in ["LifecycleAction", "WeightTier", "MoveToInactiveLibrary", "PreserveForever", "ReauditFuture"]:
        if col not in base.columns:
            base[col] = ""
    if "PreserveForever" in base.columns:
        base["PreserveForever"] = "YES"
    if "ReauditFuture" in base.columns:
        base["ReauditFuture"] = "YES"
    return base


def _v177_apply_patch_preview(sep, patch):
    patched, log = _v176_apply_patch_preview(sep, patch)
    if patch is None or not isinstance(patch, pd.DataFrame) or patch.empty or sep is None or not isinstance(sep, pd.DataFrame):
        return patched, log, pd.DataFrame()
    p = patch.copy(); p.columns = [str(c).strip() for c in p.columns]
    inactive_rows=[]
    for _, r in p.iterrows():
        approve = str(r.get("Approve", "")).strip().upper() in {"YES","Y","TRUE","1"}
        if not approve:
            continue
        move_inactive = str(r.get("MoveToInactiveLibrary", r.get("DisableRule", ""))).strip().upper() in {"YES","Y","TRUE","1"}
        if not move_inactive:
            continue
        rule_row = pd.to_numeric(r.get("RuleRow", ""), errors="coerce")
        if pd.isna(rule_row):
            continue
        idx = int(rule_row) - 1
        if idx < 0 or idx >= len(sep):
            continue
        d = sep.iloc[idx].to_dict()
        d.update({
            "InactiveReason": r.get("Reason", "approved inactive move"),
            "InactiveDate": r.get("ApprovedDate", ""),
            "PreserveForever": "YES",
            "ReauditFuture": "YES",
            "OriginalRuleRow": idx+1,
        })
        inactive_rows.append(d)
    return patched, log, pd.DataFrame(inactive_rows)


def _v177_render_support_audit_lab(hist_default=None, truth_file_obj=None, lib_file_obj=None):
    st.divider()
    st.subheader("v177 Support Audit Lab — contribution + lifecycle manager")
    st.caption("Audit/revise only. Production Truth/Separator are not replaced. Rules are preserved forever; weak rules can move to inactive libraries and be re-audited later.")
    st.info("This adds contribution auditing: helped / harmed / net impact by leave-one-rule-out. Daily engine, weights, ZLT, B2, RTE, SCL, and printable logic are unchanged.")
    c1,c2,c3 = st.columns(3)
    with c1:
        hist_up = st.file_uploader("Audit history override optional", type=["csv","txt","tsv","xlsx","xls"], key="v177_hist_upload")
    with c2:
        truth_up = st.file_uploader("Truth override optional", type=["csv","txt","tsv","xlsx","xls"], key="v177_truth_upload")
    with c3:
        sep_up = st.file_uploader("Separator override optional", type=["csv","txt","tsv","xlsx","xls"], key="v177_sep_upload")
    patch_up = st.file_uploader("Optional approved patch overlay CSV/TXT", type=["csv","txt","tsv","xlsx","xls"], key="v177_patch_upload")
    inactive_up = st.file_uploader("Optional inactive rule library for future reactivation audits", type=["csv","txt","tsv","xlsx","xls"], key="v177_inactive_upload")
    with st.expander("Audit thresholds", expanded=True):
        min_support = st.number_input("Minimum current support to consider revising a rule", min_value=1, value=5, step=1, key="v177_min_support")
        weaken_delta = st.slider("Weakened threshold: old-member rate drop", 0.01, 0.30, 0.08, 0.01, key="v177_weaken_delta")
        flip_margin = st.slider("Flip threshold: new best beats old member by", 0.01, 0.30, 0.05, 0.01, key="v177_flip_margin")
        st.caption("Lifecycle defaults: ≥70% strong, 60–69% moderate vote, 55–59% weak monitor, <55% inactive candidate when support is sufficient. Contribution overrides raw rate when a rule demonstrably helps.")
    if st.button("Run Contribution Support Audit — no replacement", type="primary", use_container_width=True, key="v177_run_audit"):
        hist_raw = _v176_load_any(hist_up) if hist_up is not None else (hist_default.copy() if isinstance(hist_default,pd.DataFrame) else pd.DataFrame())
        old_truth = _v176_load_any(truth_up) if truth_up is not None else (_v171_upload_to_df(truth_file_obj, ensure_truth) if truth_file_obj is not None else pd.DataFrame())
        old_sep = _v176_load_any(sep_up) if sep_up is not None else (_v171_upload_to_df(lib_file_obj, ensure_library) if lib_file_obj is not None else pd.DataFrame())
        hist = hist_raw if {"Date","StreamKey","Result"}.issubset(set(hist_raw.columns)) else _v176_prepare_history(hist_raw)
        transitions = _v176_build_transitions(hist)
        truth_dist, truth_meta, truth_checks, truth_detect = _v176_truth_audit(old_truth, transitions)
        sep_audit, sep_summary, sep_checks, sep_meta = _v176_audit_separator(old_sep, transitions, int(min_support), float(weaken_delta), float(flip_margin))
        contrib, contrib_details = _v177_separator_contribution_audit(old_sep, transitions)
        proposed = _v177_make_proposed_changes(sep_audit, contrib)
        patch_template = _v177_patch_template(proposed)
        v176_note = _v176_notes(truth_meta, truth_dist, truth_checks, sep_checks, sep_summary, sep_audit, proposed)
        notes = _v177_notes(v176_note, contrib)
        st.session_state["v177_truth_dist"] = truth_dist; st.session_state["v177_truth_meta"] = truth_meta
        st.session_state["v177_truth_checks"] = truth_checks; st.session_state["v177_truth_detect"] = truth_detect
        st.session_state["v177_sep_audit"] = sep_audit; st.session_state["v177_sep_summary"] = sep_summary
        st.session_state["v177_sep_checks"] = sep_checks; st.session_state["v177_proposed"] = proposed
        st.session_state["v177_patch_template"] = patch_template; st.session_state["v177_notes"] = notes
        st.session_state["v177_contrib"] = contrib; st.session_state["v177_contrib_details"] = contrib_details
        st.session_state["v177_loaded_separator_for_patch"] = old_sep
        st.success("Contribution support audit complete. No files were replaced or activated.")
    truth_checks=st.session_state.get("v177_truth_checks"); sep_checks=st.session_state.get("v177_sep_checks")
    truth_meta=st.session_state.get("v177_truth_meta"); truth_dist=st.session_state.get("v177_truth_dist"); truth_detect=st.session_state.get("v177_truth_detect")
    sep_summary=st.session_state.get("v177_sep_summary"); sep_audit=st.session_state.get("v177_sep_audit"); proposed=st.session_state.get("v177_proposed"); patch_template=st.session_state.get("v177_patch_template"); notes=st.session_state.get("v177_notes")
    contrib=st.session_state.get("v177_contrib"); contrib_details=st.session_state.get("v177_contrib_details")
    if isinstance(truth_checks,pd.DataFrame) or isinstance(sep_checks,pd.DataFrame):
        st.subheader("Audit Trust Gate")
        checks = pd.concat([df for df in [truth_checks, sep_checks] if isinstance(df,pd.DataFrame)], ignore_index=True)
        fail = checks[checks["Status"].eq("FAIL")] if not checks.empty else pd.DataFrame()
        if fail.empty:
            st.success("AUDIT TRUSTWORTHY: header normalization, truth counts, and separator parse checks passed.")
        else:
            st.error("AUDIT NOT TRUSTWORTHY YET: fix failed checks before using proposed changes.")
        st.dataframe(checks, use_container_width=True, hide_index=True)
    if isinstance(truth_meta,pd.DataFrame) and not truth_meta.empty:
        st.subheader("Truth / History Audit Meta")
        st.dataframe(truth_meta, use_container_width=True, hide_index=True)
    if isinstance(truth_dist,pd.DataFrame) and not truth_dist.empty:
        st.subheader("Member Distribution Audit")
        st.dataframe(truth_dist, use_container_width=True, hide_index=True)
    if isinstance(sep_summary,pd.DataFrame) and not sep_summary.empty:
        st.subheader("Separator Rate/Status Summary")
        st.dataframe(sep_summary, use_container_width=True, hide_index=True)
    if isinstance(contrib,pd.DataFrame) and not contrib.empty:
        st.subheader("Separator Contribution Audit — leave-one-rule-out")
        lifecycle = contrib.groupby("LifecycleRecommendation").size().rename("RuleCount").reset_index().sort_values("RuleCount", ascending=False)
        st.dataframe(lifecycle, use_container_width=True, hide_index=True)
        view_cols=[c for c in ["LifecycleRecommendation","WeightTierSuggestion","RuleID","RuleRow","TraitStack","OldWinnerMember","FiredEvents","DirectAccuracy","LOO_Helped","LOO_Harmed","LOO_NetContribution","PreserveForever","DeleteRule"] if c in contrib.columns]
        st.dataframe(contrib[view_cols], use_container_width=True, hide_index=True, height=650)
        st.download_button("Download Contribution Audit CSV", _v176_csv_bytes(contrib), "core025_v177_separator_contribution_audit.csv", "text/csv", use_container_width=True, key="v177_contrib_csv")
        if isinstance(contrib_details,pd.DataFrame) and not contrib_details.empty:
            st.download_button("Download Contribution Event Details CSV", _v176_csv_bytes(contrib_details), "core025_v177_contribution_event_details.csv", "text/csv", use_container_width=True, key="v177_contrib_details_csv")
    if isinstance(sep_audit,pd.DataFrame) and not sep_audit.empty:
        st.subheader("Separator Rule Rate Audit Detail")
        view_cols=[c for c in ["Status","RuleID","RuleRow","TraitStack","OldWinnerMember","CurrentBestMember","OldSupport","CurrentSupport","OldWinnerRate","CurrentBestRate","CurrentOldMemberRate","DeltaOldMemberRate","RecommendedAction","EvalNote"] if c in sep_audit.columns]
        st.dataframe(sep_audit[view_cols], use_container_width=True, hide_index=True, height=500)
        st.download_button("Download Full Separator Rate Audit CSV", _v176_csv_bytes(sep_audit), "core025_v177_separator_rule_rate_audit.csv", "text/csv", use_container_width=True, key="v177_sep_rate_audit_csv")
    if isinstance(proposed,pd.DataFrame) and not proposed.empty:
        st.subheader("Proposed Review / Patch / Lifecycle Items")
        st.dataframe(proposed.head(750), use_container_width=True, hide_index=True, height=500)
        st.download_button("Download Proposed Changes CSV", _v176_csv_bytes(proposed), "core025_v177_proposed_changes.csv", "text/csv", use_container_width=True, key="v177_proposed_csv")
        st.download_button("Download Proposed Changes TXT", _v176_txt_bytes(proposed.to_string(index=False)), "core025_v177_proposed_changes.txt", "text/plain", use_container_width=True, key="v177_proposed_txt")
    if isinstance(patch_template,pd.DataFrame):
        st.subheader("Approved Patch / Lifecycle Overlay Template")
        st.caption("Edit Approve=YES only for rules you explicitly accept. Base separator stays unchanged. Inactive rules are preserved and re-audited later.")
        st.download_button("Download Approved Patch Template CSV", _v176_csv_bytes(patch_template), "core025_v177_approved_separator_patch_TEMPLATE.csv", "text/csv", use_container_width=True, key="v177_patch_template_csv")
        st.download_button("Download Approved Patch Template TXT", _v176_txt_bytes(patch_template.to_csv(index=False, sep="\t")), "core025_v177_approved_separator_patch_TEMPLATE.txt", "text/plain", use_container_width=True, key="v177_patch_template_txt")
    if patch_up is not None:
        patch_df = _v176_load_any(patch_up)
        sep_base = st.session_state.get("v177_loaded_separator_for_patch", pd.DataFrame())
        patched, patch_log, inactive_library = _v177_apply_patch_preview(sep_base, patch_df)
        st.subheader("Patch Overlay Preview")
        st.dataframe(patch_log, use_container_width=True, hide_index=True)
        st.download_button("Download Patched Separator Preview CSV", _v176_csv_bytes(patched), "core025_v177_PATCHED_SEPARATOR_PREVIEW.csv", "text/csv", use_container_width=True, key="v177_patched_sep_preview")
        st.download_button("Download Inactive Rule Library CSV", _v176_csv_bytes(inactive_library), "core025_v177_inactive_separator_library.csv", "text/csv", use_container_width=True, key="v177_inactive_library_csv")
    if inactive_up is not None:
        inactive_df = _v176_load_any(inactive_up)
        st.subheader("Inactive Rule Library Loaded")
        st.caption("These rules are preserved and should be included in future reactivation audits. v177 does not delete them.")
        st.dataframe(inactive_df.head(300), use_container_width=True, hide_index=True)
    if isinstance(notes,str) and notes:
        st.download_button("Download Human-Readable Audit Notes TXT", _v176_txt_bytes(notes), "core025_v177_support_audit_notes.txt", "text/plain", use_container_width=True, key="v177_notes_txt")


# ============================================================
# v179 CALIBRATED SUPPORT AUDIT — PAIRWISE + ROLLING SUPPORT
# ============================================================
# Additive override only. Does NOT change daily engine, weights, ZLT, B2, RTE, SCL,
# printable logic, or production support files. It recalibrates the audit so it does
# not treat ~20 new wins as proof that hundreds of rules died.
# Key fixes:
# - audit each separator in the same pairwise universe style used by the deep separator builder
# - compare Old Truth universe, Full Current universe, and Equal-Size Rolling Current universe
# - use New-Wins/extra-history as warning context only, not a lifecycle killer
# - only proposes lifecycle movement; never deletes rules; inactive rules remain re-auditable

V179_BUILD_MARKER = "BUILD: core025_northern_lights__2026-06-09_v187_WF_EXPORT_FIRST_SAFE_DISPLAY"


def _v181_norm_member(x):
    try:
        return _v176_to_member(x)
    except Exception:
        try:
            return normalize_member(x)
        except Exception:
            return ""


def _v181_prepare_truth_like_events(df: pd.DataFrame) -> pd.DataFrame:
    """Normalize old Truth/current transitions into the same event-like schema for rule evaluation."""
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return pd.DataFrame()
    out = df.copy()
    out.columns = [str(c).strip() for c in out.columns]

    # Current transition tables already have next_member and seed features.
    if "next_member" not in out.columns:
        member_col = _v176_pick_col(out, [
            "next_member", "NextMember", "WinningMember", "TrueMember", "WinnerMember",
            "winner_member", "Core025Member", "ActualMember", "CapturedMember", "Member"
        ], ["member", "winner", "true"])
        if member_col:
            out["next_member"] = out[member_col].map(_v181_norm_member)
        else:
            out["next_member"] = ""
    else:
        out["next_member"] = out["next_member"].map(_v181_norm_member)

    if "is_core025_hit" not in out.columns:
        out["is_core025_hit"] = out["next_member"].isin(V176_MEMBERS).astype(int)

    # Normalize date for sorting/window comparison.
    if "event_date" not in out.columns:
        date_col = _v176_pick_col(out, ["event_date", "EventDate", "Date", "date", "DrawDate", "draw_date"], ["date"])
        if date_col:
            out["event_date"] = pd.to_datetime(out[date_col], errors="coerce")
        else:
            out["event_date"] = pd.NaT
    else:
        out["event_date"] = pd.to_datetime(out["event_date"], errors="coerce")

    # Normalize seed, then add missing features used by separator trait stacks.
    if "seed" not in out.columns:
        seed_col = _v176_pick_col(out, ["seed", "Seed", "PrevSeed", "PreviousResult", "PrevResult", "LastResult", "feat_seed"], ["seed", "prev"])
        out["seed"] = out[seed_col] if seed_col else ""
    if "seed" in out.columns:
        try:
            out = _v174_add_deep_compat_features(out, "seed") if "_v174_add_deep_compat_features" in globals() else enrich_seed_features(out, "seed")
        except Exception:
            try:
                out = enrich_seed_features(out, "seed")
            except Exception:
                pass

    return out[out["next_member"].isin(V176_MEMBERS)].copy().reset_index(drop=True)


def _v181_pair_members(pair_text, fallback_member=""):
    """Return the exact two members named by a separator pair.

    v181 fix: the previous regex could read 0225/0255 as partial 025 tokens,
    which allowed impossible third-member flips such as a 0225_vs_0255 rule
    proposing 0025. This parser only accepts exact Core025 member tokens and
    common short aliases, then preserves pair order.
    """
    s = str(pair_text or "").strip()
    found = []

    # Prefer explicit 4-digit members. Negative lookarounds prevent partial matches.
    for tok in re.findall(r"(?<!\d)(0025|0225|0255)(?!\d)", s):
        m = _v181_norm_member(tok)
        if m in V176_MEMBERS and m not in found:
            found.append(m)

    # Fallback for compact/legacy pair forms like 25_vs_225 or 225>255.
    if len(found) < 2:
        alias_map = {"25": "0025", "225": "0225", "255": "0255"}
        for tok in re.findall(r"(?<!\d)(25|225|255)(?!\d)", s):
            m = alias_map.get(tok, "")
            if m in V176_MEMBERS and m not in found:
                found.append(m)

    if len(found) >= 2:
        return found[:2]

    fb = _v181_norm_member(fallback_member)
    if fb in V176_MEMBERS:
        # Ambiguous pair: return old winner + the other two, but mark later as ambiguous.
        # The evaluator will still never choose outside this returned set.
        return [fb] + [m for m in V176_MEMBERS if m != fb]
    return V176_MEMBERS[:]


def _v181_eval_rule(dataset: pd.DataFrame, trait: str, old_member: str, pair_members=None, min_support=1) -> dict:
    """Evaluate one separator rule strictly inside its pair universe.

    v181 fix: best_member/rates are calculated only over pair_members, never all
    three Core025 members. This blocks invalid third-member flips.
    """
    eval_members = [m for m in (pair_members or V176_MEMBERS) if m in V176_MEMBERS]
    if not eval_members:
        eval_members = V176_MEMBERS[:]
    if dataset is None or not isinstance(dataset, pd.DataFrame) or dataset.empty:
        return {"support":0, "best_member":"", "best_rate":0.0, "old_rate":0.0, "counts":{m:0 for m in V176_MEMBERS}, "missing":"empty_dataset", "eval_members":"|".join(eval_members)}
    work = dataset.copy()
    work = work[work["next_member"].isin(eval_members)].copy()
    conds = _v176_parse_conditions(str(trait))
    mask, missing = _v176_condition_mask(work, conds)
    sub = work[mask].copy()
    support = int(len(sub))
    counts_all = sub["next_member"].value_counts().reindex(V176_MEMBERS).fillna(0).astype(int).to_dict()
    counts_pair = {m: int(counts_all.get(m, 0)) for m in eval_members}
    invalid_third_count = int(sum(counts_all.get(m, 0) for m in V176_MEMBERS if m not in eval_members))
    if support:
        rates = {m: counts_pair.get(m, 0)/support for m in eval_members}
        best = max(rates, key=rates.get)
        best_rate = float(rates.get(best, 0.0))
        old_rate = float(rates.get(old_member, 0.0)) if old_member in eval_members else 0.0
    else:
        best=""; best_rate=0.0; old_rate=0.0
    return {"support":support, "best_member":best, "best_rate":best_rate, "old_rate":old_rate, "counts":counts_all, "pair_counts":counts_pair, "missing":missing, "eval_members":"|".join(eval_members), "invalid_third_count":invalid_third_count}


def _v181_make_rolling_universe(current_events: pd.DataFrame, old_n: int) -> pd.DataFrame:
    if current_events is None or not isinstance(current_events, pd.DataFrame) or current_events.empty:
        return pd.DataFrame()
    cur = current_events.copy()
    if "event_date" in cur.columns and pd.to_datetime(cur["event_date"], errors="coerce").notna().any():
        cur = cur.assign(_sort_date=pd.to_datetime(cur["event_date"], errors="coerce")).sort_values(["_sort_date"] + (["stream"] if "stream" in cur.columns else [])).drop(columns=["_sort_date"], errors="ignore")
    if old_n and old_n > 0 and len(cur) > old_n:
        return cur.tail(int(old_n)).copy().reset_index(drop=True)
    return cur.copy().reset_index(drop=True)


def _v181_audit_separator_calibrated(old_sep, old_truth, transitions, min_support=5, weaken_delta=0.08, flip_margin=0.05):
    """Pairwise calibrated separator audit.

    The old v176 audit recalculated current rate on all three members together, which can overstate drift.
    This version mirrors the original deep separator builder's pairwise comparison style.
    """
    if old_sep is None or not isinstance(old_sep, pd.DataFrame) or old_sep.empty or transitions is None or transitions.empty:
        return pd.DataFrame(), pd.DataFrame(), pd.DataFrame(), {}
    sep = old_sep.copy(); sep.columns = [str(c).strip() for c in sep.columns]
    parse_checks, meta = _v176_validate_separator(sep)
    trait_col = meta.get("trait_col") or "trait_stack"
    winner_col = meta.get("winner_col") or "winner_member"
    pair_col = meta.get("pair_col") or "pair"
    rate_col = _v176_pick_col(sep, ["winner_rate", "WinnerRate", "rate"], ["winner", "rate"])
    support_col = _v176_pick_col(sep, ["support", "Support"], ["support"])
    if trait_col not in sep.columns:
        return pd.DataFrame([{"Status":"PARSE_OR_SCHEMA_REVIEW", "EvalNote":"missing trait_stack"}]), pd.DataFrame(), parse_checks, meta
    if winner_col not in sep.columns:
        sep[winner_col] = ""
    if pair_col not in sep.columns:
        sep[pair_col] = ""

    old_events = _v181_prepare_truth_like_events(old_truth)
    current_events = _v181_prepare_truth_like_events(transitions)
    old_n = int(len(old_events)) if isinstance(old_events, pd.DataFrame) else 0
    rolling_events = _v181_make_rolling_universe(current_events, old_n)
    new_extra_n = max(0, int(len(current_events)) - old_n)
    new_tail_events = current_events.tail(new_extra_n).copy() if new_extra_n > 0 else pd.DataFrame()

    rows=[]
    for idx, r in sep.iterrows():
        trait = str(r.get(trait_col, ""))
        old_member = _v181_norm_member(r.get(winner_col, ""))
        pair_members = _v181_pair_members(r.get(pair_col, ""), old_member)
        file_support = pd.to_numeric(r.get(support_col, "") if support_col else "", errors="coerce")
        file_rate = pd.to_numeric(r.get(rate_col, "") if rate_col else "", errors="coerce")

        old_eval = _v181_eval_rule(old_events, trait, old_member, pair_members, min_support)
        full_eval = _v181_eval_rule(current_events, trait, old_member, pair_members, min_support)
        roll_eval = _v181_eval_rule(rolling_events, trait, old_member, pair_members, min_support)
        new_eval = _v181_eval_rule(new_tail_events, trait, old_member, pair_members, min_support) if not new_tail_events.empty else {"support":0,"best_member":"","best_rate":0.0,"old_rate":0.0,"counts":{m:0 for m in V176_MEMBERS},"missing":"no_incremental_window"}

        # Use recalculated old rate when available. Fall back to file rate if old truth cannot reproduce it.
        old_rate_ref = old_eval["old_rate"] if old_eval["support"] >= int(min_support) else (float(file_rate) if pd.notna(file_rate) else 0.0)
        old_support_ref = old_eval["support"] if old_eval["support"] else (int(file_support) if pd.notna(file_support) else 0)
        full_old_rate = full_eval["old_rate"]
        roll_old_rate = roll_eval["old_rate"]
        full_best = full_eval["best_member"]
        full_best_rate = full_eval["best_rate"]
        roll_best = roll_eval["best_member"]
        roll_best_rate = roll_eval["best_rate"]
        pairwise_valid = (full_best in pair_members or full_best == "") and (roll_best in pair_members or roll_best == "")
        pairwise_error = "" if pairwise_valid else f"PAIRWISE_ERROR_best_outside_pair full={full_best} rolling={roll_best} pair={pair_members}"

        delta_full = old_rate_ref - full_old_rate
        delta_roll = old_rate_ref - roll_old_rate
        missing = "; ".join([x for x in [old_eval.get("missing",""), full_eval.get("missing",""), roll_eval.get("missing",""), pairwise_error] if x])

        # Calibrated lifecycle status: full + rolling must agree before demotion.
        if pairwise_error:
            status="PAIRWISE_AUDIT_ERROR_BLOCKED"; action="Blocked: audit attempted a member outside the rule pair; do not patch."
        elif missing and "missing_col" in missing:
            status="PARSE_OR_SCHEMA_REVIEW"; action="Do not change; parser could not verify rule."
        elif full_eval["support"] < int(min_support) and roll_eval["support"] < int(min_support):
            status="INSUFFICIENT_CURRENT_SUPPORT"; action="Preserve and re-audit later; do not deactivate from low support alone."
        elif old_member and full_best and roll_best and full_best != old_member and roll_best != old_member and full_best_rate >= 0.60 and roll_best_rate >= 0.60 and (full_best_rate - full_old_rate) >= float(flip_margin):
            status="FLIPPED_REVIEW_CONFIRMED"; action="Manual review only; candidate patch after production-context test."
        elif full_old_rate >= 0.70 or roll_old_rate >= 0.70:
            status="STILL_HOLDS_STRONG"; action="Keep active; old member remains strong in full or rolling universe."
        elif full_old_rate >= 0.60 or roll_old_rate >= 0.60:
            status="STILL_HOLDS_MODERATE"; action="Keep active as a moderate vote; do not treat as a decision-maker."
        elif (full_old_rate < 0.55 and roll_old_rate < 0.55 and full_eval["support"] >= 15 and roll_eval["support"] >= 15):
            status="WEAK_BOTH_WINDOWS_REVIEW"; action="Candidate for weight reduction/inactive only after contribution test confirms no value."
        elif delta_full >= float(weaken_delta) or delta_roll >= float(weaken_delta):
            status="WEAKENED_MONITOR"; action="Monitor; not enough evidence for retirement."
        elif old_member and (full_best == old_member or roll_best == old_member):
            status="STILL_HOLDS"; action="Keep unchanged."
        else:
            status="REVIEW"; action="Manual review if high impact; otherwise preserve."

        rows.append({
            "RuleID": str(r.get("RuleID", r.get("rule_id", f"SEP_ROW_{idx+1}"))),
            "RuleRow":idx+1,
            "Pair":r.get(pair_col,""),
            "PairMembers":" vs ".join(pair_members),
            "TraitStack":trait,
            "OldWinnerMember":old_member,
            "FileOldSupport":int(file_support) if pd.notna(file_support) else "",
            "FileOldWinnerRate":float(file_rate) if pd.notna(file_rate) else "",
            "OldRecalcSupport":old_eval["support"],
            "OldRecalcOldMemberRate":round(old_eval["old_rate"],4),
            "FullCurrentSupport":full_eval["support"],
            "FullCurrentBestMember":full_best,
            "FullCurrentBestRate":round(full_best_rate,4),
            "FullCurrentOldMemberRate":round(full_old_rate,4),
            "RollingSupport":roll_eval["support"],
            "RollingBestMember":roll_best,
            "RollingBestRate":round(roll_best_rate,4),
            "RollingOldMemberRate":round(roll_old_rate,4),
            "NewExtraSupport":new_eval.get("support",0),
            "NewExtraBestMember":new_eval.get("best_member",""),
            "NewExtraBestRate":round(float(new_eval.get("best_rate",0.0)),4),
            "NewExtraOldMemberRate":round(float(new_eval.get("old_rate",0.0)),4),
            "DeltaFullOldMemberRate":round(delta_full,4),
            "DeltaRollingOldMemberRate":round(delta_roll,4),
            "CountFull_0025":full_eval["counts"].get("0025",0),
            "CountFull_0225":full_eval["counts"].get("0225",0),
            "CountFull_0255":full_eval["counts"].get("0255",0),
            "Status":status,
            "RecommendedAction":action,
            "EvalNote":missing,
        })
    audit=pd.DataFrame(rows)
    summary=audit.groupby("Status").size().rename("RuleCount").reset_index().sort_values("RuleCount",ascending=False) if not audit.empty else pd.DataFrame()
    meta.update({"old_truth_events":old_n, "current_core_events":int(len(current_events)), "rolling_events":int(len(rolling_events)), "new_extra_events":int(new_extra_n), "audit_method":"v181_pairwise_full_plus_rolling"})
    extra_checks = pd.DataFrame([
        {"Check":"Audit calibration method", "Status":"PASS", "Detail":"Pairwise support + old/full/rolling comparison"},
        {"Check":"Old Truth event count", "Status":"PASS" if old_n>0 else "FAIL", "Detail":str(old_n)},
        {"Check":"Current Core025 hit count", "Status":"PASS" if len(current_events)>0 else "FAIL", "Detail":str(len(current_events))},
        {"Check":"New extra Core025 hits vs old truth", "Status":"INFO", "Detail":str(new_extra_n)},
        {"Check":"Lifecycle safety", "Status":"PASS", "Detail":"New-extra-only results are warning context; rules are not retired from incremental window alone."},
        {"Check":"Pairwise third-member flip block", "Status":"PASS", "Detail":"v181: best_member is restricted to the two members named in PairMembers; invalid third-member flips are blocked."},
    ])
    parse_checks = pd.concat([parse_checks, extra_checks], ignore_index=True)
    return audit, summary, parse_checks, meta


def _v181_separator_contribution_audit(old_sep, old_truth, transitions, sep_audit=None, max_rules=1000):
    """Conservative contribution audit.

    Keeps leave-one-rule-out as context, but lifecycle uses pairwise calibrated rate audit too.
    This prevents overlapping rules from being mass-retired simply because removing one rule
    rarely changes the final separator-only prediction.
    """
    contrib, details = _v177_separator_contribution_audit(old_sep, transitions, max_rules=max_rules)
    if contrib is None or not isinstance(contrib, pd.DataFrame) or contrib.empty:
        return contrib, details
    if isinstance(sep_audit, pd.DataFrame) and not sep_audit.empty:
        merge_cols = [c for c in ["RuleID","RuleRow","Status","FullCurrentOldMemberRate","RollingOldMemberRate","FullCurrentSupport","RollingSupport","PairMembers"] if c in sep_audit.columns]
        if "RuleRow" in merge_cols:
            contrib = contrib.merge(sep_audit[merge_cols].drop_duplicates("RuleRow"), on="RuleRow", how="left", suffixes=("", "_RateAudit"))
    # Reclassify with calibrated rates + contribution. Keep 60/40 as a vote, 70+ as strong.
    recs=[]; tiers=[]
    for _, r in contrib.iterrows():
        net = pd.to_numeric(r.get("LOO_NetContribution",0), errors="coerce")
        helped = pd.to_numeric(r.get("LOO_Helped",0), errors="coerce")
        harmed = pd.to_numeric(r.get("LOO_Harmed",0), errors="coerce")
        fires = pd.to_numeric(r.get("FiredEvents",0), errors="coerce")
        full_rate = pd.to_numeric(r.get("FullCurrentOldMemberRate", np.nan), errors="coerce")
        roll_rate = pd.to_numeric(r.get("RollingOldMemberRate", np.nan), errors="coerce")
        best_rate = max([x for x in [full_rate, roll_rate] if pd.notna(x)] or [pd.to_numeric(r.get("DirectAccuracy",0), errors="coerce")])
        status = str(r.get("Status", ""))
        if status == "FLIPPED_REVIEW_CONFIRMED":
            life="MANUAL_REVIEW_FLIP_CONFIRMED"; tier="REVIEW_ONLY_NO_AUTO_CHANGE"
        elif pd.notna(net) and net > 0:
            life="KEEP_CONTRIBUTES"; tier="CONTRIBUTING_KEEP_ACTIVE"
        elif pd.notna(best_rate) and best_rate >= 0.70 and fires >= 10:
            life="ACTIVE_STRONG"; tier="FULL_WEIGHT_70_PLUS"
        elif pd.notna(best_rate) and best_rate >= 0.60 and fires >= 10:
            life="ACTIVE_MODERATE"; tier="MODERATE_VOTE_60_69"
        elif pd.notna(best_rate) and best_rate >= 0.55 and fires >= 10:
            life="WEAK_MONITOR"; tier="WEAK_VOTE_55_59"
        elif (pd.notna(net) and net < 0 and pd.notna(harmed) and harmed >= 2 and pd.notna(best_rate) and best_rate < 0.55):
            life="INACTIVE_CANDIDATE_AFTER_REVIEW"; tier="PRESERVE_INACTIVE_REAUDIT"
        elif fires >= 15 and pd.notna(best_rate) and best_rate < 0.55:
            life="WEAK_BOTH_WINDOWS_MONITOR"; tier="POSSIBLE_INACTIVE_NEEDS_REVIEW"
        else:
            life="LOW_SUPPORT_OR_NEUTRAL_MONITOR"; tier="PRESERVE_MONITOR"
        recs.append(life); tiers.append(tier)
    contrib["LifecycleRecommendation_v179"] = recs
    contrib["WeightTierSuggestion_v179"] = tiers
    # Keep old columns but make visible recommendation the calibrated one.
    contrib["LifecycleRecommendation"] = contrib["LifecycleRecommendation_v179"]
    contrib["WeightTierSuggestion"] = contrib["WeightTierSuggestion_v179"]
    return contrib, details


def _v181_make_proposed_changes(sep_audit, contrib=None):
    if sep_audit is None or not isinstance(sep_audit, pd.DataFrame) or sep_audit.empty:
        base = pd.DataFrame()
    else:
        review_statuses = ["FLIPPED_REVIEW_CONFIRMED", "WEAK_BOTH_WINDOWS_REVIEW", "PARSE_OR_SCHEMA_REVIEW", "INSUFFICIENT_CURRENT_SUPPORT", "REVIEW"]
        review = sep_audit[sep_audit["Status"].isin(review_statuses)].copy()
        base = pd.DataFrame()
        if not review.empty:
            base["Approve"] = "NO"
            base["RuleID"] = review.get("RuleID", "")
            base["RuleRow"] = review["RuleRow"]
            base["TraitStack"] = review["TraitStack"]
            base["CurrentAction"] = review["Status"]
            def _pa(s):
                if s == "FLIPPED_REVIEW_CONFIRMED": return "CHANGE_WINNER_MEMBER_REVIEW_ONLY"
                if s == "WEAK_BOTH_WINDOWS_REVIEW": return "WEAKEN_OR_INACTIVE_REVIEW_ONLY"
                return "NO_CHANGE_REVIEW"
            base["ProposedAction"] = review["Status"].map(_pa)
            base["OldWinnerMember"] = review["OldWinnerMember"]
            base["ProposedWinnerMember"] = review.get("FullCurrentBestMember", "")
            base["EvidenceSummary"] = review.apply(lambda r: f"pair={r.get('PairMembers')} | old_recalc={r.get('OldRecalcOldMemberRate')} support={r.get('OldRecalcSupport')} | full_old_rate={r.get('FullCurrentOldMemberRate')} support={r.get('FullCurrentSupport')} | rolling_old_rate={r.get('RollingOldMemberRate')} support={r.get('RollingSupport')} | new_extra_old_rate={r.get('NewExtraOldMemberRate')} support={r.get('NewExtraSupport')}", axis=1)
            base["Reason"] = review["RecommendedAction"]
    if contrib is None or not isinstance(contrib, pd.DataFrame) or contrib.empty:
        return base
    c = contrib.copy()
    review_life = ["MANUAL_REVIEW_FLIP_CONFIRMED", "INACTIVE_CANDIDATE_AFTER_REVIEW", "WEAK_BOTH_WINDOWS_MONITOR", "KEEP_CONTRIBUTES", "ACTIVE_MODERATE"]
    c = c[c["LifecycleRecommendation"].isin(review_life)].copy()
    out = pd.DataFrame()
    if not c.empty:
        out["Approve"] = "NO"
        out["RuleID"] = c["RuleID"]
        out["RuleRow"] = c["RuleRow"]
        out["TraitStack"] = c["TraitStack"]
        out["CurrentAction"] = c["LifecycleRecommendation"]
        def action_for(life):
            if life == "MANUAL_REVIEW_FLIP_CONFIRMED": return "MANUAL_REVIEW_CHANGE_WINNER"
            if life == "INACTIVE_CANDIDATE_AFTER_REVIEW": return "MOVE_TO_INACTIVE_AFTER_APPROVAL"
            if life == "WEAK_BOTH_WINDOWS_MONITOR": return "MONITOR_OR_REDUCE_WEIGHT"
            if life == "ACTIVE_MODERATE": return "KEEP_ACTIVE_MODERATE_VOTE"
            return "KEEP_ACTIVE_CONTRIBUTES"
        out["ProposedAction"] = c["LifecycleRecommendation"].map(action_for)
        out["OldWinnerMember"] = c["OldWinnerMember"]
        out["ProposedWinnerMember"] = c["OldWinnerMember"]
        out["EvidenceSummary"] = c.apply(lambda r: f"fires={r.get('FiredEvents')} direct_acc={r.get('DirectAccuracy')} full_rate={r.get('FullCurrentOldMemberRate')} rolling_rate={r.get('RollingOldMemberRate')} helped={r.get('LOO_Helped')} harmed={r.get('LOO_Harmed')} net={r.get('LOO_NetContribution')} tier={r.get('WeightTierSuggestion')}", axis=1)
        out["Reason"] = "v179 calibrated pairwise + rolling + contribution audit; preserve forever, do not delete."
    if base.empty:
        return out
    if out.empty:
        return base
    merged = pd.concat([base, out], ignore_index=True)
    return merged.drop_duplicates(subset=["RuleRow", "ProposedAction"], keep="first")


def _v181_notes(truth_meta, truth_dist, truth_checks, sep_checks, sep_summary, sep_audit, proposed, contrib=None):
    lines=[]
    lines.append("CORE025 SUPPORT AUDIT LAB — v179")
    lines.append("Mode: CALIBRATED AUDIT + LIFECYCLE PROPOSAL ONLY. No production files were replaced automatically.")
    lines.append("Calibration: pairwise separator support, old Truth vs full current vs equal-size rolling current. New-extra-only evidence is warning context only.")
    lines.append("")
    if isinstance(truth_checks, pd.DataFrame):
        lines.append("TRUTH CHECKS")
        for _, r in truth_checks.iterrows():
            lines.append(f"- {r.get('Check')}: {r.get('Status')} ({r.get('Detail')})")
        lines.append("")
    if isinstance(sep_checks, pd.DataFrame):
        lines.append("SEPARATOR / AUDIT CALIBRATION CHECKS")
        for _, r in sep_checks.iterrows():
            lines.append(f"- {r.get('Check')}: {r.get('Status')} ({r.get('Detail')})")
        lines.append("")
    if isinstance(truth_meta, pd.DataFrame) and not truth_meta.empty:
        lines.append("TRUTH / HISTORY EVIDENCE")
        for k, v in truth_meta.iloc[0].to_dict().items():
            lines.append(f"- {k}: {v}")
        lines.append("")
    if isinstance(truth_dist, pd.DataFrame) and not truth_dist.empty:
        lines.append("MEMBER DISTRIBUTION CHECK")
        for _, r in truth_dist.iterrows():
            lines.append(f"- {r.get('Member')}: old={r.get('OldTruthCount')} current={r.get('CurrentHistoryCoreHitCount')} delta={r.get('DeltaCount')}")
        lines.append("")
    if isinstance(sep_summary, pd.DataFrame) and not sep_summary.empty:
        lines.append("CALIBRATED SEPARATOR STATUS SUMMARY")
        for _, r in sep_summary.iterrows():
            lines.append(f"- {r.get('Status')}: {int(r.get('RuleCount',0))} rules")
        lines.append("")
    if isinstance(contrib, pd.DataFrame) and not contrib.empty:
        lines.append("CONTRIBUTION / LIFECYCLE SUMMARY")
        summ = contrib.groupby("LifecycleRecommendation").size().rename("RuleCount").reset_index().sort_values("RuleCount", ascending=False)
        for _, r in summ.iterrows():
            lines.append(f"- {r['LifecycleRecommendation']}: {int(r['RuleCount'])} rules")
        lines.append("")
        lines.append("TOP POSITIVE CONTRIBUTORS")
        for _, r in contrib.sort_values(["LOO_NetContribution", "LOO_Helped"], ascending=[False, False]).head(20).iterrows():
            lines.append(f"- {r.get('RuleID')} row {r.get('RuleRow')}: net={r.get('LOO_NetContribution')} helped={r.get('LOO_Helped')} harmed={r.get('LOO_Harmed')} fires={r.get('FiredEvents')} direct_acc={r.get('DirectAccuracy')} full_rate={r.get('FullCurrentOldMemberRate')} rolling_rate={r.get('RollingOldMemberRate')} | {r.get('TraitStack')}")
        lines.append("")
    if isinstance(proposed, pd.DataFrame):
        lines.append(f"PROPOSED REVIEW/PATCH ITEMS: {len(proposed)}")
        lines.append("These are review proposals only. Apply by approved overlay; do not overwrite the production separator.")
    lines.append("")
    lines.append("RULE PRESERVATION POLICY")
    lines.append("- No separator rule is deleted by audit.")
    lines.append("- Weak/dead rules move to inactive/weak libraries only after approved overlay and remain eligible for future reactivation audits.")
    lines.append("- New-extra-only evidence does not deactivate rules.")
    return "\n".join(lines)



# ================================
# v182 AUDIT CLOCK / UPLOAD-ONLY PRODUCTION SUPPORT GOVERNANCE
# ================================
def _v182_date_today():
    try:
        return pd.Timestamp.today().normalize()
    except Exception:
        return pd.Timestamp.now().normalize()

def _v182_parse_audit_status_upload(uploaded):
    """Load optional audit_status CSV/JSON/TXT exported by this app."""
    if uploaded is None:
        return {}
    try:
        raw = _v105_upload_bytes(uploaded)
        name = _v105_upload_name(uploaded, "audit_status.json").lower()
        txt = raw.decode("utf-8", errors="ignore") if isinstance(raw, (bytes, bytearray)) else str(raw)
        if name.endswith(".json"):
            import json
            obj = json.loads(txt)
            return obj if isinstance(obj, dict) else {}
        df = pd.read_csv(io.BytesIO(raw)) if not name.endswith(".txt") else pd.read_csv(io.StringIO(txt), sep=None, engine="python")
        if isinstance(df, pd.DataFrame) and not df.empty:
            row = df.iloc[0].to_dict()
            return {str(k): ("" if pd.isna(v) else v) for k, v in row.items()}
    except Exception:
        return {}
    return {}

def _v182_core025_hit_count(hist_df):
    try:
        if hist_df is None or not isinstance(hist_df, pd.DataFrame) or hist_df.empty:
            return 0
        h = hist_df.copy()
        if "Core025Member" in h.columns:
            return int(h["Core025Member"].astype(str).str.strip().isin(MEMBERS + ["25","225","255"]).sum())
        if "Result" in h.columns:
            return int(h["Result"].apply(result_to_core025_member).astype(str).str.strip().isin(MEMBERS).sum())
    except Exception:
        pass
    return 0

def _v182_status_dict_to_df(status: dict) -> pd.DataFrame:
    if not isinstance(status, dict) or not status:
        return pd.DataFrame()
    return pd.DataFrame([{k: v for k, v in status.items()}])

def _v182_json_bytes(status: dict) -> bytes:
    import json
    return json.dumps(status, indent=2, default=str).encode("utf-8")

def _v182_compute_audit_clock(status: dict, hist_df=None) -> tuple[pd.DataFrame, str]:
    today = _v182_date_today()
    last_raw = status.get("LastAuditDate") or status.get("AuditDate") or status.get("audit_date") or ""
    last_dt = pd.to_datetime(last_raw, errors="coerce") if last_raw else pd.NaT
    audit_hits = pd.to_numeric(pd.Series([status.get("AuditCore025Hits") or status.get("CurrentCore025Hits") or status.get("AuditHitCount") or np.nan]), errors="coerce").iloc[0]
    current_hits = _v182_core025_hit_count(hist_df)
    days = None if pd.isna(last_dt) else int((today - pd.Timestamp(last_dt).normalize()).days)
    new_hits = None if pd.isna(audit_hits) else int(current_hits - int(audit_hits))
    next_due = "" if pd.isna(last_dt) else (pd.Timestamp(last_dt).normalize() + pd.Timedelta(days=90)).date().isoformat()
    if pd.isna(last_dt):
        audit_status = "NO AUDIT STAMP LOADED"
    elif days is not None and days >= 90:
        audit_status = "RED — AUDIT DUE"
    elif new_hits is not None and new_hits >= 25:
        audit_status = "YELLOW — EARLY AUDIT RECOMMENDED BY NEW WINS"
    elif days is not None and days >= 75:
        audit_status = "YELLOW — AUDIT WINDOW APPROACHING"
    else:
        audit_status = "GREEN — AUDIT NOT YET NEEDED"
    rows = [
        {"Metric":"Last Audit Date", "Value": "" if pd.isna(last_dt) else pd.Timestamp(last_dt).date().isoformat()},
        {"Metric":"Next 90-Day Audit Due", "Value": next_due},
        {"Metric":"Days Since Audit", "Value": "" if days is None else days},
        {"Metric":"Core025 Hits At Audit", "Value": "" if pd.isna(audit_hits) else int(audit_hits)},
        {"Metric":"Current Core025 Hits In Loaded History", "Value": current_hits},
        {"Metric":"New Core025 Wins Since Audit", "Value": "" if new_hits is None else new_hits},
        {"Metric":"Audit Trigger", "Value": "90 days OR 25+ new Core025 wins"},
        {"Metric":"Audit Status", "Value": audit_status},
        {"Metric":"Production Support Rule", "Value": "Daily engine uses sidebar-uploaded Truth/Separator only"},
    ]
    return pd.DataFrame(rows), audit_status

def _v182_make_audit_stamp(truth_meta=None, sep_audit=None, contrib=None, hist_df=None, decision="NO_PATCH_FREEZE_PRODUCTION") -> dict:
    today = _v182_date_today().date().isoformat()
    current_hits = _v182_core025_hit_count(hist_df)
    truth_rows = ""
    try:
        if isinstance(truth_meta, pd.DataFrame) and not truth_meta.empty and "Metric" in truth_meta.columns and "Value" in truth_meta.columns:
            m = dict(zip(truth_meta["Metric"].astype(str), truth_meta["Value"]))
            truth_rows = m.get("OldTruthRows", m.get("CurrentCore025Hits", ""))
    except Exception:
        pass
    sep_rules = int(len(sep_audit)) if isinstance(sep_audit, pd.DataFrame) else ""
    contrib_rules = int(len(contrib)) if isinstance(contrib, pd.DataFrame) else ""
    return {
        "AuditSystemVersion": "v182_AUDIT_CLOCK_UPLOAD_ONLY_SUPPORT_FREEZE",
        "LastAuditDate": today,
        "NextAuditDueDate": (pd.Timestamp(today) + pd.Timedelta(days=90)).date().isoformat(),
        "AuditCore025Hits": int(current_hits),
        "TruthRowsAtAudit": truth_rows,
        "SeparatorRulesAudited": sep_rules,
        "ContributionRulesAudited": contrib_rules,
        "ProductionDecision": decision,
        "TruthProductionSource": "sidebar uploaded Truth only",
        "SeparatorProductionSource": "sidebar uploaded Separator only",
        "PatchApplied": "NO",
        "AutoReplaceAllowed": "NO",
        "GeneratedSupportAutoActivation": "NO",
        "Notes": "Production Truth/Separator remain unchanged. Future accepted changes must be downloaded and re-uploaded in the sidebar. Re-audit at 90 days or 25+ new Core025 wins."
    }

def _v182_render_audit_clock_panel(hist_df=None):
    st.subheader("v182 Truth/Separator Audit Clock — upload-only production lock")
    st.caption("Production support is intentionally boring: the daily engine only uses the Truth and Separator files uploaded in the sidebar. Generated files are download/re-upload only.")
    up = st.file_uploader("Optional: upload prior audit_status.json/csv to restore the 90-day audit clock", type=["json","csv","txt"], key="v182_audit_status_upload")
    uploaded_status = _v182_parse_audit_status_upload(up)
    session_status = st.session_state.get("v182_audit_status", {})
    status = uploaded_status or session_status
    clock, audit_status = _v182_compute_audit_clock(status, hist_df)
    if not status:
        st.warning("No audit stamp loaded yet. After tonight's audit/freeze, download audit_status.json and keep it with your production Truth/Separator files.")
    elif str(audit_status).startswith("GREEN"):
        st.success(audit_status)
    elif str(audit_status).startswith("YELLOW"):
        st.warning(audit_status)
    else:
        st.error(audit_status)
    if isinstance(clock, pd.DataFrame) and not clock.empty:
        st.dataframe(clock, use_container_width=True, hide_index=True)
    if status:
        c1, c2 = st.columns(2)
        with c1:
            st.download_button("Download audit_status.json", _v182_json_bytes(status), "core025_audit_status_v182.json", "application/json", use_container_width=True, key="v182_dl_audit_status_json")
        with c2:
            st.download_button("Download audit_status.csv", _v176_csv_bytes(_v182_status_dict_to_df(status)), "core025_audit_status_v182.csv", "text/csv", use_container_width=True, key="v182_dl_audit_status_csv")

def _v181_render_support_audit_lab(hist_default=None, truth_file_obj=None, lib_file_obj=None):
    st.divider()
    st.subheader("v181 Support Audit Lab — pairwise-safe calibrated audit")
    st.caption("Audit/revise only. Production Truth/Separator are not replaced. Rules are preserved forever; weak rules can move to inactive libraries and be re-audited later.")
    st.info("v181 fixes the third-member flip bug and preserves the v179 overreaction protection: it uses original-style pairwise support and compares old Truth, full current, and equal-size rolling current. New-extra-only evidence is context, not a rule killer.")
    c1,c2,c3 = st.columns(3)
    with c1:
        hist_up = st.file_uploader("Audit history override optional", type=["csv","txt","tsv","xlsx","xls"], key="v181_hist_upload")
    with c2:
        truth_up = st.file_uploader("Truth override optional", type=["csv","txt","tsv","xlsx","xls"], key="v181_truth_upload")
    with c3:
        sep_up = st.file_uploader("Separator override optional", type=["csv","txt","tsv","xlsx","xls"], key="v181_sep_upload")
    patch_up = st.file_uploader("Optional approved patch overlay CSV/TXT", type=["csv","txt","tsv","xlsx","xls"], key="v181_patch_upload")
    inactive_up = st.file_uploader("Optional inactive rule library for future reactivation audits", type=["csv","txt","tsv","xlsx","xls"], key="v181_inactive_upload")
    with st.expander("Audit thresholds", expanded=True):
        min_support = st.number_input("Minimum current support to consider revising a rule", min_value=1, value=5, step=1, key="v181_min_support")
        weaken_delta = st.slider("Weakened threshold: old-member rate drop", 0.01, 0.30, 0.08, 0.01, key="v181_weaken_delta")
        flip_margin = st.slider("Confirmed flip threshold: new best beats old member by", 0.01, 0.30, 0.05, 0.01, key="v181_flip_margin")
        st.caption("Lifecycle: 70%+ strong, 60–69% moderate vote, 55–59% weak monitor. Inactive requires both full+rolling weakness and/or confirmed negative contribution; no auto-delete.")
    if st.button("Run Calibrated Support Audit — no replacement", type="primary", use_container_width=True, key="v181_run_audit"):
        hist_raw = _v176_load_any(hist_up) if hist_up is not None else (hist_default.copy() if isinstance(hist_default,pd.DataFrame) else pd.DataFrame())
        old_truth = _v176_load_any(truth_up) if truth_up is not None else (_v171_upload_to_df(truth_file_obj, ensure_truth) if truth_file_obj is not None else pd.DataFrame())
        old_sep = _v176_load_any(sep_up) if sep_up is not None else (_v171_upload_to_df(lib_file_obj, ensure_library) if lib_file_obj is not None else pd.DataFrame())
        hist = hist_raw if {"Date","StreamKey","Result"}.issubset(set(hist_raw.columns)) else _v176_prepare_history(hist_raw)
        transitions = _v176_build_transitions(hist)
        truth_dist, truth_meta, truth_checks, truth_detect = _v176_truth_audit(old_truth, transitions)
        sep_audit, sep_summary, sep_checks, sep_meta = _v181_audit_separator_calibrated(old_sep, old_truth, transitions, int(min_support), float(weaken_delta), float(flip_margin))
        contrib, contrib_details = _v181_separator_contribution_audit(old_sep, old_truth, transitions, sep_audit=sep_audit)
        proposed = _v181_make_proposed_changes(sep_audit, contrib)
        patch_template = _v177_patch_template(proposed)
        notes = _v181_notes(truth_meta, truth_dist, truth_checks, sep_checks, sep_summary, sep_audit, proposed, contrib)
        st.session_state["v181_truth_dist"] = truth_dist; st.session_state["v181_truth_meta"] = truth_meta
        st.session_state["v181_truth_checks"] = truth_checks; st.session_state["v181_truth_detect"] = truth_detect
        st.session_state["v181_sep_audit"] = sep_audit; st.session_state["v181_sep_summary"] = sep_summary
        st.session_state["v181_sep_checks"] = sep_checks; st.session_state["v181_proposed"] = proposed
        st.session_state["v181_patch_template"] = patch_template; st.session_state["v181_notes"] = notes
        st.session_state["v181_contrib"] = contrib; st.session_state["v181_contrib_details"] = contrib_details
        st.session_state["v181_loaded_separator_for_patch"] = old_sep
        st.session_state["v182_audit_status"] = _v182_make_audit_stamp(truth_meta, sep_audit, contrib, hist, decision="NO_PATCH_FREEZE_PRODUCTION")
        st.success("Calibrated support audit complete. No files were replaced or activated.")
    truth_checks=st.session_state.get("v181_truth_checks"); sep_checks=st.session_state.get("v181_sep_checks")
    truth_meta=st.session_state.get("v181_truth_meta"); truth_dist=st.session_state.get("v181_truth_dist"); truth_detect=st.session_state.get("v181_truth_detect")
    sep_summary=st.session_state.get("v181_sep_summary"); sep_audit=st.session_state.get("v181_sep_audit"); proposed=st.session_state.get("v181_proposed"); patch_template=st.session_state.get("v181_patch_template"); notes=st.session_state.get("v181_notes")
    contrib=st.session_state.get("v181_contrib"); contrib_details=st.session_state.get("v181_contrib_details")
    if isinstance(truth_checks,pd.DataFrame) or isinstance(sep_checks,pd.DataFrame):
        st.subheader("Audit Trust + Calibration Gate")
        checks = pd.concat([df for df in [truth_checks, sep_checks] if isinstance(df,pd.DataFrame)], ignore_index=True)
        fail = checks[checks["Status"].eq("FAIL")] if not checks.empty and "Status" in checks.columns else pd.DataFrame()
        if fail.empty:
            st.success("AUDIT TRUSTWORTHY: header normalization, truth counts, separator parse checks, and v179 calibration checks passed.")
        else:
            st.error("AUDIT NOT TRUSTWORTHY YET: fix failed checks before using proposed changes.")
        st.dataframe(checks, use_container_width=True, hide_index=True)
    if isinstance(truth_meta,pd.DataFrame) and not truth_meta.empty:
        st.subheader("Truth / History Audit Meta")
        st.dataframe(truth_meta, use_container_width=True, hide_index=True)
    if isinstance(truth_dist,pd.DataFrame) and not truth_dist.empty:
        st.subheader("Member Distribution Audit")
        st.dataframe(truth_dist, use_container_width=True, hide_index=True)
    if isinstance(truth_detect,pd.DataFrame) and not truth_detect.empty:
        with st.expander("Truth member-column normalization details", expanded=False):
            st.dataframe(truth_detect, use_container_width=True, hide_index=True)
    if isinstance(sep_summary,pd.DataFrame) and not sep_summary.empty:
        st.subheader("Calibrated Separator Status Summary")
        st.dataframe(sep_summary, use_container_width=True, hide_index=True)
    if isinstance(sep_audit,pd.DataFrame) and not sep_audit.empty:
        st.subheader("Calibrated Separator Rule Audit Detail")
        view_cols=[c for c in ["Status","RuleID","RuleRow","PairMembers","TraitStack","OldWinnerMember","OldRecalcSupport","OldRecalcOldMemberRate","FullCurrentSupport","FullCurrentOldMemberRate","RollingSupport","RollingOldMemberRate","NewExtraSupport","NewExtraOldMemberRate","FullCurrentBestMember","RollingBestMember","RecommendedAction","EvalNote"] if c in sep_audit.columns]
        st.dataframe(sep_audit[view_cols], use_container_width=True, hide_index=True, height=650)
        st.download_button("Download Calibrated Separator Rate Audit CSV", _v176_csv_bytes(sep_audit), "core025_v181_calibrated_separator_rule_audit.csv", "text/csv", use_container_width=True, key="v181_sep_rate_audit_csv")
    if isinstance(contrib,pd.DataFrame) and not contrib.empty:
        st.subheader("Separator Contribution Audit — calibrated lifecycle")
        lifecycle = contrib.groupby("LifecycleRecommendation").size().rename("RuleCount").reset_index().sort_values("RuleCount", ascending=False)
        st.dataframe(lifecycle, use_container_width=True, hide_index=True)
        view_cols=[c for c in ["LifecycleRecommendation","WeightTierSuggestion","RuleID","RuleRow","TraitStack","OldWinnerMember","FiredEvents","DirectAccuracy","FullCurrentOldMemberRate","RollingOldMemberRate","LOO_Helped","LOO_Harmed","LOO_NetContribution","PreserveForever","DeleteRule"] if c in contrib.columns]
        st.dataframe(contrib[view_cols], use_container_width=True, hide_index=True, height=650)
        st.download_button("Download Calibrated Contribution Audit CSV", _v176_csv_bytes(contrib), "core025_v181_separator_contribution_audit.csv", "text/csv", use_container_width=True, key="v181_contrib_csv")
        if isinstance(contrib_details,pd.DataFrame) and not contrib_details.empty:
            st.download_button("Download Contribution Event Details CSV", _v176_csv_bytes(contrib_details), "core025_v181_contribution_event_details.csv", "text/csv", use_container_width=True, key="v181_contrib_details_csv")
    if isinstance(proposed,pd.DataFrame) and not proposed.empty:
        st.subheader("Proposed Review / Patch / Lifecycle Items")
        st.dataframe(proposed.head(500), use_container_width=True, hide_index=True, height=500)
        st.download_button("Download Proposed Changes CSV", _v176_csv_bytes(proposed), "core025_v181_proposed_changes.csv", "text/csv", use_container_width=True, key="v181_proposed_csv")
        st.download_button("Download Proposed Changes TXT", _v176_txt_bytes(proposed.to_string(index=False)), "core025_v181_proposed_changes.txt", "text/plain", use_container_width=True, key="v181_proposed_txt")
    if isinstance(patch_template,pd.DataFrame):
        st.subheader("Approved Patch / Lifecycle Overlay Template")
        st.caption("Edit Approve=YES only for rules you explicitly accept. Base separator stays unchanged. Inactive rules are preserved and re-audited later.")
        st.download_button("Download Approved Patch Template CSV", _v176_csv_bytes(patch_template), "core025_v181_approved_separator_patch_TEMPLATE.csv", "text/csv", use_container_width=True, key="v181_patch_template_csv")
        st.download_button("Download Approved Patch Template TXT", _v176_txt_bytes(patch_template.to_csv(index=False, sep="\t")), "core025_v181_approved_separator_patch_TEMPLATE.txt", "text/plain", use_container_width=True, key="v181_patch_template_txt")
    if patch_up is not None:
        patch_df = _v176_load_any(patch_up)
        sep_base = st.session_state.get("v181_loaded_separator_for_patch", pd.DataFrame())
        patched, patch_log, inactive_library = _v177_apply_patch_preview(sep_base, patch_df)
        st.subheader("Patch Overlay Preview")
        st.dataframe(patch_log, use_container_width=True, hide_index=True)
        st.download_button("Download Patched Separator Preview CSV", _v176_csv_bytes(patched), "core025_v181_PATCHED_SEPARATOR_PREVIEW.csv", "text/csv", use_container_width=True, key="v181_patched_sep_preview")
        st.download_button("Download Inactive Rule Library CSV", _v176_csv_bytes(inactive_library), "core025_v181_inactive_separator_library.csv", "text/csv", use_container_width=True, key="v181_inactive_library_csv")
    if inactive_up is not None:
        inactive_df = _v176_load_any(inactive_up)
        st.subheader("Inactive Rule Library Loaded")
        st.caption("These rules are preserved and should be included in future reactivation audits. v181 does not delete them.")
        st.dataframe(inactive_df.head(300), use_container_width=True, hide_index=True)
    if isinstance(notes,str) and notes:
        st.download_button("Download Human-Readable Audit Notes TXT", _v176_txt_bytes(notes), "core025_v181_support_audit_notes.txt", "text/plain", use_container_width=True, key="v181_notes_txt")
    status = st.session_state.get("v182_audit_status", {})
    if isinstance(status, dict) and status:
        st.subheader("v182 Audit Stamp / 90-Day Clock")
        st.dataframe(_v182_status_dict_to_df(status), use_container_width=True, hide_index=True)
        c1, c2 = st.columns(2)
        with c1:
            st.download_button("Download audit_status.json", _v182_json_bytes(status), "core025_audit_status_v182.json", "application/json", use_container_width=True, key="v181_v182_status_json")
        with c2:
            st.download_button("Download audit_status.csv", _v176_csv_bytes(_v182_status_dict_to_df(status)), "core025_audit_status_v182.csv", "text/csv", use_container_width=True, key="v181_v182_status_csv")


with tab_daily:
    v85_promote_canonical_outputs()  # tab_daily
    st.subheader("Daily 025 prediction playlist")
    c1, c2, c3, c4 = st.columns(4)
    c1.metric("History rows", f"{len(hist):,}")
    c2.metric("Streams", hist["StreamKey"].nunique())
    c3.metric("Kept streams", len(kept_streams))
    c4.metric("Total active rules", len(rules))
    st.caption(f"Recommended stream marker: Top-N={recommended_top_n}, Row percentile cutoff={row_pct_cutoff}%. All streams still remain visible.")
    try:
        _v140_render_date_staleness_panel(hist)
    except Exception as _v140_date_e:
        st.warning("v140 Date/Staleness panel unavailable: " + str(_v140_date_e))
    if "v138_last_stream_diag" not in st.session_state:
        st.info("v138 upload guard active: files are loaded, but stream reduction/rules/scoring will not run until you click Run Daily Prediction.")

    _v182_render_audit_clock_panel(hist)
    _v171_render_support_maintenance(hist, truth_file, lib_file, truth_min_rate, truth_min_support)
    try:
        _v181_render_support_audit_lab(hist, truth_file, lib_file)
    except Exception as _v176_audit_e:
        st.warning("v181 Support Audit Lab unavailable: " + str(_v176_audit_e))
        try:
            import traceback as _v180_traceback
            with st.expander("v181 audit error details", expanded=False):
                st.code(_v180_traceback.format_exc())
        except Exception:
            pass

    if st.button("Run Daily Prediction", type="primary", use_container_width=True, key="daily_run"):
        status = st.status("Running daily prediction...", expanded=True)
        prog = st.progress(0, text="Loading support files")
        try:
            uploaded_truth = ensure_truth(load_upload(truth_file)) if truth_file is not None else None
            uploaded_lib = ensure_library(load_upload(lib_file)) if lib_file is not None else None
            truth, truth_source = _v171_get_active_truth(uploaded_truth)
            lib, lib_source = _v171_get_active_library(uploaded_lib)
            st.info(f"Using support files for this run: Truth = {truth_source}; Separator = {lib_source}")
        except Exception as e:
            st.error(f"Could not load truth/library file: {e}")
            st.stop()

        prog.progress(12, text="Building stream reduction diagnostics")
        stream_diag, kept_streams = stream_reduction(hist, window_days, prune_pct)
        stream_diag = assign_stream_tiers(stream_diag)
        stream_diag = add_stream_selection_flags(stream_diag, recommended_top_n, row_pct_cutoff)

        prog.progress(22, text="Building rules")
        rules = pd.DataFrame(columns=["pair", "trait_stack", "winner_member", "winner_rate", "support", "pair_gap", "stack_size"])
        new_truth_rules = pd.DataFrame(columns=rules.columns)
        if lib is not None:
            rules = pd.concat([rules, lib], ignore_index=True)
        if truth is not None:
            truth = enrich_seed_features(truth, "seed")
            # v172 guard: if the active separator is already session-generated from the active truth,
            # do not mine the same truth again in the daily run.  That double-counting was one
            # contributor to member-score collapse.
            if "session-generated Separator" not in str(lib_source):
                new_truth_rules = deep_mine_separators(truth, truth_min_rate, truth_min_support)
                if not new_truth_rules.empty:
                    rules = pd.concat([rules, new_truth_rules], ignore_index=True)

        st.session_state["v138_last_stream_diag"] = stream_diag
        st.session_state["v138_last_kept_streams"] = kept_streams
        st.session_state["v138_last_rules"] = rules

        prog.progress(30, text="Preparing stream rows")
        live_rows = build_live_seed_rows(hist, None)  # v79: keep all streams visible; final play list sorts by SingleRow historical priority
        prog.progress(35, text="Scoring members")
        scored = []
        for _, row in live_rows.iterrows():
            pick = v22_pick(row, rules, trait_weight, min_margin, enable_margin_swap, top2_zone_ratio, top2_zone_margin, top2_risk_threshold) if not rules.empty else {
                "PredictedMember": "0025", "Top2_pred": "0225", "Margin": 0.0, "Top2ToTop1Ratio": 0.0,
                "Top2Zone": 0, "Top2RiskScore": 0, "Top2Decision": "TOP1_SAFE", "Top2RiskReasons": "",
                "DecisionMode": "NO_RULES_FALLBACK", "MarginSwap": 0, "Fired_Rules": "",
                "GATED_TOP3": 0, "score_0025": 0, "score_0225": 0, "score_0255": 0
            }
            scored.append({**row.to_dict(), **pick})
        playlist = pd.DataFrame(scored)
        if not playlist.empty:
            merge_cols = [c for c in [
                "StreamKey", "hit_density", "rank", "StreamRank", "kept", "RowPercentile",
                "SingleRow", "RowBucket10", "StreamTier", "RecommendedByTopN",
                "RecommendedByRowPct", "RecommendedStream"
            ] if c in stream_diag.columns]
            playlist = playlist.merge(stream_diag[merge_cols], on="StreamKey", how="left")
            playlist = add_rare_top3_and_universal_scores(
                playlist, enable_top3_rescue, top3_rescue_min_score,
                w_model, w_row, w_density, w_outlier
            )
            row_model_df = build_row_play_model(
                st.session_state.get("row_single_perf"),
                row_model_min_hits,
                row_top3_rate_threshold,
                row_top2_rate_threshold,
                row_top1_rate_threshold,
                row_low_top2_rate_threshold,
            )
            st.session_state["row_play_model"] = row_model_df
            playlist = apply_row_playtype_model(playlist, row_model_df, enable_row_playtype_model)
            playlist = apply_play_recommendation(playlist, play_policy)
            playlist = playlist.sort_values(["RecommendedStream", "RowPercentile", "UniversalFamilyScore", "hit_density", "Margin"], ascending=[False, True, False, False, False]).reset_index(drop=True)
            playlist["PlaylistRank"] = playlist.index + 1
            playlist["margin_percentile"] = playlist["Margin"].rank(pct=True, method="average").round(4)
            front_cols = [
                "PlaylistRank", "RecommendedStream", "StreamRank", "RowPercentile", "SingleRow", "StreamTier",
                "StreamKey", "State", "Game", "LastResult", "UniversalFamilyScore", "PlayType", "PLAY_FLAG", "ActualBoxPlayDisplay", "ActualBoxPlay", "BoxPlayInstruction", "RecommendedPlay",
                "Top1_Display", "Top2_Display", "Top3_Display", "PredictedMember", "Top2_pred", "ThirdMember",
                "Top3Rescue", "Top3RescueScore", "Top3RescueReasons",
                "RowPlayType", "RowPlayTypeReason", "RowModelHits", "RowTop1Rate", "RowTop2Rate", "RowTop3Rate", "RowLowTop2Threshold",
                "Margin", "Top2ToTop1Ratio",
                "Top2Zone", "Top2RiskScore", "Top2Decision", "Top2RiskReasons", "DecisionMode",
                "score_0025", "score_0225", "score_0255", "ModelConfidenceScore",
                "RowStrengthScore", "FamilyHitDensityScore", "MissOutlierRiskScore", "hit_density", "Fired_Rules"
            ]
            playlist = playlist[[c for c in front_cols if c in playlist.columns] + [c for c in playlist.columns if c not in front_cols]]
        st.session_state["daily_playlist"] = playlist
        st.session_state["v64_ensemble_marked"] = v64_apply_ensemble(st.session_state["daily_playlist"], v64_agreement_threshold)
        st.session_state["v64_final_playlist"] = v64_final_play_list(st.session_state["daily_playlist"], v64_agreement_threshold)
        st.session_state["v64_ensemble_summary"] = v64_ensemble_summary(st.session_state["v64_ensemble_marked"], st.session_state["v64_final_playlist"], v64_agreement_threshold)
