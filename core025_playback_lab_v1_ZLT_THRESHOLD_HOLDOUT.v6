                "Date", "seed", "Result", "TrueMember", "Core025WinnerEvent", "NonCore025Event", "WalkForwardUniverse", "UniversalFamilyScore", "PlayType", "RecommendedPlay",
                "PredictedMember", "Top2_pred", "ThirdMember", "Top3Rescue", "Top3RescueScore",
