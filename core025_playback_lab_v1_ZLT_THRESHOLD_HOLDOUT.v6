# ================================
# v121 DEEP COMBO 75 ENGINE
# Isolated add-on. Does not replace baseline prediction logic.
# Offline proof target from full-history mining:
# 234/312 = 75.00% capture, ~36.70 plays/day.
# ================================
def _v121_member(x):
    try:
        if pd.isna(x):
            return ""
    except Exception:
        pass
    s = str(x)
    for tok in re.findall(r"\d+", s):
        if tok in {"0025","0225","0255"}:
            return tok
        if tok in {"25","225","255"}:
            return {"25":"0025","225":"0225","255":"0255"}[tok]
        z = tok.zfill(4)
        if z in {"0025","0225","0255"}:
            return z
    return ""

def _v121_load_any(uploaded):
    if uploaded is None:
        return pd.DataFrame()
    try:
        name = str(getattr(uploaded, "name", "")).lower()
        if name.endswith((".xlsx",".xls")):
            return pd.read_excel(uploaded)
        sep = "\t" if name.endswith(".tsv") else None
        return pd.read_csv(uploaded, sep=sep, engine="python")
    except Exception:
        try:
            return _v108_load_miner_table(uploaded) if "_v108_load_miner_table" in globals() else pd.DataFrame()
        except Exception:
            return pd.DataFrame()

def _v121_digits(x):
    ds = re.findall(r"\d", str(x))
    return ds[-4:] if len(ds) >= 4 else list(str(x).zfill(4)[-4:])

def _v121_add_features(df):
    out = df.copy()

    # v122 daily-column aliases: align real Daily output with mined-rule field names.
    alias_pairs = {
        "seed": "PrevResult",
        "LastResult": "PrevResult",
        "seed_parity_pattern": "seed_parity",
        "seed_highlow_pattern": "seed_highlow",
        "seed_repeat_shape": "seed_shape",
        "rank": "BlindRollingRank",
        "StreamRank": "BlindRollingRank",
    }
    for src, dst in alias_pairs.items():
        if src in out.columns and dst not in out.columns:
            out[dst] = out[src]
    # Preserve original RowPercentile/SingleRow/StreamRank; aliases only fill missing mined fields.
    # Normalize common members.
    for c in ["TrueMember","PredictedMember","Top2_pred","ThirdMember"]:
        if c not in out.columns:
            out[c] = ""
        out[c] = out[c].fillna("").map(_v121_member)

    # Seed / previous result source.
    seed_col = None
    for c in ["PrevResult","Seed","SeedResult","PreviousResult","Result"]:
        if c in out.columns:
            seed_col = c
            break
    if seed_col is None:
        out["PrevResult"] = "0000"
        seed_col = "PrevResult"

    sd = [_v121_digits(x) for x in out[seed_col]]
    sd_int = []
    for row in sd:
        try:
            sd_int.append([int(x) for x in row])
        except Exception:
            sd_int.append([0,0,0,0])
    seed_sums = [sum(x) for x in sd_int]
    out["seed_sum_exact2"] = [str(x) for x in seed_sums]
    out["seed_sum_parity2"] = ["sum_even" if x % 2 == 0 else "sum_odd" for x in seed_sums]
    out["seed_sum_mod5_2"] = [str(x % 5) for x in seed_sums]
    out["seed_sum_end2"] = [str(x % 10) for x in seed_sums]

    def _struct(row):
        counts = sorted([list(row).count(d) for d in set(row)], reverse=True)
        if counts == [4]: return "quad"
        if counts == [3,1]: return "triple"
        if counts == [2,2]: return "double_double"
        if counts == [2,1,1]: return "single_pair"
        return "all_unique"
    out["seed_structure2"] = [_struct(row) for row in sd]

    for d in ["0","2","5","9"]:
        out[f"seed_inc2_{d}"] = ["1" if d in row else "0" for row in sd]

    # If old feature names don't exist, derive common approximations.
    if "seed_sum_bucket" not in out.columns:
        def _sum_bucket(s):
            try: s = int(s)
            except Exception: s = 0
            if s <= 9: return "sum_0_9"
            if s <= 13: return "sum_10_13"
            if s <= 17: return "sum_14_17"
            if s <= 21: return "sum_18_21"
            return "sum_22_plus"
        out["seed_sum_bucket"] = [_sum_bucket(x) for x in seed_sums]

    if "seed_spread_bucket" not in out.columns:
        def _spread_bucket(row):
            try:
                vals = [int(x) for x in row]
                sp = max(vals)-min(vals)
            except Exception:
                sp = 0
            if sp <= 2: return "spread_0_2"
            if sp <= 4: return "spread_3_4"
            if sp <= 6: return "spread_5_6"
            return "spread_7_plus"
        out["seed_spread_bucket"] = [_spread_bucket(row) for row in sd]

    if "seed_parity" not in out.columns:
        out["seed_parity"] = ["".join("E" if int(x)%2==0 else "O" for x in row) for row in sd]
    if "seed_highlow" not in out.columns:
        out["seed_highlow"] = ["".join("H" if int(x)>=5 else "L" for x in row) for row in sd]
    if "seed_shape" not in out.columns:
        out["seed_shape"] = out["seed_structure2"]
    for d in ["0","2","5","9"]:
        old = f"seed_has{d}"
        if old not in out.columns:
            out[old] = out[f"seed_inc2_{d}"]

    out["top1_member2"] = out["PredictedMember"].replace({"0025":"25","0225":"225","0255":"255"})
    out["top2_member2"] = out["Top2_pred"].replace({"0025":"25","0225":"225","0255":"255"})
    out["top3_member2"] = out["ThirdMember"].replace({"0025":"25","0225":"225","0255":"255"})
    out["top12_pair2"] = out["top1_member2"].astype(str) + "_" + out["top2_member2"].astype(str)
    out["top_order2"] = out["top1_member2"].astype(str) + "_" + out["top2_member2"].astype(str) + "_" + out["top3_member2"].astype(str)
    return out

def _v121_parse_rule(rule):
    return [p.strip() for p in str(rule).split(" AND ") if str(p).strip()]

def _v121_rule_mask(df, rule):
    mask = pd.Series(True, index=df.index)
    for part in _v121_parse_rule(rule):
        if "==" not in part:
            mask &= False
            continue
        col, val = part.split("==", 1)
        col = col.strip(); val = val.strip()
        if col not in df.columns:
            mask &= False
        else:
            mask &= df[col].fillna("NA").astype(str).eq(val)
    return mask

def _v121_initial_depth(df):
    # Prefer integrated prior/final depth; fallback to PlayType.
    for c in ["FinalReducedDepth","ReducedDepth","DeepStackDepth","DeepStackDepthPrior","RecommendedDepth"]:
        if c in df.columns:
            return pd.to_numeric(df[c], errors="coerce").fillna(0).astype(int)
    if "DeepStackAction" in df.columns:
        a = df["DeepStackAction"].astype(str).str.upper()
    elif "PlayType" in df.columns:
        a = df["PlayType"].astype(str).str.upper()
    elif "RowPlayType" in df.columns:
        a = df["RowPlayType"].astype(str).str.upper()
    else:
        a = pd.Series("", index=df.index)
    return pd.Series(
        np.where(a.str.contains("TOP3"), 3, np.where(a.str.contains("TOP2"), 2, np.where(a.str.contains("TOP1|PLAY"), 1, 0))),
        index=df.index
    ).astype(int)

def _v121_apply_reduction_stack(df, reduction_rules):
    out = _v121_add_features(df)
    depth = _v121_initial_depth(out).copy()
    log_rows = []
    if reduction_rules is None or not isinstance(reduction_rules, pd.DataFrame) or reduction_rules.empty:
        out["v121_Depth"] = depth
        out["v121_Action"] = np.where(depth==0, "NO_PLAY", np.where(depth==1, "PLAY_TOP1", np.where(depth==2, "PLAY_TOP2", "PLAY_TOP3")))
        return out, pd.DataFrame()

    for idx, r in reduction_rules.iterrows():
        rule = str(r.get("Rule", ""))
        action = str(r.get("ReductionAction", r.get("Action", "")))
        m = re.search(r"(?:SET_DEPTH_|TOP)(\d)", action)
        if not m:
            continue
        new_depth = int(m.group(1))
        mask = _v121_rule_mask(out, rule) & (depth > new_depth)
        affected = int(mask.sum())
        if affected > 0:
            depth.loc[mask] = new_depth
        log_rows.append({
            "Step": int(r.get("ReductionStep", idx+1)) if str(r.get("ReductionStep", idx+1)).replace(".0","").isdigit() else idx+1,
            "Rule": rule,
            "ReductionAction": f"SET_DEPTH_{new_depth}",
            "RowsAffected": affected,
        })

    out["v121_Depth"] = depth
    out["v121_Action"] = np.where(depth==0, "NO_PLAY", np.where(depth==1, "PLAY_TOP1", np.where(depth==2, "PLAY_TOP2", "PLAY_TOP3")))
    return out, pd.DataFrame(log_rows)

def _v121_apply_action_members(df):
    out = df.copy()
    def _members(row):
        d = int(row.get("v121_Depth", 0))
        vals = []
        if d >= 1: vals.append(row.get("PredictedMember",""))
        if d >= 2: vals.append(row.get("Top2_pred",""))
        if d >= 3: vals.append(row.get("ThirdMember",""))
        vals = [str(x) for x in vals if str(x) not in {"", "nan", "None"}]
        return ",".join(vals)
    out["v121_MembersToPlay"] = out.apply(_members, axis=1)
    out["v121_PlayCount"] = out["v121_Depth"].astype(int)
    return out

def _v121_score_if_truth(df):
    out = df.copy()
    if "TrueMember" not in out.columns or out["TrueMember"].fillna("").astype(str).str.len().sum() == 0:
        return pd.DataFrame()
    true = out["TrueMember"].map(_v121_member)
    d = pd.to_numeric(out.get("v121_Depth", 0), errors="coerce").fillna(0).astype(int)
    top1 = out.get("PredictedMember", "").map(_v121_member) if "PredictedMember" in out.columns else pd.Series("", index=out.index)
    top2 = out.get("Top2_pred", "").map(_v121_member) if "Top2_pred" in out.columns else pd.Series("", index=out.index)
    top3 = out.get("ThirdMember", "").map(_v121_member) if "ThirdMember" in out.columns else pd.Series("", index=out.index)
    is_hit = true.isin(["0025","0225","0255"])
    cap = is_hit & (((d>=1)&top1.eq(true)) | ((d>=2)&top2.eq(true)) | ((d>=3)&top3.eq(true)))
    total_hits = int(is_hit.sum())
    captured = int(cap.sum())
    return pd.DataFrame([{
        "Rows": len(out),
        "TotalHits": total_hits,
        "CapturedHits": captured,
        "MissedHits": total_hits-captured,
        "CaptureRate": captured/total_hits if total_hits else None,
        "TotalPlays": int(d.sum()),
        "AvgPlaysPerDay": int(d.sum())/out["Date"].nunique() if "Date" in out.columns and out["Date"].nunique() else None,
        "Top1Rows": int((d==1).sum()),
        "Top2Rows": int((d==2).sum()),
        "Top3Rows": int((d==3).sum()),
        "NoPlayRows": int((d==0).sum()),
    }])


# ================================
# v120 WALK-FORWARD TRUTH EXPORT FIX
# ================================
def _v120_member(x):
    if "_v111_member" in globals():
        try: return _v111_member(x)
        except Exception: pass
    if pd.isna(x): return None
    for tok in re.findall(r"\d+", str(x)):
        z = tok.zfill(4)
        if z in {"0025","0225","0255"}: return z
        if tok in {"25","225","255"}: return {"25":"0025","225":"0225","255":"0255"}[tok]
    return None

def _v120_result_member(x):
    if pd.isna(x): return None
    digs = re.findall(r"\d", str(x))
    if len(digs) < 4: return _v120_member(x)
    z = "".join(sorted("".join(digs)[-4:]))
    if z in {"0025","0225","0255"}: return z
    return _v120_member(x)

def _v120_ranked(row):
    out=[]
    for grp in [["PredictedMember","Top1","Top1_Display"],["Top2_pred","Top2","Top2_Display"],["ThirdMember","Top3","Top3_Display"]]:
        for c in grp:
            if c in row.index:
                m=_v120_member(row.get(c))
                if m and m not in out:
                    out.append(m); break
    for m in ["0025","0225","0255"]:
        if m not in out: out.append(m)
    return out[:3]

def _v120_played(row):
    for c in ["ActualBoxPlay","RecommendedPlay","ActualBoxPlayDisplay","BoxPlayInstruction","BeforeMembers","AfterMembers"]:
        if c in row.index and pd.notna(row.get(c)):
            found=[]
            for tok in re.findall(r"\d+", str(row.get(c))):
                m=_v120_member(tok)
                if m and m not in found: found.append(m)
            if found: return found
    r=_v120_ranked(row)
    pt=str(row.get("PlayType","")).upper() if "PlayType" in row.index else ""
    if "TOP3" in pt: return r[:3]
    if "TOP2" in pt: return r[:2]
    return r[:1]

def _v120_true(row):
    for c in ["TrueMember","WinningMember","ActualMember"]:
        if c in row.index:
            m=_v120_member(row.get(c))
            if m: return m
    for c in ["Result","WinningResult","ActualResult"]:
        if c in row.index:
            m=_v120_result_member(row.get(c))
            if m: return m
    return None

def _v120_fix_truth(df):
    if df is None or not isinstance(df,pd.DataFrame) or df.empty: return pd.DataFrame()
    out=df.copy()
    true_list=[]; t1_list=[]; t2_list=[]; t3_list=[]; miss_list=[]; cap_list=[]; target_list=[]
    for _,row in out.iterrows():
        true=_v120_true(row)
        ranked=_v120_ranked(row)
        played=_v120_played(row)
        t1=int(bool(true and ranked and true==ranked[0]))
        t2=int(bool(true and len(ranked)>1 and true==ranked[1]))
        t3=int(bool(true and len(ranked)>2 and true==ranked[2]))
        cap=int(bool(true and true in set(played)))
        miss=int(bool(true and not cap))
        if not true: target="UNCLASSIFIED_NO_TRUE_MEMBER"
        elif t1 and len(played)>1: target="WASTE"
        elif t1: target="TOP1_WIN"
        elif t2: target="NEEDED"
        elif t3: target="TOP3_WIN"
        else: target="MISS"
        true_list.append(true or "")
        t1_list.append(t1); t2_list.append(t2); t3_list.append(t3); miss_list.append(miss); cap_list.append(cap); target_list.append(target)
    out["TrueMember"]=true_list
    out["Top1_Correct"]=t1_list
    out["Needed_Top2"]=t2_list
    out["Top3_Win"]=t3_list
    out["Miss"]=miss_list
    out["BeforeCaptured"]=cap_list
    out["v120_TargetOutcome"]=target_list
    out["v111_TargetOutcome"]=target_list
    return out

def _v120_audit(df):
    fixed=_v120_fix_truth(df)
    rows=[{"Metric":"rows","Value":len(fixed)}]
    if fixed.empty: return pd.DataFrame(rows)
    rows += [
        {"Metric":"TrueMember_nonblank","Value":int(fixed["TrueMember"].astype(str).str.len().gt(0).sum())},
        {"Metric":"Top1_Correct_sum","Value":int(pd.to_numeric(fixed["Top1_Correct"],errors="coerce").fillna(0).sum())},
        {"Metric":"Needed_Top2_sum","Value":int(pd.to_numeric(fixed["Needed_Top2"],errors="coerce").fillna(0).sum())},
        {"Metric":"Top3_Win_sum","Value":int(pd.to_numeric(fixed["Top3_Win"],errors="coerce").fillna(0).sum())},
        {"Metric":"Miss_sum","Value":int(pd.to_numeric(fixed["Miss"],errors="coerce").fillna(0).sum())},
    ]
    for k,v in fixed["v120_TargetOutcome"].astype(str).value_counts().items():
        rows.append({"Metric":"target__"+str(k),"Value":int(v)})
    return pd.DataFrame(rows)

def _v120_load_src(uploaded=None):
    if uploaded is not None:
        try:
            df=_v108_load_miner_table(uploaded)
            if isinstance(df,pd.DataFrame) and not df.empty: return "uploaded",df
        except Exception: pass
    for k in ["v113_per_event","v112_per_event","v114_per_event","v117_per_event","v119_per_event"]:
        df=st.session_state.get(k)
        if isinstance(df,pd.DataFrame) and not df.empty: return "session:"+k,df
    return "none",pd.DataFrame()


# ================================
# v119 SCHEMA-AWARE TARGET CLASSIFIER HELPERS
# ================================
def _v119_norm(s):
    return re.sub(r"[^a-z0-9]+","",str(s).lower())

def _v119_find(df, names):
    cmap={_v119_norm(c):c for c in df.columns}
    for n in names:
        k=_v119_norm(n)
        if k in cmap: return cmap[k]
    for n in names:
        k=_v119_norm(n)
        for ck,c in cmap.items():
            if k and (k in ck or ck in k): return c
    return None

def _v119_mem(x):
    if "_v111_member" in globals():
        try: return _v111_member(x)
        except Exception: pass
    if pd.isna(x): return None
    for tok in re.findall(r"\d+",str(x)):
        z=tok.zfill(4)
        if z in {"0025","0225","0255"}: return z
        if tok in {"25","225","255"}: return {"25":"0025","225":"0225","255":"0255"}[tok]
    return None

def _v119_bool(x):
    try:
        if pd.isna(x): return 0
        s=str(x).strip().lower()
        if s in {"1","true","yes","y"}: return 1
        if s in {"0","false","no","n",""}: return 0
        return int(float(s))
    except Exception: return 0

def _v119_members_text(x):
    out=[]
    if pd.isna(x): return out
    for tok in re.findall(r"\d+",str(x)):
        m=_v119_mem(tok)
        if m and m not in out: out.append(m)
    return out

def _v119_map(df):
    return {
        "true":_v119_find(df,["TrueMember","WinningMember","ActualMember"]),
        "result":_v119_find(df,["Result","WinningResult","ActualResult"]),
        "top1":_v119_find(df,["PredictedMember","Top1","Top1_Display"]),
        "top2":_v119_find(df,["Top2_pred","Top2","Top2_Display"]),
        "top3":_v119_find(df,["ThirdMember","Top3","Top3_Display"]),
        "top1_correct":_v119_find(df,["Top1_Correct","Top1Correct"]),
        "needed_top2":_v119_find(df,["Needed_Top2","NeededTop2","Top2Needed"]),
        "miss":_v119_find(df,["Miss","IsMiss"]),
        "target":_v119_find(df,["v111_TargetOutcome","v118_TargetLabel","v108_OutcomeGroup","OutcomeGroup"]),
        "play_type":_v119_find(df,["PlayType","RowPlayType"]),
        "play_members":_v119_find(df,["ActualBoxPlay","RecommendedPlay","ActualBoxPlayDisplay","BoxPlayInstruction","BeforeMembers","AfterMembers"]),
        "before_captured":_v119_find(df,["BeforeCaptured"]),
        "after_captured":_v119_find(df,["AfterCaptured"]),
    }

def _v119_true(row, mp):
    for k in ["true","result"]:
        c=mp.get(k)
        if c and c in row.index:
            m=_v119_mem(row.get(c))
            if m: return m
    return None

def _v119_ranked(row, mp):
    out=[]
    for k in ["top1","top2","top3"]:
        c=mp.get(k)
        if c and c in row.index:
            m=_v119_mem(row.get(c))
            if m and m not in out: out.append(m)
    for m in ["0025","0225","0255"]:
        if m not in out: out.append(m)
    return out[:3]

def _v119_current(row, mp):
    c=mp.get("play_members")
    if c and c in row.index:
        mm=_v119_members_text(row.get(c))
        if mm: return mm
    ranked=_v119_ranked(row,mp)
    ptc=mp.get("play_type")
    pt=str(row.get(ptc,"")).upper() if ptc and ptc in row.index else ""
    if "TOP3" in pt: return ranked[:3]
    if "TOP2" in pt: return ranked[:2]
    return ranked[:1]

def _v119_label(row, mp):
    c=mp.get("target")
    if c and c in row.index:
        v=str(row.get(c)).strip()
        if v in {"TOP1_WIN","WASTE","NEEDED","TOP3_WIN","MISS"}: return v
    c1=mp.get("top1_correct"); c2=mp.get("needed_top2"); cm=mp.get("miss")
    if c1 and _v119_bool(row.get(c1))==1: return "WASTE" if len(_v119_current(row,mp))>1 else "TOP1_WIN"
    if c2 and _v119_bool(row.get(c2))==1: return "NEEDED"
    if cm and _v119_bool(row.get(cm))==1: return "MISS"
    bc=mp.get("before_captured"); ac=mp.get("after_captured")
    if bc and ac and bc in row.index and ac in row.index:
        b=_v119_bool(row.get(bc)); a=_v119_bool(row.get(ac))
        if b==1 and a==0: return "HARMED_BY_ACTION"
        if b==0 and a==1: return "RESCUED_BY_ACTION"
    true=_v119_true(row,mp); ranked=_v119_ranked(row,mp); cur=_v119_current(row,mp)
    if true and ranked:
        if true==ranked[0]: return "WASTE" if len(cur)>1 else "TOP1_WIN"
        if len(ranked)>1 and true==ranked[1]: return "NEEDED"
        if len(ranked)>2 and true==ranked[2]: return "TOP3_WIN"
        return "MISS"
    return "UNCLASSIFIED"

def _v119_prepare(df):
    out=df.copy()
    if "_v111_add_bucket_features" in globals():
        try: out=_v111_add_bucket_features(out)
        except Exception: pass
    mp=_v119_map(out)
    out["v119_TargetLabel"]=out.apply(lambda r:_v119_label(r,mp),axis=1)
    audit=pd.DataFrame([{"LogicalField":k,"MappedColumn":v if v else "","Found":bool(v)} for k,v in mp.items()])
    return out.reset_index(drop=True),mp,audit

def _v119_mine(df,min_support=8,min_gap=.05,max_pair=60,max_rules=500):
    work,mp,audit=_v119_prepare(df)
    tm=_v118_traits(work,max_pair) if "_v118_traits" in globals() else pd.DataFrame()
    rows=[]
    if tm.empty: return work,mp,tm,pd.DataFrame(),audit
    y=work["v119_TargetLabel"].astype(str)
    specs=[("WASTE","SUPPRESS_TOP2",.55),("NEEDED","KEEP_TOP2",.35),("NEEDED","SWAP_TOP2_TO_TOP1_REVIEW",.35),("TOP3_WIN","ADD_TOP3",.18),("MISS","REVIEW_SKIP",.45)]
    for trait in tm.columns:
        mask=tm[trait].fillna(False).astype(bool); sup=int(mask.sum())
        if sup<int(min_support): continue
        rest=y[~mask]
        for target,action,minrate in specs:
            hits=int((y[mask]==target).sum()); rate=hits/sup if sup else 0
            rr=int((rest==target).sum())/len(rest) if len(rest) else 0
            gap=rate-rr
            if rate>=minrate and gap>=float(min_gap):
                rows.append({"ActionLabel":action,"TargetGroup":target,"Trait":trait,"Support":sup,"TargetHits":hits,"TargetRate":rate,"RestRate":rr,"Gap":gap})
    rules=pd.DataFrame(rows)
    if not rules.empty:
        pri={"SUPPRESS_TOP2":1,"KEEP_TOP2":2,"SWAP_TOP2_TO_TOP1_REVIEW":3,"ADD_TOP3":4,"REVIEW_SKIP":5}
        rules["Priority"]=rules["ActionLabel"].map(pri).fillna(99)
        rules=rules.sort_values(["Priority","Gap","TargetRate","Support"],ascending=[True,False,False,False]).head(int(max_rules)).reset_index(drop=True)
    return work,mp,tm,rules,audit

def _v119_apply(row,action,mp):
    r=_v119_ranked(row,mp); cur=_v119_current(row,mp)
    if action=="SUPPRESS_TOP2": return r[:1]
    if action=="KEEP_TOP2": return r[:2]
    if action=="SWAP_TOP2_TO_TOP1_REVIEW": return r[1:2] if len(r)>1 else r[:1]
    if action=="ADD_TOP3": return r[:3]
    return cur

def _v119_score(work,mp,tm,rules):
    if rules is None or rules.empty or tm is None or tm.empty: return pd.DataFrame()
    rows=[]
    for _,rule in rules.iterrows():
        trait=str(rule["Trait"]); action=str(rule["ActionLabel"])
        if trait not in tm.columns: continue
        bp=ap=bc=ac=tested=0
        for _,row in work[tm[trait].fillna(False)].iterrows():
            true=_v119_true(row,mp)
            if not true: continue
            cur=_v119_current(row,mp); final=_v119_apply(row,action,mp)
            tested+=1; bp+=len(cur); ap+=len(final); bc+=int(true in set(cur)); ac+=int(true in set(final))
        saved=bp-ap; harm=max(0,bc-ac)
        if saved>0 and harm==0: status="LOCK_CANDIDATE_ZERO_HARM"
        elif action in {"KEEP_TOP2","ADD_TOP3"} and ac>=bc: status="PROTECTIVE_RULE_CANDIDATE"
        elif action=="SWAP_TOP2_TO_TOP1_REVIEW" and ac>bc: status="SWAP_CANDIDATE_REVIEW"
        elif saved>0 and harm<=1 and saved/max(harm,1)>=25: status="REVIEW_LOW_HARM_HIGH_VALUE"
        elif saved>0: status="HOLD_TOO_MUCH_HARM"
        else: status="REVIEW_NO_SAVINGS_OR_PROTECTIVE"
        d=rule.to_dict(); d.update({"EventsTested":tested,"BeforePlays":bp,"AfterPlays":ap,"PlaysSaved":saved,"BeforeCaptured":bc,"AfterCaptured":ac,"WinsHarmed":harm,"WinsGained":max(0,ac-bc),"NetCaptureDelta":ac-bc,"PlaysSavedPerHarmedWin":(saved/harm if harm else None),"NetScore_PlaysMinus25xHarm":saved-(25*harm),"PromotionStatus":status})
        rows.append(d)
    out=pd.DataFrame(rows)
    if out.empty: return out
    order={"LOCK_CANDIDATE_ZERO_HARM":1,"PROTECTIVE_RULE_CANDIDATE":2,"SWAP_CANDIDATE_REVIEW":3,"REVIEW_LOW_HARM_HIGH_VALUE":4,"HOLD_TOO_MUCH_HARM":5,"REVIEW_NO_SAVINGS_OR_PROTECTIVE":6}
    out["StatusOrder"]=out["PromotionStatus"].map(order).fillna(99)
    return out.sort_values(["StatusOrder","NetScore_PlaysMinus25xHarm","AfterCaptured"],ascending=[True,False,False]).drop(columns=["StatusOrder"]).reset_index(drop=True)


# ================================
# v118 FOCUSED SEPARATOR CORRECTION HELPERS
# ================================
def _v118_load(uploaded):
    if uploaded is None: return pd.DataFrame()
    try: return _v108_load_miner_table(uploaded)
    except Exception: return pd.DataFrame()

def _v118_src(keys, uploaded=None):
    up=_v118_load(uploaded)
    if isinstance(up,pd.DataFrame) and not up.empty: return "uploaded", up
    for k in keys:
        x=st.session_state.get(k)
        if isinstance(x,pd.DataFrame) and not x.empty: return "session:"+k, x
    return "none", pd.DataFrame()

def _v118_member(x):
    return _v111_member(x) if "_v111_member" in globals() else None

def _v118_prepare(df):
    out=df.copy()
    if "_v111_compute_correct_outcome_targets" in globals():
        try: out=_v111_compute_correct_outcome_targets(out)
        except Exception: pass
    if "_v111_add_bucket_features" in globals():
        try: out=_v111_add_bucket_features(out)
        except Exception: pass
    return out.reset_index(drop=True)

def _v118_ranked(row):
    if "_v112_ranked_members" in globals():
        try: return _v112_ranked_members(row)
        except Exception: pass
    ranked=[]
    for grp in [["PredictedMember","Top1","Top1_Display"],["Top2_pred","Top2","Top2_Display"],["ThirdMember","Top3","Top3_Display"]]:
        for c in grp:
            if c in row.index:
                m=_v118_member(row.get(c))
                if m and m not in ranked: ranked.append(m); break
    for m in ["0025","0225","0255"]:
        if m not in ranked: ranked.append(m)
    return ranked[:3]

def _v118_current(row):
    if "_v112_current_members" in globals():
        try: return _v112_current_members(row)
        except Exception: pass
    return _v118_ranked(row)[:1]

def _v118_true(row):
    for c in ["TrueMember","WinningMember","ActualMember"]:
        if c in row.index:
            m=_v118_member(row.get(c))
            if m: return m
    return None

def _v118_label(row):
    if "v111_TargetOutcome" in row.index and str(row.get("v111_TargetOutcome")) not in {"","nan","None"}:
        return str(row.get("v111_TargetOutcome"))
    tm=_v118_true(row); r=_v118_ranked(row); cur=_v118_current(row)
    if not tm or not r: return "UNKNOWN"
    if tm==r[0]: return "WASTE" if len(cur)>1 else "TOP1_WIN"
    if len(r)>1 and tm==r[1]: return "NEEDED"
    if len(r)>2 and tm==r[2]: return "TOP3_WIN"
    return "MISS"

def _v118_traits(work, max_pair=60):
    raw={}
    if "_v111_trait_masks" in globals():
        try: raw=_v111_trait_masks(work)
        except Exception: raw={}
    bad=["true","winning","actualmember","top1correct","neededtop2","miss","targetoutcome","outcomegroup","captured"]
    traits={}
    for k,m in raw.items():
        nk=re.sub(r"[^a-z0-9]+","",str(k).lower())
        if any(b in nk for b in bad): continue
        try:
            s=m.fillna(False).astype(bool).reset_index(drop=True)
            if 1<int(s.sum())<len(work): traits[str(k)]=s
        except Exception: pass
    scored=sorted([(min(int(s.sum()),len(work)-int(s.sum())),k) for k,s in traits.items()], reverse=True)
    base=[k for _,k in scored[:int(max_pair)]]
    for i,a in enumerate(base):
        for b in base[i+1:]:
            s=traits[a]&traits[b]
            if 1<int(s.sum())<len(work): traits[f"{a} AND {b}"]=s
    return pd.DataFrame(traits).astype(bool) if traits else pd.DataFrame()

def _v118_mine(df, min_support=8, min_gap=0.05, max_pair=60, max_rules=500):
    work=_v118_prepare(df)
    work["v118_TargetLabel"]=work.apply(_v118_label, axis=1)
    tm=_v118_traits(work, max_pair)
    rows=[]
    if tm.empty: return work,tm,pd.DataFrame()
    specs=[("WASTE","SUPPRESS_TOP2",.55),("NEEDED","KEEP_TOP2",.35),("NEEDED","SWAP_TOP2_TO_TOP1_REVIEW",.35),("TOP3_WIN","ADD_TOP3",.18),("MISS","REVIEW_SKIP",.45)]
    y=work["v118_TargetLabel"].astype(str)
    for trait in tm.columns:
        mask=tm[trait].fillna(False).astype(bool); support=int(mask.sum())
        if support<int(min_support): continue
        rest=y[~mask]
        for target,action,minrate in specs:
            hits=int((y[mask]==target).sum()); rate=hits/support if support else 0
            rr=int((rest==target).sum())/len(rest) if len(rest) else 0
            gap=rate-rr
            if rate>=minrate and gap>=float(min_gap):
                rows.append({"ActionLabel":action,"TargetGroup":target,"Trait":trait,"Support":support,"TargetHits":hits,"TargetRate":rate,"RestRate":rr,"Gap":gap})
    out=pd.DataFrame(rows)
    if out.empty: return work,tm,out
    pri={"SUPPRESS_TOP2":1,"KEEP_TOP2":2,"SWAP_TOP2_TO_TOP1_REVIEW":3,"ADD_TOP3":4,"REVIEW_SKIP":5}
    out["Priority"]=out["ActionLabel"].map(pri).fillna(99)
    return work,tm,out.sort_values(["Priority","Gap","TargetRate","Support"], ascending=[True,False,False,False]).head(int(max_rules)).reset_index(drop=True)

def _v118_apply(row, action):
    r=_v118_ranked(row); cur=_v118_current(row)
    if action=="SUPPRESS_TOP2": return r[:1]
    if action=="KEEP_TOP2": return r[:2]
    if action=="SWAP_TOP2_TO_TOP1_REVIEW": return r[1:2] if len(r)>1 else r[:1]
    if action=="ADD_TOP3": return r[:3]
    return cur

def _v118_score(work, tm, rules):
    if rules is None or rules.empty or tm is None or tm.empty: return pd.DataFrame()
    rows=[]
    for _,rule in rules.iterrows():
        trait=str(rule["Trait"]); action=str(rule["ActionLabel"])
        if trait not in tm.columns: continue
        sub=work[tm[trait].fillna(False)].copy()
        bp=ap=bc=ac=tested=0
        for _,row in sub.iterrows():
            true=_v118_true(row)
            if not true: continue
            cur=_v118_current(row); final=_v118_apply(row, action)
            tested+=1; bp+=len(cur); ap+=len(final); bc+=int(true in set(cur)); ac+=int(true in set(final))
        saved=bp-ap; harm=max(0,bc-ac)
        if saved>0 and harm==0: status="LOCK_CANDIDATE_ZERO_HARM"
        elif action in {"KEEP_TOP2","ADD_TOP3"} and ac>=bc: status="PROTECTIVE_RULE_CANDIDATE"
        elif action=="SWAP_TOP2_TO_TOP1_REVIEW" and ac>bc: status="SWAP_CANDIDATE_REVIEW"
        elif saved>0 and harm<=1 and saved/max(harm,1)>=25: status="REVIEW_LOW_HARM_HIGH_VALUE"
        elif saved>0: status="HOLD_TOO_MUCH_HARM"
        else: status="REVIEW_NO_SAVINGS_OR_PROTECTIVE"
        d=rule.to_dict(); d.update({"EventsTested":tested,"BeforePlays":bp,"AfterPlays":ap,"PlaysSaved":saved,"BeforeCaptured":bc,"AfterCaptured":ac,"WinsHarmed":harm,"WinsGained":max(0,ac-bc),"NetCaptureDelta":ac-bc,"PlaysSavedPerHarmedWin":(saved/harm if harm else None),"NetScore_PlaysMinus25xHarm":saved-(25*harm),"PromotionStatus":status})
        rows.append(d)
    out=pd.DataFrame(rows)
    if out.empty: return out
    order={"LOCK_CANDIDATE_ZERO_HARM":1,"PROTECTIVE_RULE_CANDIDATE":2,"SWAP_CANDIDATE_REVIEW":3,"REVIEW_LOW_HARM_HIGH_VALUE":4,"HOLD_TOO_MUCH_HARM":5,"REVIEW_NO_SAVINGS_OR_PROTECTIVE":6}
    out["StatusOrder"]=out["PromotionStatus"].map(order).fillna(99)
    return out.sort_values(["StatusOrder","NetScore_PlaysMinus25xHarm","AfterCaptured"], ascending=[True,False,False]).drop(columns=["StatusOrder"]).reset_index(drop=True)


# ================================
# v117 PER-EVENT FRESHNESS GUARD
# ================================
def _v117_parse_dates(series):
    try:
        return pd.to_datetime(series, errors="coerce")
    except Exception:
        return pd.Series(dtype="datetime64[ns]")

def _v117_get_latest_date_from_df(df, date_candidates=None):
    if date_candidates is None:
        date_candidates = ["Date", "date", "DrawDate", "draw_date", "SeedDate", "seed_date", "LastDate", "last_date"]
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return None, None
    for c in date_candidates:
        if c in df.columns:
            d = _v117_parse_dates(df[c])
            if d.notna().any():
                return d.max().date(), c
    return None, None

def _v117_get_current_play_date_from_daily(daily_df=None):
    """
    Best-effort current play/date anchor.
    Priority:
    1. Current daily playlist date columns
    2. Uploaded/daily seed date columns
    3. Today
    """
    if isinstance(daily_df, pd.DataFrame) and not daily_df.empty:
        dt, col = _v117_get_latest_date_from_df(
            daily_df,
            ["PlayDate", "play_date", "CurrentPlayDate", "Date", "date", "SeedDate", "seed_date"]
        )
        if dt is not None:
            return dt, "daily_column:" + str(col)
    try:
        return pd.Timestamp.today().date(), "system_today"
    except Exception:
        return None, "unknown"

def _v117_get_per_event_source_for_freshness(uploaded=None):
    """
    Uses same per-event sources as v116, upload fallback only.
    """
    up = pd.DataFrame()
    if uploaded is not None:
        try:
            up = _v108_load_miner_table(uploaded)
        except Exception:
            up = pd.DataFrame()
        if isinstance(up, pd.DataFrame) and not up.empty:
            return "uploaded", up

    for key in ["v113_per_event", "v112_per_event", "v114_per_event", "v117_per_event", "v116_per_event"]:
        df = st.session_state.get(key)
        if isinstance(df, pd.DataFrame) and not df.empty:
            return "session:" + key, df
    return "none", pd.DataFrame()

def _v117_freshness_audit(per_event_df=None, daily_df=None, uploaded_per_event=None, max_age_days=1):
    if per_event_df is None or not isinstance(per_event_df, pd.DataFrame) or per_event_df.empty:
        src, per_event_df = _v117_get_per_event_source_for_freshness(uploaded_per_event)
    else:
        src = "provided_df"

    latest_per_event_date, per_event_date_col = _v117_get_latest_date_from_df(per_event_df)
    current_play_date, current_source = _v117_get_current_play_date_from_daily(daily_df)

    status = "UNKNOWN"
    message = ""
    age_days = None

    if latest_per_event_date is None:
        status = "MISSING_OR_NO_DATE"
        message = "Per-event file is missing or has no recognizable date column. Refresh by running v113 FAST Blind WF or upload the current per-event file."
    elif current_play_date is None:
        status = "UNKNOWN_CURRENT_PLAY_DATE"
        message = "Could not identify current play date. Per-event file date found, but freshness cannot be confirmed."
    else:
        try:
            age_days = int((pd.Timestamp(current_play_date) - pd.Timestamp(latest_per_event_date)).days)
        except Exception:
            age_days = None

        if age_days is None:
            status = "UNKNOWN"
            message = "Could not compare current play date to per-event date."
        elif age_days < 0:
            status = "PER_EVENT_AHEAD_OF_PLAY_DATE"
            message = "Per-event file date is ahead of current play date. Check date/source alignment."
        elif age_days <= int(max_age_days):
            status = "CURRENT"
            message = "Per-event file appears current enough for this run."
        else:
            status = "STALE_REFRESH_RECOMMENDED"
            message = "Per-event file is older than the allowed freshness window. Run v113 FAST Blind WF to refresh proof outputs before locking/promoting rules."

    return pd.DataFrame([{
        "FreshnessStatus": status,
        "Message": message,
        "PerEventSource": src,
        "PerEventLatestDate": str(latest_per_event_date) if latest_per_event_date else "",
        "PerEventDateColumn": str(per_event_date_col) if per_event_date_col else "",
        "CurrentPlayDate": str(current_play_date) if current_play_date else "",
        "CurrentPlayDateSource": str(current_source),
        "AgeDays_CurrentMinusPerEvent": age_days,
        "MaxAllowedAgeDays": int(max_age_days),
        "RefreshNeeded": bool(status in {"MISSING_OR_NO_DATE", "STALE_REFRESH_RECOMMENDED", "UNKNOWN_CURRENT_PLAY_DATE"}),
    }])


# ================================
# v116 HARM-SCORED SUPPRESSION FINALIZER HELPERS
# ================================
def _v116_load_optional(uploaded):
    if uploaded is None:
        return pd.DataFrame()
    try:
        return _v108_load_miner_table(uploaded)
    except Exception:
        return pd.DataFrame()

def _v116_get_source(keys, uploaded=None):
    up = _v116_load_optional(uploaded)
    if isinstance(up, pd.DataFrame) and not up.empty:
        return "uploaded", up
    for key in keys:
        df = st.session_state.get(key)
        if isinstance(df, pd.DataFrame) and not df.empty:
            return "session:" + key, df
    return "none", pd.DataFrame()

def _v116_extract_rule_signature(reason):
    s = str(reason or "").strip()
    if not s:
        return ""
    # reasons look like ACTION | trait | rate=...
    parts = [p.strip() for p in s.split("|")]
    if len(parts) >= 2:
        return parts[1]
    return s[:240]

def _v116_harm_score_from_per_event(per_event):
    """
    True harm scoring from blind per-event output.
    Counts how each applied suppression rule affected capture and plays.
    """
    if per_event is None or not isinstance(per_event, pd.DataFrame) or per_event.empty:
        return pd.DataFrame()

    df = per_event.copy()
    if "ActionApplied" not in df.columns:
        return pd.DataFrame()

    # Focus on actual Top1-only / suppression actions.
    mask = df["ActionApplied"].astype(str).str.contains("TOP1_ONLY|WASTE|FORCE_TOP1", case=False, na=False)
    df = df[mask].copy()
    if df.empty:
        return pd.DataFrame()

    df["RuleSignature"] = df.get("RuleReason", "").map(_v116_extract_rule_signature)
    df = df[df["RuleSignature"].astype(str).str.len() > 0].copy()

    rows = []
    for rule, g in df.groupby("RuleSignature", dropna=False):
        bp = pd.to_numeric(g.get("BeforePlayCount", 0), errors="coerce").fillna(0)
        ap = pd.to_numeric(g.get("AfterPlayCount", 0), errors="coerce").fillna(0)
        bc = pd.to_numeric(g.get("BeforeCaptured", 0), errors="coerce").fillna(0)
        ac = pd.to_numeric(g.get("AfterCaptured", 0), errors="coerce").fillna(0)

        plays_saved = int((bp - ap).sum())
        wins_harmed = int(((bc == 1) & (ac == 0)).sum())
        wins_preserved = int(((bc == 1) & (ac == 1)).sum())
        already_missed = int(((bc == 0) & (ac == 0)).sum())
        wins_rescued = int(((bc == 0) & (ac == 1)).sum())
        affected = int(len(g))

        # Conservative operational score: 1 harmed win costs 25 plays of value.
        net_score = plays_saved - (25 * wins_harmed)
        if plays_saved > 0 and wins_harmed == 0:
            status = "LOCK_CANDIDATE_ZERO_HARM"
        elif plays_saved > 0 and wins_harmed <= 1 and (plays_saved / max(wins_harmed, 1)) >= 25:
            status = "REVIEW_LOW_HARM_HIGH_VALUE"
        elif plays_saved > 0:
            status = "HOLD_TOO_MUCH_HARM"
        else:
            status = "HOLD_NO_SAVINGS"

        rows.append({
            "RuleSignature": str(rule)[:260],
            "EventsAffected": affected,
            "PlaysSaved": plays_saved,
            "WinsHarmed": wins_harmed,
            "WinsPreserved": wins_preserved,
            "AlreadyMissedRows": already_missed,
            "WinsRescued": wins_rescued,
            "PlaysSavedPerHarmedWin": (plays_saved / wins_harmed) if wins_harmed else None,
            "NetScore_PlaysMinus25xHarm": net_score,
            "PromotionStatus": status,
            "Source": "blind_per_event_harm_scored",
        })

    out = pd.DataFrame(rows)
    if out.empty:
        return out
    status_order = {
        "LOCK_CANDIDATE_ZERO_HARM": 1,
        "REVIEW_LOW_HARM_HIGH_VALUE": 2,
        "HOLD_TOO_MUCH_HARM": 3,
        "HOLD_NO_SAVINGS": 4,
    }
    out["StatusOrder"] = out["PromotionStatus"].map(status_order).fillna(99)
    return out.sort_values(["StatusOrder", "NetScore_PlaysMinus25xHarm", "PlaysSaved"], ascending=[True, False, False]).drop(columns=["StatusOrder"]).reset_index(drop=True)

def _v116_locked_rule_list(harm_table, include_low_harm=False):
    if harm_table is None or not isinstance(harm_table, pd.DataFrame) or harm_table.empty:
        return pd.DataFrame()
    keep = ["LOCK_CANDIDATE_ZERO_HARM"]
    if include_low_harm:
        keep.append("REVIEW_LOW_HARM_HIGH_VALUE")
    out = harm_table[harm_table["PromotionStatus"].isin(keep)].copy()
    out["LockedAction"] = "FORCE_TOP1_ONLY"
    out["UseInDailyProduction"] = True
    return out.reset_index(drop=True)

def _v116_full_strategy_validation(per_event):
    if per_event is None or not isinstance(per_event, pd.DataFrame) or per_event.empty:
        return pd.DataFrame()
    df = per_event.copy()
    rows = []
    if "strategy" in df.columns:
        groups = df.groupby("strategy", dropna=False)
    else:
        groups = [("production_preview", df)]
    for strat, g in groups:
        ac = pd.to_numeric(g.get("AfterCaptured", 0), errors="coerce").fillna(0)
        bc = pd.to_numeric(g.get("BeforeCaptured", 0), errors="coerce").fillna(0)
        ap = pd.to_numeric(g.get("AfterPlayCount", 0), errors="coerce").fillna(0)
        bp = pd.to_numeric(g.get("BeforePlayCount", 0), errors="coerce").fillna(0)
        n = len(g)
        rows.append({
            "Strategy": strat,
            "Events": int(n),
            "AfterCaptureCount": int(ac.sum()),
            "AfterCaptureRate": float(ac.mean()) if n else 0,
            "BeforeCaptureCount": int(bc.sum()),
            "BeforeCaptureRate": float(bc.mean()) if n else 0,
            "CaptureDelta": int(ac.sum() - bc.sum()),
            "AfterTotalPlays": int(ap.sum()),
            "BeforeTotalPlays": int(bp.sum()),
            "PlaysSaved": int(bp.sum() - ap.sum()),
            "AfterPlaysPerCapture": float(ap.sum() / ac.sum()) if ac.sum() else None,
            "Meets75PctFullUniverseFloor": bool((float(ac.mean()) if n else 0) >= 0.75),
        })
    return pd.DataFrame(rows).sort_values(["Meets75PctFullUniverseFloor", "AfterTotalPlays"], ascending=[False, True]).reset_index(drop=True)

def _v116_run_instructions_table():
    return pd.DataFrame([
        {"Mode":"Fresh model validation", "RequiredSteps":"Daily Prediction → v113 FAST Blind WF → v114 Promotion Executor → v116 Harm Finalizer", "WhenToUse":"When history/rules changed or you need fresh blind proof."},
        {"Mode":"Daily play generation", "RequiredSteps":"Daily Prediction → v114 Promotion Executor using locked rules → final playlist", "WhenToUse":"After suppression rules are locked. Do not rerun v113 daily."},
        {"Mode":"Recovery if session drops", "RequiredSteps":"Upload v113 per-event + v114 promoted rules directly into v116", "WhenToUse":"Only if Streamlit lost session state."},
    ])


# ================================
# v115 BOX ENGINE FINALIZER HELPERS
# ================================
def _v115_load_optional(uploaded):
    if uploaded is None:
        return pd.DataFrame()
    try:
        return _v108_load_miner_table(uploaded)
    except Exception:
        return pd.DataFrame()

def _v115_session_first(keys, uploaded=None):
    df = _v115_load_optional(uploaded)
    if isinstance(df, pd.DataFrame) and not df.empty:
        return "uploaded", df
    for k in keys:
        x = st.session_state.get(k)
        if isinstance(x, pd.DataFrame) and not x.empty:
            return "session:" + k, x
    return "none", pd.DataFrame()

def _v115_rank_suppression(per_event, rules):
    rows = []
    if isinstance(per_event, pd.DataFrame) and not per_event.empty and "RuleReason" in per_event.columns:
        pe = per_event.copy()
        if "ActionApplied" in pe.columns:
            pe = pe[pe["ActionApplied"].astype(str).str.contains("TOP1_ONLY|WASTE|FORCE_TOP1", case=False, na=False)].copy()
        for reason, g in pe.groupby("RuleReason", dropna=False):
            if not str(reason).strip(): 
                continue
            bp = pd.to_numeric(g.get("BeforePlayCount",0), errors="coerce").fillna(0)
            ap = pd.to_numeric(g.get("AfterPlayCount",0), errors="coerce").fillna(0)
            bc = pd.to_numeric(g.get("BeforeCaptured",0), errors="coerce").fillna(0)
            ac = pd.to_numeric(g.get("AfterCaptured",0), errors="coerce").fillna(0)
            saved = int((bp-ap).sum())
            harm = int(((bc==1)&(ac==0)).sum())
            keep = int(((bc==1)&(ac==1)).sum())
            rows.append({"RuleKey":str(reason)[:240],"Source":"blind_per_event","EventsAffected":int(len(g)),"PlaysSaved":saved,"WinsHarmed":harm,"WinsPreserved":keep,"PlaysSavedPerHarmedWin":(saved/harm if harm else None),"NetScore":saved-(25*harm),"PromotionStatus":"LOCK_CANDIDATE" if saved>0 and harm==0 else ("REVIEW" if saved>0 else "HOLD")})
    if not rows and isinstance(rules, pd.DataFrame) and not rules.empty:
        rr = rules.copy()
        if "v115_Action" not in rr.columns:
            if "v114_Action" in rr.columns:
                rr["v115_Action"] = rr["v114_Action"]
            elif "recommended_action" in rr.columns and "_v114_action" in globals():
                rr["v115_Action"] = rr["recommended_action"].map(_v114_action)
            else:
                rr["v115_Action"] = ""
        rr = rr[rr["v115_Action"].astype(str).str.contains("TOP1_ONLY|WASTE", case=False, na=False)].copy()
        for _, r in rr.iterrows():
            rows.append({"RuleKey":str(r.get("trait",""))[:240],"Source":"rule_stats_only","EventsAffected":int(r.get("support",0) or 0),"PlaysSaved":None,"WinsHarmed":None,"WinsPreserved":None,"PlaysSavedPerHarmedWin":None,"NetScore":float(r.get("gap",0) or 0)*1000+float(r.get("target_rate",0) or 0)*100,"PromotionStatus":"REVIEW_NEEDS_PER_EVENT_HARM","TargetRate":r.get("target_rate",None),"Gap":r.get("gap",None),"Support":r.get("support",None),"Action":r.get("v115_Action","")})
    out = pd.DataFrame(rows)
    return out.sort_values(["PromotionStatus","NetScore"], ascending=[True,False]).reset_index(drop=True) if not out.empty else out

def _v115_regime(per_event):
    if per_event is None or not isinstance(per_event, pd.DataFrame) or per_event.empty:
        return pd.DataFrame()
    df=per_event.copy()
    df["Regime9"]="UNKNOWN9"; df["Regime0"]="UNKNOWN0"
    if "seed_has9" in df.columns: df["Regime9"]=df["seed_has9"].map(lambda x:"HAS9" if str(x) in {"1","1.0","True","true"} else "NO9")
    if "seed_has0" in df.columns: df["Regime0"]=df["seed_has0"].map(lambda x:"HAS0" if str(x) in {"1","1.0","True","true"} else "NO0")
    rows=[]
    for cols in [["Regime9"],["Regime0"],["Regime9","Regime0"]]:
        for key,g in df.groupby(cols, dropna=False):
            if not isinstance(key, tuple): key=(key,)
            cap=pd.to_numeric(g.get("AfterCaptured",0), errors="coerce").fillna(0)
            plays=pd.to_numeric(g.get("AfterPlayCount",0), errors="coerce").fillna(0)
            rows.append({"RegimeType":"+".join(cols),"Regime":"+".join(map(str,key)),"Rows":len(g),"CaptureCount":int(cap.sum()),"CaptureRate":float(cap.mean()) if len(g) else 0,"TotalPlays":int(plays.sum()),"AvgPlaysPerRow":float(plays.mean()) if len(g) else 0})
    return pd.DataFrame(rows)

def _v115_stream_compare(df):
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return pd.DataFrame()
    rows=[]
    for n in [20,25,30,35,40,45,50]:
        sr = pd.to_numeric(df.get("StreamRank",999999), errors="coerce") <= n
        if "SingleRow" in df.columns:
            rr = pd.to_numeric(df["SingleRow"], errors="coerce") <= n
        else:
            rr = pd.to_numeric(df.get("RowPercentile",999999), errors="coerce") <= n
        for method,mask in [("StreamRankTopN",sr),("SingleRowTopN",rr),("AgreementBothTopN",sr&rr),("EitherTopN",sr|rr)]:
            sub=df[mask.fillna(False)]
            pc="v115_FinalPlayCount" if "v115_FinalPlayCount" in sub.columns else ("v114_FinalPlayCount" if "v114_FinalPlayCount" in sub.columns else "AfterPlayCount")
            cc="AfterCaptured" if "AfterCaptured" in sub.columns else None
            rows.append({"N":n,"Method":method,"RowsKept":len(sub),"TotalPlays":int(pd.to_numeric(sub.get(pc,0), errors="coerce").fillna(0).sum()),"CaptureCount":int(pd.to_numeric(sub.get(cc,0), errors="coerce").fillna(0).sum()) if cc else None})
    return pd.DataFrame(rows)

def _v115_cost(daily, cost=1.0):
    if daily is None or not isinstance(daily, pd.DataFrame) or daily.empty: return pd.DataFrame()
    after_col = "v114_FinalPlayCount" if "v114_FinalPlayCount" in daily.columns else "AfterPlayCount"
    before_col = "v114_CurrentPlayCount" if "v114_CurrentPlayCount" in daily.columns else "BeforePlayCount"
    after=int(pd.to_numeric(daily.get(after_col,0), errors="coerce").fillna(0).sum())
    before=int(pd.to_numeric(daily.get(before_col,0), errors="coerce").fillna(0).sum())
    return pd.DataFrame([{"Metric":"RowsPlayed","Value":len(daily)},{"Metric":"BoxPlaysBeforeSuppression","Value":before},{"Metric":"BoxPlaysAfterSuppression","Value":after},{"Metric":"BoxPlaysSaved","Value":before-after},{"Metric":"EstimatedCost","Value":after*float(cost)},{"Metric":"EstimatedSavings","Value":(before-after)*float(cost)}])

def _v115_validation(per_event):
    if per_event is None or not isinstance(per_event,pd.DataFrame) or per_event.empty: return pd.DataFrame()
    rows=[]
    groups=per_event.groupby("strategy", dropna=False) if "strategy" in per_event.columns else [("production_preview",per_event)]
    for strat,g in groups:
        cap=pd.to_numeric(g.get("AfterCaptured",0), errors="coerce").fillna(0)
        plays=pd.to_numeric(g.get("AfterPlayCount",0), errors="coerce").fillna(0)
        rows.append({"Strategy":strat,"Events":len(g),"CaptureCount":int(cap.sum()),"CaptureRate":float(cap.mean()) if len(g) else 0,"TotalPlays":int(plays.sum()),"AvgPlaysPerEvent":float(plays.mean()) if len(g) else 0,"Meets75PctCapture":bool((float(cap.mean()) if len(g) else 0)>=0.75)})
    return pd.DataFrame(rows).sort_values(["Meets75PctCapture","TotalPlays"], ascending=[False,True])


# ================================
# v114 PROMOTION EXECUTOR HELPERS
# ================================
def _v114_get_rule_source(uploaded=None):
    if uploaded is not None:
        try:
            df = _v108_load_miner_table(uploaded)
            if isinstance(df, pd.DataFrame) and not df.empty:
                return "uploaded_rules", df
        except Exception:
            pass
    for key in ["v113_rules_log","v112_rules_log","v111_correct_separator_scores","v108_miner_scores","v107_separator_scores"]:
        df = st.session_state.get(key)
        if isinstance(df, pd.DataFrame) and not df.empty:
            return "session:" + key, df
    return "none", pd.DataFrame()

def _v114_action(a):
    s = str(a)
    if "TOP1_ONLY" in s or "WASTE" in s:
        return "FORCE_TOP1_ONLY"
    if "TOP1_TOP2_TOP3" in s or "TOP3" in s:
        return "FORCE_TOP1_TOP2_TOP3"
    if "TOP1_TOP2" in s or "NEEDED" in s or "TOP2" in s:
        return "FORCE_TOP1_TOP2"
    if "MISS" in s or "SKIP" in s:
        return "MISS_FLAG_REVIEW"
    return "REVIEW"

def _v114_filter_rules(rules, min_support=8, min_gap=0.05, min_rate=0.20, allow_miss=True, max_rules=300):
    if rules is None or not isinstance(rules, pd.DataFrame) or rules.empty or "recommended_action" not in rules.columns:
        return pd.DataFrame()
    df = rules.copy()
    for c in ["support","gap","target_rate"]:
        if c not in df.columns: df[c] = 0
        df[c] = pd.to_numeric(df[c], errors="coerce").fillna(0)
    df["v114_Action"] = df["recommended_action"].map(_v114_action)
    df = df[df["v114_Action"] != "REVIEW"].copy()
    if not allow_miss:
        df = df[df["v114_Action"] != "MISS_FLAG_REVIEW"].copy()
    df = df[(df["support"] >= int(min_support)) & (df["gap"] >= float(min_gap)) & (df["target_rate"] >= float(min_rate))].copy()
    if df.empty: return df
    pri = {"FORCE_TOP1_ONLY":1,"FORCE_TOP1_TOP2":2,"FORCE_TOP1_TOP2_TOP3":3,"MISS_FLAG_REVIEW":4}
    df["v114_Priority"] = df["v114_Action"].map(pri).fillna(99)
    df = df.sort_values(["v114_Priority","gap","target_rate","support"], ascending=[True,False,False,False])
    if "trait" in df.columns:
        df = df.drop_duplicates(subset=["v114_Action","trait"], keep="first")
    return df.head(int(max_rules)).reset_index(drop=True)

def _v114_ranked(row):
    if "_v112_ranked_members" in globals():
        try: return _v112_ranked_members(row)
        except Exception: pass
    return []

def _v114_current(row):
    if "_v112_current_members" in globals():
        try: return _v112_current_members(row)
        except Exception: pass
    r = _v114_ranked(row)
    return r[:1]

def _v114_rule_passes(row, trait):
    if "_v112_rule_passes" in globals():
        try: return _v112_rule_passes(row, trait)
        except Exception: pass
    parts = [p.strip() for p in str(trait).split(" AND ")]
    for part in parts:
        if "==" in part:
            col, val = part.split("==", 1)
            if col.strip() not in row.index or str(row.get(col.strip())) != val.strip(): return False
        else:
            col = part.strip()
            if col not in row.index: return False
            try:
                if int(float(row.get(col))) != 1: return False
            except Exception:
                if str(row.get(col)).lower() not in {"1","true","yes"}: return False
    return True

def _v114_prepare_daily(df):
    out = df.copy()
    if "_v111_add_bucket_features" in globals():
        try: out = _v111_add_bucket_features(out)
        except Exception: pass
    return out

def _v114_apply_daily(daily, rules, enable_skip=False):
    if daily is None or not isinstance(daily, pd.DataFrame) or daily.empty:
        return pd.DataFrame(), pd.DataFrame()
    work = _v114_prepare_daily(daily)
    rows = []
    for _, row in work.iterrows():
        cur = _v114_current(row)
        ranked = _v114_ranked(row)
        final = list(cur)
        action, reason = "KEEP_EXISTING", ""
        for _, rule in rules.iterrows():
            trait = str(rule.get("trait",""))
            if not trait or not _v114_rule_passes(row, trait): continue
            act = str(rule.get("v114_Action", _v114_action(rule.get("recommended_action",""))))
            reason = f"{act} | {trait} | target={rule.get('target','')} | rate={float(rule.get('target_rate',0)):.3f} | support={int(rule.get('support',0))} | gap={float(rule.get('gap',0)):.3f}"
            action = act
            if act == "FORCE_TOP1_ONLY": final = ranked[:1]
            elif act == "FORCE_TOP1_TOP2": final = ranked[:2]
            elif act == "FORCE_TOP1_TOP2_TOP3": final = ranked[:3]
            elif act == "MISS_FLAG_REVIEW":
                action = "SKIP_PREVIEW" if enable_skip else "MISS_FLAG_REVIEW"
                final = [] if enable_skip else list(cur)
            break
        d = row.to_dict()
        d["v114_CurrentMembersToPlay"] = " + ".join(cur)
        d["v114_CurrentPlayCount"] = len(cur)
        d["v114_FinalMembersToPlay"] = " + ".join(final)
        d["v114_FinalPlayCount"] = len(final)
        d["v114_PlayDelta"] = len(final)-len(cur)
        d["v114_PromotionAction"] = action
        d["v114_PromotionReason"] = reason
        rows.append(d)
    prev = pd.DataFrame(rows)
    return prev, _v114_summary(prev)

def _v114_summary(prev):
    if prev is None or prev.empty: return pd.DataFrame()
    before = int(pd.to_numeric(prev["v114_CurrentPlayCount"], errors="coerce").fillna(0).sum())
    after = int(pd.to_numeric(prev["v114_FinalPlayCount"], errors="coerce").fillna(0).sum())
    rows = [{"metric":"rows","value":len(prev)},{"metric":"current_box_plays","value":before},{"metric":"v114_final_box_plays","value":after},{"metric":"plays_saved","value":before-after}]
    for k,v in prev["v114_PromotionAction"].astype(str).value_counts().items():
        rows.append({"metric":"action__"+k,"value":int(v)})
    return pd.DataFrame(rows)


# ================================
# v113 FAST BLIND WALK-FORWARD SEPARATOR LAB
# ================================
def _v113_source(uploaded=None):
    if uploaded is not None:
        return "uploaded:" + str(getattr(uploaded, "name", "file")), _v108_load_miner_table(uploaded)
    if "_v111_get_available_miner_source" in globals():
        return _v111_get_available_miner_source()
    return "none", pd.DataFrame()

def _v113_prepare_matrix(df, max_pair_traits=30):
    work = _v112_prepare_event_table(df)
    work = _v112_sort_events(work)
    raw = _v112_trait_masks_live_safe(work) if "_v112_trait_masks_live_safe" in globals() else {}
    cols = {}
    for name, mask in raw.items():
        try:
            s = mask.fillna(False).astype(bool).reset_index(drop=True)
            if 1 < int(s.sum()) < len(work):
                cols[str(name)] = s
        except Exception:
            pass
    # limit paired traits to prevent lockups
    scored = sorted([(min(int(s.sum()), len(work)-int(s.sum())), n) for n,s in cols.items()], reverse=True)
    base_names = [n for _, n in scored[:int(max_pair_traits)]]
    for i, a in enumerate(base_names):
        for b in base_names[i+1:]:
            s = cols[a] & cols[b]
            if 1 < int(s.sum()) < len(work):
                cols[f"{a} AND {b}"] = s
    tm = pd.DataFrame(cols).astype(bool) if cols else pd.DataFrame()
    return work, tm

def _v113_mine(train_end, work, tm, min_support=8, min_gap=0.05, max_rules=150):
    if train_end <= 0 or tm is None or tm.empty or "v111_TargetOutcome" not in work.columns:
        return pd.DataFrame()
    y = work.iloc[:train_end]["v111_TargetOutcome"].astype(str).reset_index(drop=True)
    x = tm.iloc[:train_end].reset_index(drop=True)
    rows = []
    specs = [
        ("WASTE","FIX_TOP2_WASTE__FORCE_TOP1_ONLY",0.55,1),
        ("NEEDED","FIX_TOP2_NEEDED__FORCE_TOP1_TOP2",0.35,2),
        ("TOP3_WIN","FIX_TOP3_NEEDED__FORCE_TOP1_TOP2_TOP3",0.18,3),
        ("MISS","FIX_MISS_POCKET__SKIP_OR_DOWNRANK_REVIEW",0.45,4),
    ]
    for trait in x.columns:
        mask = x[trait].fillna(False).astype(bool)
        support = int(mask.sum())
        if support < int(min_support) or support == len(x):
            continue
        sy, ry = y[mask], y[~mask]
        for target, action, min_rate, pri in specs:
            h = int((sy == target).sum())
            rate = h / support if support else 0
            rest_rate = int((ry == target).sum()) / len(ry) if len(ry) else 0
            gap = rate - rest_rate
            if rate >= min_rate and gap >= float(min_gap):
                rows.append(dict(target=target, trait=trait, support=support, target_hits=h,
                                 target_rate=rate, rest_rate=rest_rate, gap=gap,
                                 recommended_action=action, priority=pri, train_end=train_end))
    out = pd.DataFrame(rows)
    return out.sort_values(["priority","gap","target_rate","support"], ascending=[True,False,False,False]).head(int(max_rules)).reset_index(drop=True) if not out.empty else out

def _v113_current(row):
    return _v112_current_members(row)

def _v113_ranked(row):
    return _v112_ranked_members(row)

def _v113_true(row):
    return _v112_true_member(row)

def _v113_apply(i, row, rules, tm, stages, enable_skip=False):
    current = _v113_current(row)
    ranked = _v113_ranked(row)
    if rules is None or not isinstance(rules, pd.DataFrame) or rules.empty:
        return current, "KEEP_EXISTING", ""
    allow = []
    if "waste" in stages: allow.append("FIX_TOP2_WASTE__FORCE_TOP1_ONLY")
    if "needed" in stages: allow.append("FIX_TOP2_NEEDED__FORCE_TOP1_TOP2")
    if "top3" in stages: allow.append("FIX_TOP3_NEEDED__FORCE_TOP1_TOP2_TOP3")
    if "miss" in stages: allow.append("FIX_MISS_POCKET__SKIP_OR_DOWNRANK_REVIEW")
    for _, r in rules.iterrows():
        action, trait = str(r.get("recommended_action","")), str(r.get("trait",""))
        if action not in allow or trait not in tm.columns or not bool(tm.iloc[i][trait]):
            continue
        reason = f"{action} | {trait} | rate={float(r.get('target_rate',0)):.3f} | support={int(r.get('support',0))}"
        if action == "FIX_TOP2_WASTE__FORCE_TOP1_ONLY": return ranked[:1], action, reason
        if action == "FIX_TOP2_NEEDED__FORCE_TOP1_TOP2": return ranked[:2], action, reason
        if action == "FIX_TOP3_NEEDED__FORCE_TOP1_TOP2_TOP3": return ranked[:3], action, reason
        if action == "FIX_MISS_POCKET__SKIP_OR_DOWNRANK_REVIEW":
            return ([] if enable_skip else current), ("SKIP_PREVIEW" if enable_skip else "MISS_FLAG_ONLY"), reason
    return current, "KEEP_EXISTING", ""

def _v113_fast_lab(df, train_min=60, retrain_every=5, min_support=8, min_gap=0.05, max_rules=150, max_pair_traits=30, max_events=0, enable_skip=False):
    strategies = {
        "baseline_no_separator": (),
        "waste_only": ("waste",),
        "needed_only": ("needed",),
        "top3_only": ("top3",),
        "waste_plus_needed": ("waste","needed"),
        "waste_needed_top3": ("waste","needed","top3"),
        "full_stack_no_skip": ("waste","needed","top3","miss"),
    }
    work, tm = _v113_prepare_matrix(df, max_pair_traits=max_pair_traits)
    n = len(work) if not max_events else min(len(work), int(max_events))
    cached, last = pd.DataFrame(), None
    per, logs = [], []
    for i in range(n):
        if i >= int(train_min) and (last is None or i - last >= int(retrain_every)):
            cached = _v113_mine(i, work, tm, min_support=min_support, min_gap=min_gap, max_rules=max_rules)
            last = i
            if isinstance(cached, pd.DataFrame) and not cached.empty:
                c = cached.copy(); c["event_index_used_from"] = i; logs.append(c)
        row = work.iloc[i]
        for sname, stages in strategies.items():
            before = _v113_current(row)
            after, action, reason = (before, "BASELINE", "") if sname == "baseline_no_separator" else _v113_apply(i,row,cached,tm,stages,enable_skip and "miss" in stages)
            true = _v113_true(row)
            d = {"event_index":i,"strategy":sname,"train_events_available":i,"rules_cached_from_event":last}
            for c in ["Date","StreamKey","RecommendedStream","State","Game","StreamRank","RowPercentile","SingleRow","PlayType","PredictedMember","Top2_pred","ThirdMember","v111_TargetOutcome"]:
                if c in work.columns: d[c] = row.get(c)
            d.update({"BeforeMembers":" + ".join(before),"AfterMembers":" + ".join(after),
                      "BeforePlayCount":len(before),"AfterPlayCount":len(after),
                      "PlayDelta":len(after)-len(before),"TrueMember":true,
                      "BeforeCaptured":int(true in set(before)) if true else None,
                      "AfterCaptured":int(true in set(after)) if true else None,
                      "ActionApplied":action,"RuleReason":reason})
            per.append(d)
    per = pd.DataFrame(per)
    rules = pd.concat(logs, ignore_index=True) if logs else pd.DataFrame()
    summ = _v112_summary(per)
    queue = _v112_promotion_queue(summ)
    meta = pd.DataFrame([dict(BuildMarker="v113_FAST_BLIND_WF_SEPARATOR_LAB", events_processed=n,
                              traits_precomputed=int(tm.shape[1]) if isinstance(tm,pd.DataFrame) else 0,
                              train_min=train_min, retrain_every=retrain_every, min_support=min_support,
                              min_gap=min_gap, max_rules=max_rules, max_pair_traits=max_pair_traits)])
    return per, rules, summ, queue, meta, pd.DataFrame({"trait": list(tm.columns)}) if isinstance(tm,pd.DataFrame) else pd.DataFrame()


# ================================
# v112 BLIND WALK-FORWARD SEPARATOR LAB
# ================================
V112_FORBIDDEN_TARGET_OR_LEAK_COLS = [
    "TrueMember","WinningMember","ActualMember","Top1_Correct","Needed_Top2",
    "Top2Needed","Needed_Top3","Top3Needed","Top3_Needed","Miss","WinnerSurvived",
    "Captured","v111_TargetOutcome","v111_TargetOutcomeDetail","v108_OutcomeGroup",
    "OutcomeGroup","play_rule_hit"
]

def _v112_norm(s):
    return re.sub(r"[^a-z0-9]+", "", str(s).lower())

def _v112_member(x):
    return _v111_member(x) if "_v111_member" in globals() else None

def _v112_prepare_event_table(df):
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return pd.DataFrame()
    out = df.copy()
    if "_v111_compute_correct_outcome_targets" in globals():
        out = _v111_compute_correct_outcome_targets(out)
    if "_v111_add_bucket_features" in globals():
        out = _v111_add_bucket_features(out)
    return out

def _v112_safe_feature_audit(df):
    cols = list(df.columns) if isinstance(df, pd.DataFrame) else []
    forbid = [_v112_norm(c) for c in V112_FORBIDDEN_TARGET_OR_LEAK_COLS]
    rows = []
    for c in cols:
        n = _v112_norm(c)
        forbidden = any(f == n for f in forbid)
        live_safe = (
            str(c).startswith(("cnt","has","seed_","Row","Stream","v64_","v106_","v111_bucket_"))
            or c in ["sum_bucket","spread_bucket","parity_pattern","highlow_pattern","structure","PlayType",
                     "PredictedMember","Top2_pred","ThirdMember","Margin","Top2RiskScore","Top2Decision",
                     "Top2ToTop1Ratio","ModelConfidenceScore","RowPercentile","SingleRow","StreamRank"]
        )
        rows.append({"column":c,"role":"TARGET_ONLY_DO_NOT_USE_LIVE" if forbidden else ("LIVE_SAFE_FEATURE" if live_safe else "REVIEW_BEFORE_LIVE"),"used_by_v112_miner": bool(live_safe and not forbidden)})
    return pd.DataFrame(rows)

def _v112_sort_events(df):
    out = df.copy()
    date_col = "Date" if "Date" in out.columns else None
    stream_col = "StreamKey" if "StreamKey" in out.columns else ("RecommendedStream" if "RecommendedStream" in out.columns else None)
    out["_v112_date_sort"] = pd.to_datetime(out[date_col], errors="coerce") if date_col else range(len(out))
    out["_v112_stream_sort"] = out[stream_col].astype(str) if stream_col else ""
    return out.sort_values(["_v112_date_sort","_v112_stream_sort"]).reset_index(drop=True)

def _v112_ranked_members(row):
    ranked = []
    for group in [["PredictedMember","Top1","Top1_Display"],["Top2_pred","Top2","Top2_Display"],["ThirdMember","Top3","Top3_Display"]]:
        for col in group:
            if col in row.index:
                m = _v112_member(row.get(col))
                if m and m not in ranked:
                    ranked.append(m); break
    for m in ["0025","0225","0255"]:
        if m not in ranked:
            ranked.append(m)
    return ranked[:3]

def _v112_current_members(row):
    for col in ["ActualBoxPlay","RecommendedPlay","ActualBoxPlayDisplay","BoxPlayInstruction"]:
        if col in row.index and pd.notna(row.get(col)):
            found = []
            for tok in re.findall(r"\d+", str(row.get(col))):
                m = _v112_member(tok)
                if m and m not in found:
                    found.append(m)
            if found:
                return found
    ranked = _v112_ranked_members(row)
    pt = str(row.get("PlayType","")).upper()
    return ranked[:3] if "TOP3" in pt else (ranked[:2] if "TOP2" in pt else ranked[:1])

def _v112_true_member(row):
    for col in ["TrueMember","WinningMember","ActualMember"]:
        if col in row.index:
            m = _v112_member(row.get(col))
            if m:
                return m
    return None

def _v112_trait_masks_live_safe(df):
    traits = {}
    if "_v111_trait_masks" in globals():
        try:
            raw = _v111_trait_masks(df)
        except Exception:
            raw = {}
    else:
        raw = {}
    forbidden = [_v112_norm(c) for c in V112_FORBIDDEN_TARGET_OR_LEAK_COLS]
    for k, mask in raw.items():
        nk = _v112_norm(k)
        if any(f in nk for f in forbidden):
            continue
        traits[k] = mask
    return traits

def _v112_mine_rules_from_train(train_df, min_support=8, min_gap=0.05, max_rules=200):
    if train_df is None or train_df.empty or "v111_TargetOutcome" not in train_df.columns:
        return pd.DataFrame()
    traits = _v112_trait_masks_live_safe(train_df)
    rows = []
    for trait, mask in traits.items():
        mask = mask.fillna(False).astype(bool)
        support = int(mask.sum())
        if support < int(min_support) or support == len(train_df):
            continue
        sub, rest = train_df[mask], train_df[~mask]
        for target, action, min_rate in [
            ("WASTE","FIX_TOP2_WASTE__FORCE_TOP1_ONLY",0.55),
            ("NEEDED","FIX_TOP2_NEEDED__FORCE_TOP1_TOP2",0.35),
            ("TOP3_WIN","FIX_TOP3_NEEDED__FORCE_TOP1_TOP2_TOP3",0.18),
            ("MISS","FIX_MISS_POCKET__SKIP_OR_DOWNRANK_REVIEW",0.45),
        ]:
            h = int((sub["v111_TargetOutcome"] == target).sum())
            r = int((rest["v111_TargetOutcome"] == target).sum())
            rate = h/support if support else 0
            rest_rate = r/len(rest) if len(rest) else 0
            gap = rate - rest_rate
            if rate >= min_rate and gap >= float(min_gap):
                rows.append({"target":target,"trait":trait,"support":support,"target_hits":h,"target_rate":rate,"rest_rate":rest_rate,"gap":gap,"recommended_action":action})
    out = pd.DataFrame(rows)
    if out.empty:
        return out
    priority = {"FIX_TOP2_WASTE__FORCE_TOP1_ONLY":1,"FIX_TOP2_NEEDED__FORCE_TOP1_TOP2":2,"FIX_TOP3_NEEDED__FORCE_TOP1_TOP2_TOP3":3,"FIX_MISS_POCKET__SKIP_OR_DOWNRANK_REVIEW":4}
    out["priority"] = out["recommended_action"].map(priority).fillna(99)
    return out.sort_values(["priority","gap","target_rate","support"], ascending=[True,False,False,False]).head(int(max_rules)).reset_index(drop=True)

def _v112_rule_passes(row, trait):
    parts = [p.strip() for p in str(trait).split(" AND ")]
    for part in parts:
        if "==" in part:
            col, val = part.split("==",1)
            if col.strip() not in row.index or str(row.get(col.strip())) != val.strip():
                return False
        else:
            col = part.strip()
            if col not in row.index:
                return False
            try:
                if int(float(row.get(col))) != 1:
                    return False
            except Exception:
                if str(row.get(col)).lower() not in {"1","true","yes"}:
                    return False
    return True

def _v112_apply_rules(row, rules, stages, enable_skip=False):
    current = _v112_current_members(row)
    ranked = _v112_ranked_members(row)
    if rules is None or rules.empty:
        return current, "KEEP_EXISTING", ""
    allowed = []
    if "waste" in stages: allowed.append("FIX_TOP2_WASTE__FORCE_TOP1_ONLY")
    if "needed" in stages: allowed.append("FIX_TOP2_NEEDED__FORCE_TOP1_TOP2")
    if "top3" in stages: allowed.append("FIX_TOP3_NEEDED__FORCE_TOP1_TOP2_TOP3")
    if "miss" in stages: allowed.append("FIX_MISS_POCKET__SKIP_OR_DOWNRANK_REVIEW")
    for _, r in rules.iterrows():
        action = str(r.get("recommended_action",""))
        if action not in allowed:
            continue
        if _v112_rule_passes(row, str(r.get("trait",""))):
            if action == "FIX_TOP2_WASTE__FORCE_TOP1_ONLY":
                return ranked[:1], action, f"{r.get('trait')} | train_rate={float(r.get('target_rate',0)):.3f}"
            if action == "FIX_TOP2_NEEDED__FORCE_TOP1_TOP2":
                return ranked[:2], action, f"{r.get('trait')} | train_rate={float(r.get('target_rate',0)):.3f}"
            if action == "FIX_TOP3_NEEDED__FORCE_TOP1_TOP2_TOP3":
                return ranked[:3], action, f"{r.get('trait')} | train_rate={float(r.get('target_rate',0)):.3f}"
            if action == "FIX_MISS_POCKET__SKIP_OR_DOWNRANK_REVIEW":
                return ([] if enable_skip else current), ("SKIP_PREVIEW" if enable_skip else "MISS_FLAG_ONLY"), f"{r.get('trait')} | train_rate={float(r.get('target_rate',0)):.3f}"
    return current, "KEEP_EXISTING", ""

def _v112_blind_walk_forward_lab(df, train_min_events=60, min_support=8, min_gap=0.05, max_rules=200, enable_skip=False):
    strategies = {
        "baseline_no_separator": tuple(),
        "waste_only": ("waste",),
        "needed_only": ("needed",),
        "top3_only": ("top3",),
        "miss_flag_only": ("miss",),
        "waste_plus_needed": ("waste","needed"),
        "waste_needed_top3": ("waste","needed","top3"),
        "full_stack_no_skip": ("waste","needed","top3","miss"),
    }
    work = _v112_sort_events(_v112_prepare_event_table(df))
    rows, rule_logs = [], []
    for i in range(len(work)):
        event = work.iloc[i]
        train = work.iloc[:i].copy()
        rules = pd.DataFrame()
        if len(train) >= int(train_min_events):
            rules = _v112_mine_rules_from_train(train, min_support=min_support, min_gap=min_gap, max_rules=max_rules)
            if not rules.empty:
                rr = rules.copy(); rr["event_index"] = i; rule_logs.append(rr)
        for name, stages in strategies.items():
            before = _v112_current_members(event)
            after, action, reason = (before, "BASELINE", "") if name == "baseline_no_separator" else _v112_apply_rules(event, rules, stages, enable_skip=(enable_skip and "miss" in stages))
            tm = _v112_true_member(event)
            d = {"event_index":i,"strategy":name,"train_events_available":len(train)}
            for c in ["Date","StreamKey","RecommendedStream","State","Game","StreamRank","RowPercentile","SingleRow","PlayType","PredictedMember","Top2_pred","ThirdMember","v111_TargetOutcome"]:
                if c in work.columns: d[c] = event.get(c)
            d.update({"BeforeMembers":" + ".join(before),"AfterMembers":" + ".join(after),"BeforePlayCount":len(before),"AfterPlayCount":len(after),"PlayDelta":len(after)-len(before),"TrueMember":tm,"BeforeCaptured":int(tm in set(before)) if tm else None,"AfterCaptured":int(tm in set(after)) if tm else None,"ActionApplied":action,"RuleReason":reason})
            rows.append(d)
    per = pd.DataFrame(rows)
    rules_all = pd.concat(rule_logs, ignore_index=True) if rule_logs else pd.DataFrame()
    return per, rules_all, _v112_summary(per)

def _v112_summary(per):
    if per is None or per.empty: return pd.DataFrame()
    rows = []
    for strat, g in per.groupby("strategy"):
        valid = g[g["AfterCaptured"].notna()].copy()
        n = len(valid); cap = int(valid["AfterCaptured"].sum()) if n else 0; basecap = int(valid["BeforeCaptured"].sum()) if n else 0
        plays = int(pd.to_numeric(valid["AfterPlayCount"], errors="coerce").fillna(0).sum())
        baseplays = int(pd.to_numeric(valid["BeforePlayCount"], errors="coerce").fillna(0).sum())
        rows.append({"strategy":strat,"events_tested":n,"capture_count":cap,"capture_rate":cap/n if n else 0,"baseline_capture_count_same_events":basecap,"capture_delta_vs_baseline":cap-basecap,"total_plays":plays,"baseline_total_plays_same_events":baseplays,"plays_saved_vs_baseline":baseplays-plays,"plays_per_capture":plays/cap if cap else None,"avg_plays_per_event":plays/n if n else None,"top1_only_events":int((pd.to_numeric(valid["AfterPlayCount"], errors="coerce")==1).sum()),"two_play_events":int((pd.to_numeric(valid["AfterPlayCount"], errors="coerce")==2).sum()),"three_play_events":int((pd.to_numeric(valid["AfterPlayCount"], errors="coerce")==3).sum()),"zero_play_events":int((pd.to_numeric(valid["AfterPlayCount"], errors="coerce")==0).sum())})
    return pd.DataFrame(rows).sort_values(["capture_rate","total_plays"], ascending=[False, True]).reset_index(drop=True)

def _v112_promotion_queue(summary):
    if summary is None or summary.empty: return pd.DataFrame()
    rows = []
    for _, r in summary.iterrows():
        status = "BASELINE_REFERENCE" if r["strategy"] == "baseline_no_separator" else ("TESTED_PROMOTION_CANDIDATE" if float(r["capture_rate"]) >= .75 and int(r["plays_saved_vs_baseline"]) >= 0 else "HOLD")
        rows.append({"Status":status,"Strategy":r["strategy"],"CaptureRateFullTestedUniverse":r["capture_rate"],"CaptureCount":r["capture_count"],"EventsTested":r["events_tested"],"TotalPlays":r["total_plays"],"PlaysSavedVsBaseline":r["plays_saved_vs_baseline"],"NextAction":"Review per-event harm before promotion" if status=="TESTED_PROMOTION_CANDIDATE" else "Review/hold"})
    return pd.DataFrame(rows)


# ================================
# v111 CORRECT TARGETS + BUCKET FEATURES + SELF-ACCESS
# ================================
def _v111_to_int01(x):
    try:
        if pd.isna(x):
            return 0
        s = str(x).strip().lower()
        if s in {"1", "true", "yes", "y"}:
            return 1
        if s in {"0", "false", "no", "n", ""}:
            return 0
        return int(float(s))
    except Exception:
        return 0

def _v111_find_col(df, candidates, required=False):
    if "_v108_find_col" in globals():
        return _v108_find_col(df, candidates, required=required)
    nmap = {re.sub(r"[^a-z0-9]+", "", str(c).lower()): c for c in getattr(df, "columns", [])}
    for cand in candidates:
        key = re.sub(r"[^a-z0-9]+", "", str(cand).lower())
        if key in nmap:
            return nmap[key]
    if required:
        raise KeyError(f"Missing required column from {candidates}")
    return None

def _v111_member(x):
    if "_v108_member" in globals():
        return _v108_member(x)
    if pd.isna(x):
        return None
    nums = re.findall(r"\d+", str(x))
    for token in reversed(nums):
        z = token.zfill(4)
        if z in {"0025", "0225", "0255"}:
            return z
        if token in {"25", "225", "255"}:
            return {"25":"0025","225":"0225","255":"0255"}[token]
    return None

def _v111_compute_correct_outcome_targets(df):
    """
    Correctly computes TARGETS separate from feature buckets.
    Keeps existing bucket columns like sum_bucket/spread_bucket as predictors, not labels.
    """
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return pd.DataFrame()
    out = df.copy()

    # Preserve any existing mistaken bucket label but do not trust it as outcome.
    old_outcome = _v111_find_col(out, ["v108_OutcomeGroup", "OutcomeGroup", "outcome_group"], required=False)
    if old_outcome and old_outcome in out.columns:
        out["v111_PreviousOutcomeLabel_Preserved"] = out[old_outcome].astype(str)

    top1_correct_col = _v111_find_col(out, ["Top1_Correct", "top1_correct", "IsTop1Correct"], required=False)
    needed_top2_col = _v111_find_col(out, ["Needed_Top2", "needed_top2", "Top2Needed"], required=False)
    miss_col = _v111_find_col(out, ["Miss", "miss", "IsMiss"], required=False)
    top3_needed_col = _v111_find_col(out, ["Top3_Needed", "Needed_Top3", "top3_needed", "Top3Needed"], required=False)

    win_col = _v111_find_col(out, ["WinningMember", "winning_member", "TrueMember", "ActualMember"], required=False)
    top1_col = _v111_find_col(out, ["PredictedMember", "Top1", "Top1_Display"], required=False)
    top2_col = _v111_find_col(out, ["Top2_pred", "Top2", "Top2_Display"], required=False)
    top3_col = _v111_find_col(out, ["ThirdMember", "Top3", "Top3_Display"], required=False)
    play_col = _v111_find_col(out, ["ActualBoxPlay", "RecommendedPlay", "PlayMembers", "MembersToPlay", "PlayType"], required=False)

    groups = []
    details = []
    for _, r in out.iterrows():
        # Prefer explicit diagnostic columns when present.
        top1_correct = _v111_to_int01(r.get(top1_correct_col)) if top1_correct_col else None
        needed_top2 = _v111_to_int01(r.get(needed_top2_col)) if needed_top2_col else None
        miss = _v111_to_int01(r.get(miss_col)) if miss_col else None
        top3_needed = _v111_to_int01(r.get(top3_needed_col)) if top3_needed_col else None

        if top1_correct == 1:
            # If app played Top2 but Top1 was already right, this is WASTE.
            play_text = str(r.get(play_col, "")) if play_col else ""
            if "TOP2" in play_text.upper() or "+" in play_text:
                groups.append("WASTE")
                details.append("TOP2_WASTE_FROM_TOP1_CORRECT")
            else:
                groups.append("TOP1_WIN")
                details.append("TOP1_WIN")
            continue
        if needed_top2 == 1:
            groups.append("NEEDED")
            details.append("TOP2_NEEDED")
            continue
        if top3_needed == 1:
            groups.append("TOP3_WIN")
            details.append("TOP3_NEEDED")
            continue
        if miss == 1:
            groups.append("MISS")
            details.append("MISS")
            continue

        # Fallback to member comparisons.
        win = _v111_member(r.get(win_col)) if win_col else None
        t1 = _v111_member(r.get(top1_col)) if top1_col else None
        t2 = _v111_member(r.get(top2_col)) if top2_col else None
        t3 = _v111_member(r.get(top3_col)) if top3_col else None
        play_text = str(r.get(play_col, "")) if play_col else ""
        if win is None:
            groups.append("UNCLASSIFIED")
            details.append("NO_WINNER_COLUMN")
        elif t1 == win:
            if "TOP2" in play_text.upper() or "+" in play_text:
                groups.append("WASTE")
                details.append("TOP2_WASTE_FROM_MEMBER_COMPARE")
            else:
                groups.append("TOP1_WIN")
                details.append("TOP1_WIN_FROM_MEMBER_COMPARE")
        elif t2 == win:
            groups.append("NEEDED")
            details.append("TOP2_NEEDED_FROM_MEMBER_COMPARE")
        elif t3 == win:
            groups.append("TOP3_WIN")
            details.append("TOP3_NEEDED_FROM_MEMBER_COMPARE")
        else:
            groups.append("MISS")
            details.append("MISS_FROM_MEMBER_COMPARE")

    out["v111_TargetOutcome"] = groups
    out["v111_TargetOutcomeDetail"] = details
    # For compatibility with v108/v109 scoring functions:
    out["v108_OutcomeGroup"] = out["v111_TargetOutcome"]
    return out

def _v111_add_bucket_features(df):
    """
    Keeps produced buckets as features for gating.
    This is where sum_bucket/spread_bucket/parity/highlow/etc. are retained.
    """
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return pd.DataFrame()
    out = df.copy()

    # Preserve existing v108 traits.
    if "_v108_add_miner_traits" in globals():
        out = _v108_add_miner_traits(out)

    bucket_cols = []
    for c in out.columns:
        lc = str(c).lower()
        if lc in {"sum_bucket", "spread_bucket", "seed_parity_pattern", "seed_highlow_pattern", "seed_repeat_shape", "parity_pattern", "highlow_pattern", "structure"}:
            bucket_cols.append(c)
        elif lc.startswith(("rowbucket", "streamtier", "top2zone", "top2decision", "rowplaytype", "decisionmode")):
            bucket_cols.append(c)

    for c in bucket_cols:
        vals = out[c].astype(str).fillna("")
        for v, n in vals.value_counts().items():
            if v and v.lower() not in {"nan", "none"} and n >= 2:
                safe = re.sub(r"[^A-Za-z0-9_]+", "_", f"v111_bucket_{c}_{v}")[:120]
                out[safe] = vals.eq(v).astype(int)

    # Numeric banding for useful row/model/risk fields.
    for c in ["RowTop1Rate", "RowTop2Rate", "RowTop3Rate", "Top2RiskScore", "Top2ToTop1Ratio", "Margin", "ModelConfidenceScore", "StreamRank", "RowPercentile", "SingleRow"]:
        if c in out.columns:
            vals = pd.to_numeric(out[c], errors="coerce")
            if vals.notna().sum() >= 5:
                try:
                    out[f"v111_{c}_high_q75"] = (vals >= vals.quantile(0.75)).astype(int)
                    out[f"v111_{c}_low_q25"] = (vals <= vals.quantile(0.25)).astype(int)
                except Exception:
                    pass
    return out

def _v111_trait_masks(df):
    """
    Uses v108 masks PLUS v111 bucket/rate masks.
    """
    traits = {}
    if "_v108_trait_masks" in globals():
        try:
            traits.update(_v108_trait_masks(df))
        except Exception:
            pass
    for c in df.columns:
        if str(c).startswith("v111_bucket_") or str(c).startswith("v111_"):
            if c in {"v111_TargetOutcome", "v111_TargetOutcomeDetail", "v111_PreviousOutcomeLabel_Preserved"}:
                continue
            try:
                s = pd.to_numeric(df[c], errors="coerce").fillna(0).astype(int)
                if s.sum() >= 2 and s.sum() < len(df):
                    traits[c] = s.eq(1)
            except Exception:
                pass
    # Limited stacks: combine high-value seed/member buckets with bucket features.
    keys = list(traits.keys())
    high_value = [k for k in keys if any(x in k for x in ["seed_has9","seed_no9","seed_has0","seed_no0","tie_flag","top1_member","top2_member","bucket_sum","bucket_spread","RowTop","Top2Risk","RowPercentile","SingleRow","StreamRank"])]
    high_value = high_value[:80]
    for i in range(len(high_value)):
        for j in range(i + 1, len(high_value)):
            traits[f"{high_value[i]} AND {high_value[j]}"] = traits[high_value[i]] & traits[high_value[j]]
    return traits

def _v111_action(target, rate, support):
    if target in {"TOP1_WIN", "WASTE"} and rate >= 0.60 and support >= 5:
        return "CANDIDATE_TOP1_ONLY"
    if target == "NEEDED" and rate >= 0.30 and support >= 5:
        return "CANDIDATE_TOP1_TOP2_REQUIRED"
    if target == "TOP3_WIN" and rate >= 0.18 and support >= 5:
        return "CANDIDATE_TOP3_REQUIRED"
    if target == "MISS" and rate >= 0.45 and support >= 5:
        return "CANDIDATE_SKIP_OR_DOWNRANK"
    return "REVIEW"

def _v111_score_correct_target_traits(df, min_support=5):
    """
    Scores features against correct outcome targets.
    """
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return pd.DataFrame()
    work = _v111_compute_correct_outcome_targets(df)
    work = _v111_add_bucket_features(work)
    traits = _v111_trait_masks(work)
    targets = ["TOP1_WIN", "WASTE", "NEEDED", "TOP3_WIN", "MISS"]
    rows = []
    total_n = len(work)
    for trait, mask in traits.items():
        mask = mask.fillna(False).astype(bool)
        support = int(mask.sum())
        if support < int(min_support) or support == total_n:
            continue
        sub, rest = work[mask], work[~mask]
        for target in targets:
            h = int((sub["v111_TargetOutcome"] == target).sum())
            r = int((rest["v111_TargetOutcome"] == target).sum())
            rate = h / support if support else 0
            rest_rate = r / len(rest) if len(rest) else 0
            rows.append({
                "target": target,
                "trait": trait,
                "support": support,
                "target_hits": h,
                "target_rate": rate,
                "rest_hits": r,
                "rest_rate": rest_rate,
                "gap": rate - rest_rate,
                "lift_vs_rest": (rate / rest_rate) if rest_rate else None,
                "recommended_action": _v111_action(target, rate, support),
                "BuildMarker": "v111_CORRECT_TARGETS_BUCKET_FEATURES_SELF_ACCESS",
            })
    out = pd.DataFrame(rows)
    if out.empty:
        return out
    return out.sort_values(["recommended_action", "gap", "target_rate", "support"], ascending=[True, False, False, False]).reset_index(drop=True)

def _v111_get_available_miner_source():
    """
    Self-access outputs produced by prior portions of the app.
    No download/reupload required inside the same app.
    """
    # Prefer classified raw data if present.
    for key in ["v108_miner_classified", "v107_separator_classified", "miner_outputs_v6"]:
        obj = st.session_state.get(key)
        if isinstance(obj, pd.DataFrame) and not obj.empty:
            return key, obj
        if isinstance(obj, dict):
            for subkey in ["prepared_df", "work_df"]:
                df = obj.get(subkey)
                if isinstance(df, pd.DataFrame) and not df.empty:
                    return f"{key}.{subkey}", df

    # Fall back to current daily playlist only for preview, not full mining.
    try:
        src, daily = v85_get_daily_playlist()
        if isinstance(daily, pd.DataFrame) and not daily.empty:
            return "current_daily_playlist:" + str(src), daily
    except Exception:
        pass
    return "none", pd.DataFrame()

def _v111_prepare_scores_from_session_or_upload(uploaded_scores=None, uploaded_classified=None, min_support=5):
    """
    No required re-upload: uses session classified data if available.
    Uploads are optional fallback.
    """
    if uploaded_scores is not None:
        try:
            scores = _v108_load_miner_table(uploaded_scores)
            if isinstance(scores, pd.DataFrame) and not scores.empty and "recommended_action" in scores.columns:
                return "uploaded_scores", scores
        except Exception:
            pass
    if uploaded_classified is not None:
        df = _v108_load_miner_table(uploaded_classified)
        scores = _v111_score_correct_target_traits(df, min_support=min_support)
        return "uploaded_classified_recomputed", scores

    src, df = _v111_get_available_miner_source()
    if isinstance(df, pd.DataFrame) and not df.empty:
        scores = _v111_score_correct_target_traits(df, min_support=min_support)
        return "session_recomputed:" + str(src), scores

    return "none", pd.DataFrame()


# ================================
# v110 ROW HISTORY ACTIVATION / AUDIT GUARDS
# ================================
def _v110_row_history_audit(df):
    report = {
        "rows": int(len(df)) if isinstance(df, pd.DataFrame) else 0,
        "status": "UNKNOWN",
        "has_RowPlayTypeReason": False,
        "no_row_history_rows": 0,
        "no_row_history_pct": 0.0,
        "has_RowModelHits": False,
        "rows_with_RowModelHits_gt0": 0,
        "has_RowTopRates": False,
        "ready_for_separator_promotion": False,
        "message": "",
    }
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        report["status"] = "EMPTY"
        report["message"] = "No daily playlist found. Run Daily Prediction and Walk-forward Lab first."
        return report
    n = len(df)
    if "RowPlayTypeReason" in df.columns:
        report["has_RowPlayTypeReason"] = True
        reason = df["RowPlayTypeReason"].astype(str)
        no_hist = reason.str.contains("NO_ROW_HISTORY_YET", case=False, na=False) | reason.str.contains("Run Walk-forward Lab", case=False, na=False)
        report["no_row_history_rows"] = int(no_hist.sum())
        report["no_row_history_pct"] = float(no_hist.mean()) if n else 0.0
    if "RowModelHits" in df.columns:
        report["has_RowModelHits"] = True
        hits = pd.to_numeric(df["RowModelHits"], errors="coerce").fillna(0)
        report["rows_with_RowModelHits_gt0"] = int((hits > 0).sum())
    rate_cols = [c for c in ["RowTop1Rate", "RowTop2Rate", "RowTop3Rate"] if c in df.columns]
    report["has_RowTopRates"] = len(rate_cols) == 3
    if report["no_row_history_rows"] == 0 and report["rows_with_RowModelHits_gt0"] > 0 and report["has_RowTopRates"]:
        report["status"] = "ROW_HISTORY_ACTIVE"
        report["ready_for_separator_promotion"] = True
        report["message"] = "Row history appears active. Separator preview can be evaluated."
    elif report["no_row_history_rows"] > 0:
        report["status"] = "ROW_HISTORY_FALLBACK_ACTIVE"
        report["message"] = "Current playlist still contains NO_ROW_HISTORY_YET fallback rows. Run Walk-forward Lab / row play model before trusting separator promotion."
    else:
        report["status"] = "ROW_HISTORY_INCOMPLETE"
        report["message"] = "Row history fields are incomplete or not populated enough for promotion."
    return report

def _v110_gate_preview_if_needed(daily_df, require_row_history=True):
    audit = _v110_row_history_audit(daily_df)
    if require_row_history and not audit.get("ready_for_separator_promotion", False):
        out = daily_df.copy() if isinstance(daily_df, pd.DataFrame) else pd.DataFrame()
        if isinstance(out, pd.DataFrame) and not out.empty:
            out["v110_RowHistoryGateStatus"] = audit.get("status", "UNKNOWN")
            out["v110_RowHistoryGateMessage"] = audit.get("message", "")
            out["v110_SeparatorAction"] = "BLOCKED_ROW_HISTORY_NOT_ACTIVE"
            out["v110_SeparatorReason"] = audit.get("message", "")
            out["v110_CurrentMembersToPlay"] = ""
            out["v110_CurrentPlayCount"] = 0
            out["v110_PreviewMembersToPlay"] = ""
            out["v110_PreviewPlayCount"] = 0
            out["v110_PlayCountDelta"] = 0
            out["v110_IsPreviewOnly"] = True
        return False, out, pd.DataFrame([audit])
    return True, None, pd.DataFrame([audit])


# ================================
# v109 STAGED SEPARATOR OPTIMIZER HELPERS
# ================================
def _v109_members_from_text(text):
    found = []
    for tok in re.findall(r"\d+", str(text)):
        m = _v108_member(tok) if "_v108_member" in globals() else None
        if m and m not in found:
            found.append(m)
    return found

def _v109_ranked_members_from_row(row):
    ranked = []
    for group in [["PredictedMember","Top1","Top1_Display"], ["Top2_pred","Top2","Top2_Display"], ["ThirdMember","Top3","Top3_Display"]]:
        for col in group:
            if col in row.index:
                m = _v108_member(row.get(col)) if "_v108_member" in globals() else None
                if m and m not in ranked:
                    ranked.append(m); break
    for m in ["0025","0225","0255"]:
        if m not in ranked:
            ranked.append(m)
    return ranked[:3]

def _v109_current_members(row):
    for col in ["ActualBoxPlay","RecommendedPlay","ActualBoxPlayDisplay","BoxPlayInstruction"]:
        if col in row.index and pd.notna(row.get(col)):
            members = _v109_members_from_text(row.get(col))
            if members:
                return members
    ranked = _v109_ranked_members_from_row(row)
    pt = str(row.get("PlayType","")).upper()
    if "TOP3" in pt:
        return ranked[:3]
    if "TOP2" in pt:
        return ranked[:2]
    return ranked[:1]

def _v109_format_members(members):
    return " + ".join([m for m in members if m])

def _v109_stage_priority(action):
    return {"CANDIDATE_TOP1_ONLY":1,"CANDIDATE_TOP1_TOP2_REQUIRED":2,"CANDIDATE_TOP3_REQUIRED":3,"CANDIDATE_SKIP_OR_DOWNRANK":4}.get(str(action),99)

def _v109_rule_passes(row, trait):
    parts = [p.strip() for p in str(trait).split(" AND ")]
    for part in parts:
        if "==" in part:
            col, val = part.split("==",1)
            col, val = col.strip(), val.strip()
            if col not in row.index or str(row.get(col)) != val:
                return False
        else:
            col = part.strip()
            if col not in row.index:
                return False
            try:
                if int(float(row.get(col))) != 1:
                    return False
            except Exception:
                if str(row.get(col)).lower() not in {"1","true","yes"}:
                    return False
    return True

def _v109_filter_rules(scores, min_support=5, min_gap=0.05, min_rate=0.20, max_rules=250):
    if scores is None or not isinstance(scores, pd.DataFrame) or scores.empty or "recommended_action" not in scores.columns:
        return pd.DataFrame()
    df = scores.copy()
    df = df[df["recommended_action"].astype(str).str.startswith("CANDIDATE_")].copy()
    for c in ["support","gap","target_rate"]:
        if c in df.columns:
            df[c] = pd.to_numeric(df[c], errors="coerce")
    df = df[(df["support"] >= int(min_support)) & (df["gap"] >= float(min_gap)) & (df["target_rate"] >= float(min_rate))].copy()
    if df.empty:
        return df
    df["v109_stage_priority"] = df["recommended_action"].map(_v109_stage_priority)
    return df.sort_values(["v109_stage_priority","gap","target_rate","support"], ascending=[True,False,False,False]).head(int(max_rules)).reset_index(drop=True)

def _v109_apply_staged_optimizer(daily_df, scores, min_support=5, min_gap=0.05, min_rate=0.20, max_rules=250, enable_skip_preview=False):
    if daily_df is None or not isinstance(daily_df, pd.DataFrame) or daily_df.empty:
        return pd.DataFrame()
    work = daily_df.copy()
    if "_v108_add_miner_traits" in globals():
        work = _v108_add_miner_traits(work)
    rules = _v109_filter_rules(scores, min_support, min_gap, min_rate, max_rules)
    rows = []
    for _, row in work.iterrows():
        current = _v109_current_members(row)
        ranked = _v109_ranked_members_from_row(row)
        chosen = None
        for _, rule in rules.iterrows():
            if _v109_rule_passes(row, rule.get("trait","")):
                chosen = rule
                break
        action, reason, after = "KEEP_EXISTING", "", list(current)
        if chosen is not None:
            action = str(chosen.get("recommended_action","REVIEW"))
            reason = f"{chosen.get('trait')} | target={chosen.get('target')} | gap={float(chosen.get('gap',0)):.3f} | rate={float(chosen.get('target_rate',0)):.3f} | support={int(chosen.get('support',0))}"
            if action == "CANDIDATE_TOP1_ONLY":
                after = ranked[:1]
            elif action == "CANDIDATE_TOP1_TOP2_REQUIRED":
                after = ranked[:2]
            elif action == "CANDIDATE_TOP3_REQUIRED":
                after = ranked[:3]
            elif action == "CANDIDATE_SKIP_OR_DOWNRANK" and enable_skip_preview:
                after = []
        d = row.to_dict()
        d["v109_CurrentMembersToPlay"] = _v109_format_members(current)
        d["v109_CurrentPlayCount"] = len(current)
        d["v109_SeparatorAction"] = action
        d["v109_SeparatorReason"] = reason
        d["v109_PreviewMembersToPlay"] = _v109_format_members(after)
        d["v109_PreviewPlayCount"] = len(after)
        d["v109_PlayCountDelta"] = len(after) - len(current)
        d["v109_IsPreviewOnly"] = True
        rows.append(d)
    return pd.DataFrame(rows)

def _v109_summary(df):
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return pd.DataFrame()
    before = int(pd.to_numeric(df["v109_CurrentPlayCount"], errors="coerce").fillna(0).sum())
    after = int(pd.to_numeric(df["v109_PreviewPlayCount"], errors="coerce").fillna(0).sum())
    rows = [
        {"metric":"rows","value":int(len(df))},
        {"metric":"current_box_plays","value":before},
        {"metric":"preview_box_plays","value":after},
        {"metric":"plays_saved_preview","value":before-after},
    ]
    for k,v in df["v109_SeparatorAction"].astype(str).value_counts().items():
        rows.append({"metric":"action__"+k,"value":int(v)})
    return pd.DataFrame(rows)


# ================================
# v108 ISOLATED DEEP MINER HELPERS
# ================================
def _v108_miner_bytes(obj):
    if obj is None:
        return b""
    try:
        if isinstance(obj, bytes):
            return obj
        if isinstance(obj, bytearray):
            return bytes(obj)
        if isinstance(obj, str):
            p = Path(obj)
            return p.read_bytes() if p.exists() else obj.encode("utf-8")
        if isinstance(obj, Path):
            return obj.read_bytes() if obj.exists() else str(obj).encode("utf-8")
        if hasattr(obj, "getvalue"):
            v = obj.getvalue()
            return v if isinstance(v, bytes) else str(v).encode("utf-8")
        if hasattr(obj, "read"):
            try:
                obj.seek(0)
            except Exception:
                pass
            v = obj.read()
            return v if isinstance(v, bytes) else str(v).encode("utf-8")
        return str(obj).encode("utf-8")
    except Exception:
        return str(obj).encode("utf-8")

def _v108_miner_name(obj, fallback="miner_input.csv"):
    try:
        nm = getattr(obj, "name", None)
        if nm:
            return str(nm).lower()
        if isinstance(obj, Path):
            return obj.name.lower()
        if isinstance(obj, str):
            p = Path(obj)
            return p.name.lower() if p.suffix else fallback
        return fallback
    except Exception:
        return fallback

def _v108_load_miner_table(uploaded_file):
    import io
    if uploaded_file is None:
        return pd.DataFrame()
    raw = _v108_miner_bytes(uploaded_file)
    name = _v108_miner_name(uploaded_file)
    if name.endswith((".xlsx", ".xls")):
        return pd.read_excel(io.BytesIO(raw))
    text = raw.decode("utf-8", errors="replace")
    for kwargs in [
        dict(sep=None, engine="python"),
        dict(sep="\t"),
        dict(sep=","),
        dict(sep="|", engine="python"),
        dict(sep=";"),
    ]:
        try:
            df = pd.read_csv(io.StringIO(text), **kwargs)
            if isinstance(df, pd.DataFrame) and not df.empty:
                return df
        except Exception:
            continue
    return pd.DataFrame()

def _v108_norm_col(c):
    return re.sub(r"[^a-z0-9]+", "", str(c).lower())

def _v108_find_col(df, candidates, required=False):
    if df is None or not isinstance(df, pd.DataFrame):
        if required:
            raise KeyError("No dataframe supplied")
        return None
    nmap = {_v108_norm_col(c): c for c in df.columns}
    for cand in candidates:
        key = _v108_norm_col(cand)
        if key in nmap:
            return nmap[key]
    for cand in candidates:
        key = _v108_norm_col(cand)
        for nk, orig in nmap.items():
            if key and (key in nk or nk in key):
                return orig
    if required:
        raise KeyError(f"Required column not found. Tried {candidates}. Available: {list(df.columns)}")
    return None

def _v108_member(x):
    if pd.isna(x):
        return None
    s = str(x).strip()
    nums = re.findall(r"\d+", s)
    for token in reversed(nums):
        z = token.zfill(4)
        if z in {"0025", "0225", "0255"}:
            return z
        if token in {"25", "225", "255"}:
            return {"25":"0025","225":"0225","255":"0255"}[token]
    return s if s in {"0025", "0225", "0255"} else None

def _v108_classify_miner_rows(df):
    """
    Isolated classifier for uploaded miner/per-event files only.
    It never writes to app history/session keys used by Daily Prediction.
    """
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return pd.DataFrame()
    out = df.copy()
    og = _v108_find_col(out, ["OutcomeGroup", "outcome_group", "Group", "bucket"], required=False)
    if og:
        out["v108_OutcomeGroup"] = out[og].astype(str).str.upper().replace({
            "WASTE_TOP2":"WASTE", "NEEDED_TOP2":"NEEDED", "MISSED":"MISS", "TOP1":"TOP1_WIN", "TOP3":"TOP3_WIN"
        })
    else:
        win_col = _v108_find_col(out, ["WinningMember", "winning_member", "TrueMember", "ActualMember"], required=False)
        top1_col = _v108_find_col(out, ["Top1", "Top1_Display", "PredictedMember", "top1"], required=False)
        top2_col = _v108_find_col(out, ["Top2", "Top2_pred", "top2"], required=False)
        top3_col = _v108_find_col(out, ["Top3", "ThirdMember", "top3"], required=False)
        play_col = _v108_find_col(out, ["ActualBoxPlay", "RecommendedPlay", "PlayMembers", "MembersToPlay"], required=False)
        hit_col = _v108_find_col(out, ["play_rule_hit", "PlayRuleHit", "WinnerSurvived", "Captured"], required=False)
        groups = []
        if not win_col or not top1_col:
            out["v108_OutcomeGroup"] = "UNCLASSIFIED"
        else:
            for _, r in out.iterrows():
                win = _v108_member(r.get(win_col))
                t1 = _v108_member(r.get(top1_col))
                t2 = _v108_member(r.get(top2_col)) if top2_col else None
                t3 = _v108_member(r.get(top3_col)) if top3_col else None
                play_text = str(r.get(play_col, "")) if play_col else ""
                played = set()
                for tok in re.findall(r"\d+", play_text):
                    m = _v108_member(tok)
                    if m:
                        played.add(m)
                # Fallback: if play text missing, classify by rank relationship only.
                if win is None:
                    groups.append("UNCLASSIFIED")
                elif t1 == win:
                    groups.append("WASTE" if t2 and (t2 in played or "TOP2" in play_text.upper()) else "TOP1_WIN")
                elif t2 == win:
                    groups.append("NEEDED")
                elif t3 == win:
                    groups.append("TOP3_WIN")
                elif hit_col and str(r.get(hit_col)).lower() in {"1","true","yes"}:
                    groups.append("OTHER_CAPTURE")
                else:
                    groups.append("MISS")
            out["v108_OutcomeGroup"] = groups
    return out

def _v108_add_miner_traits(df):
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return pd.DataFrame()
    out = df.copy()
    seed_col = _v108_find_col(out, ["seed", "PrevSeed", "prev_seed", "LastResult"], required=False)
    if seed_col:
        seed_digits = out[seed_col].astype(str).str.replace(r"\D", "", regex=True).str[:4]
        out["v108_seed_has9"] = seed_digits.str.contains("9", na=False).astype(int)
        out["v108_seed_no9"] = (out["v108_seed_has9"] == 0).astype(int)
        out["v108_seed_has0"] = seed_digits.str.contains("0", na=False).astype(int)
        out["v108_seed_no0"] = (out["v108_seed_has0"] == 0).astype(int)
        out["v108_seed_has9_has0"] = ((out["v108_seed_has9"] == 1) & (out["v108_seed_has0"] == 1)).astype(int)
        out["v108_seed_no9_no0"] = ((out["v108_seed_has9"] == 0) & (out["v108_seed_has0"] == 0)).astype(int)
    for cands, name in [
        (["Top1", "PredictedMember", "Top1_Display"], "v108_top1_member"),
        (["Top2", "Top2_pred", "Top2_Display"], "v108_top2_member"),
        (["ThirdMember", "Top3", "Top3_Display"], "v108_top3_member"),
    ]:
        c = _v108_find_col(out, cands, required=False)
        if c:
            out[name] = out[c].map(_v108_member).fillna("")
    tie_col = _v108_find_col(out, ["TieFired", "DeadTie", "Top2Zone", "Top2Decision"], required=False)
    out["v108_tie_flag"] = out[tie_col].astype(str).str.lower().isin(["1","true","yes","tie","dead_tie"]).astype(int) if tie_col else 0
    sr_col = _v108_find_col(out, ["StreamRank"], required=False)
    if sr_col:
        vals = pd.to_numeric(out[sr_col], errors="coerce")
        out["v108_streamrank_band"] = pd.cut(vals, bins=[0,10,20,30,40,50,9999], labels=["SR_1_10","SR_11_20","SR_21_30","SR_31_40","SR_41_50","SR_51_PLUS"], include_lowest=True).astype(str)
    row_col = _v108_find_col(out, ["SingleRowPercentile", "RowPercentile", "SingleRow"], required=False)
    if row_col:
        vals = pd.to_numeric(out[row_col], errors="coerce")
        out["v108_singlerow_band"] = pd.cut(vals, bins=[0,10,20,30,40,50,9999], labels=["ROW_1_10","ROW_11_20","ROW_21_30","ROW_31_40","ROW_41_50","ROW_51_PLUS"], include_lowest=True).astype(str)
    return out

def _v108_trait_masks(df):
    traits = {}
    for col in ["v108_seed_has9","v108_seed_no9","v108_seed_has0","v108_seed_no0","v108_seed_has9_has0","v108_seed_no9_no0","v108_tie_flag"]:
        if col in df.columns:
            traits[col] = df[col].astype(int).eq(1)
    for col in ["v108_top1_member","v108_top2_member","v108_top3_member","v108_streamrank_band","v108_singlerow_band"]:
        if col in df.columns:
            for v, n in df[col].astype(str).value_counts().items():
                if v and v != "nan" and n >= 2:
                    traits[f"{col}=={v}"] = df[col].astype(str).eq(v)
    keys = list(traits.keys())
    for i in range(len(keys)):
        for j in range(i + 1, len(keys)):
            traits[f"{keys[i]} AND {keys[j]}"] = traits[keys[i]] & traits[keys[j]]
    return traits

def _v108_action(target, rate, support):
    if target in {"TOP1_WIN", "WASTE"} and rate >= 0.65 and support >= 5:
        return "CANDIDATE_TOP1_ONLY"
    if target == "NEEDED" and rate >= 0.35 and support >= 5:
        return "CANDIDATE_TOP1_TOP2_REQUIRED"
    if target == "TOP3_WIN" and rate >= 0.20 and support >= 5:
        return "CANDIDATE_TOP3_REQUIRED"
    if target == "MISS" and rate >= 0.50 and support >= 5:
        return "CANDIDATE_SKIP_OR_DOWNRANK"
    return "REVIEW"

def _v108_score_miner_traits(df, min_support=5):
    if df is None or df.empty or "v108_OutcomeGroup" not in df.columns:
        return pd.DataFrame()
    traits = _v108_trait_masks(df)
    targets = ["TOP1_WIN", "WASTE", "NEEDED", "TOP3_WIN", "MISS"]
    rows = []
    for trait, mask in traits.items():
        mask = mask.fillna(False).astype(bool)
        support = int(mask.sum())
        if support < int(min_support) or support == len(df):
            continue
        sub, rest = df[mask], df[~mask]
        for target in targets:
            h = int((sub["v108_OutcomeGroup"] == target).sum())
            r = int((rest["v108_OutcomeGroup"] == target).sum())
            rate = h / support if support else 0
            rest_rate = r / len(rest) if len(rest) else 0
            rows.append({
                "target": target,
                "trait": trait,
                "support": support,
                "target_hits": h,
                "target_rate": rate,
                "rest_hits": r,
                "rest_rate": rest_rate,
                "gap": rate - rest_rate,
                "lift_vs_rest": (rate / rest_rate) if rest_rate else None,
                "recommended_action": _v108_action(target, rate, support),
                "BuildMarker": "v108_DEEP_MINER_ISOLATED_NO_PARSER_TOUCH",
            })
    out = pd.DataFrame(rows)
    return out.sort_values(["gap","target_rate","support"], ascending=[False,False,False]).reset_index(drop=True) if not out.empty else out

def _v108_queue():
    return pd.DataFrame([
        {"Status":"LOCKED_TERM","Item":"SingleRowPercentile definition","Action":"Historical winner-production strength by individual row; distinct from StreamRank/PlaylistRank."},
        {"Status":"LOCKED_GUARD","Item":"Rank/row separation","Action":"Keep StreamRank, SingleRowPercentile, and PlaylistRank visibly separate."},
        {"Status":"CANDIDATE","Item":"Deep Miner separator layer","Action":"Use uploaded per-event/classified file to mine TOP1/WASTE/NEEDED/TOP3/MISS pockets. Preview only."},
        {"Status":"CANDIDATE","Item":"Actual members-to-play clarity","Action":"Expose final members-to-play as primary output after rules are promoted."},
        {"Status":"SOFT_ONLY","Item":"Row/stream cadence","Action":"Caution/tie-breaker only until full replay proves hard suppression safe."},
    ])


# ================================
# v88 DISPLAY-ONLY PLAY VISIBILITY HELPERS
# ================================
# These helpers add obvious ACTUAL PLAY markers for the UI and downloads only.
# They intentionally do not change any prediction, ranking, filtering, scoring,
# stream selection, box member selection, or straight recommendation logic.

def v88_clean_member(value) -> str:
    txt = str(value if value is not None else "").replace("*", "").strip()
    if not txt or txt.lower() in {"nan", "none"}:
        return ""
    return txt.zfill(4) if txt.isdigit() else txt


def v88_box_actual_members(row) -> List[str]:
    play_type = str(row.get("PlayType", row.get("BoxPlayType", ""))).strip()
    top1 = v88_clean_member(row.get("PredictedMember", row.get("Top1_Display", "")))
    top2 = v88_clean_member(row.get("Top2_pred", row.get("Top2_Display", "")))
    top3 = v88_clean_member(row.get("ThirdMember", row.get("Top3_Display", "")))
    members = []
    if play_type == "TOP1_TOP2_TOP3":
        members = [top1, top2, top3]
    elif play_type == "TOP1_TOP2":
        members = [top1, top2]
    elif play_type == "TOP1_ONLY":
        members = [top1]
    else:
        # Preserve prior behavior: if a row is missing PlayType, treat Top1 as the visible play.
        members = [top1]
    return [m for m in members if m]


def v88_add_box_play_markers(df: pd.DataFrame) -> pd.DataFrame:
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return df
    out = df.copy()
    out["PLAY_FLAG"] = "🔴 PLAY"
    out["ActualBoxPlay"] = out.apply(lambda r: " + ".join(v88_box_actual_members(r)), axis=1)
    out["ActualBoxPlayDisplay"] = out["ActualBoxPlay"].apply(
        lambda x: " + ".join([f"🔴 **{p.strip()}**" for p in str(x).split("+") if p.strip()])
    )
    out["BoxPlayInstruction"] = out.apply(
        lambda r: f"🔴 PLAY ONLY: {r['ActualBoxPlay']}" if str(r.get("ActualBoxPlay", "")).strip() else "",
        axis=1,
    )
    return out


def v88_add_straight_play_markers(df: pd.DataFrame) -> pd.DataFrame:
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return df
    out = df.copy()
    rec = pd.to_numeric(out.get("RecommendedStraight", 0), errors="coerce").fillna(0).astype(int)
    out["PLAY_FLAG"] = rec.apply(lambda x: "🔴 PLAY" if int(x) == 1 else "")
    out["ActualStraightPlay"] = out.apply(
        lambda r: str(r.get("StraightPermutation", "")).zfill(4) if int(pd.to_numeric(pd.Series([r.get("RecommendedStraight", 0)]), errors="coerce").fillna(0).iloc[0]) == 1 else "",
        axis=1,
    )
    out["ActualStraightPlayDisplay"] = out.apply(
        lambda r: f"🔴 **{str(r.get('StraightPermutation', '')).zfill(4)}**" if int(pd.to_numeric(pd.Series([r.get("RecommendedStraight", 0)]), errors="coerce").fillna(0).iloc[0]) == 1 else "",
        axis=1,
    )
    out["StraightPlayInstruction"] = out.apply(
        lambda r: f"🔴 PLAY THIS STRAIGHT: {str(r.get('StraightPermutation', '')).zfill(4)}" if int(pd.to_numeric(pd.Series([r.get("RecommendedStraight", 0)]), errors="coerce").fillna(0).iloc[0]) == 1 else "REVIEW ONLY — not a recommended straight play",
        axis=1,
    )
    return out


def v88_play_styler(df: pd.DataFrame, flag_col: str = "PLAY_FLAG"):
    """
    v89 display-only fix: highlight only the actual play cells, not the entire row/table.

    The prior v88 row-level style turned the whole daily playlist red when every visible
    stream was playable. This keeps all diagnostic columns visible while making the
    actual box/straight play columns impossible to miss. No selection/ranking/scoring
    logic is changed here.
    """
    if df is None or not isinstance(df, pd.DataFrame) or df.empty:
        return df

    play_cols = {
        "PLAY_FLAG",
        "ActualBoxPlayDisplay", "ActualBoxPlay", "BoxPlayInstruction",
        "ActualStraightPlayDisplay", "ActualStraightPlay", "StraightPlayInstruction",
    }
    available_play_cols = play_cols.intersection(set(df.columns))
    if not available_play_cols:
        return df

    red_style = (
        "background-color: #b00020; color: white; font-weight: 900; "
        "border: 3px solid #4a000b; font-size: 1.08em;"
    )

    def _cell_style(value, col_name):
        txt = str(value).strip()
        if col_name in available_play_cols and txt and txt.lower() not in {"nan", "none"}:
            if "REVIEW ONLY" in txt.upper():
                return "color: #777; font-style: italic;"
            return red_style
        return ""

    def _style_frame(data):
        styles = pd.DataFrame("", index=data.index, columns=data.columns)
        for col in available_play_cols:
            styles[col] = data[col].apply(lambda v, c=col: _cell_style(v, c))
        return styles

    return df.style.apply(_style_frame, axis=None)

for k in [
    "daily_playlist", "lab_results", "lab_summary", "stream_diag",
    "truth_rules", "loaded_meta", "percentile_df", "stream_method_tests", "row_single_perf", "row_play_model", "straight_playlist", "straight_summary"
, "v64_ensemble_marked", "v64_final_playlist", "v64_ensemble_summary", "straight_backtest_events", "straight_backtest_summary", "straight_backtest_rank_distribution", "v643_final_single_row_test", "v643_top1_confidence_subset", "v643_cached_straight_events", "v643_final_straight_summary", "v643_final_straight_per_event", "v643_final_straight_depth", "v645_row_coverage_table", "v645_stream_elimination_marked", "v645_stream_elimination_playable", "v645_stream_elimination_summary", "v645_stream_elimination_policy_table", "v646_excluded_0255_rescue_events", "v646_excluded_0255_rescue_by_row", "v646_excluded_0255_rescue_summary", "v646_daily_excluded_0255_rescue_list", "v647_consensus_summary", "v647_consensus_per_event", "v647_daily_consensus_marked", "v648_full312_straight_per_event", "v648_full312_straight_summary", "v648_full312_straight_depth_curve", "v648_rescue_empty_reason", "v649_daily_by_single_row_capture", "v649_chunked_straight_events", "v649_chunked_straight_next_pos", "v649_chunked_straight_summary", "v649_chunked_straight_depth_curve", "v65_optimal_tier_summary", "v65_optimal_tier_grid", "v65_optimal_tier_per_event", "v65_daily_optimal_tier_playlist", "v78_last_member_summary", "v78_last_member_depth", "v78_last_member_detail", "v79_final_daily_play_list", "v79_straight_recommended", "v79_straight_lookup_table", "v80_final_box_playlist", "v80_final_straight_playlist", "CANONICAL_DAILY_PLAYLIST", "CANONICAL_LAB_RESULTS"]:
    if k not in st.session_state:
        st.session_state[k] = None


def _clean_upload_column_name(col) -> str:
    """Normalize upload headers only; does not change downstream app column contracts."""
    c = str(col).replace("\ufeff", "").strip()
    c = re.sub(r"\s+", " ", c)
    return c


def _header_hit_score(cols) -> int:
    aliases = {
        "date", "draw date", "drawdate", "time", "draw time", "state", "st", "game",
        "streamkey", "stream key", "result", "results", "winning numbers", "winning_numbers",
        "winningnumbers", "number", "numbers", "seed", "prevseed", "winningmember",
        "truemember", "trait_stack", "winner_member", "winner_rate", "support", "stack_size"
    }
    return sum(1 for c in cols if _clean_upload_column_name(c).lower().replace("_", " ") in aliases)


def _looks_like_data_row(cols) -> bool:
    text = " | ".join(str(c) for c in cols)
    has_date = bool(re.search(r"\b\d{1,2}[/-]\d{1,2}[/-]\d{2,4}\b|\b\d{4}[/-]\d{1,2}[/-]\d{1,2}\b", text))
    has_pick4 = bool(re.search(r"(?<!\d)\d\D*\d\D*\d\D*\d(?!\d)", text))
    return has_date and has_pick4


def load_upload(uploaded_file, header: Optional[int] = "infer") -> pd.DataFrame:
    """
    Robust upload reader for CSV/TXT/TSV app inputs.

    Fix scope: parsing only. It deliberately returns a DataFrame for the existing
    normalize_history / ensure_truth / ensure_library paths without altering any
    scoring, stream reduction, lab, daily, or straight-play behavior.
    """
    raw = _v102_file_to_bytes(uploaded_file)
    name = _v102_get_upload_name(uploaded_file)

    # v146 loader repair:
    # Some Streamlit sessions can expose an internal file id/UUID as the apparent
    # upload name even though the real file is present in the sidebar. Do not fail
    # only because that displayed/internal name has no extension. Keep extension-
    # based priority when available; otherwise sniff the actual bytes. Parsing only.
    if name.endswith(".csv"):
        seps = [",", "\t", "|", ";"]
    elif name.endswith(".tsv"):
        seps = ["\t", ",", "|", ";"]
    elif name.endswith(".txt"):
        seps = ["\t", ",", "|", ";"]
    else:
        try:
            sample = raw[:12000].decode("utf-8", errors="replace") if isinstance(raw, (bytes, bytearray)) else str(raw)[:12000]
        except Exception:
            sample = ""
        if "\t" in sample:
            seps = ["\t", ",", "|", ";"]
        elif "|" in sample and sample.count("|") > sample.count(","):
            seps = ["|", "\t", ",", ";"]
        elif "," in sample:
            seps = [",", "\t", "|", ";"]
        else:
            seps = ["\t", ",", "|", ";"]

    candidates = []
    for sep in seps:
        for hdr in [0, None]:
            try:
                df = pd.read_csv(
                    io.BytesIO(raw),
                    sep=sep,
                    header=hdr,
                    dtype=str,
                    low_memory=False,
                    encoding="utf-8-sig",
                    on_bad_lines="skip",
                )
                if df is None or df.empty:
                    continue
                df = df.dropna(how="all").copy()
                if hdr is None:
                    df.columns = [f"col_{i}" for i in range(df.shape[1])]
                else:
                    df.columns = [_clean_upload_column_name(c) for c in df.columns]
                df = df.loc[:, ~pd.Index(df.columns).astype(str).str.startswith("Unnamed")].copy()
                hits = _header_hit_score(df.columns)
                penalty = 50 if hdr == 0 and hits == 0 and _looks_like_data_row(df.columns) else 0
                score = (hits * 100) + (df.shape[1] * 10) + min(len(df), 10) - penalty
                candidates.append((score, hits, df.shape[1], len(df), df))
            except Exception:
                continue

    if candidates:
        candidates.sort(key=lambda x: (x[0], x[1], x[2], x[3]), reverse=True)
        return candidates[0][4]

    try:
        df = pd.read_csv(io.BytesIO(raw), sep=None, engine="python", dtype=str, encoding="utf-8-sig", on_bad_lines="skip")
        df.columns = [_clean_upload_column_name(c) for c in df.columns]
        return df.dropna(how="all").copy()
    except Exception:
        df = pd.read_csv(io.BytesIO(raw), sep="\t", header=None, dtype=str, encoding="utf-8-sig", low_memory=False, on_bad_lines="skip")
        df.columns = [f"col_{i}" for i in range(df.shape[1])]
        return df.dropna(how="all").copy()


def extract_pick4_digits(x) -> str:
    if x is None:
        return ""
    s = str(x)
    m = re.search(r"(\d)\D+(\d)\D+(\d)\D+(\d)", s)
    if m:
        return "".join(m.groups())
    m2 = re.search(r"(?<!\d)(\d{4})(?!\d)", s)
    if m2:
        return m2.group(1)
    digits = re.findall(r"\d", s)
    if len(digits) >= 4:
        return "".join(digits[:4])
    return ""


def box_key(s: str) -> str:
    s = extract_pick4_digits(s) or str(s)
    return "".join(sorted(re.sub(r"\D", "", s).zfill(4)[-4:]))


def normalize_member(x) -> str:
    if x is None:
        return ""
    s = str(x).strip().replace("'", "")
    s = re.sub(r"\D", "", s)
    if s in {"25", "025", "0025"}:
        return "0025"
    if s in {"225", "0225"}:
        return "0225"
    if s in {"255", "0255"}:
        return "0255"
    return s.zfill(4) if s else ""


def result_to_core025_member(result4: str) -> str:
    b = box_key(result4)
    return b if b in set(MEMBERS) else ""


def canonical_stream(state: str, game: str) -> str:
    return f"{str(state).strip()} | {str(game).strip()}"



def ensure_streamkey_columns(df: pd.DataFrame, context: str = "data") -> pd.DataFrame:
    """v82: guarantee StreamKey exists whenever possible, without changing existing StreamKey values."""
    out = df.copy()
    out.columns = [str(c).strip() for c in out.columns]
    if "StreamKey" in out.columns:
        out["StreamKey"] = out["StreamKey"].astype(str).str.strip()
        return out

    lower = {str(c).strip().lower(): c for c in out.columns}
    state_col = lower.get("state")
    game_col = lower.get("game")

    # Some exports split draw time/session from game. Include it only when Game does not already carry timing.
    time_col = None
    for cand in ["drawtime", "draw_time", "time", "period", "session", "draw", "daypart"]:
        if cand in lower:
            time_col = lower[cand]
            break

    if state_col is not None and game_col is not None:
        game_text = out[game_col].astype(str).str.strip()
        if time_col is not None:
            time_text = out[time_col].astype(str).str.strip()
            # Avoid duplicating time if already embedded in game label.
            needs_time = ~game_text.str.lower().str.contains("morning|midday|day|evening|night|noon|pm|am|10pm|1:50|7:50", regex=True, na=False)
            game_text = game_text.where(~needs_time, game_text + " " + time_text)
        out["StreamKey"] = out[state_col].astype(str).str.strip() + " | " + game_text.astype(str).str.strip()
        return out

    raise ValueError(f"Could not auto-build StreamKey for {context}. Need StreamKey, or State + Game columns.")

def empty_lab_results_frame() -> pd.DataFrame:
    """v82: standard empty lab frame so downstream references do not KeyError."""
    return pd.DataFrame(columns=[
        "StreamKey", "Date", "seed", "TrueMember", "Result", "PredictedMember", "Top2_pred",
        "ThirdMember", "Top1_Correct", "Needed_Top2", "Miss", "StreamRank", "RowPercentile",
        "SingleRow", "RecommendedStream", "PlayType", "RecommendedPlay"
    ])


def v83_is_nonempty_df(x) -> bool:
    return isinstance(x, pd.DataFrame) and not x.empty

def v83_first_nonempty_session_df(keys: List[str]) -> Tuple[Optional[str], Optional[pd.DataFrame]]:
    """Return first non-empty DataFrame from session_state. Prevents straight tabs from using empty placeholders."""
    for key in keys:
        val = st.session_state.get(key)
        if v83_is_nonempty_df(val):
            return key, val.copy()
    return None, None

def v84_score_playlist_candidate(df: pd.DataFrame) -> int:
    """Score whether a session_state DataFrame looks like a daily playlist for straight generation."""
    if not v83_is_nonempty_df(df):
        return -999
    cols = set(map(str, df.columns))
    score = 0
    for c in ["StreamKey", "seed", "PredictedMember", "Top2_pred", "PlayType"]:
        if c in cols:
            score += 10
    for c in ["StreamRank", "RowPercentile", "SingleRow", "RecommendedStream", "UniversalFamilyScore"]:
        if c in cols:
            score += 4
    if "Result" in cols and "TrueMember" in cols:
        score -= 10
    return score

def v84_find_best_playlist_anywhere() -> Tuple[Optional[str], Optional[pd.DataFrame]]:
    """Fallback: scan all session_state objects for the best playlist-like non-empty DataFrame."""
    best_key, best_df, best_score = None, None, -999
    for key, val in st.session_state.items():
        if not v83_is_nonempty_df(val):
            continue
        score = v84_score_playlist_candidate(val)
        if score > best_score:
            best_key, best_df, best_score = key, val.copy(), score
    if best_score >= 30:
        return best_key, best_df
    return None, None

def v83_get_straight_source_playlist(v64_use_ensemble_for_straights: bool = True) -> Tuple[Optional[str], Optional[pd.DataFrame]]:
    """Best available daily playlist source for straight generation."""
    keys = [
        "v80_final_box_playlist",
        "v79_final_daily_play_list",
        "v79_final_play_this_today",
        "v65_daily_optimal_tier_playlist",
        "v645_stream_elimination_playable",
        "v64_final_playlist",
        "v64_ensemble_marked",
        "daily_playlist",
        "playlist",
        "daily_final_playlist",
        "final_playlist",
    ]
    key, df = v83_first_nonempty_session_df(keys)
    if df is not None and v84_score_playlist_candidate(df) >= 30:
        return key, df
    return v84_find_best_playlist_anywhere()

def v84_score_lab_candidate(df: pd.DataFrame) -> int:
    if not v83_is_nonempty_df(df):
        return -999
    cols = set(map(str, df.columns))
    score = 0
    for c in ["StreamKey", "Date", "seed", "TrueMember", "Result"]:
        if c in cols:
            score += 10
    for c in ["PredictedMember", "Top2_pred", "PlayType", "StreamRank", "RowPercentile", "SingleRow"]:
        if c in cols:
            score += 4
    return score

def v84_find_best_lab_anywhere() -> Tuple[Optional[str], Optional[pd.DataFrame]]:
    best_key, best_df, best_score = None, None, -999
    for key, val in st.session_state.items():
        if not v83_is_nonempty_df(val):
            continue
        score = v84_score_lab_candidate(val)
        if score > best_score:
            best_key, best_df, best_score = key, val.copy(), score
    if best_score >= 40:
        return best_key, best_df
    return None, None

def v83_get_lab_results_for_backtest() -> Tuple[Optional[str], Optional[pd.DataFrame]]:
    """Best available full-event lab table for straight backtests."""
    key, df = v83_first_nonempty_session_df([
        "lab_results",
        "v65_optimal_tier_per_event",
        "v648_full312_straight_per_event",
        "v643_final_straight_per_event",
        "straight_backtest_events",
    ])
    if df is not None and v84_score_lab_candidate(df) >= 40:
        return key, df
    return v84_find_best_lab_anywhere()


def v85_promote_canonical_outputs() -> None:
    """Canonical downstream handoff. Safe to call repeatedly after any tab creates outputs."""
    daily_keys = [
        "v80_final_box_playlist",
        "v79_final_daily_play_list",
        "v65_daily_optimal_tier_playlist",
        "v645_stream_elimination_playable",
        "v64_final_playlist",
        "v64_ensemble_marked",
        "daily_playlist",
    ]
    for key in daily_keys:
        val = st.session_state.get(key)
        if isinstance(val, pd.DataFrame) and not val.empty:
            st.session_state["CANONICAL_DAILY_PLAYLIST"] = val.copy()
            st.session_state["v85_canonical_daily_source"] = key
            break

    lab_keys = [
        "lab_results",
        "v65_optimal_tier_per_event",
        "v648_full312_straight_per_event",
        "v643_final_straight_per_event",
        "straight_backtest_events",
    ]
    for key in lab_keys:
        val = st.session_state.get(key)
        if isinstance(val, pd.DataFrame) and not val.empty:
            st.session_state["CANONICAL_LAB_RESULTS"] = val.copy()
            st.session_state["v85_canonical_lab_source"] = key
            break

def v85_get_daily_playlist() -> Tuple[Optional[str], Optional[pd.DataFrame]]:
    v85_promote_canonical_outputs()
    df = st.session_state.get("CANONICAL_DAILY_PLAYLIST")
    if isinstance(df, pd.DataFrame) and not df.empty:
        return st.session_state.get("v85_canonical_daily_source", "CANONICAL_DAILY_PLAYLIST"), df.copy()
    return None, None

def v85_get_lab_results() -> Tuple[Optional[str], Optional[pd.DataFrame]]:
    v85_promote_canonical_outputs()
    df = st.session_state.get("CANONICAL_LAB_RESULTS")
    if isinstance(df, pd.DataFrame) and not df.empty:
        return st.session_state.get("v85_canonical_lab_source", "CANONICAL_LAB_RESULTS"), df.copy()
    return None, None


def _norm_col_key(c: str) -> str:
    return re.sub(r"[^a-z0-9]", "", str(c).strip().lower())


def _find_col(df: pd.DataFrame, aliases: List[str]) -> Optional[str]:
    wanted = {_norm_col_key(a) for a in aliases}
    for c in df.columns:
        if _norm_col_key(c) in wanted:
            return c
    return None


def _split_streamkey(value: str) -> Tuple[str, str]:
    s = str(value).strip()
    if "|" in s:
        a, b = s.split("|", 1)
        return a.strip(), b.strip()
    parts = re.split(r"\s+-\s+|\s{2,}", s, maxsplit=1)
    if len(parts) == 2:
        return parts[0].strip(), parts[1].strip()
    return "", s


def _v183_parse_raw_history_lines_from_df(df_raw: pd.DataFrame) -> pd.DataFrame:
    """
    v183 WF loader repair: parse raw LotteryPost-style history lines when the
    WF reader produced a 1-column/unrecognized dataframe. Parsing only; no
    scoring/ranking/member logic changed.
    Supported examples:
      Fri, Feb 20, 2026<TAB>Wisconsin<TAB>Pick 4 Midday<TAB>8-5-7-7
      2026-02-20<TAB>Wisconsin<TAB>Pick 4 Midday<TAB>8577
    """
    if df_raw is None or not isinstance(df_raw, pd.DataFrame) or df_raw.empty:
        return pd.DataFrame()

    rows = []

    # Include column labels too, because pd.read_csv(header=0) can accidentally
    # consume the first raw history row as headers.
    possible_lines = []
    try:
        possible_lines.append("\t".join(str(c) for c in df_raw.columns if str(c).strip() and not str(c).startswith("Unnamed")))
    except Exception:
        pass

    for _, r in df_raw.iterrows():
        vals = [str(x).strip() for x in list(r.values) if str(x).strip() and str(x).strip().lower() != "nan"]
        if not vals:
            continue
        possible_lines.append("\t".join(vals))

    date_re = re.compile(
        r"^(?P<date>(?:Mon|Tue|Wed|Thu|Fri|Sat|Sun),\s+[A-Za-z]{3,9}\s+\d{1,2},\s+\d{4}|\d{4}[-/]\d{1,2}[-/]\d{1,2}|\d{1,2}[-/]\d{1,2}[-/]\d{2,4})\s*[\t,| ]+",
        re.I,
    )

    for line in possible_lines:
        line = str(line).replace("\ufeff", "").strip()
        if not line:
            continue

        # Prefer clean tab/pipe/csv-ish splitting.
        parts = [p.strip() for p in re.split(r"\t+|\s*\|\s*", line) if p.strip()]
        if len(parts) < 4:
            # Raw line may have date containing commas; capture date first, then
            # split the remaining text from the right by the pick-4 result.
            m = date_re.search(line)
            if not m:
                continue
            date_txt = m.group("date").strip()
            rest = line[m.end():].strip(" \t,|")
            rm = re.search(r"(\d\D+\d\D+\d\D+\d|\b\d{4}\b)\s*$", rest)
            if not rm:
                continue
            result_txt = rm.group(1)
            left = rest[:rm.start()].strip(" \t,|")
            # State and game are best separated by tabs/pipe. If not present,
            # split on 2+ spaces; final fallback keeps full left as game.
            left_parts = [p.strip() for p in re.split(r"\t+|\s*\|\s*|\s{2,}", left) if p.strip()]
            if len(left_parts) >= 2:
                state_txt = left_parts[0]
                game_txt = " ".join(left_parts[1:])
            else:
                state_txt = ""
                game_txt = left
        else:
            date_txt, state_txt, game_txt = parts[0], parts[1], parts[2]
            result_txt = parts[3]

        result4 = extract_pick4_digits(result_txt)
        if not result4:
            continue
        dt = pd.to_datetime(date_txt, errors="coerce")
        if pd.isna(dt):
            continue
        state_txt = str(state_txt).strip()
        game_txt = str(game_txt).strip()
        if not state_txt or not game_txt:
            continue
        rows.append({
            "Date": dt,
            "State": state_txt,
            "Game": game_txt,
            "Results": result_txt,
            "Result": result4,
        })

    if not rows:
        return pd.DataFrame()

    out = pd.DataFrame(rows)
    out["Box"] = out["Result"].apply(box_key)
    out["StreamKey"] = out.apply(lambda r: canonical_stream(r["State"], r["Game"]), axis=1)
    out["Core025Member"] = out["Result"].apply(result_to_core025_member)
    out = out.drop_duplicates(["Date", "StreamKey", "Result"]).sort_values(["StreamKey", "Date"]).reset_index(drop=True)
    return out


def normalize_history(df_raw: pd.DataFrame) -> pd.DataFrame:
    df = df_raw.copy()
    df.columns = [_clean_upload_column_name(c) for c in df.columns]
    df = df.dropna(how="all").copy()
    df = df.loc[:, ~pd.Index(df.columns).astype(str).str.startswith("Unnamed")].copy()

    date_col = _find_col(df, ["Date", "Draw Date", "DrawDate", "Draw_Date"])
    state_col = _find_col(df, ["State", "ST", "Jurisdiction"])
    game_col = _find_col(df, ["Game", "Game Name", "Draw", "Draw Time", "DrawTime", "Session", "Period"])
    stream_col = _find_col(df, ["StreamKey", "Stream Key", "Stream", "State Game", "State_Game"])
    result_col = _find_col(df, [
        "Results", "Result", "Winning Numbers", "Winning_Numbers", "WinningNumbers",
        "Number", "Numbers", "Pick4", "Pick 4", "Draw Result", "DrawResult"
    ])

    # v183: WF lab must accept the same raw LotteryPost-style history text that
    # the daily side can use. This is a parser-only fallback before failing.
    if date_col is None or result_col is None or ((state_col is None or game_col is None) and stream_col is None):
        raw_parsed = _v183_parse_raw_history_lines_from_df(df)
        if isinstance(raw_parsed, pd.DataFrame) and not raw_parsed.empty:
            return raw_parsed

    # Headerless history remains supported: Date, State, Game, Results in first 4 fields.
    if date_col is None or result_col is None or ((state_col is None or game_col is None) and stream_col is None):
        if df.shape[1] >= 4:
            cols = list(df.columns)
            date_col = date_col or cols[0]
            state_col = state_col or cols[1]
            game_col = game_col or cols[2]
            result_col = result_col or cols[3]
        elif df.shape[1] >= 3 and stream_col is not None:
            cols = list(df.columns)
            date_col = date_col or cols[0]
            result_col = result_col or cols[-1]
        else:
            raise ValueError("History file must contain Date + Result plus either StreamKey or State + Game columns.")

    if stream_col is not None and (state_col is None or game_col is None):
        tmp = df[stream_col].apply(_split_streamkey)
        state_vals = tmp.apply(lambda x: x[0])
        game_vals = tmp.apply(lambda x: x[1])
    else:
        state_vals = df[state_col].astype(str) if state_col is not None else ""
        game_vals = df[game_col].astype(str) if game_col is not None else ""

    out = pd.DataFrame({
        "Date": df[date_col],
        "State": state_vals,
        "Game": game_vals,
        "Results": df[result_col],
    })

    out["Date"] = pd.to_datetime(out["Date"], errors="coerce")
    out["State"] = out["State"].astype(str).str.strip()
    out["Game"] = out["Game"].astype(str).str.strip()
    out["Result"] = out["Results"].apply(extract_pick4_digits)
    out = out[out["Date"].notna() & out["Result"].str.len().eq(4)].copy()
    if out.empty:
        raw_parsed = _v183_parse_raw_history_lines_from_df(df)
        if isinstance(raw_parsed, pd.DataFrame) and not raw_parsed.empty:
            return raw_parsed
        raise ValueError("History upload parsed, but no valid Pick 4 rows were found. Check Date/State/Game/Result columns or delimiter.")
    out["Box"] = out["Result"].apply(box_key)
    out["StreamKey"] = out.apply(lambda r: canonical_stream(r["State"], r["Game"]), axis=1)
    out["Core025Member"] = out["Result"].apply(result_to_core025_member)
    out = out.sort_values(["StreamKey", "Date"]).reset_index(drop=True)
    return out



def ensure_truth(df_raw: pd.DataFrame) -> pd.DataFrame:
    df = df_raw.copy()
    df.columns = [_clean_upload_column_name(c) for c in df.columns]
    df = df.dropna(how="all").copy()
    df = df.loc[:, ~pd.Index(df.columns).astype(str).str.startswith("Unnamed")].copy()

    # Canonicalize common truth/export aliases without changing downstream contracts.
    true_col = _find_col(df, ["WinningMember", "TrueMember", "WinnerMember", "winner_member", "Member", "Core025Member"])
    if true_col is None:
        raise ValueError("FULL TRUTH file must contain WinningMember or TrueMember.")
    df["TrueMember"] = df[true_col].apply(normalize_member)

    seed_col = _find_col(df, ["seed", "PrevSeed", "feat_seed", "Seed", "Previous Result", "PreviousResult", "LastResult"])
    if seed_col is not None:
        df["seed"] = df[seed_col].astype(str)
    elif "seed" not in df.columns:
        df["seed"] = ""

    # Preserve existing StreamKey values when present; otherwise build it when possible.
    try:
        df = ensure_streamkey_columns(df, "truth/lab file")
    except Exception:
        # Truth files used only for member scoring may not always include stream fields.
        pass

    return df


def ensure_library(df_raw: pd.DataFrame) -> pd.DataFrame:
    df = df_raw.copy()
    df.columns = [_clean_upload_column_name(c) for c in df.columns]
    alias_map = {}
    for target, aliases in {
        "trait_stack": ["trait_stack", "trait stack", "TraitStack"],
        "winner_member": ["winner_member", "winner member", "WinningMember", "TrueMember"],
        "winner_rate": ["winner_rate", "winner rate", "WinRate", "Rate"],
        "support": ["support", "Support", "Hits"],
        "stack_size": ["stack_size", "stack size", "StackSize"],
    }.items():
        col = _find_col(df, aliases)
        if col is not None and col != target:
            alias_map[col] = target
    if alias_map:
        df = df.rename(columns=alias_map)
    required = ["trait_stack", "winner_member", "winner_rate", "support", "stack_size"]
    missing = [c for c in required if c not in df.columns]
    if missing:
        raise ValueError(f"Promoted separator library missing required columns: {missing}")
    df["winner_member"] = df["winner_member"].apply(normalize_member)
    df["winner_rate"] = pd.to_numeric(df["winner_rate"], errors="coerce").fillna(0.0)
    return df


def digits4(seed: str) -> List[int]:
    s = extract_pick4_digits(seed)
    if len(s) != 4:
        s = re.sub(r"\D", "", str(seed)).zfill(4)[-4:]
    return [int(ch) for ch in s] if len(s) == 4 else [0, 0, 0, 0]


def repeat_shape(d: List[int]) -> str:
    counts = sorted(pd.Series(d).value_counts().tolist(), reverse=True)
    if counts == [1, 1, 1, 1]:
        return "all_unique"
    if counts == [2, 1, 1]:
        return "one_pair"
    if counts == [2, 2]:
        return "two_pair"
    if counts == [3, 1]:
        return "triple"
    if counts == [4]:
        return "quad"
    return "other"


def structure_4(d: List[int]) -> str:
    counts = sorted(pd.Series(d).value_counts().tolist(), reverse=True)
    if counts == [4]:
        return "AAAA"
    if counts == [3, 1]:
        return "AAAB"
    if counts == [2, 2]:
        return "AABB"
    if counts == [2, 1, 1]:
        return "AABC"
    return "ABCD"


def sum_bucket(v: int) -> str:
    if v <= 13:
        return "sum_10_13"
    if v <= 17:
        return "sum_14_17"
    if v <= 21:
        return "sum_18_21"
    return "sum_22_plus"


def spread_bucket(v: int) -> str:
    if v <= 2:
        return "spread_0_2"
    if v <= 4:
        return "spread_3_4"
    if v <= 6:
        return "spread_5_6"
    return "spread_7_plus"


def consec_links_count(d: List[int]) -> int:
    u = sorted(set(d))
    return sum(1 for a, b in zip(u, u[1:]) if b - a == 1)


def enrich_seed_features(df: pd.DataFrame, seed_col: str = "seed") -> pd.DataFrame:
    out = df.copy()
    if seed_col not in out.columns:
        out[seed_col] = ""

    ds = out[seed_col].apply(digits4)
    sums = [sum(d) for d in ds]
    spreads = [max(d) - min(d) for d in ds]

    out["seed_sum"] = sums
    out["seed_spread"] = spreads
    out["seed_even_cnt"] = [sum(1 for x in d if x % 2 == 0) for d in ds]
    out["seed_high_cnt"] = [sum(1 for x in d if x >= 5) for d in ds]
    out["seed_low_cnt"] = [sum(1 for x in d if x <= 4) for d in ds]
    out["seed_has9"] = [1 if 9 in d else 0 for d in ds]
    out["seed_has0"] = [1 if 0 in d else 0 for d in ds]
    out["seed_parity_pattern"] = ["".join("E" if x % 2 == 0 else "O" for x in d) for d in ds]
    out["seed_highlow_pattern"] = ["".join("H" if x >= 5 else "L" for x in d) for d in ds]
    out["seed_repeat_shape"] = [repeat_shape(d) for d in ds]
    out["seed"] = out[seed_col].astype(str).apply(lambda x: extract_pick4_digits(x) or re.sub(r"\D", "", str(x)).zfill(4)[-4:])

    # Critical compatibility layer for the promoted separator library.
    # The promoted library uses unprefixed trait names like cnt0, has0, high, low,
    # parity_pattern, highlow_pattern, structure, sum_bucket, spread_bucket.
    # These are generated from the current seed so daily and lab rule matching actually fires.
    for digit in range(10):
        out[f"cnt{digit}"] = [d.count(digit) for d in ds]
        out[f"has{digit}"] = [1 if digit in d else 0 for d in ds]

    out["even"] = out["seed_even_cnt"]
    out["odd"] = [4 - int(v) for v in out["seed_even_cnt"]]
    out["high"] = out["seed_high_cnt"]
    out["low"] = out["seed_low_cnt"]
    out["parity_pattern"] = out["seed_parity_pattern"]
    out["highlow_pattern"] = out["seed_highlow_pattern"]
    out["structure"] = [structure_4(d) for d in ds]
    out["unique"] = [len(set(d)) for d in ds]
    out["max_rep"] = [max(pd.Series(d).value_counts().tolist()) for d in ds]
    out["consec_links"] = [consec_links_count(d) for d in ds]
    out["pair"] = [1 if max(pd.Series(d).value_counts().tolist()) >= 2 else 0 for d in ds]
    out["sum_bucket"] = [sum_bucket(int(v)) for v in sums]
    out["spread_bucket"] = [spread_bucket(int(v)) for v in spreads]

    return out


def deep_mine_separators(df: pd.DataFrame, min_rate: float = 0.76, min_support: int = 5) -> pd.DataFrame:
    mined: List[Dict] = []
    trait_cols = [
        c for c in df.columns
        if any(k in c.lower() for k in [
            "pair_has_", "adj_ord_has_", "parity_pattern", "highlow_pattern",
            "repeat_shape", "palindrome", "consec", "mirror", "sum_bucket",
            "spread_bucket", "has", "cnt", "seed_sum", "seed_spread"
        ])
    ]

    for col in trait_cols:
        vals = df[col].astype(str).fillna("").unique()
        for val in vals:
            if val in ["", "nan", "None"]:
                continue
            subset = df[df[col].astype(str) == val]
            if len(subset) < min_support:
                continue
            for m in MEMBERS:
                rate = (subset["TrueMember"] == m).sum() / len(subset)
                if rate >= min_rate:
                    mined.append({
                        "pair": "TRUTH_MINED",
                        "trait_stack": f"{col}={val}",
                        "winner_member": m,
                        "winner_rate": rate,
                        "support": int((subset["TrueMember"] == m).sum()),
                        "pair_gap": 0.0,
                        "stack_size": 1,
                    })

    for i, col1 in enumerate(trait_cols[:25]):
        for col2 in trait_cols[i + 1:i + 20]:
            vals1 = list(df[col1].astype(str).fillna("").unique())[:12]
            vals2 = list(df[col2].astype(str).fillna("").unique())[:12]
            for v1 in vals1:
                for v2 in vals2:
                    if v1 in ["", "nan"] or v2 in ["", "nan"]:
                        continue
                    subset = df[(df[col1].astype(str) == v1) & (df[col2].astype(str) == v2)]
                    if len(subset) < min_support:
                        continue
                    for m in MEMBERS:
                        rate = (subset["TrueMember"] == m).sum() / len(subset)
                        if rate >= min_rate + 0.05:
                            mined.append({
                                "pair": "TRUTH_MINED",
                                "trait_stack": f"{col1}={v1} && {col2}={v2}",
                                "winner_member": m,
                                "winner_rate": rate,
                                "support": int((subset["TrueMember"] == m).sum()),
                                "pair_gap": 0.0,
                                "stack_size": 2,
                            })

    if not mined:
        return pd.DataFrame(columns=["pair", "trait_stack", "winner_member", "winner_rate", "support", "pair_gap", "stack_size"])
    return pd.DataFrame(mined).drop_duplicates(subset=["trait_stack", "winner_member"]).reset_index(drop=True)


def _val_equal(a, b) -> bool:
    sa = str(a).strip()
    sb = str(b).strip()
    if sa == sb:
        return True
    try:
        fa = float(sa)
        fb = float(sb)
        return abs(fa - fb) < 1e-9
    except Exception:
        return False


def apply_rules(row: pd.Series, rules_df: pd.DataFrame, trait_weight: float) -> Tuple[Dict[str, float], List[str]]:
    boosts = {m: 0.0 for m in MEMBERS}
    fired: List[str] = []

    for _, r in rules_df.iterrows():
        stack_text = str(r.get("trait_stack", ""))
        if not stack_text or stack_text.lower() == "nan":
            continue

        # Support both current promoted-library format "a=b && c=d"
        # and older pipe-delimited stacked formats.
        stack = [s.strip() for s in re.split(r"\s*&&\s*|\|", stack_text) if s.strip()]
        matched = True

        for cond in stack:
            if "=" not in cond:
                matched = False
                break
            col, val = [x.strip() for x in cond.split("=", 1)]
            if col not in row.index or not _val_equal(row.get(col, ""), val):
                matched = False
                break

        if matched:
            winner = normalize_member(r.get("winner_member"))
            if winner in boosts:
                boost = float(r.get("winner_rate", 1.0)) * trait_weight
                boosts[winner] += boost
                fired.append(f"{winner}+{boost:.2f}:{stack_text}")
    return boosts, fired


def v22_pick(
    row: pd.Series,
    rules_df: pd.DataFrame,
    trait_weight: float,
    min_margin: float,
    enable_margin_swap: bool = False,
    top2_zone_ratio: float = 0.90,
    top2_zone_margin: float = 5.0,
    top2_risk_threshold: int = 3,
) -> Dict:
    """
    v39 decision layer:
    - Preserve v34/v36 scoring and strict score ranking.
    - Top1 is highest score; Top2 is second-highest score.
    - No third-choice hijack.
    - FIRST gate: evaluate deep Top2-risk traits only if row is already in a Top2 zone.
    """
    boosts, fired = apply_rules(row, rules_df, trait_weight)
    sorted_scores = sorted(boosts.items(), key=lambda x: x[1], reverse=True)

    top = sorted_scores[0][0]
    second = sorted_scores[1][0]
    margin = float(sorted_scores[0][1]) - float(sorted_scores[1][1])
    top1_score = float(sorted_scores[0][1])
    top2_score = float(sorted_scores[1][1])
    ratio = (top2_score / top1_score) if top1_score > 0 else 0.0
    seed = str(row.get("seed", ""))

    margin_swap = 0
    if enable_margin_swap and margin < float(min_margin):
        danger_seed = (
            ("0" in seed and "9" in seed)
            or len(set(seed)) <= 2
            or "00" in seed
            or "88" in seed
            or "99" in seed
        )
        if danger_seed:
            top, second = second, top
            margin_swap = 1
            fired.append("MARGIN_SWAP_TOP1_TOP2_ONLY")

    is_top2_zone = (ratio >= float(top2_zone_ratio)) or (margin <= float(top2_zone_margin))

    risk_score = 0
    risk_reasons = []

    if is_top2_zone:
        if ratio >= float(top2_zone_ratio):
            risk_score += 3
            risk_reasons.append("ratio>=zone")

        if margin <= float(top2_zone_margin):
            risk_score += 3
            risk_reasons.append("margin<=zone")

        if (
            str(row.get("sum_bucket", "")) == "sum_22_plus"
            and str(row.get("spread_bucket", "")) == "spread_3_4"
            and int(float(row.get("seed_has9", 0) or 0)) == 0
        ):
            risk_score += 2
            risk_reasons.append("sum22_spread34_no9")

        if (
            top == "0255"
            and str(row.get("structure", "")) == "AABC"
            and int(float(row.get("seed_has9", 0) or 0)) == 1
        ):
            risk_score += 2
            risk_reasons.append("0255_AABC_has9")

        score_pair = f"{top}>{second}"
        if (
            score_pair == "0225>0255"
            and str(row.get("sum_bucket", "")) == "sum_10_13"
            and int(float(row.get("consec_links", 0) or 0)) == 1
        ):
            risk_score += 2
            risk_reasons.append("0225_0255_sum10_consec1")

        if (
            str(row.get("parity_pattern", "")) == "EOOO"
            and int(float(row.get("pair", 0) or 0)) == 1
        ):
            risk_score += 1
            risk_reasons.append("EOOO_pair")

        if (
            str(row.get("highlow_pattern", "")) == "HLLH"
            and int(float(row.get("seed_has0", 0) or 0)) == 0
        ):
            risk_score += 1
            risk_reasons.append("HLLH_no0")

    top2_decision = "TOP2_REQUIRED" if (is_top2_zone and risk_score >= int(top2_risk_threshold)) else "TOP1_SAFE"

    return {
        "PredictedMember": top,
        "Top2_pred": second,
        "Margin": round(margin, 3),
        "Top2ToTop1Ratio": round(ratio, 4),
        "Top2Zone": int(is_top2_zone),
        "Top2RiskScore": int(risk_score),
        "Top2Decision": top2_decision,
        "Top2RiskReasons": "|".join(risk_reasons),
        "DecisionMode": "STRICT_SCORE_RANK" if margin_swap == 0 else "MARGIN_SWAP_TOP1_TOP2_ONLY",
        "MarginSwap": margin_swap,
        "Fired_Rules": " | ".join(fired[:20]),
        "GATED_TOP3": 0,
        "score_0025": boosts["0025"],
        "score_0225": boosts["0225"],
        "score_0255": boosts["0255"],
    }


def build_live_seed_rows(hist: pd.DataFrame, top_streams: Optional[List[str]] = None) -> pd.DataFrame:
    rows = []
    for stream, g in hist.groupby("StreamKey"):
        g = g.sort_values("Date")
        if g.empty:
            continue
        last = g.iloc[-1]
        rows.append({
            "StreamKey": stream,
            "Date": last["Date"],
            "seed": last["Result"],
            "LastResult": last["Result"],
            "State": last["State"],
            "Game": last["Game"],
        })
    out = pd.DataFrame(rows)
    if out.empty:
        return out
    if top_streams is not None:
        out = out[out["StreamKey"].isin(top_streams)].copy()
    return enrich_seed_features(out, "seed")


def build_lab_event_rows(hist: pd.DataFrame, include_full_universe: bool = False) -> pd.DataFrame:
    """
    Build walk-forward rows from real uploaded history only.

    include_full_universe=False preserves the older winner-event-only lab behavior.
    include_full_universe=True includes every stream transition in the selected date range:
    Core025 winner events plus non-Core025 events. Non-Core025 events are not counted
    as member misses; they are evaluated as non-winner play/cost opportunities.
    """
    rows = []
    for stream, g in hist.groupby("StreamKey"):
        g = g.sort_values("Date").reset_index(drop=True)
        for i in range(1, len(g)):
            true_member = result_to_core025_member(g.loc[i, "Result"])
            is_core_event = int(bool(true_member))
            if include_full_universe or true_member:
                rows.append({
                    "StreamKey": stream,
                    "Date": g.loc[i, "Date"],
                    "seed": g.loc[i - 1, "Result"],
                    "TrueMember": true_member if true_member else "",
                    "Result": g.loc[i, "Result"],
                    "Core025WinnerEvent": is_core_event,
                    "NonCore025Event": int(not is_core_event),
                    "WalkForwardUniverse": "FULL_UNIVERSE" if include_full_universe else "WINNER_EVENTS_ONLY",
                })
    out = pd.DataFrame(rows)
    if out.empty:
        return empty_lab_results_frame()
    return enrich_seed_features(out, "seed")

def v147_filter_history_by_date_range(hist: pd.DataFrame, start_date=None, end_date=None) -> pd.DataFrame:
    if hist is None or not isinstance(hist, pd.DataFrame) or hist.empty or "Date" not in hist.columns:
        return hist
    out = hist.copy()
    out["Date"] = pd.to_datetime(out["Date"], errors="coerce")
    out = out[out["Date"].notna()].copy()
    if start_date is not None:
        start_ts = pd.to_datetime(start_date, errors="coerce")
        if pd.notna(start_ts):
            out = out[out["Date"] >= start_ts.normalize()].copy()
    if end_date is not None:
        end_ts = pd.to_datetime(end_date, errors="coerce")
        if pd.notna(end_ts):
            out = out[out["Date"] <= end_ts.normalize() + pd.Timedelta(days=1) - pd.Timedelta(microseconds=1)].copy()
    return out


def stream_reduction(hist: pd.DataFrame, window_days: int, prune_pct: int) -> Tuple[pd.DataFrame, List[str]]:
    max_date = hist["Date"].max()
    cutoff = max_date - pd.Timedelta(days=int(window_days))
    win = hist[hist["Date"] >= cutoff].copy()
    grp = win.groupby("StreamKey").agg(
        draws=("Result", "size"),
        core025_hits=("Core025Member", lambda s: int((s != "").sum())),
        last_date=("Date", "max"),
    ).reset_index()
    # v82 numeric safety: mixed TXT/CSV uploads can make aggregate columns object dtype.
    grp["core025_hits"] = pd.to_numeric(grp["core025_hits"], errors="coerce").fillna(0)
    grp["draws"] = pd.to_numeric(grp["draws"], errors="coerce").fillna(0)
    denom = grp["draws"].where(grp["draws"] != 0)
    grp["hit_density"] = (grp["core025_hits"] / denom).fillna(0.0)
    grp["hit_density"] = pd.to_numeric(grp["hit_density"], errors="coerce").fillna(0.0)
    thresh = grp["hit_density"].quantile(prune_pct / 100.0) if len(grp) else 0.0
    grp["kept"] = (grp["hit_density"] >= thresh).astype(int)
    grp["rank"] = pd.to_numeric(grp["hit_density"], errors="coerce").fillna(0.0).rank(ascending=False, method="first").astype(int)
    grp["StreamRank"] = grp["rank"]
    grp = grp.sort_values(["kept", "hit_density", "core025_hits"], ascending=[False, False, False]).reset_index(drop=True)
    kept_streams = grp[grp["kept"] == 1]["StreamKey"].tolist()
    return grp, kept_streams



def v152_build_historical_stream_advisory(hist: pd.DataFrame, target_dates, window_days: int, prune_pct: int) -> pd.DataFrame:
    """
    v152: Blind historical stream-reduction advisory builder.

    This recomputes stream_reduction using only history BEFORE each target date,
    then returns advisory fields for every stream/date. It does NOT filter rows.
    kept_streams is preserved only as KeptStreamFlag/advisory metadata so all 78
    streams remain visible and scorable for each historical date.
    """
    if hist is None or not isinstance(hist, pd.DataFrame) or hist.empty or "Date" not in hist.columns:
        return pd.DataFrame()
    h = hist.copy()
    h["Date"] = pd.to_datetime(h["Date"], errors="coerce")
    h = h[h["Date"].notna()].copy()
    if h.empty:
        return pd.DataFrame()
    dates = pd.to_datetime(pd.Series(list(target_dates)), errors="coerce").dropna().dt.normalize().drop_duplicates().sort_values().tolist()
    parts = []
    for d in dates:
        prior = h[h["Date"] < d].copy()
        if prior.empty:
            continue
        try:
            diag, kept = stream_reduction(prior, int(window_days), int(prune_pct))
        except Exception:
            continue
        if diag is None or not isinstance(diag, pd.DataFrame) or diag.empty or "StreamKey" not in diag.columns:
            continue
        dd = diag.copy()
        dd["Date"] = pd.to_datetime(d)
        dd["KeptStreamFlag"] = dd.get("kept", 0)
        dd["KeptStreamAdvisory"] = dd["KeptStreamFlag"].map(lambda x: "KEEP_ADVISORY" if int(float(x or 0)) == 1 else "DOWNRANK_ADVISORY")
        parts.append(dd)
    if not parts:
        return pd.DataFrame()
    adv = pd.concat(parts, ignore_index=True)
    adv["Date"] = pd.to_datetime(adv["Date"], errors="coerce").dt.normalize()
    adv["StreamKey"] = adv["StreamKey"].astype(str)
    return adv


def v152_apply_daily_hybrid_movement(full_rows: pd.DataFrame) -> pd.DataFrame:
    """
    v152: Calculate the same visible hybrid movement fields for every historical
    daily 78-stream playlist. This is analysis/ranking presentation only; it does
    not remove streams or alter member scoring rules.
    """
    if full_rows is None or not isinstance(full_rows, pd.DataFrame) or full_rows.empty:
        return full_rows
    out = full_rows.copy()
    if "Date" not in out.columns:
        return out
    out["Date"] = pd.to_datetime(out["Date"], errors="coerce")
    parts = []
    for d, g in out.groupby(out["Date"].dt.normalize(), sort=True):
        gg = g.copy()
        try:
            ranked = _v141_build_verification_play_table(gg)
            if ranked is None or not isinstance(ranked, pd.DataFrame) or ranked.empty:
                ranked = gg
        except Exception:
            ranked = gg
        if "StreamRank_COMPARE_FIRST" not in ranked.columns:
            ranked["StreamRank_COMPARE_FIRST"] = pd.to_numeric(ranked.get("StreamRank", ranked.get("rank", pd.Series(range(1, len(ranked)+1), index=ranked.index))), errors="coerce")
        if "PctRank_COMPARE_FIRST" not in ranked.columns:
            ranked["PctRank_COMPARE_FIRST"] = pd.to_numeric(ranked.get("SingleRow", ranked.get("RowPercentile", ranked.get("StreamRank_COMPARE_FIRST", pd.Series(range(1, len(ranked)+1), index=ranked.index)))), errors="coerce")
        if "HybridRank_COMPARE_FIRST" not in ranked.columns:
            # Fallback only if the visible hybrid table builder could not run.
            ranked["HybridRank_COMPARE_FIRST"] = pd.to_numeric(ranked.get("PlayOrder", ranked.get("StreamRank_COMPARE_FIRST", pd.Series(range(1, len(ranked)+1), index=ranked.index))), errors="coerce")
        ranked["v152_StreamRank"] = pd.to_numeric(ranked["StreamRank_COMPARE_FIRST"], errors="coerce")
        ranked["v152_PctRank"] = pd.to_numeric(ranked["PctRank_COMPARE_FIRST"], errors="coerce")
        ranked["v152_HybridRank"] = pd.to_numeric(ranked["HybridRank_COMPARE_FIRST"], errors="coerce")
        ranked["v152_MovementVsStream"] = ranked["v152_HybridRank"] - ranked["v152_StreamRank"]
        ranked["v152_MovementBucket"] = ranked["v152_MovementVsStream"].map(_v146_bucket_movement if "_v146_bucket_movement" in globals() else lambda x: "unknown")
        ranked["v152_DatePlaylistRows"] = len(ranked)
        ranked["v152_Full78PlaylistFlag"] = int(len(ranked) >= 78)
        parts.append(ranked)
    if not parts:
        return out
    final = pd.concat(parts, ignore_index=True)
    return final

def assign_stream_tiers(stream_df: pd.DataFrame) -> pd.DataFrame:
    out = stream_df.copy()
    if out.empty:
        return out
    n = len(out)
    out = out.sort_values(["StreamRank"], ascending=True).reset_index(drop=True)
    out["RowPercentile"] = ((out["StreamRank"] / n) * 100).round(2)
    out["SingleRow"] = out["StreamRank"].astype(int)
    out["RowBucket10"] = (((out["StreamRank"] - 1) // max(1, int(n / 10))) + 1).clip(1, 10)
    out["StreamTier"] = pd.cut(
        out["RowPercentile"],
        bins=[-0.01, 25, 50, 75, 100],
        labels=["A_TOP25", "B_26_50", "C_51_75", "D_76_100"],
    ).astype(str)
    return out




